---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Receives Demolition Site Photos',
    text: "Developers and contractors WhatsApp photos of buildings to be demolished — elevation shots, structural close-ups, aerial perspectives, and access route images. The AI responds immediately, asks about the frame type and programme, and attaches every photo to your lead."
  },
  {
    icon: '📸',
    title: 'Wins Urgent Clearance Contracts',
    text: "When a developer needs a derelict structure cleared before planning conditions expire, the first demolition firm to respond with availability gets the emergency commission. Speed of response directly impacts contract award."
  },
  {
    icon: '⚡',
    title: 'Captures Contractor Soft Strip Requests',
    text: "Main contractors WhatsApp soft strip requests with programme urgency: 'soft strip starting Monday on a 3-floor office block — can you confirm your crew is available?' The AI captures the scope and mobilisation date while you operate the 360."
  },
  {
    icon: '🌙',
    title: 'Active During Evening Planning',
    text: "Developers finalise demolition programmes after hours. Project managers coordinate subcontract packages in the evening. The AI catches every after-hours demolition WhatsApp."
  },
  {
    icon: '📋',
    title: 'Structures Complex Demolition Messages',
    text: "A WhatsApp saying 'got a demo job — old factory, 3 buildings, need prices by Friday' becomes a structured lead with building types, construction materials, approximate areas, and the tender deadline."
  },
  {
    icon: '🔒',
    title: 'Professional Tender Channel',
    text: "AI WhatsApp uses your business number. Demolition tender discussions, site logistics, and subcontract negotiations stay professional and separated from personal messages."
  }
];

const faqs = [
  {
    question: "Can the AI assess a building from photos?",
    answer: "The AI does not produce demolition quotes or structural assessments from photographs. It responds effectively — acknowledging the images — and asks the questions you need for tendering: approximate floor area, number of storeys, the frame type (steel, concrete, masonry), whether an asbestos survey has been completed, the programme timeline, the required post-demolition condition, and any access or neighbour constraints. Every photo is saved to your lead for your own pre-visit assessment."
  },
  {
    question: "What about multi-message demolition threads?",
    answer: "Demolition conversations evolve — a developer sends a building photo, then forwards the planning approval, then asks about crushing on site, then queries the programme. The AI maintains the full thread and consolidates every message, photo, and document reference into one comprehensive tender lead."
  },
  {
    question: "How much does AI WhatsApp cost for demolition firms?",
    answer: `WhatsApp is £${pricing.addOn.price}/month as a channel add-on. Demolition projects range from £2,000 domestic garage clearances to £500,000 complex structural demolitions. Capturing a developer's office block demolition tender through a prompt WhatsApp response — while you managed the exclusion zone on another site — often secures a six-figure contract from a thirty-second AI interaction.`
  },
  {
    question: "Can I continue the WhatsApp conversation?",
    answer: "Send one message in any thread and the AI hands the conversation to you. It detects your reply and withdraws. Most demolition firms let the AI capture the initial scope — building type, frame construction, floor area, asbestos status, programme, and tender deadline — then take over personally to discuss site logistics, plant requirements, and pricing."
  },
  {
    question: "How is WhatsApp data from demolition enquiries protected?",
    answer: "Every WhatsApp message — building photographs, site locations, structural assessments, demolition programme details, and sender contact information — is encrypted and stored on UK and EU servers under UK GDPR. Your data goes only to you. No tender information is shared with competing demolition firms, disclosed to neighbouring property occupants, or repurposed for any secondary use."
  }
];
