const faqs = [
  {
    question: "How does AI Instagram DMs work?",
    answer: "When a potential customer sends a direct message to your Instagram business account, the AI reads the message and sends one professional response within seconds. It acknowledges their enquiry, captures key details, and lets them know you'll follow up. The lead is sent to you with all the information."
  },
  {
