---
import BaseLayout from '../../layouts/BaseLayout.astro';
import pricing from '../../data/pricing.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import trades from '../../data/trades.json';

/* Group trades by category */
const tradesByCategory = trades.reduce((acc: Record<string, typeof trades>, trade) => {
  if (!acc[trade.category]) acc[trade.category] = [];
  acc[trade.category].push(trade);
  return acc;
}, {} as Record<string, typeof trades>);

const categoryOrder = [
  'Finishing Trades',
  'Groundwork & Structure',
  'Roofing & Weatherproofing',
  'External & Landscaping',
  'Building Services',
  'M&E Trades',
  'Specialist Trades'
];
---

<BaseLayout
  title="AI Receptionist for UK 46 UK Construction Trades | Rapid Receptionist"
  description=`Find the rapid response AI receptionist for your construction trade. 46 UK trades covered � plasterers, bricklayers, electricians, roofers, plumbing contractors, and more. From �${pricing.tiers.core.price}/month.`
  canonicalUrl="/construction-trades/"
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="section directory-hero" id="directory-hero">
    <div class="container">
      <span class="badge badge--accent">46 Construction Trades</span>
      <h1>The Rapid Response AI Receptionist for <span class="text-accent">Every Construction Trade</span></h1>
      <p class="directory-hero__sub">From groundworkers laying foundations to plasterers finishing ceilings � every construction trade gets a bespoke AI receptionist configured with trade-specific vocabulary, urgency signals, and job types. Find yours below.</p>
    </div>
  </section>

  <!-- Trade Directory -->
  <section class="section section--alt" id="trade-directory">
    <div class="container">
      {categoryOrder.map((category) => {
        const categoryTrades = tradesByCategory[category];
        if (!categoryTrades) return null;
        return (
          <div class="trade-category">
            <h2 class="trade-category__title">{category}</h2>
            <div class="trades-grid">
              {categoryTrades.map((trade) => (
                <a href={`/${trade.slug}/ai-receptionist/`} class="trade-card fade-in">
                  <span class="trade-card__icon">{trade.icon}</span>
                  <div class="trade-card__content">
                    <h3 class="trade-card__name">{trade.name}</h3>
                    <p class="trade-card__context">{trade.context}</p>
                  </div>
                  <span class="trade-card__arrow">?</span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="section" id="directory-stats">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <span class="stats-bar__number">46</span>
          <span class="stats-bar__label">Construction Trades</span>
        </div>
        <div class="stats-bar__item">
          <span class="stats-bar__number">8</span>
          <span class="stats-bar__label">Communication Channels</span>
        </div>
        <div class="stats-bar__item">
          <span class="stats-bar__number">24/7</span>
          <span class="stats-bar__label">Year-Round Coverage</span>
        </div>
        <div class="stats-bar__item">
          <span class="stats-bar__number">�{pricing.tiers.core.price}</span>
          <span class="stats-bar__label">Per Month From</span>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="Respond First. Win the Job."
    subhead={`Every construction trade. Every communication channel. From �${pricing.tiers.core.price}/month with a 30-day money-back guarantee.`}
  />

  <CookieConsent />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .directory-hero {
    padding-top: calc(var(--header-height) + var(--space-16));
    padding-bottom: var(--space-12);
    text-align: center;
  }

  .directory-hero h1 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-extrabold);
    line-height: var(--leading-tight);
    max-width: 800px;
    margin: var(--space-4) auto var(--space-6);
  }

  .directory-hero__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 660px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Trade Categories */
  .trade-category {
    margin-bottom: var(--space-12);
  }

  .trade-category:last-child {
    margin-bottom: 0;
  }

  .trade-category__title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-accent);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-border-accent);
  }

  .trades-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .trade-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: border-color var(--transition-fast), transform var(--transition-fast), background var(--transition-fast);
  }

  .trade-card:hover {
    border-color: var(--color-border-accent);
    background: var(--color-accent-subtle);
    transform: translateY(-2px);
  }

  .trade-card__icon {
    font-size: var(--text-2xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .trade-card__content {
    flex: 1;
    min-width: 0;
  }

  .trade-card__name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .trade-card__context {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .trade-card__arrow {
    color: var(--color-accent);
    font-size: var(--text-lg);
    opacity: 0;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .trade-card:hover .trade-card__arrow {
    opacity: 1;
  }

  /* Stats Bar */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    text-align: center;
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stats-bar__number {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-accent);
  }

  .stats-bar__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .trades-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats-bar {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  @media (max-width: 600px) {
    .trades-grid {
      grid-template-columns: 1fr;
    }

    .stats-bar {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
