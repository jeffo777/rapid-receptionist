---
import ChannelServiceLayout from '../../layouts/ChannelServiceLayout.astro';
import pricing from '../../data/pricing.json';

const steps = [
  {
    number: 1,
    title: 'A Customer Texts Your Business Number',
    description: "Not everyone wants to call. Some customers prefer texting — especially when they're at work themselves, or when it's late and they don't want to disturb anyone. They fire off a text with what they need."
  },
  {
    number: 2,
    title: 'Your AI Sends a Professional Reply',
    description: "Within seconds, the AI reads the text, identifies the enquiry, and sends one professional SMS response — acknowledging the message, confirming key details, and letting the customer know you'll be in touch."
  },
  {
    number: 3,
    title: 'You Get the Lead Details',
    description: "The customer's name, number, what they need, and the urgency level are packaged as a lead and sent to you. You follow up at the right time with full context."
  }
];

const benefits = [
  {
    icon: '📱',
    title: 'Catches the Texters',
    text: "Not every customer calls. Some prefer texting — it's quick, it's non-intrusive, and they can send it during their own lunch break. Without AI SMS, those text enquiries sit unread in your phone until you remember to check."
  },
  {
    icon: '?',
    title: 'Instant Professional Response',
    text: "A text reply that arrives in seconds signals professionalism and responsiveness. It tells the customer: this business is organised, this business cares about enquiries, this business is going to be easy to work with."
  },
  {
    icon: '🔗',
    title: 'Works When Your Phone Is Off',
    text: "Whether your phone is on silent while you're in a client meeting, switched off on a flight, or out of signal in a basement — the AI handles SMS enquiries independently. It doesn't rely on your handset."
  },
  {
    icon: '🔄',
    title: 'Pairs With Missed Call Text-Back',
    text: "AI SMS and Missed Call Text-Back work hand in hand. If someone calls and hangs up, they get an automatic text. If they then reply to that text, the AI handles the response. The whole chain is covered."
  },
  {
    icon: '🕐',
    title: 'After-Hours Coverage',
    text: "Text messages don't respect office hours. Customers send them at 6am, at 11pm, on Sunday mornings. The AI responds to every one of them, instantly, regardless of when they arrive."
  },
  {
    icon: '📞',
    title: 'Full Lead Tracking',
    text: "Every SMS enquiry is logged, timestamped, and sent to you with the customer's details and the nature of the work. No more scrolling through old texts trying to find that message from last Thursday."
  }
];

const faqs = [
  {
    question: "How does AI SMS work?",
    answer: "When a customer sends a text message to your business number, the AI reads the content, identifies what they need, and sends one professional reply within seconds. The reply acknowledges their enquiry, captures key details, and confirms you'll be in touch personally. The lead is then sent to you with all the information."
  },
  {
    question: "Does the AI have a full text conversation?",
    answer: "No — AI SMS uses a one-reply model. The AI sends one professional response to each text message. This is deliberate: it captures the lead and sets expectations without creating a long text thread. Full conversational AI is available on phone and website chat."
  },
  {
    question: "Do I need a separate number for SMS?",
    answer: "Your Rapid Receptionist number handles both calls and texts. If a customer calls it, the AI answers the phone. If they text it, the AI replies by text. Same number, two channels covered. During setup, we configure call forwarding from your existing business number."
  },
  {
    question: "What kinds of construction enquiries come in via text?",
    answer: "In our experience, common SMS enquiries include: availability checks ('Hi, are you available next week for a kitchen refit?'), follow-ups from missed calls, quote requests, and appointment confirmations. Many customers text when they're at work themselves and can't make a phone call."
  },
  {
    question: "How much does AI SMS cost?",
    answer: `AI SMS is an add-on channel at £${pricing.addOn.price}/month. You can pair it with the Core plan (£${pricing.tiers.core.price}/month for phone + chat) or add it standalone.`
  },
  {
    question: "Can the AI respond to texts sent outside normal hours?",
    answer: "Yes — the AI responds 24/7/365, including evenings, weekends, and bank holidays. It doesn't matter when the text arrives; the customer gets a professional reply within seconds."
  }
];
---

<ChannelServiceLayout
  title="AI SMS for UK Construction Trades | Rapid Receptionist"
  description=`AI SMS for 46 UK construction trades. Responds instantly to text message enquiries, captures lead details, and works 24/7. £${pricing.addOn.price}/month add-on.`
  canonicalUrl="/construction-trades/ai-sms/"
  channelName="AI SMS"
  channelSlugPrefix="ai-sms"
  headline="AI SMS for UK Construction Trades"
  accentWord="AI SMS"
  subhead=`A customer texts your business number while you're mid-job. Instead of silence, your AI sends a professional reply in seconds — capturing their details and confirming you'll be in touch. £${pricing.addOn.price}/month.`
  speedStat="90% of text messages are read within 3 minutes of being received."
  speedText="Texts carry urgency. When a customer texts your business, they expect a reply fast — not hours later when you've finished the job. AI SMS responds in seconds, making sure the first impression they get is a professional one."
  scenario="It's 2pm on a Wednesday. You're fitting skirting boards in a new build when your phone buzzes. A text from an unknown number: 'Hi, I found you on Google. Looking for a joiner to build fitted wardrobes in two bedrooms. What's your availability like for next month?' You can't reply now — you're measuring and cutting. Three hours later, you remember — but by then, they've had a reply from someone else and booked them. With AI SMS, they'd have received a reply within ten seconds: 'Thanks for your message. We'd be happy to help with the fitted wardrobes. Could you confirm your postcode and I'll arrange for a callback today?' The lead is captured. The customer feels valued. And you call them back at 5pm with all the details in front of you."
  steps={steps}
  benefits={benefits}
  pricingNote=`AI SMS is available as an <strong>add-on channel at £${pricing.addOn.price}/month</strong>. Pair it with the Core plan (£${pricing.tiers.core.price}/month for phone + chat), use it standalone, or include it in the <strong>. <a href='/pricing/'>See full pricing ?</a>`
  faqs={faqs}
  ctaHeadline="Stop Missing Text Enquiries"
  ctaSubhead=`Every unanswered text is a customer who'll message your competitor next. AI SMS responds instantly — £${pricing.addOn.price}/month.`
/>
