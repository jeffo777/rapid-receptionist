---
import TradeHubLayout from '../layouts/TradeHubLayout.astro';

const faqs = [
  {
    question: "How does the AI handle electrical enquiries?",
    answer: "Your AI receptionist is trained with electrical terminology — it understands the difference between a rewire and a socket addition, a consumer unit upgrade and a tripped RCD, an EICR and a PAT test. When someone calls, it captures the job type, property details, urgency level, and contact information. It won't attempt to provide technical advice or diagnose faults — it focuses on capturing the lead professionally so you can follow up when you're ready."
  },
  {
    question: "Can it handle emergency electrical calls properly?",
    answer: "Absolutely. The AI is specifically trained to recognise electrical emergencies — burning smells from sockets or consumer units, exposed wiring, complete power loss, sparking fixtures, or situations involving water near electrics. When it identifies an emergency, it escalates immediately to your mobile. If you can't be reached, our human operators take over. Routine enquiries like additional sockets, outdoor lighting, or EV charger installations are logged and sent to you to handle at your convenience."
  },
  {
    question: "I'm NICEIC/NAPIT registered — does the AI mention that?",
    answer: "The AI doesn't discuss your accreditations or qualifications during calls — that's a conversation for you to have directly with the customer. What it does is capture the enquiry accurately and professionally. When you follow up, you can discuss your NICEIC, NAPIT, or Part P registration in your own words. The AI focuses on what it does best: making sure no enquiry slips through the cracks while you're on a job."
  },
  {
    question: "What kinds of electrical jobs does the AI understand?",
    answer: "We train the AI with a comprehensive understanding of residential and commercial electrical work — rewires, consumer unit upgrades, fault finding, additional circuits, lighting design and installation, garden and outdoor electrics, EV charger installations, fire alarm and smoke detector systems, EICRs, landlord certificates, and emergency callouts. If you specialise in a particular area, we configure the AI to focus on those services specifically."
  },
  {
    question: "Most of my work comes from recommendations — will this still help me?",
    answer: "Referrals are brilliant, but they still need to reach you. When someone's been recommended to you by a neighbour or a friend, they call your number expecting to speak to someone. If they get voicemail or no answer, the recommendation means nothing — they'll call the next electrician instead. Rapid Receptionist makes sure every referral call is answered instantly, the customer feels valued, and you don't lose work that was already practically won."
  },
  {
    question: "How does this work with my existing diary and quoting process?",
    answer: "Rapid Receptionist doesn't touch your diary or your pricing. The AI captures the lead — customer name, number, location, job type, and urgency — and sends it straight to you. You decide when to call back, what to quote, and when to book the job. It slots into however you already work. Whether you use a paper diary, Google Calendar, or a job management app, the AI just makes sure you never miss the initial enquiry."
  },
  {
    question: "I work across domestic and commercial — can it handle both?",
    answer: "Yes. We configure the AI to understand both domestic and commercial electrical enquiries. It can differentiate between a homeowner who needs a couple of extra sockets and a facilities manager who needs emergency lighting testing across a commercial property. The details it captures are tailored to the type of enquiry, so you get the information you need to respond appropriately."
  },
  {
    question: "What's the actual cost versus hiring someone to answer my phone?",
    answer: "A part-time receptionist costs at least £12,000 a year, only works set hours, and only covers the phone. A virtual answering service costs £200-500 per month and typically answers during office hours only. Rapid Receptionist costs £99/month for phone and web chat, works 24/7/365 including bank holidays, responds instantly, and never calls in sick. Add WhatsApp, SMS, or social channels from £19/month each. For a sole trader or small electrical firm, the maths is straightforward — it's a fraction of the cost with significantly more coverage."
  }
];
---

<TradeHubLayout
  title="AI Receptionist for UK Electricians — Never Miss a Job | Rapid Receptionist"
  description="AI receptionist built for UK electricians. Answers calls, WhatsApp, SMS & 6 more channels 24/7. Understands electrical terminology. Only £99/mo."
  canonicalUrl="/ai-receptionist-for-electricians/"
  tradeName="Electrician"
  tradeNamePlural="Electricians"
  tradeSlug="electricians"
  headline="The AI Receptionist Built for UK Electricians. Always Answering."
  accentWord="UK Electricians"
  subhead="You're in the loft running cables, up a ladder swapping a fitting, or inside a consumer unit that needs your full attention. Your AI receptionist handles every call and message — so the work keeps coming even when your hands are full."
  speedStat="62% of calls to UK trade businesses go unanswered."
  speedText="That's not a guess — it's a measured statistic across the trades. For electricians, a missed call often means a missed rewire, a lost consumer unit upgrade, or an emergency callout that goes to your competitor. Rapid Receptionist answers every single one."
  scenario="It's Thursday afternoon. You're mid-way through a first-fix rewire on a new build in Reading — dust sheet down, cables pulled, consumer unit half-wired. Your phone rings three times in 20 minutes. A landlord in Slough needs an urgent EICR for a property sale that's completing next week. A homeowner in Bracknell wants a quote for an EV charger installation. A letting agent needs emergency callout for a tenant whose power keeps tripping. You can't answer any of them without downing tools and losing two hours. Without Rapid Receptionist, those three leads ring the next sparky on Google. With it, all three are answered, details captured, and the emergency is flagged to you immediately."
  faqs={faqs}
/>
