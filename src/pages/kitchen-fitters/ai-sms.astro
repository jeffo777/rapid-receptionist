const benefits = [
  {
    icon: '📱',
    title: 'Instant Text Reply',
    text: "A letting agent texts about replacing kitchens in two rental flats before new tenants arrive. You are drilling into masonry for a wall unit bracket. The AI replies within seconds, captures both properties, and confirms you will call back."
  },
  {
    icon: '🏗️',
    title: 'Handles Trade Texts',
    text: "Builders and property managers often text rather than call. The AI captures project details — number of kitchens, specification level, timeline — so you can respond with a professional quote."
  },
  {
    icon: '🕐',
    title: 'Active Outside Working Hours',
    text: "Homeowners text at 9pm after measuring their kitchen. Landlords message at 7am about vacant properties. Every text gets a prompt, professional response regardless of the hour."
  },
  {
    icon: '📋',
    title: 'Captures Key Details',
    text: "The AI asks about kitchen style, room dimensions, worktop preferences, and timeline. You get a structured brief via text without chasing for information."
  },
  {
    icon: '⚡',
    title: 'Speed Wins Consultations',
    text: "When a homeowner texts three kitchen fitters, the first to reply gets the design visit. Your AI responds in seconds."
  },
  {
    icon: '🎯',
    title: 'Professional SMS Presence',
    text: "Instant, well-crafted text responses position your business as organised and responsive — exactly what homeowners want from someone who will spend a week in their house fitting a kitchen."
  }
];

const faqs = [
  {
    question: "How does AI SMS work for kitchen fitters?",
    answer: "When a customer texts your business number, the AI responds instantly with a natural text conversation. It captures what type of kitchen work they need — full replacement, door swap, worktop change — their timeline, room details, and contact information."
  },
  {
    question: "How much does AI SMS cost?",
    answer: `AI SMS is an add-on at £${pricing.addOn.price}/month on top of the Core plan (£${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of talk time). Setup is £${pricing.setup.price} one-time, refundable within 30 days.`
  },
  {
    question: "Can I still text customers myself?",
    answer: "Yes. The AI handles initial responses. Once you are free, you can continue any text conversation personally."
  },
  {
    question: "Does it work with my existing number?",
    answer: "Yes. AI SMS integrates with your existing business phone number. Customers text the same number they always have."
  },
  {
    question: "How is text data protected?",
    answer: "All SMS data is managed under UK GDPR. Messages and contact details are encrypted and stored on UK and EU servers, shared only with you."
  }
];
