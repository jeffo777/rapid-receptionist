---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls while you are scribing a worktop into an out-of-square wall. Your jigsaw is running, the dust extraction is on, and you are holding the template in place. Their call goes to voicemail. They found you on Instagram and were ready to book a design consultation — but they call the next kitchen fitter instead.",
    with: "The same homeowner calls. Your AI receptionist answers: 'Good morning, thank you for calling, how can I help?' It captures the kitchen size, what they want (full replacement or refresh), their timeline, and books a callback for your lunch break. You finish the scribe and ring them back with every detail."
  },
  {
    without: "An interior designer emails on Thursday evening with a brief for a high-end kitchen installation in a barn conversion — handle-less units, quartz worktops, integrated appliances. You do not see the email until Monday. By then, two other kitchen companies have already responded.",
    with: "The email gets an immediate acknowledgement confirming you have received the specification. Monday morning, you open a complete lead summary — property type, kitchen style, appliance requirements, and the designer's direct line — and call first thing."
  },
  {
    without: "A builder WhatsApps you about fitting kitchens in a block of six new-build apartments. You are installing wall units in a property across town and your phone is in the van. The message sits unread for five hours. The builder needed confirmation by end of day and has moved on.",
    with: "The WhatsApp gets an instant reply capturing the number of units, the specification level, timeline, and the builder's availability for a site meeting. You see the lead at lunch and confirm you can attend site tomorrow morning."
  }
];

const specialisms = [
  {
    category: "Domestic Kitchen Installation",
    items: ["Full kitchen design and installation", "Kitchen replacement and refurbishment", "Worktop templating and fitting", "Handle-less and push-to-open kitchens", "Kitchen island installation", "Breakfast bar construction"]
  },
  {
    category: "Joinery & Bespoke Work",
    items: ["Bespoke kitchen cabinetry", "Pantry and larder cupboard fitting", "Wine rack and display shelving", "Under-stair kitchen storage", "Utility room and bootroom fitting", "Custom end panels and plinths"]
  },
  {
    category: "Commercial & Multi-Unit",
    items: ["New-build kitchen installations", "Multi-unit apartment kitchens", "Show home kitchen fitting", "Landlord and rental property kitchens", "Commercial kitchen refurbishment", "Kitchen showroom construction"]
  }
];

const clientTypes = [
  {
    icon: "🏠",
    title: "Domestic Homeowners",
    description: "Homeowners planning their dream kitchen — they have spent months browsing Pinterest, visiting showrooms, and comparing quotes. They want a kitchen fitter who listens to what they want, explains the process clearly, and has a portfolio that proves they deliver quality work. Responsiveness is a huge trust signal at this stage."
  },
  {
    icon: "🏗️",
    title: "Builders & Developers",
    description: "Main contractors and property developers who need reliable kitchen installation subcontractors for new builds and refurbishments. They want someone who can handle multiple plots, work to tight programme schedules, and fit kitchens to a consistent standard across ten, twenty, or fifty units."
  },
  {
    icon: "🎨",
    title: "Interior Designers & Architects",
    description: "Designers working on high-end residential projects who need a kitchen installer capable of handling bespoke units, complex worktop templating, and integrated appliances. They expect professional communication and precise execution of their specifications."
  },
  {
    icon: "🏘️",
    title: "Landlords & Property Managers",
    description: "Landlords replacing dated kitchens in rental properties between tenancies. They need competitive pricing, quick turnaround, and a fitter who can handle the full job — strip-out, fitting, worktop, and tiling splash-backs — without needing to coordinate multiple trades."
  }
];

const faqs = [
  {
    question: "Does the AI understand kitchen fitting terminology?",
    answer: "Yes. During setup, your AI receptionist is configured with kitchen-specific vocabulary — base units, wall cabinets, cornice, pelmet, plinth, soft-close hinges, integrated appliances, worktop templating, end panels, breakfast bars, and more. When a homeowner says 'I want a handle-less kitchen with quartz worktops and an island,' the AI understands exactly what they mean and records it accurately."
  },
  {
    question: "Can the AI handle calls about both domestic kitchens and multi-unit installations?",
    answer: "Absolutely. Whether a homeowner is calling about a single kitchen renovation or a developer needs kitchens fitted in twenty new-build apartments, the AI captures the scope, specification level, timeline, and contact details. You get the full picture before you call back."
  },
  {
    question: "What happens if someone calls about an urgent kitchen problem?",
    answer: "The AI recognises urgency. If a caller describes a worktop that has collapsed, a gas disconnection issue during a kitchen strip-out, or water damage behind removed units, the AI escalates immediately — trying your mobile first, then our human operators. Routine new kitchen enquiries are handled as standard leads."
  },
  {
    question: "How much does it cost for a kitchen fitting business?",
    answer: `The Starter plan is £${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of AI phone answering plus unlimited website chat — ideal for sole trader kitchen fitters. The Core plan at £${pricing.tiers.core.price}/month gives you ${pricing.tiers.core.minutes} minutes for busier businesses. Additional channels like WhatsApp and Facebook are £${pricing.addOn.price}/month each, or get the All Channels bundle at £${pricing.addOn.price}/month. Setup is £${pricing.setup.price} one-time (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a one-man kitchen fitting operation?",
    answer: "It was designed for exactly this. A sole trader kitchen fitter cannot stop mid-installation to answer calls — you are cutting worktops, hanging wall units, or plumbing in sinks. The AI handles every call, captures what the customer needs, and sends you the details so you can follow up between jobs or in the evening."
  },
  {
    question: "Can I still take calls when I am available?",
    answer: "Yes. The AI only activates when you are unavailable — on a job, driving, or after hours. When you are free, calls ring through to you as normal. You control when the AI picks up."
  },
  {
    question: "How does Rapid Receptionist handle customer data?",
    answer: "All customer data is managed under UK GDPR and the Data Protection Act 2018. Names, addresses, phone numbers, kitchen specifications, and job descriptions are encrypted during transmission and storage, held exclusively on UK and EU servers, and shared only with you. We never sell, share, or repurpose enquiry data."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for Kitchen Fitters | Rapid Receptionist"
  description={`AI receptionist for UK kitchen fitters, kitchen installation companies, and kitchen fitting businesses. Answers calls, captures leads from chat, WhatsApp, and social media while you are on site. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/kitchen-fitters/ai-receptionist/"
  tradeName="Kitchen Fitter"
  tradeNamePlural="Kitchen Fitters"
  tradeSlug="kitchen-fitters"
  headline="The Rapid Response AI Receptionist for Kitchen Fitters"
  accentWord="Kitchen Fitters"
  subhead={`You cannot answer the phone while you are scribing a worktop, hanging wall units, or plumbing in a sink. Your AI receptionist picks up every call, captures every lead from chat, WhatsApp, and social media, and sends you the details between installations. From £${pricing.tiers.core.price}/month.`}
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Kitchen Jobs to Missed Calls"
  ctaSubhead={`Every call your kitchen fitting business misses is a customer booking another installer. From £${pricing.tiers.core.price}/month — respond first, win the work.`}
/>
