---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Five-Second Recovery',
    text: "A homeowner calls about a kitchen renovation. You are routing a worktop for an undermount sink and cannot stop. Within five seconds of the missed call, they receive a text from your business: 'Sorry I missed your call — I am fitting a kitchen. How can I help?' The lead stays warm."
  },
  {
    icon: '🔄',
    title: 'Turns Missed Calls into Conversations',
    text: "Most callers who reach voicemail do not leave a message — they call the next kitchen fitter. A text response changes everything. They reply with what they want and you have a conversation on your terms."
  },
  {
    icon: '🕐',
    title: 'Works After Hours',
    text: "A couple calls at 8pm after discussing their kitchen renovation over dinner. You do not answer. Five seconds later, they receive a text. They reply with their kitchen dimensions and style preferences. By 8:10pm, you have a qualified lead."
  },
  {
    icon: '⚡',
    title: 'Fastest Response in the Trade',
    text: "Five seconds. Faster than any competitor can physically reach their phone. The instant text positions your kitchen business as responsive and professional — a crucial trust signal for customers about to spend thousands on a kitchen."
  },
  {
    icon: '📋',
    title: 'Captures Leads Without Interrupting',
    text: "You do not need to stop fitting. The text goes out automatically. The customer replies at their convenience. You review the thread during your break and call back with full context."
  },
  {
    icon: '💰',
    title: 'Pays for Itself Immediately',
    text: "One missed kitchen enquiry — a full refit worth £8,000 to £15,000 — easily exceeds the annual cost of this service. Recovering a single lost lead pays for everything."
  }
];

const faqs = [
  {
    question: "How does missed call text-back work for kitchen fitters?",
    answer: "When a call to your business goes unanswered, the system sends a text to the caller within five seconds. The message is personalised with your business name and invites them to describe what they need. Most callers reply by text, creating a lead you can follow up at your convenience."
  },
  {
    question: "What does the text message say?",
    answer: "Something like: 'Hi, this is [Your Kitchen Business]. Sorry I missed your call — I am currently on a job. If you let me know what you need, I will get back to you as soon as possible.' The wording is customised during onboarding."
  },
  {
    question: "What if the caller does not reply?",
    answer: "You still have their phone number from the missed call log. The text serves as an immediate touchpoint that keeps your business front of mind. Even without a reply, they know you tried to respond — which most kitchen fitters do not."
  },
  {
    question: "How much does missed call text-back cost?",
    answer: `Missed call text-back is an add-on at £${pricing.addOn.price}/month on any plan. Pair with Starter (£${pricing.tiers.core.price}/month) or Core (£${pricing.tiers.core.price}/month), or get everything in the All Channels bundle at £${pricing.addOn.price}/month.`
  },
  {
    question: "Does it work with my existing number?",
    answer: "Yes. It integrates with your existing business number. Callers dial the same number — the text response happens automatically in the background."
  },
  {
    question: "How is caller data protected?",
    answer: "All data is managed under UK GDPR. Phone numbers and text messages are encrypted and stored on UK and EU servers, shared only with you."
  }
];
---

<ChannelTradeLayout
  title="Missed Call Text-Back for Kitchen Fitters | Rapid Receptionist"
  description={`Missed call text-back for UK kitchen fitters and kitchen installation companies. Automatic text within 5 seconds of every missed call. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/kitchen-fitters/missed-call-text-back/"
  channelName="Missed Call Text-Back"
  tradeName="Kitchen Fitter"
  tradeNamePlural="Kitchen Fitters"
  tradeSlug="kitchen-fitters"
  headline="Missed Call Text-Back for Kitchen Fitters"
  accentWord="Kitchen Fitters"
  subhead={`You are routing a worktop for an undermount sink and your phone rings. You cannot stop. Five seconds after the missed call, the caller receives a text from your business. They reply with their kitchen plans. You call them back at lunch with every detail. £${pricing.addOn.price}/month add-on.`}
  scenario="It is 10:50am on a Wednesday. You are fitting soft-close hinges on eighteen cabinet doors in a new kitchen in a semi-detached in Cardiff. It is fiddly work — each hinge needs exact alignment and you are working through them methodically. Your phone rings in your tool bag across the kitchen. A homeowner in Penarth is calling — they saw your kitchen on a neighbour's recommendation and want to discuss a full renovation. They have measured the room, chosen a style, and are ready to get quotes. Without missed call text-back, they hear your voicemail, do not leave a message, and call the kitchen company whose advert they saw on Facebook. With missed call text-back, they receive a text at 10:51am: 'Hi, this is [Your Business]. Sorry I missed your call — I am fitting a kitchen right now. Let me know what you are looking for and I will call you back today.' They reply: 'Hi, looking for full kitchen refit. Shaker style, about 4x3m. Neighbours recommended you.' By 10:55am you have a referred lead with room dimensions, style preference, and their phone number."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/missed-call-text-back/"
  tradePageUrl="/kitchen-fitters/ai-receptionist/"
  ctaHeadline="Never Lose a Kitchen Lead to a Missed Call"
  ctaSubhead={`One text. Five seconds. The difference between losing a kitchen customer and winning a £10,000 refit. £${pricing.addOn.price}/month add-on.`}
/>
