---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '⚡',
    title: 'Answers While You Are Fitting',
    text: "Kitchen installation is precision work — you cannot put down a jigsaw mid-cut or step away from a worktop template to answer a call. The AI handles every call with your business name while you keep the installation on track."
  },
  {
    icon: '🧠',
    title: 'Understands Kitchen Enquiries',
    text: "When a caller says 'I want a handle-less kitchen with an island and integrated appliances,' the AI knows what that means. It captures the kitchen style, worktop preferences, appliance requirements, room dimensions if mentioned, and whether they want a full replacement or a refresh."
  },
  {
    icon: '🚨',
    title: 'Escalates Genuine Emergencies',
    text: "A worktop collapse during a dinner party. A gas smell after a cooker was reconnected. Water pouring from a disconnected waste pipe. The AI recognises urgency and escalates immediately — reaching your mobile, then our human team if needed."
  },
  {
    icon: '🕐',
    title: 'Captures Evening Enquiries',
    text: "Couples discuss kitchen renovations over dinner and call fitters between 7pm and 9pm. Those evening calls are your warmest leads — the decision is fresh and they want to move. The AI captures every one."
  },
  {
    icon: '📋',
    title: 'Detailed Lead Summaries',
    text: "Every call is summarised with the caller's name, number, address, what they want, their budget range if mentioned, and how soon they want to start. You call back knowing whether it is a basic kitchen swap or a high-end renovation."
  },
  {
    icon: '🎯',
    title: 'Professional First Impression',
    text: "The AI answers as your kitchen business — 'Good morning, thank you for calling Oakwood Kitchens, how can I help?' Callers hear a professional greeting that builds confidence before you have even spoken to them."
  }
];

const faqs = [
  {
    question: "What does the AI say when a kitchen customer calls?",
    answer: "It greets them with your business name and has a natural conversation. For kitchen businesses, it asks about what kind of kitchen they are looking for — style, worktop preference, whether they need appliances — the room layout, their timeline, and captures their contact details. It does not design kitchens or give quotes — it captures the brief so you can follow up professionally."
  },
  {
    question: "Can the AI tell the difference between a kitchen refresh and a full refit?",
    answer: "The AI captures what the caller describes. If someone says 'just new doors and worktops,' that is recorded. If someone says 'rip everything out and start again with an island,' that is recorded too. You see the scope in the lead summary and prioritise accordingly."
  },
  {
    question: "How many minutes of phone time do I get?",
    answer: `The Core plan includes ${pricing.tiers.core.minutes} minutes per month — enough for most sole trader kitchen fitters. The Core plan gives you ${pricing.tiers.core.minutes} minutes for busier kitchen companies. Additional minutes are 20p each with no cap.`
  },
  {
    question: "Can I still take calls myself when I want to?",
    answer: "Yes. You set when the AI activates — only when you are unavailable, busy, or after hours. When you are in the showroom or between jobs, calls ring through to you as normal."
  },
  {
    question: "How does Rapid Receptionist protect customer data?",
    answer: "All data from phone calls — names, numbers, addresses, kitchen specifications — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted, stored on UK and EU servers, and shared only with you. We never sell or repurpose it."
  }
];
---

<ChannelTradeLayout
  title="AI Phone Answering for Kitchen Fitters | Rapid Receptionist"
  description={`AI phone answering for UK kitchen fitters, kitchen installers, and kitchen fitting companies. Answers every call, captures kitchen enquiry details, and escalates emergencies. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/kitchen-fitters/ai-phone-answering/"
  channelName="AI Phone Answering"
  tradeName="Kitchen Fitter"
  tradeNamePlural="Kitchen Fitters"
  tradeSlug="kitchen-fitters"
  headline="AI Phone Answering for Kitchen Fitters"
  accentWord="Kitchen Fitters"
  subhead={`You are scribing a laminate worktop into a wall that is 15mm out of square. The jigsaw is running, the template is clamped, and a homeowner who found you on Checkatrade is calling about a full kitchen refit. Your AI answers, captures the brief, and the lead is in your inbox before the dust settles. From £${pricing.tiers.core.price}/month.`}
  scenario="It is 11:30am on a Tuesday. You are fitting wall units in a new kitchen in a Victorian terrace in Bristol — the walls are not plumb, you have shimmed the first three cabinets to level, and you are drilling through brick for the fourth bracket. Your phone rings in the hallway. A couple who just moved to Clifton have gutted their kitchen and need a full installation — handle-less units, quartz worktops, integrated Bosch appliances. They visited a showroom last weekend and now want a fitter they can trust. Without AI Phone Answering, they hear your voicemail, assume you are too busy, and call the next fitter on their list. With AI Phone Answering, they hear: 'Good morning, thank you for calling, how can I help?' The AI captures the full brief — kitchen style, worktop material, appliance brand, Clifton postcode, available for a home visit this Saturday. You finish the wall units at 1pm and call them back with their entire specification in front of you."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-phone-answering/"
  tradePageUrl="/kitchen-fitters/ai-receptionist/"
  ctaHeadline="Stop Missing Kitchen Installation Enquiries"
  ctaSubhead={`Every missed call is a kitchen that someone else will fit. From £${pricing.tiers.core.price}/month.`}
/>
