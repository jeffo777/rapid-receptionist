---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls while you are lifting an aluminium bi-fold into a new extension opening. Your mate is holding the frame, the spirit level is on the threshold, and you cannot let go. Their call goes to voicemail. They wanted replacement windows for the entire house — ten units worth of work — but they call the next company on their list.",
    with: "The same homeowner calls. Your AI receptionist answers: 'Good morning, thank you for calling, how can I help?' It captures the property type, number of windows, current frame material, and whether they want UPVC, aluminium, or timber. You finish the bi-fold installation and call them back at lunch with the full brief."
  },
  {
    without: "A builder emails on Friday evening about supplying and fitting windows and doors for a six-plot development — a mix of casements, French doors, and sliding patios. You do not check email until Monday. By then, two competitors have acknowledged the spec and one has quoted.",
    with: "The email gets an instant acknowledgement confirming receipt. Monday morning, you open a clean lead summary — six plots, window and door schedule, programme timeline — and call the builder first thing."
  },
  {
    without: "A property manager WhatsApps you about replacing a failed sealed unit in a rental flat. The tenant is complaining about condensation between the panes. You are fitting a composite front door across town and your phone is in the van. The message sits unread for five hours.",
    with: "The WhatsApp gets an instant reply capturing the property address, the window type, which unit has failed, and the tenant's availability for access. You see the lead at your next break and arrange a visit for tomorrow."
  }
];

const specialisms = [
  {
    category: "Domestic Windows",
    items: ["UPVC window replacement", "Aluminium window installation", "Timber window fitting and restoration", "Bay and bow window construction", "Casement and tilt-and-turn windows", "Secondary glazing installation"]
  },
  {
    category: "Doors & Entrances",
    items: ["Composite front door installation", "UPVC and aluminium back doors", "French door fitting", "Sliding and inline patio doors", "Bi-fold door installation", "Stable doors and side panels"]
  },
  {
    category: "Commercial & Specialist",
    items: ["New-build window and door packages", "Multi-unit residential developments", "Sealed unit replacement and repairs", "FENSA-registered installations", "Conservation area and listed building glazing", "Shopfront and commercial glazing"]
  }
];

const clientTypes = [
  {
    icon: "🏠",
    title: "Domestic Homeowners",
    description: "Homeowners replacing old windows or upgrading to energy-efficient glazing. They have been comparing quotes online, worrying about condensation in their twenty-year-old sealed units, or planning a new extension that needs bi-folds. They want a FENSA-registered installer who explains the options clearly, turns up when they say they will, and leaves the house clean."
  },
  {
    icon: "🏗️",
    title: "Builders & Developers",
    description: "Main contractors and developers needing window and door packages for new builds and conversions. They want reliable supply and installation subcontractors who can handle full window schedules — casements, French doors, bi-folds, and front doors — across multiple plots to programme."
  },
  {
    icon: "🏘️",
    title: "Landlords & Property Managers",
    description: "Landlords replacing failed sealed units, upgrading single glazing to comply with EPC regulations, or fitting new doors in rental properties between tenancies. They need competitive pricing, quick turnaround, and a company that handles the FENSA certificate."
  },
  {
    icon: "🏛️",
    title: "Conservation & Heritage Projects",
    description: "Homeowners and architects working on listed buildings or properties in conservation areas who need sympathetic glazing solutions — slim-profile aluminium, timber flush casements, or secondary glazing that maintains the building's character while meeting modern performance standards."
  }
];

const faqs = [
  {
    question: "Does the AI understand window and door terminology?",
    answer: "Yes. During setup, your AI receptionist is configured with glazing-specific vocabulary — UPVC, aluminium, timber, composite doors, bi-folds, sliding patios, casements, tilt-and-turn, sealed units, trickle vents, FENSA, Certass, energy ratings, and more. When a homeowner says 'the sealed units have blown in the front bay window,' the AI understands exactly what they mean."
  },
  {
    question: "Can the AI handle calls about both windows and doors?",
    answer: "Absolutely. Whether someone calls about replacing ten windows, fitting a single composite front door, installing bi-folds in a new extension, or fixing a dropped hinge on a French door — the AI captures the exact scope, product type, and customer details."
  },
  {
    question: "What happens if someone calls about a security emergency?",
    answer: "The AI recognises urgency. If a caller reports a smashed window, a break-in, a door that will not lock, or glass that needs boarding up, the AI escalates immediately — trying your mobile first, then our human operators. Routine replacement window enquiries are handled as standard leads."
  },
  {
    question: "How much does it cost for a window and door company?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of AI phone answering plus unlimited website chat. Additional channels like WhatsApp and Facebook are £${pricing.addOn.price}/month each. Setup is £${pricing.setup.price} one-time (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a small window fitting operation?",
    answer: "It was built for exactly this. A two-man window fitting team cannot stop mid-installation to answer calls — you are holding frames, drilling fixings, and sealing units. The AI handles every call and sends you the details so you can follow up between installations."
  },
  {
    question: "Can I still take calls when I am available?",
    answer: "Yes. The AI only activates when you are unavailable. When you are in the office or showroom, calls ring through as normal. You control when the AI picks up."
  },
  {
    question: "How does Rapid Receptionist handle customer data?",
    answer: "All customer data is managed under UK GDPR and the Data Protection Act 2018. Names, addresses, window specifications, and job details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never sell or repurpose enquiry data."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for UK Window & Door Installers | Rapid Receptionist"
  description={`AI receptionist for UK window and door installers, glazing companies, and FENSA-registered fitters. Answers calls, captures leads from chat, WhatsApp, and social media while you are on site. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/window-door-installers/ai-receptionist/"
  tradeName="Window & Door Installer"
  tradeNamePlural="Window & Door Installers"
  tradeSlug="window-door-installers"
  headline="The Rapid Response AI Receptionist for UK Window & Door Installers"
  accentWord="Window & Door Installers"
  subhead="You cannot answer the phone while fitting window frames, adjusting multi-point door locks, or siliconing around sealed units. Your AI captures every window and door lead on site."
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Window & Door Jobs to Missed Calls"
  ctasubhead="You cannot answer the phone while fitting window frames, adjusting multi-point door locks, or siliconing around sealed units. Your AI captures every window and door lead on site."
/>
