---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '👥', title: 'Captures Recommendations', text: "Someone asks in a local Facebook group: 'Anyone know a good window fitter?' A past customer tags your page. They message you. The AI responds in seconds, captures their requirements, and books a callback." },
  { icon: '⚡', title: 'Responds Before Competitors', text: "Facebook messages are impulsive — someone sees your bi-fold installation post, likes it, and taps message. Your AI responds before competitors notice their notifications." },
  { icon: '🏠', title: 'Handles Every Enquiry Type', text: "Full house re-glazing, a single replacement door, sealed unit repairs, bi-folds for extensions — the AI captures the type, quantity, and preferences." },
  { icon: '🕐', title: 'Active During Peak Hours', text: "Facebook usage peaks in evenings and weekends. The AI ensures every message gets an instant response during those decision-making hours." },
  { icon: '📋', title: 'Structured Leads', text: "The AI captures window types, number of units, frame preference, and timeline — delivering a brief instead of a messy thread." },
  { icon: '🔗', title: 'Social Content to Sales', text: "You post a completed bi-fold installation. Someone messages: 'How much for similar?' The AI captures the lead in real time." }
];

const faqs = [
  { question: "How does AI Facebook Messenger work for window companies?", answer: "When someone messages your Facebook page, the AI responds immediately. It captures the glazing work needed, frame preference, number of units, and contact details — compiled into a lead summary." },
  { question: "How much does it cost?", answer: `AI Facebook Messenger is an add-on at £${pricing.addOn.price}/month on any plan. Pair with Starter (£${pricing.tiers.core.price}/month) or Core (£${pricing.tiers.core.price}/month), or get everything in the All Channels bundle at £${pricing.addOn.price}/month.` },
  { question: "Can I reply personally?", answer: "Yes. The AI handles initial responses. You can jump into any conversation at any time." },
  { question: "How is data protected?", answer: "All data is managed under UK GDPR. Conversations and contact details are encrypted and stored on UK and EU servers, shared only with you." }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for Window & Door Installers | Rapid Receptionist"
  description={`AI Facebook Messenger for UK window and door installers and glazing companies. Instant Messenger responses to glazing enquiries. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/window-door-installers/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Window & Door Installer"
  tradeNamePlural="Window & Door Installers"
  tradeSlug="window-door-installers"
  headline="AI Facebook Messenger for Window & Door Installers"
  accentWord="Window & Door Installers"
  subhead={`A neighbour tags your page in a local group: 'These fitted our bi-folds — brilliant job.' Someone messages your page asking about replacement windows. You are on a ladder fitting a first-floor casement. Your AI captures the lead before you climb down. £${pricing.addOn.price}/month add-on.`}
  scenario="It is 6:30pm on a Saturday. A homeowner in Exeter has been browsing your Facebook page. They see photos of a whole-house UPVC replacement you completed last month — new windows, composite front door, and French doors to the garden. They message: 'Hi, our windows are original from 1995 and we think it is time. We have a 3-bed semi with about 9 windows plus front and back doors. Do you do free quotes?' You are at a barbecue. Without AI Messenger, the message waits until Monday. With it, the reply comes at 6:31pm — confirming free surveys, asking about their preferred frame colour and whether they want to keep the same window styles, and suggesting a visit next week. They reply with their address and availability."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/window-door-installers/ai-receptionist/"
  ctaHeadline="Turn Facebook Enquiries into Window Surveys"
  ctaSubhead={`A recommendation in a local group could be a whole-house re-glaze. Your AI responds instantly. £${pricing.addOn.price}/month add-on.`}
/>
