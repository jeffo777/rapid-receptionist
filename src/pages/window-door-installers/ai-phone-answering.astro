---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '⚡',
    title: 'Answers While You Are Installing',
    text: "Window fitting is a two-person job that demands total focus — you cannot put a frame down mid-lift to answer a call. The AI handles every call with your business name while you and your mate get the installation right."
  },
  {
    icon: '🧠',
    title: 'Understands Glazing Enquiries',
    text: "When a caller says 'I need my bay window replacing — it is UPVC but the sealed units have gone' or 'we want bi-folds for our new extension,' the AI captures the window type, frame material, number of units, and any specific requirements."
  },
  {
    icon: '🚨',
    title: 'Escalates Emergencies',
    text: "A smashed window after a break-in. A door that will not lock. Glass cracked by a storm. The AI recognises emergency language and escalates immediately — reaching your mobile first, then our human team."
  },
  {
    icon: '🕐',
    title: 'Captures Evening Enquiries',
    text: "Homeowners notice draughty windows in the evening, condensation between panes on cold mornings, and call installers between 6pm and 9pm. Those calls are your warmest leads. The AI catches every one."
  },
  {
    icon: '📋',
    title: 'Detailed Lead Summaries',
    text: "Every call is summarised with the caller's name, number, address, what they need (replacements, new installation, repair), the number of windows or doors, frame material preference, and timeline."
  },
  {
    icon: '🎯',
    title: 'Professional First Impression',
    text: "The AI answers as your glazing business — 'Good afternoon, thank you for calling Clearview Windows, how can I help?' Callers hear a professional greeting that builds confidence."
  }
];

const faqs = [
  {
    question: "What does the AI say when a window customer calls?",
    answer: "It greets the caller with your glazing business name and has a natural conversation about what they need. For window and door companies, it asks about the type of work — replacements, new installations, repairs — the frame material, how many units, the property type, and their timeline. You receive a structured lead summary with every detail so you can call back prepared rather than going in blind."
  },
  {
    question: "Can it handle calls about both windows and doors?",
    answer: "Yes. Whether someone calls about ten replacement windows, a single composite front door, bi-folds for an extension, or a failed sealed unit — the AI captures the scope and details for your follow-up. It adapts the conversation naturally, asking about frame materials and energy ratings with homeowners, and about window schedules and programme dates with developers. Every call gets the same professional treatment regardless of project size."
  },
  {
    question: "How many minutes do I get?",
    answer: `The Core plan includes ${pricing.tiers.core.minutes} minutes per month, which comfortably covers most window and door fitting teams. Extra minutes are charged at 20p each with no penalty rates or hidden fees. Most glazing businesses find the included minutes more than sufficient for their enquiry volume.`
  },
  {
    question: "Can I still take calls when I am free?",
    answer: "Yes. The AI only activates when you are unavailable — fitting frames on site, siliconing a sealed unit, or outside working hours. When you are in the office, showroom, or between jobs, calls ring through to you as normal. You stay in full control of when the AI steps in."
  },
  {
    question: "How is customer data protected?",
    answer: "All caller data is managed under UK GDPR and the Data Protection Act 2018. Names, addresses, window specifications, and job details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never sell or repurpose enquiry data from your glazing leads."
  }
];
