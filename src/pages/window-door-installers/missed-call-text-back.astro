---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '📱', title: 'Five-Second Recovery', text: "A homeowner calls about replacing every window in their house. You are screwing a frame into a masonry reveal. Five seconds after the missed call, they receive a text: 'Sorry I missed your call — I am fitting windows. How can I help?' The lead stays warm." },
  { icon: '🔄', title: 'Turns Missed Calls into Conversations', text: "Most callers who reach voicemail call the next window company. A text changes everything — they reply with what they need and you have a conversation on your terms." },
  { icon: '🕐', title: 'Works After Hours', text: "A homeowner calls at 8pm after noticing condensation in their bedroom windows. They do not get through. Five seconds later, they get a text. They reply describing the problem and you follow up the next morning." },
  { icon: '⚡', title: 'Fastest Response', text: "Five seconds. Faster than any competitor can reach their phone. The instant text positions your glazing business as responsive and professional." },
  { icon: '📋', title: 'Captures Without Interrupting', text: "You do not stop installing. The text goes out automatically. The customer replies. You review the thread at your next break." },
  { icon: '💰', title: 'Pays for Itself', text: "One missed window enquiry — a whole-house re-glaze worth £5,000 to £15,000 — exceeds the annual cost of this service. Recovering a single lost lead pays for everything." }
];

const faqs = [
  { question: "How does missed call text-back work?", answer: "When a call goes unanswered, the system sends a text within five seconds. It is personalised with your business name and invites them to describe what they need." },
  { question: "What does the text say?", answer: "Something like: 'Hi, this is [Your Window Company]. Sorry I missed your call — I am on a job. Let me know what you need and I will get back to you today.' The wording is set during onboarding." },
  { question: "How much does it cost?", answer: `Missed call text-back is an add-on at £${pricing.addOn.price}/month on top of the Core plan (£${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of talk time). Setup is £${pricing.setup.price} one-time, refundable within 30 days.` },
  { question: "Does it work with my existing number?", answer: "Yes. It integrates with your existing business number. Nothing changes for customers." },
  { question: "How is data protected?", answer: "All data is managed under UK GDPR. Phone numbers and messages are encrypted and stored on UK and EU servers, shared only with you." }
];
---

<ChannelTradeLayout
  title="Missed Call Text-Back for Window & Door Installers | Rapid Receptionist"
  description={`Missed call text-back for UK window and door installers and glazing companies. Automatic text within 5 seconds of every missed call. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/window-door-installers/missed-call-text-back/"
  channelName="Missed Call Text-Back"
  tradeName="Window & Door Installer"
  tradeNamePlural="Window & Door Installers"
  tradeSlug="window-door-installers"
  headline="Missed Call Text-Back for Window & Door Installers"
  accentWord="Window & Door Installers"
  subhead={`You are lifting a frame into an opening and your phone rings in the van. You cannot stop. Five seconds after the missed call, the caller receives a text from your business. They reply with their window requirements. You call them back at lunch with every detail. £${pricing.addOn.price}/month add-on.`}
  scenario="It is 11:15am on a Thursday. You are fitting a sliding patio door in a ground-floor extension in Winchester — the threshold is level, the door is offered up, and your mate is holding the outer frame while you drill the first fixing. Your phone rings in the hallway. A homeowner two miles away is calling — their 1980s hardwood windows are rotting through and they want to replace all twelve with UPVC or aluminium before winter. They got your number from a neighbour. Without missed call text-back, they hear voicemail, do not leave a message, and google 'window installers near me' instead. They call the first result. With missed call text-back, they receive a text at 11:16am: 'Hi, this is [Your Business]. Sorry I missed your call — I am fitting a patio door right now. Let me know what you need and I will call you back today.' They reply: 'Hi, 12 windows all need replacing. 1980s timber, all rotten. Neighbour recommended you.' By 11:20am, you have a whole-house re-glaze lead from a referral."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/missed-call-text-back/"
  tradePageUrl="/window-door-installers/ai-receptionist/"
  ctaHeadline="Never Lose a Glazing Lead to a Missed Call"
  ctaSubhead={`One text. Five seconds. The difference between losing a customer and winning a £10,000 whole-house re-glaze. £${pricing.addOn.price}/month add-on.`}
/>
