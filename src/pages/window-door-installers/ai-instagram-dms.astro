---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '📸', title: 'Converts Portfolio Admirers', text: "You post a before-and-after of a full house re-glaze — old single-glazed timber replaced with sleek anthracite aluminium. Someone DMs: 'These are stunning — do you do bay windows too?' Your AI responds instantly." },
  { icon: '⚡', title: 'Instant Replies', text: "Instagram users see a bi-fold installation and message immediately. If your reply takes hours, they scroll to the next company. Your AI responds in seconds." },
  { icon: '🎨', title: 'Handles Design Conversations', text: "Window DMs on Instagram are visual — 'What colour is that frame?', 'Are those flush casements?', 'Can you do slim aluminium sightlines?' The AI handles these naturally." },
  { icon: '🕐', title: 'Active During Peak Hours', text: "Instagram peaks between 7pm and 11pm — when homeowners browse home improvement inspiration. The AI captures every evening DM." },
  { icon: '📋', title: 'Structured Leads', text: "The AI extracts key information from casual DMs and delivers clean, actionable lead summaries." },
  { icon: '🔗', title: 'Content to Revenue', text: "Every installation photo you post is a potential lead. The AI converts admirers into booked surveys." }
];

const faqs = [
  { question: "How does AI Instagram DMs work for window companies?", answer: "We connect the AI to your Instagram Business account during onboarding — no technical work required from you. Once live, every DM receives an instant professional response that discusses the window or door project, asks about frame types, colour preferences, and opening sizes, and delivers you a structured lead summary with contact details." },
  { question: "How much does it cost?", answer: `AI Instagram DMs is an add-on at £${pricing.addOn.price}/month on top of the Core plan (£${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of talk time). Setup is £${pricing.setup.price} one-time, refundable within 30 days.` },
  { question: "Do I need a business account?", answer: "Yes — and we walk you through the switch during onboarding if your profile is still personal. The conversion is free, takes about two minutes, and once done we handle the integration from our end. Window and door installers posting bi-fold reveals, flush casement close-ups, and full re-glaze transformations frequently already run Business accounts for the content promotion tools." },
  { question: "Can I reply personally?", answer: "Yes. The AI handles initial responses. You can continue any conversation yourself." },
  { question: "How is data protected?", answer: "All data is managed under UK GDPR. Messages and contact details are encrypted and stored on UK and EU servers, shared only with you." }
];
---

<ChannelTradeLayout
  title="AI Instagram DMs for UK Window & Door Installers | Rapid Receptionist"
  description={`AI Instagram DMs for UK window and door installers and glazing companies. Instant responses to Instagram direct messages. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/window-door-installers/ai-instagram-dms/"
  channelName="AI Instagram DMs"
  tradeName="Window & Door Installer"
  tradeNamePlural="Window & Door Installers"
  tradeSlug="window-door-installers"
  headline="AI Instagram DMs for UK Window & Door Installers"
  accentWord="Window & Door Installers"
  subhead="Your reel of a bi-fold door installation opening onto a garden earns six thousand views. A homeowner DMs about a similar setup for their extension. Your AI responds while you hang sashes."
  scenario="It is 8:45pm on a Friday. You posted photos earlier today of a stunning anthracite grey aluminium window installation — flush casements with slim sightlines on a modern new-build. A homeowner in Bristol DMs: 'These windows are exactly what we want for our self-build. We are at planning stage in BS9. Do you cover Bristol and how long is the lead time for aluminium?' You are relaxing for the evening. Without AI Instagram DMs, the message waits until tomorrow afternoon. They DM two other window companies — one responds within the hour. With AI Instagram DMs, the reply comes at 8:46pm — confirming Bristol coverage, asking about the number of openings, colours, and build programme timeline, and suggesting a meeting once the structural openings are confirmed. They reply with the architect's contact details and a link to the planning drawings."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-instagram-dms/"
  tradePageUrl="/window-door-installers/ai-receptionist/"
  ctaHeadline="Turn Instagram Followers into Glazing Customers"
  ctasubhead="Your reel of a bi-fold door installation opening onto a garden earns six thousand views. A homeowner DMs about a similar setup for their extension. Your AI responds while you hang sashes."
/>
