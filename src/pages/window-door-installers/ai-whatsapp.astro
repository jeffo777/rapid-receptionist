---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '📸', title: 'Customers Share Window Photos', text: "Homeowners photograph their condensation-covered windows and message: 'All of these need replacing — can you quote?' The AI responds instantly, captures the number of units and frame preference, and confirms a callback." },
  { icon: '⚡', title: 'Fastest Reply Wins the Survey', text: "A homeowner messages three window companies. The first to reply books the home survey. Your AI responds in seconds." },
  { icon: '🏗️', title: 'Handles Builder Messages', text: "Site managers WhatsApp about window and door schedules for new builds — unit counts, frame colours, configurations. The AI captures the scope for your quotation." },
  { icon: '🕐', title: 'Active When You Cannot Be', text: "WhatsApp messages arrive at all hours — homeowners noticing draughts on a cold evening, landlords messaging on Sunday about rental properties. Every message gets an instant response." },
  { icon: '📋', title: 'Rich Enquiry Data', text: "WhatsApp conversations about windows are detailed — photos of existing frames, links to products they like, measurements. The AI captures everything." },
  { icon: '🎯', title: 'Professional Presence', text: "Instant responses position your glazing business as organised and responsive — exactly the impression you need when quoting against national window companies." }
];

const faqs = [
  { question: "How does AI WhatsApp work for window installers?", answer: "When a customer messages your business WhatsApp, the AI responds immediately with a professional reply. It captures the type of glazing work, frame material, number of units, property details, and any photos sent — all compiled into a structured lead summary. You get the full picture before you even pick up the phone to call them back." },
  { question: "Can it handle photos of existing windows?", answer: "Yes. Customers regularly send photos of blown sealed units, rotten timber frames, misted double glazing, and windows they want replacing. The AI acknowledges the images, references them in the conversation, and includes them in the lead summary so you can assess the scope before arranging a site visit." },
  { question: "How much does AI WhatsApp cost?", answer: `AI WhatsApp is an add-on channel at £${pricing.addOn.price}/month on top of the Core plan at £${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of talk time. Setup is £${pricing.setup.price} one-time, refundable within 30 days. One whole-house re-glaze lead recovered from an instant WhatsApp reply covers the add-on cost for years.` },
  { question: "How is data protected?", answer: "All WhatsApp data is managed under UK GDPR and the Data Protection Act 2018. Messages, photos, and contact details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never access or repurpose your WhatsApp enquiry data." }
];
---

<ChannelTradeLayout
  title="AI WhatsApp for UK Window & Door Installers | Rapid Receptionist"
  description={`AI WhatsApp for UK window and door installers and glazing companies. Instant responses to WhatsApp glazing enquiries. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/window-door-installers/ai-whatsapp/"
  channelName="AI WhatsApp"
  tradeName="Window & Door Installer"
  tradeNamePlural="Window & Door Installers"
  tradeSlug="window-door-installers"
  headline="AI WhatsApp for UK Window & Door Installers"
  accentWord="Window & Door Installers"
  subhead="A builder WhatsApps photos of window openings with dimensions and asks for an aluminium casement quote for a barn conversion. Your AI responds while you level a door threshold."
  scenario="It is 7:15pm on a Monday. A retired couple in Harrogate have been putting off replacing their windows for three years. Tonight, with the central heating on, every sealed unit in the front of the house is misted up. The husband photographs the worst three and WhatsApps you: 'Hi, we have 8 windows at the front, all UPVC from 2002. The sealed units are gone in at least 5 of them. Can you come and have a look? We are in HG1.' You are eating dinner. Without AI WhatsApp, the message waits until tomorrow — and they WhatsApp two more companies tonight. With AI WhatsApp, the reply comes at 7:16pm — confirming you replace sealed units and full windows, asking about their preferred frame material and whether they would like to consider upgrading to A-rated glazing, and suggesting a free survey this week. They reply with their address and preferred time."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-whatsapp/"
  tradePageUrl="/window-door-installers/ai-receptionist/"
  ctaHeadline="Respond to Every Glazing Enquiry on WhatsApp"
  ctasubhead="A builder WhatsApps photos of window openings with dimensions and asks for an aluminium casement quote for a barn conversion. Your AI responds while you level a door threshold."
/>
