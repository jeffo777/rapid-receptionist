---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Receives Structural Photos for Quoting',
    text: "Builders and surveyors WhatsApp photos of cracked lintels, corroded beams, overloaded structures, and prepared foundations with holding-down bolts. The AI responds instantly, asks about the engineer's specification, and attaches every image to your lead."
  },
  {
    icon: '📸',
    title: 'Wins Urgent Beam Orders',
    text: "When a builder discovers a defective lintel mid-renovation, the first steel firm to reply gets the order. WhatsApp speed directly determines whether your beam goes into the opening or a competitor's does."
  },
  {
    icon: '⚡',
    title: 'Captures Builder RSJ Requests',
    text: "Builders WhatsApp structural steel orders constantly: 'need a 203x133x25 UB, 3.6m long, with 150mm end plates welded on, delivered Thursday.' The AI captures the size, length, connection details, and delivery date while you fabricate in the workshop."
  },
  {
    icon: '🌙',
    title: 'Active After Workshop Hours',
    text: "Builders confirm beam requirements in the evening — 'engineer changed the spec to a 254x146x31 UB — can you update the order?' The AI captures specification changes and order revisions instantly."
  },
  {
    icon: '📋',
    title: 'Structures Quick Steelwork Briefs',
    text: "A WhatsApp saying 'portal frame needed — 15m span, 6m eaves, 3 bays, farm building, Charlbury' becomes a structured lead with span, eaves height, bay count, use, and location."
  },
  {
    icon: '🔒',
    title: 'Professional Business Channel',
    text: "AI WhatsApp operates on your business number. Fabrication schedules, beam specifications, and tender pricing conversations stay professional and separated from personal messaging."
  }
];

const faqs = [
  {
    question: "Can the AI handle structural photos on WhatsApp?",
    answer: "The AI does not perform structural assessments from photographs, but it responds constructively — acknowledging the image of the corroded beam, cracked lintel, or prepared foundation — and asks the questions essential for your pricing: whether a structural engineer has specified the replacement steel, the beam size and span, the connection type, the access constraints, and the urgency. Every photograph attaches to your lead for your own visual assessment."
  },
  {
    question: "What about multi-message steelwork threads?",
    answer: "Steelwork orders evolve through conversation — a builder specifies a beam, then sends the structural drawing, then confirms the padstone detail, then asks about delivery. The AI maintains the complete thread history and compiles every message into a single consolidated steelwork order with beam specification, connection detail, delivery date, and site access notes."
  },
  {
    question: "How much does AI WhatsApp cost for steel firms?",
    answer: `WhatsApp is £${pricing.addOn.price}/month as a channel add-on. Structural steelwork values range from £800 single RSJ installations to £200,000 multi-storey commercial frame packages. Securing a developer's warehouse portal frame tender through a rapid WhatsApp reply — while you welded end plates in the workshop — delivers returns that dwarf the channel cost for years.`
  },
  {
    question: "Can I take over a WhatsApp conversation?",
    answer: "Reply in any thread and the AI transfers the conversation to you instantly. It recognises your message and withdraws permanently. Most steel firms let the AI capture the opening scope — beam sizes, spans, tonnage, connection types, and delivery or erection dates — then follow up to discuss fabrication drawings, crane access, and commercial terms."
  },
  {
    question: "How is WhatsApp data from steelwork enquiries protected?",
    answer: "Every WhatsApp message — structural photographs, site locations, beam specifications, fabrication schedules, and sender contact details — is encrypted and stored on UK and EU servers under UK GDPR. Your data stays exclusively with you. No project details reach competing steel fabricators, are disclosed to crane hire companies, or are used for any secondary purpose."
  }
];
---

<ChannelTradeLayout
  title="AI WhatsApp for UK Structural Steelworkers | Rapid Receptionist"
  description={`AI WhatsApp for UK structural steelworkers. Responds to beam specification photos, RSJ orders, and portal frame tenders while you fabricate in the workshop. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/structural-steelworkers/ai-whatsapp/"
  channelName="AI WhatsApp"
  tradeName="Structural Steelworker"
  tradeNamePlural="Structural Steelworkers"
  tradeSlug="structural-steelworkers"
  headline="AI WhatsApp for UK Structural Steelwork Companies"
  accentWord="Steelwork"
  subhead="A site manager WhatsApps structural engineer drawings and asks for a fabrication and install quote on a steel frame. Your AI responds while you grind a fillet weld on a staircase stringer."
  scenario="It is 7pm on a Tuesday. An agricultural contractor near Faringdon needs a new grain store — a three-bay portal frame, 18-metre clear span, 6-metre eaves, with concrete panel walls to 3 metres and profiled steel cladding above. The structural engineer has produced the frame calculations and the contractor has planning consent. He WhatsApps three steel fabricators: 'Evening — need a portal frame for a grain store. 3 bays at 6m centres, 18m clear span, 6m eaves. Concrete panels to 3m with steel cladding above. Engineer has done the design. We need fabrication, delivery, and erection. Good access — it is in an open field off the A420. Can you price the steelwork package? Want to start in about 8 weeks.' Without AI WhatsApp, two firms reply Wednesday morning. With AI WhatsApp, your response lands at 7:02pm: 'Thank you — grain stores are a regular project for us. Could you confirm the roof pitch and whether the engineer has specified haunched or non-haunched rafters? We will prepare a programme covering fabrication drawings, fabrication, delivery, and erection.' He confirms 10-degree pitch and non-haunched rafters. Wednesday you open the lead: grain store, Faringdon, 3-bay portal, 18m span, 6m eaves, concrete panels to 3m, A420 access, 8-week start."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-whatsapp/"
  tradePageUrl="/structural-steelworkers/ai-receptionist/"
  ctaHeadline="Respond to the RSJ Drawing While You Torque the Valley Beam Splice"
  ctaSubhead={`A builder sends the structural drawing for a 254x146x31 UB knock-through. The AI responds while the crane holds. Add-on at £${pricing.addOn.price}/month.`}
/>
