<ChannelTradeLayout
  title="Missed Call Text Back for UK Structural Steelworkers | Rapid Receptionist"
  description={`Missed Call Text Back for UK structural steelworkers. Automatically texts callers while you erect the frame — keeps portal frame tenders and RSJ bookings warm. Add-on at £${pricing.addOn.price}/month.`}
