---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📧',
    title: 'Acknowledges Steel Frame Tenders',
    text: "Main contractors email steel frame subcontract tenders with programme deadlines and tender return dates. The fabricator-erector that acknowledges first — referencing the frame type, tonnage, and programme — stays on the shortlist."
  },
  {
    icon: '📐',
    title: 'References Structural Specifications',
    text: "When a developer emails specifying 'a 120-tonne portal frame warehouse — 24m clear span, 8m eaves, haunched rafters, CE marked EXC2, intumescent paint to 60-minute rating,' the AI acknowledgement references the span, tonnage, execution class, and fire protection."
  },
  {
    icon: '🕒',
    title: 'Covers Your Workshop and Site Gap',
    text: "Structural steelworkers split between workshop fabrication and site erection — both physically demanding and noise-intensive. A developer's tender arriving at 9am goes unread until the workshop quietens at 5pm. The instant acknowledgement puts your firm ahead."
  },
  {
    icon: '🗂️',
    title: 'Separates Tenders from Operations',
    text: "Your inbox mixes developer tenders, steel stockholder delivery confirmations, crane hire invoices, paint supplier data sheets, and BCSA audit documentation. The AI identifies genuine subcontract tenders and project enquiries from operational correspondence."
  },
  {
    icon: '🤝',
    title: 'Builds Main Contractor Loyalty',
    text: "Main contractors who find a reliable fabricator-erector use them on every steel frame project. Consistent instant acknowledgements establish your position as the go-to steelwork subcontractor across their programme."
  },
  {
    icon: '📎',
    title: 'Notes Drawing Attachments',
    text: "Steel frame tenders routinely include structural general arrangement drawings, connection schedules, steelwork specification documents, and programme bar charts. The AI notes these attachments in the acknowledgement and your lead summary."
  }
];

const faqs = [
  {
    question: "Does the AI produce steelwork quotes from tender emails?",
    answer: "No pricing is generated by the AI — only the initial acknowledgement confirming receipt, referencing the frame type and tonnage, and indicating that your detailed quotation will follow. Your steelwork pricing — material costs from the steel stockholder, fabrication hours, surface treatment, transport, crane hire, erection labour, and programme scheduling — is calculated by you from the structural drawings and your own workshop assessment."
  },
  {
    question: "Will it respond to stockholder and supplier emails?",
    answer: "You define during onboarding which senders and email types trigger the auto-acknowledgement. Steel delivery confirmations from stockholders, crane hire availability notifications, paint and coating supplier invoices, bolt and fixing supply confirmations, and BCSA membership communications are excluded. Only genuine subcontract tenders and project enquiries receive the professional response."
  },
  {
    question: "How does it handle domestic RSJ enquiries by email?",
    answer: "Builder and homeowner emails via your contact form — 'the structural engineer says we need an RSJ for the kitchen extension, it is a 203x133, can you supply and fit it?' — receive a professional reply confirming your domestic beam installation capability, asking about the beam span, the property type, whether temporary propping is required, and the preferred installation date."
  },
  {
    question: "What does email response cost for steel firms?",
    answer: `Email response is £${pricing.addOn.price}/month as an add-on. Structural steelwork contracts range from £800 domestic RSJ installations to £200,000 commercial frame packages. Acknowledging a developer's portal frame tender within sixty seconds — while you aligned a column on a holding-down bolt on another site — frequently determines whether your firm makes the tender list for a six-figure fabrication contract.`
  },
  {
    question: "Can all follow-up tender correspondence come from me?",
    answer: "After the initial receipt acknowledgement, every subsequent communication is yours. Your fabrication tender, connection design proposals, fabrication drawing submissions, erection method statement, crane lift plan, and contractual correspondence are produced and issued by you and your engineering team."
  },
  {
    question: "How is steelwork tender data secured?",
    answer: "Steel frame tenders contain structural general arrangement drawings, connection schedules, loading specifications, tonnage calculations, and commercially confidential subcontract pricing. All email content is encrypted, stored on UK and EU servers under UK GDPR, and shared only with you. No tender information is disclosed to competing fabricators or third parties."
  }
];
---

<ChannelTradeLayout
  title="AI Email Response for Structural Steelworkers | Rapid Receptionist"
  description={`AI email response for UK structural steelworkers. Acknowledges portal frame tenders, RSJ orders, and mezzanine quotation requests within sixty seconds. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/structural-steelworkers/ai-email-response/"
  channelName="AI Email Response"
  tradeName="Structural Steelworker"
  tradeNamePlural="Structural Steelworkers"
  tradeSlug="structural-steelworkers"
  headline="AI Email Response for Structural Steelwork Companies"
  accentWord="Steelwork"
  subhead="A main contractor emails a comprehensive steel frame tender for a new sixth-form college in central Oxford — a three-storey braced frame with moment connections at the beam-column junctions, 520 tonnes of structural steelwork including cellular floor beams for service integration, external feature steelwork with architecturally exposed structural steel (AESS) finish to the entrance canopy, intumescent paint fire protection throughout, and CE marking to Execution Class 3 given the building's public occupancy classification. The structural engineer's general arrangement drawings, connection schedule, and steelwork specification are attached. Tender return in three weeks. You are on an erection site outside Bicester — the 80-tonne mobile crane is lifting the final ridge beam onto a portal frame warehouse, your erector is connecting the apex plate bolts, and you are checking the frame alignment with a plumb bob before the crane releases the load. Your phone is locked in the site office. Without AI Email Response, the sixth-form college tender sits until the evening. Two competing BCSA members acknowledged within the hour. With it, your acknowledgement arrives within sixty seconds, referencing the three-storey braced frame, 520 tonnes, moment connections, cellular beams, AESS entrance canopy, intumescent paint, EXC3 certification, and the three-week tender return."
  scenario="It is 7am on a Monday. Your inbox collected over the weekend: a residential developer requesting prices for structural steelwork on a four-storey apartment building — braced frame, 85 tonnes, composite metal deck floors, base plates and holding-down bolts to the piled foundations, a farm manager needing a replacement portal frame for a collapsed Dutch barn — 12-metre span, 5-metre eaves, 3 bays, a builder asking via your contact form about a pair of RSJs for a loft conversion in Botley — 'the structural engineer has specified two beams but I cannot read the sizes from the drawing,' and a steel stockholder confirming next week's rolling delivery. Without AI Email Response, you scan subjects while loading the van. The apartment building tender sits until Tuesday evening. Two competitors responded Monday morning. With AI Email Response, the apartment building receives an immediate acknowledgement referencing the four storeys, 85 tonnes, composite deck, and piled foundations, the Dutch barn gets acknowledged with span and eaves noted, the loft conversion enquiry is handled professionally, and the stockholder email is filtered. At lunch you prioritise the apartment building — estimated fabrication value £120,000 — and begin reviewing the connection schedule."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-email-response/"
  tradePageUrl="/structural-steelworkers/ai-receptionist/"
  ctaHeadline="Acknowledge the 520-Tonne College Frame Tender While You Align the Ridge Beam"
  ctaSubhead={`A main contractor's three-week tender return for EXC3 structural steelwork starts when the email lands. Your sixty-second acknowledgement secures the shortlist. Add-on at £${pricing.addOn.price}/month.`}
/>
