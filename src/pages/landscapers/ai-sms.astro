---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Catches Quick Availability Texts',
    text: "Homeowners and garden designers often text to check availability — 'are you free to start a patio job in the next fortnight?' A fast reply says yes and books the conversation. A four-hour silence while you are operating a compactor says 'try someone else.' The AI responds within seconds, confirms your interest, and captures the project details."
  },
  {
    icon: '📐',
    title: 'Builds Project Briefs from Informal Texts',
    text: "A text saying 'need patio and fencing done in Reading, garden about 8x10m' has enough for the AI to work with — but it asks follow-up questions to build a proper brief: materials preferred, access to the rear garden, timeline, and contact details. Your lead summary reads like a quote request, not a three-line text."
  },
  {
    icon: '🔔',
    title: 'Responds to Designer and Trade Texts',
    text: "Garden designers and architects occasionally text rather than call — a quick check before including you on a tender list. A fast, professional text reply positions you as responsive and organised. The AI handles this while you are elbow-deep in a planting bed or running a petrol hedgecutter."
  },
  {
    icon: '🌙',
    title: 'Active Outside Your Working Hours',
    text: "Homeowners text about gardens when the mood strikes — Saturday evening after a barbecue on a tired patio, Sunday morning looking at the fence the storm blew down, Tuesday night after watching a garden transformation programme. The AI catches every message and delivers structured leads for your workday follow-up."
  },
  {
    icon: '📋',
    title: 'Consolidates Multi-message Threads',
    text: "People text in fragments — 'need a landscaper' then 'patio about 5x4m' then 'maybe some planting too' then 'we are in Oxford.' The AI waits for the thread to settle, processes everything together, and sends you a single consolidated lead with the full picture."
  },
  {
    icon: '📱',
    title: 'Uses Your Business Number',
    text: "AI SMS works through your existing business number. Clients text the same number they would call, and the AI responds from that number. Your personal phone stays completely separate."
  }
];

const faqs = [
  {
    question: "How does the AI handle a text about a garden project?",
    answer: "When a landscaping enquiry arrives by text, the AI reads the message, identifies it as a project request, and sends a professional response. If there is enough detail — 'need sandstone patio, 30sqm, rear garden in Newbury, want it done June' — it confirms interest and logs the lead. If the text is vague — 'do you do gardens?' — the AI asks what type of work they need, their location, and approximate garden size to build a useful brief."
  },
  {
    question: "Will people know they are texting an AI?",
    answer: "The responses read like a well-organised landscaping company replying quickly between jobs. The AI identifies itself as your business, not as a separate service. Most homeowners texting a landscaper are pleased to get a fast, relevant response — they care about the content of the reply, not who composed it."
  },
  {
    question: "What if someone texts about garden maintenance rather than a project?",
    answer: "The AI captures maintenance enquiries with the same detail as project work — lawn care schedules, hedge cutting frequency, seasonal planting requirements, and the property location. Whether you handle maintenance yourself or subcontract it, the lead arrives with enough detail for you to respond appropriately."
  },
  {
    question: "What does AI SMS cost for a landscaping company?",
    answer: `Texting is an add-on at £${pricing.addOn.price}/month alongside your Core plan. For landscaping businesses where homeowners and designers frequently text to check availability before committing to a phone call, this captures a communication channel you would otherwise miss during your busiest hours on site. One patio job captured from a text lead covers the add-on cost for years.`
  },
  {
    question: "Can I text back myself when I want to?",
    answer: "When you reply to a text thread directly, the AI steps aside. During quiet periods — driving to the yard, waiting for a delivery, at home in the evening — you handle texts personally. During active work — digging, paving, planting — the AI covers. The transition is seamless for the person messaging you."
  },
  {
    question: "Are text conversations stored securely?",
    answer: "Every SMS exchange — including garden project details, property addresses, and contact information — is encrypted and stored on UK and EU servers under UK GDPR. The data is shared only with you and is never repurposed. For landscaping enquiries where homeowners share their address and garden plans, this ensures full privacy protection."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for Landscapers | Rapid Receptionist"
  description={`AI SMS for UK landscaping companies. Responds to texts from homeowners and garden designers while you are on the tools — captures patio quotes, garden makeover enquiries, and availability checks. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/landscapers/ai-sms/"
  channelName="AI SMS"
  tradeName="Landscaper"
  tradeNamePlural="Landscapers"
  tradeSlug="landscapers"
  headline="AI SMS for Landscapers"
  accentWord="Landscapers"
  subhead="A garden designer texts: 'Are you available for a residential garden build in the Cotswolds starting late June? Approx 80sqm hard landscaping plus planting.' You are operating a mini digger stripping topsoil on another project, engine running, vibration through every bone. Without AI SMS, the text goes unread until you shut the machine down at 5pm. By then the designer has confirmed two other landscapers. With it, the reply goes back in seconds and your name stays on the shortlist."
  scenario="It is 2:45pm on a Thursday in June. You are laying Indian sandstone in a herringbone pattern in a rear garden in Winchester, string lines set, mortar mixed, trowel in hand. Your phone is on the garden wall behind you and the screen is dim in the sunlight. A homeowner in Alresford texts: 'Hi, your name was recommended by our neighbour. We need our back garden done — patio, lawn, and raised beds. About 12m by 7m. Are you taking on work at the moment?' Without AI SMS, you are absorbed in the paving detail and do not check your phone until 5:30pm. The homeowner, expecting a quick text back, messaged another landscaper at 3:30pm who responded in ten minutes and offered a site visit tomorrow. With AI SMS, the response arrives in seconds: 'Thank you for your message and the recommendation. We are currently taking on new projects. Could you share your address and preferred times for a site visit, and one of our team will arrange it?' The homeowner replies with her address and says Tuesday afternoon works. At 5:30pm you see a lead summary with the garden dimensions, recommended by a neighbour, the address, and her availability. You call, confirm Tuesday, and book a job that was secured by a thirty-second text response."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/landscapers/ai-receptionist/"
  ctaHeadline="Never Miss a Garden Quote Request by Text"
  ctaSubhead={`Homeowners text landscapers to check availability. The AI responds before you have put down the trowel. Add-on at £${pricing.addOn.price}/month.`}
/>
