---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Catches Calls You Cannot Reach on Site',
    text: "Operating a mini digger, running a plate compactor, or mixing mortar with both hands occupied — landscaping makes you physically unreachable for hours at a time. When a call hits voicemail, Missed Call Text Back sends a branded text within seconds. The caller knows you are working and will call back. Instead of googling the next landscaper, they wait."
  },
  {
    icon: '⏱️',
    title: 'Responds Before They Call Someone Else',
    text: "A homeowner who calls three landscapers about a garden makeover goes with the first to answer. Your voicemail tells them you are busy. A text arriving six seconds later tells them you are in demand — and that you value their call enough to acknowledge it immediately. That distinction wins work."
  },
  {
    icon: '🏷️',
    title: 'Branded and Professional',
    text: "The text arrives from your business number with your company name and a personalised message. Not a cold 'missed call' notification but a warm, professional acknowledgement. For a trade built on trust — homeowners are inviting you into their gardens, their private outdoor space — this first impression sets the tone."
  },
  {
    icon: '📊',
    title: 'Safety Net During Peak Season',
    text: "Spring and summer are peak landscaping season. Enquiry calls flood in while you are on site from sunrise to sunset, every day. Missed Call Text Back provides a safety net during these overwhelmed weeks, ensuring every unanswered call gets an instant acknowledgement rather than joining an ever-growing voicemail queue."
  },
  {
    icon: '📋',
    title: 'Captures Context from Text Replies',
    text: "Many callers reply to the text with context — 'it is about a patio quote for a rear garden in Headington' or 'I need fencing down both sides, about 30 metres.' These replies are logged in your lead summary. You get a phone number and a brief before you have even finished the mortar mix."
  },
  {
    icon: '🔄',
    title: 'Backup to AI Phone Answering',
    text: "Missed Call Text Back catches the rare calls that slip past AI Phone Answering — a caller who hangs up after one ring, a brief connectivity gap, or a moment when the system is handling another call. Used together, they form a complete safety net where no enquiry goes unacknowledged."
  }
];

const faqs = [
  {
    question: "When does the text message get sent?",
    answer: "The instant a call goes to voicemail or is not answered within your set ring time, the text fires. The caller receives it within seconds — typically before they have scrolled to the next landscaper in their search results. For garden project enquiries where homeowners are comparing three or four companies simultaneously, this speed keeps your name in the conversation."
  },
  {
    question: "What does the text say?",
    answer: "You write the message during setup and it is fully customisable. A typical landscaping business text might read: 'Thank you for calling [your business name]. We are currently on site and will return your call as soon as possible. If you would like a quicker response, reply to this text with your garden project details.' The wording is yours — professional, warm, on-brand."
  },
  {
    question: "Does this replace AI Phone Answering?",
    answer: "They complement each other. AI Phone Answering answers the call and has a full conversation, capturing a detailed lead. Missed Call Text Back is the fallback for the small number of calls that are not answered — the caller who hangs up too quickly, or a rare moment the system is occupied. Phone answering is the main line; text back is the safety net."
  },
  {
    question: "What is the cost for Missed Call Text Back?",
    answer: `The feature costs £${pricing.addOn.price}/month as an add-on to the Core plan. For a landscaping business where a single garden makeover can be worth £5,000 to £50,000, recovering even one missed call per season through the text back represents an exceptional return. During peak spring and summer when enquiry volume is highest, the value multiplies.`
  },
  {
    question: "Can callers reply to the text with project details?",
    answer: "Yes, and homeowners often do. Replies like 'looking for a patio and new lawn, garden about 10x6m, in Abingdon' give you project type, approximate size, and location before you have even looked at your missed calls. The reply is captured in your lead summary alongside the missed call record."
  },
  {
    question: "How is missed call data protected?",
    answer: "All missed call records, phone numbers, and text replies are encrypted and stored on UK and EU servers under UK GDPR. The data is shared only with you and is never used for marketing or sold to third parties. Your callers' contact details and project descriptions remain confidential."
  }
];
