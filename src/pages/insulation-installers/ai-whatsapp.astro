---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Responds to WhatsApp Enquiries While You Work',
    text: "Insulation work keeps both hands busy — operating injection equipment, handling rolls of mineral wool in confined loft spaces, or applying adhesive and mesh to EWI boards on a scaffold. A WhatsApp message from a landlord asking 'can you insulate six properties in Derby this month?' needs a fast response, but you cannot type a reply from inside a roof space. The AI responds professionally within seconds and captures the full scope."
  },
  {
    icon: '📸',
    title: 'Processes Photo-Based Property Enquiries',
    text: "Landlords and homeowners often send photos through WhatsApp — a picture of a cold external wall, a photo of their current loft insulation depth, or an image of their EPC certificate showing a poor rating. The AI acknowledges the images, asks about the property type and location, and packages the conversation into a lead summary with the photos attached for your review."
  },
  {
    icon: '⚡',
    title: 'Secures Multi-Property Contracts Fast',
    text: "When a landlord WhatsApps three insulation companies about upgrading eight rental properties, the first to respond gets the most attention. A four-hour delay while you are on a loft job means the landlord has already discussed timelines with a competitor. The AI responds immediately, confirms your interest, and captures the property portfolio details — keeping you in contention for the contract."
  },
  {
    icon: '🌙',
    title: 'Active When Homeowners Message',
    text: "Most homeowners think about insulation in the evening — after feeling cold walls, checking their energy bill, or reading about grants online. A WhatsApp at 9pm about cavity wall insulation for a draughty Victorian terrace is a prime lead. The AI engages the homeowner, captures the property details and their concern, and the lead is ready for your morning callback."
  },
  {
    icon: '📋',
    title: 'Creates Structured Leads from Casual Messages',
    text: "WhatsApp messages about insulation tend to be informal — 'hi mate, can you do loft insulation for a 3 bed semi in Stoke?' The AI converts this into a structured lead: service type (loft insulation), property type (3-bed semi-detached), location (Stoke), plus the sender's name and number. You read a brief, not a text thread."
  },
  {
    icon: '🔒',
    title: 'Keeps Your Personal WhatsApp Private',
    text: "AI WhatsApp connects to your business number, so customers message your professional line. Your personal WhatsApp stays separate. You can disconnect from work without missing business enquiries, and your personal conversations remain private."
  }
];

const faqs = [
  {
    question: "Does the AI understand insulation-specific WhatsApp messages?",
    answer: "When a landlord messages 'need cavity wall and loft insulation across 6 BTL properties in Derbyshire, EPC upgrades needed before April,' the AI captures the scope accurately — service types, property count, location, and the EPC compliance driver. It does not attempt to quote or advise, but it records the detail precisely and sends you a lead summary that reads like a project brief. Trade terminology like cavity fill, blown fibre, EWI, U-value, and Part L are all recognised."
  },
  {
    question: "What happens when someone sends photos of their property or EPC?",
    answer: "The AI acknowledges the images and asks clarifying questions — property age, which areas feel cold, whether they have had a professional energy assessment, and their postcode and contact details. The photos are included in your lead summary, so you can see the property condition or EPC rating before your callback. This is especially useful for cavity wall assessments where a photo of the external wall construction can indicate suitability before you visit."
  },
  {
    question: "How much does AI WhatsApp cost?",
    answer: `WhatsApp is an add-on at £${pricing.addOn.price}/month on top of the Core plan. For insulation companies whose customers — particularly landlords managing multiple properties — frequently use WhatsApp as their preferred communication channel, this captures enquiries that would otherwise sit unread while you are inside a loft space or operating injection equipment. A single landlord portfolio lead captured through WhatsApp typically exceeds the annual cost of the add-on.`
  },
  {
    question: "Can I jump into a WhatsApp conversation started by the AI?",
    answer: "When you reply to a WhatsApp thread directly, the AI recognises your response and steps back. You take over the conversation seamlessly. Many insulation installers let the AI capture the initial enquiry — service type, property details, location — and then follow up personally with a more detailed discussion about suitable insulation systems, timelines, and pricing. The handover is smooth and the customer sees a continuous conversation."
  },
  {
    question: "Is WhatsApp data kept confidential?",
    answer: "All WhatsApp messages, images, property details, and contact information are encrypted and stored on UK and EU servers under UK GDPR. The data is accessible only to you and is never shared with third parties or used for any purpose beyond delivering your leads. For insulation enquiries involving landlord property portfolios, tenant information, or grant eligibility details, this ensures commercially sensitive data stays between you and your customer."
  }
];
---

<ChannelTradeLayout
  title="AI WhatsApp for UK Insulation Installers | Rapid Receptionist"
  description={`AI WhatsApp for UK insulation companies. Responds to messages from homeowners and landlords instantly while you are on site. Captures cavity wall, loft, and EWI enquiries. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/insulation-installers/ai-whatsapp/"
  channelName="AI WhatsApp"
  tradeName="Insulation Installer"
  tradeNamePlural="Insulation Installers"
  tradeSlug="insulation-installers"
  headline="AI WhatsApp for UK Insulation Contractors"
  accentWord="Insulation Contractors"
  subhead="A letting agent WhatsApps EPC reports for three rental properties needing cavity wall and loft insulation to reach Band C. Your AI responds while you inject polystyrene beads into a gable end."
  scenario="It is 2:15pm on a Wednesday. You are on a scaffold platform on the side of a 1960s council block in Sunderland, applying adhesive to PIR boards as part of an EWI retrofit. Your phone is in the breast pocket of your high-vis, but you cannot touch it with adhesive-covered gloves. A homeowner in Durham WhatsApps you a photo of her latest gas bill — £380 for a single month — along with a message: 'My neighbour had cavity wall insulation done by you last year and her bills halved. Can you quote for my house? It is a 1970s detached, four bedrooms.' Without AI WhatsApp, the message sits with a single tick until 6pm. The homeowner, frustrated at the lack of response, messages another insulation company at 3pm who replies within minutes and books a survey for Saturday. With AI WhatsApp, the reply comes back in seconds: 'Thank you for your message. We would be happy to take a look at your property. Could you confirm your postcode and a good time for a survey, and one of our team will get back to you today?' The homeowner replies with her address and says mornings work best. At 4pm you peel off your gloves, check your phone, and see a lead summary with the property details, the neighbour referral, the postcode, and her availability. You call, book the survey for Friday morning, and ask her to send photos of the external walls."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-whatsapp/"
  tradePageUrl="/insulation-installers/ai-receptionist/"
  ctaHeadline="Capture Landlord and Homeowner WhatsApp Leads Instantly"
  ctaSubhead={`When a landlord WhatsApps about a property portfolio, the first installer to respond gets the contract. AI WhatsApp guarantees it is you. Add-on at £${pricing.addOn.price}/month.`}
/>
