---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Captures Enquiries from Your Facebook Presence',
    text: "Insulation companies increasingly maintain Facebook pages showing completed work — before-and-after thermal imaging shots, loft insulation installations, EWI projects transforming cold estates. When a homeowner sees your post and sends a Messenger enquiry about their own property, the AI responds while you are on site, captures the details, and delivers a lead. Your social media presence works as a sales channel, not just a portfolio."
  },
  {
    icon: '📸',
    title: 'Handles Photo Messages',
    text: "Homeowners often send photos through Messenger — a picture of a thin layer of loft insulation, an image of mould on an internal wall, or a screenshot of their EPC rating showing a D or E. The AI acknowledges the photos, asks about the property type and age, and captures the full context. You see the images alongside the lead summary, giving you a head start on assessing the problem before you call back."
  },
  {
    icon: '⚡',
    title: 'Responds Before Competitors',
    text: "Homeowners researching insulation on Facebook often message two or three companies simultaneously. The first professional response typically initiates the relationship that leads to a booked survey. The AI guarantees that first response is yours — within seconds, not hours. For domestic insulation work where the customer simply needs reassurance and a competent-sounding response, this speed advantage is decisive."
  },
  {
    icon: '🕐',
    title: 'Active During Peak Social Media Hours',
    text: "Facebook browsing peaks in the evening and at weekends — precisely when you are off site and unlikely to check business messages. A homeowner scrolling at 8pm who sees your cavity wall insulation post and messages 'can you insulate solid walls?' deserves a fast reply. The AI provides one, captures the lead, and your evening stays uninterrupted."
  },
  {
    icon: '📋',
    title: 'Converts Comments into Leads',
    text: "When someone comments on your Facebook post asking 'do you cover the NG area?' or 'how much is loft insulation?', the Messenger DM that often follows is captured by the AI. The casual enquiry is converted into a structured lead with property details, location, and contact information — ready for your follow-up."
  },
  {
    icon: '🔗',
    title: 'Links Social Proof to Sales',
    text: "A thermal imaging photo showing the difference between insulated and uninsulated walls is powerful social proof. When a homeowner sees it, feels concerned about their own property, and messages you through Facebook, the AI closes the gap between social engagement and a booked survey. Likes become leads."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page?",
    answer: "We connect Messenger to your existing Business page during onboarding — the whole process takes a couple of minutes and there is nothing technical for you to handle. Many insulation companies have a basic Facebook page that occasionally receives enquiries they do not notice for days, so linking the AI ensures every message gets an immediate, professional response even if you post rarely. If you do not have a Business page yet, our team helps you create one on the call."
  },
  {
    question: "What kind of insulation enquiries come through Facebook?",
    answer: "Messenger enquiries tend to come from homeowners rather than commercial clients or housing associations. They have seen your work on Facebook, heard about you from a neighbour, or searched for local insulation companies on the platform. Common enquiries include cavity wall insulation quotes, loft insulation upgrades, questions about ECO funding eligibility, and concerns about damp or cold walls. These are typically domestic-scale projects, but they can lead to neighbour referrals or landlord portfolio work once you establish the relationship."
  },
  {
    question: "How fast does the AI respond to a Messenger enquiry?",
    answer: "Within seconds. Facebook Messenger shows read receipts and typing indicators, so the homeowner sees immediate engagement. For insulation enquiries, speed matters less than in commercial tender situations, but a fast and professional response still outperforms a 48-hour silence. Homeowners are often nervous about insulation — they have read mixed reviews about spray foam or cavity wall — and a prompt, reassuring response builds confidence in your company."
  },
  {
    question: "What does AI Facebook Messenger cost?",
    answer: `Messenger is an add-on at £${pricing.addOn.price}/month on top of the Core plan. For insulation companies that post project photos, thermal imaging results, or grant eligibility information on Facebook, this channel ensures that the interest generated by your content actually converts into surveyed and booked work. The monthly cost is a fraction of a single domestic cavity wall insulation job.`
  },
  {
    question: "Can I reply to Messenger conversations myself?",
    answer: "When you respond directly to a Messenger thread, the AI steps back and you take over the conversation. Many insulation installers let the AI capture the initial enquiry and then follow up personally to discuss the property, suitable insulation systems, and available funding. The customer experiences a seamless conversation from start to finish."
  },
  {
    question: "How is Messenger data protected?",
    answer: "All Messenger conversations, images, property details, and contact information are encrypted and stored on UK and EU servers under UK GDPR. The data is used only to generate your lead summaries and is shared with no one outside your business. Facebook applies its own platform policies, but the enquiry data we extract from your Messenger conversations is handled within our UK infrastructure with full data protection compliance."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Insulation Installers | Rapid Receptionist"
  description={`AI Facebook Messenger for UK insulation companies. Responds to homeowner enquiries about cavity wall, loft, and EWI insulation through your Facebook page. Captures leads instantly. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/insulation-installers/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Insulation Installer"
  tradeNamePlural="Insulation Installers"
  tradeSlug="insulation-installers"
  headline="AI Facebook Messenger for UK Insulation Companies"
  accentWord="Insulation Companies"
  subhead="You post thermal imaging showing a cold, uninsulated wall beside a treated one. A homeowner messages about cavity wall insulation costs. Your AI captures the property details while you drill."
  scenario="It is 7:20pm on a Thursday. A homeowner in Kettering is scrolling through Facebook after putting the children to bed. She sees a friend has shared your post about ECO4 funding — 'Free cavity wall insulation for eligible homeowners in Northamptonshire.' She clicks through to your page, sees project photos and positive reviews, and sends a Messenger message: 'Hi, I think I might be eligible for the free insulation scheme. My house is a 1970s semi with solid brick walls on the front and cavity on the sides. I am on Universal Credit. Can you help?' Without AI Facebook Messenger, her message sits in your page's message requests — a tab you last checked on Monday. By Friday evening she has found another insulation company through Facebook who responded within the hour, checked her eligibility, and booked a survey. With AI Facebook Messenger, the AI replies at 7:21pm: 'Thank you for reaching out. We can certainly help check your eligibility for the ECO scheme. Could you confirm your postcode and whether you are the homeowner or tenant, and we will get back to you with more information?' She replies with her postcode, confirms she is the owner, and mentions her neighbour is interested too. Friday morning you open a lead summary with two potential ECO referrals — property details, benefit status, postcode, and the neighbour referral — and call her after breakfast."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/insulation-installers/ai-receptionist/"
  ctaHeadline="Turn Facebook Engagement into Insulation Survey Bookings"
  ctaSubhead={`Every thermal image you post could generate an enquiry. AI Messenger ensures every enquiry becomes a lead. Add-on at £${pricing.addOn.price}/month.`}
/>
