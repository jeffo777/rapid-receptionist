---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Engages Homeowners Researching Drain Problems',
    text: "Homeowners with recurrent blockages spend evenings searching for drainage solutions — reading about CCTV surveys, root cutting, and pipe lining. Chat captures them on your website at peak problem-solving momentum."
  },
  {
    icon: '📐',
    title: 'Qualifies Drainage Scope Online',
    text: "Through conversation, the AI determines whether the visitor needs emergency jetting, a CCTV diagnostic survey, a pre-purchase drainage report, a soakaway installation, or a new-build drainage package. You receive a correctly classified lead."
  },
  {
    icon: '🕐',
    title: 'Converts Evening Sewage Emergencies',
    text: "Drains block after the office closes — the kitchen waste backs up at 8pm, the external manhole overflows at 10pm, the ground-floor WC floods at midnight. Homeowners find your website and type their emergency into chat. The AI captures the contamination and urgency."
  },
  {
    icon: '📊',
    title: 'Explains Drainage Options to Visitors',
    text: "Visitors ask 'do I need a CCTV survey?', 'what is pipe lining?', 'is my drain shared?' The AI responds from your configured expertise — comparing jetting versus lining, explaining WRc condition coding, and discussing adoption responsibilities — while capturing the property details."
  },
  {
    icon: '🔗',
    title: 'Works Alongside CCTV Gallery',
    text: "Your website shows CCTV survey footage stills — root ingress, displaced joints, and collapsed pipes alongside the completed repairs. Chat converts visitors who recognise their own drainage symptoms into booked surveys."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat comes included with phone answering at £${pricing.tiers.core.price}/month. Unlimited drainage conversations — from emergency blocked drains to forty-plot adoptable drainage tenders.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my drainage website?",
    answer: "Onboarding delivers a JavaScript snippet for your website header — WordPress, Wix, Squarespace, or custom HTML compatible. The branded chat widget appears on every page immediately. Drainage firms with CCTV survey footage galleries and before-and-after repair photographs find that visitors engage with chat directly from pages showing root ingress cleared and pipes restored — the visual evidence of competence triggers immediate enquiries."
  },
  {
    question: "Can the AI explain CCTV survey findings?",
    answer: "Your drainage company profile trains the AI with your survey methodology and defect explanation approach. When a visitor types 'our surveyor said the drains have displaced joints and root ingress — what does that mean?' the AI explains in accessible terms while capturing the property address, the survey source, and the visitor's contact details for your detailed diagnostic follow-up."
  },
  {
    question: "What does chat capture from drainage visitors?",
    answer: "The AI records the drainage requirement (blocked drain, CCTV survey, repair, installation, or soakaway), the property type and age, the blockage frequency and history, the suspected cause, any previous survey findings, whether sewage is visible, and the visitor's contact information for your callback."
  },
  {
    question: "Does chat slow my drainage website?",
    answer: "CCTV survey footage stills, before-and-after repair galleries, WRc accreditation badges, and customer review widgets load at their standard speed before chat activates. The lightweight widget initialises asynchronously after all page content renders. No measurable impact on loading speed or search engine ranking."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Chat is part of the phone answering package at £${pricing.tiers.core.price}/month — nothing extra. Drainage firms benefit from overlapping coverage: weekday phone calls from developers tendering adoptable networks and solicitors booking pre-purchase surveys, combined with evening and weekend chats from homeowners whose toilets have just started backing up.`
  },
  {
    question: "How is visitor data from drainage queries handled?",
    answer: "Chat conversations containing property addresses, drainage survey references, blockage histories, sewage contamination reports, and visitor contact details are encrypted and stored on UK and EU servers under UK GDPR. Leads go exclusively to you. No drainage project details reach competitors or third-party aggregators."
  }
];
---

<ChannelTradeLayout
  title="AI Website Chat for Drainage Contractors | Rapid Receptionist"
  description={`AI website chat for UK drainage contractors. Engages homeowners with blocked drains and solicitors booking pre-purchase CCTV surveys. Included at £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/drainage-contractors/ai-website-chat/"
  channelName="AI Website Chat"
  tradeName="Drainage Contractor"
  tradeNamePlural="Drainage Contractors"
  tradeSlug="drainage-contractors"
  headline="AI Website Chat for Drainage Contractor Companies"
  accentWord="Drainage"
  subhead="A homeowner finds your website at 11pm on a rainy October Wednesday. The manhole cover in her back garden has lifted — raw sewage is pooling around it, the smell is overpowering, and the ground-floor WC will not flush. The house is a 1930s semi in Headington with original clay drainage — she knows because the previous owner told her the drains had never been replaced. It rained heavily all evening and the problem started two hours ago. She types: 'Help — our manhole is overflowing with sewage in the back garden. Toilet won't flush. House is a 1930s semi with old clay drains. It has been raining heavily. This happened once before about a year ago but went away on its own. We have two young children and the smell is terrible. Can someone come first thing tomorrow? Do you do CCTV surveys to find out what is wrong? We suspect tree roots — there is a large sycamore about three metres from the manhole. We are in Headington.' Without chat, she bookmarks and calls at 7am. With AI Website Chat, the AI asks whether the manhole is the only one overflowing and whether sewage is entering the house through any internal drains. She confirms only the external manhole is overflowing, no internal flooding. Thursday 7:30am you attend: Headington 1930s semi, clay drains original, manhole overflowing sewage, WC not flushing, heavy rain, previous overflow 1yr ago, sycamore 3m from manhole suspected roots, 2 children, CCTV survey + jetting."
  scenario="It is 1am on a Saturday. A conveyancing solicitor types into chat — she is working late preparing for Monday exchanges: 'Good evening — I act for a buyer purchasing a 1920s detached house in Summertown. The property survey flagged potential drainage concerns — the surveyor noted a depression in the rear garden near the drainage run and recommended a CCTV drain survey before exchange. Exchange is scheduled for next Friday. Can you conduct a CCTV survey with a WRc-coded report early next week? The seller's agent has confirmed access Monday or Tuesday. The buyer will not proceed without a clear drainage report — this is a deal-breaker. The property has a shared drain with the neighbouring semi — is that something your survey covers? Approximately how much is a residential CCTV survey with a written report?' Without chat, she emails Monday morning. With AI Website Chat, the AI confirms you provide WRc-coded CCTV survey reports, asks about the property's approximate drain run length and whether the depression is near any trees, and captures: Summertown 1920s detached, rear garden depression, drainage concerns, CCTV survey Monday/Tuesday, WRc-coded report, exchange Friday, shared drain with neighbour, deal-breaker, solicitor client."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-website-chat/"
  tradePageUrl="/drainage-contractors/ai-receptionist/"
  ctaHeadline="Win the Headington Sewage Emergency While the Manhole Overflows at 11pm"
  ctaSubhead={`A mother with two children, a 1930s clay drain, and a sycamore attacking the lateral needs a drainage engineer at dawn. Chat captures the overflow, the blockage history, and the CCTV request. Included at £${pricing.tiers.core.price}/month.`}
/>
