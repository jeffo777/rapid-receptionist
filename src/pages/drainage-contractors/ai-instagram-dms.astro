---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📷',
    title: 'Converts Excavation Time-Lapses',
    text: "Drainage excavation reels are riveting — a trench opens, a collapsed Victorian clay pipe emerges, new uPVC replaces it, granular bedding compacts around it, and the ground restores. When followers DM about their own recurring blockages, the AI captures a diagnostic lead."
  },
  {
    icon: '🎯',
    title: 'Reaches Homeowners with Active Problems',
    text: "Instagram draws homeowners comparing drainage companies, studying CCTV footage, and deciding to finally investigate recurring blockages. A DM from a homeowner whose drain blocked for the fourth time represents maximum diagnostic intent."
  },
  {
    icon: '📱',
    title: 'Handles Emergency Drainage DMs',
    text: "Homeowners DM photos of overflowing manholes, sewage-soaked lawns, and backed-up toilets — seeking immediate help. The AI asks about internal contamination and the blockage history, building a priority attendance lead."
  },
  {
    icon: '🌙',
    title: 'Catches Late Drain Failures',
    text: "Drains overflow at night — heavy rain overwhelms ageing clay pipes, tree roots trap debris, and sewage surfaces through inspection chambers. Homeowners DM drainage engineers after midnight. The AI captures every nocturnal drainage crisis."
  },
  {
    icon: '📋',
    title: 'Structures Diagnostic DMs',
    text: "DMs begin with 'our drain keeps blocking' or 'same problem as your photos.' The AI asks about the blockage frequency, the property age, the pipe material, and the nearest trees — assembling a pre-survey diagnostic brief."
  },
  {
    icon: '🔗',
    title: 'Monetises Every CCTV Still',
    text: "Every root ingress image, every collapsed pipe photo, and every completed repair generates DMs from homeowners whose drains display identical symptoms. Your footage is both portfolio and diagnostic reference."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "Switch your Instagram account to a Business or Creator profile in the app settings — completely free and instant. Drainage firms posting CCTV survey footage, root extraction time-lapses, and before-and-after pipe replacement sequences earn unusual engagement — the visual drama of a collapsed pipe unearthed, roots extracted, and new drainage installed is inherently compelling content that homeowners relate to when their own drains repeatedly fail."
  },
  {
    question: "What drainage DMs arrive through Instagram?",
    answer: "Homeowners with recurring blockages who recognise their symptoms in your CCTV footage. Letting agents needing emergency jetting for rental properties before tenant complaints escalate. Solicitors wanting pre-purchase CCTV surveys after finding your WRc-approved profile. Property developers studying your adoptable drainage installations for upcoming estates. Each follower has already evaluated your diagnostic capability."
  },
  {
    question: "How quickly does the AI respond to drainage DMs?",
    answer: "DM responses dispatch within seconds. Instagram's activity indicator shows your drainage firm actively monitors. A homeowner standing in her garden at 10pm watching sewage rise through the manhole cover — children inside, towels ready for the back door — demands an immediate, knowledgeable response from a drainage specialist rather than a profile that last posted three weeks ago."
  },
  {
    question: "What do Instagram DMs cost for drainage contractors?",
    answer: `Instagram DMs cost £${pricing.addOn.price}/month as an add-on channel. Emergency jetting generates £150 to £350. A CCTV survey with lining recommendation generates £250 to £500 for the survey and £800 to £2,500 for the lining. One homeowner's root ingress diagnosis — initiated by a DM after she watched your cherry tree excavation reel — leads to patch lining plus annual maintenance, covering the channel cost from the first investigation.`
  },
  {
    question: "Can I reply to DMs myself?",
    answer: "Send one message in any thread and the AI yields control permanently. Most drainage engineers let the AI establish the initial scope — blockage location, frequency, property type, tree proximity, and pipe material — then take over to confirm the CCTV survey date, the equipment being dispatched, and the approximate investigation cost."
  },
  {
    question: "Is DM data from drainage queries private?",
    answer: "Instagram DMs — manhole overflow photographs, property addresses, CCTV survey references, blockage histories, and sender contact information — are encrypted and stored on UK and EU servers under UK GDPR. Nothing reaches competing drainage firms, lead-generation platforms, or third-party aggregators."
  }
];
---

<ChannelTradeLayout
  title="AI Instagram DMs for UK Drainage Contractors | Rapid Receptionist"
  description={`AI Instagram DMs for UK drainage contractors. Converts CCTV footage reels and excavation time-lapses into diagnostic surveys and jetting callouts. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/drainage-contractors/ai-instagram-dms/"
  channelName="AI Instagram DMs"
  tradeName="Drainage Contractor"
  tradeNamePlural="Drainage Contractors"
  tradeSlug="drainage-contractors"
  headline="AI Instagram DMs for UK Drainage Contractor Companies"
  accentWord="Drainage"
  subhead="Your latest reel is a ninety-second time-lapse of a complete drainage excavation and replacement in Abingdon. Scene one: the CCTV push-rod camera navigating a 100mm clay drain — the footage reveals three displaced joints with active root ingress from a row of Leylandii, a bellied section where the pipe has dropped below invert level, and a partial collapse with the pipe crown fractured and soil intruding from above. Scene two: the excavation — a two-and-a-half-metre trench dug alongside the Leylandii boundary, timber shoring installed, the fractured clay pipe exposed showing root penetration through every joint and the collapsed section visibly deformed with earth pressing through the crack. Scene three: the removal — the old clay is broken out, the root ball at each joint cut back to clean soil, and the trench base is re-graded to achieve the correct 1:40 gradient. Scene four: the installation — new 110mm uPVC pipe with rubber ring joints bedded on 100mm of compacted pea gravel, the pipe surrounded with gravel haunching to half pipe height, then selected backfill in 150mm compacted layers. Scene five: the CCTV verification — the push-rod camera showing a perfectly aligned bore with smooth joints, no root residue, and consistent gradient throughout. Six thousand views. A homeowner in Marcham DMs: 'That is EXACTLY what we think is happening to ours. We have Leylandii along the boundary and the drain blocks every two or three months. The kitchen and the downstairs toilet both drain slowly after jetting. We had a drainage company jet it four times in the last year but it always comes back within weeks. House is 1970s detached in Marcham — about five minutes from Abingdon. Can you do a CCTV survey to check? If it is roots like yours we want the same repair — dig it all up and replace with plastic pipe. We have been quoted for lining but not sure that is the right solution with so many joint problems. Happy for any weekday.' You are connecting a lateral. Without AI DMs, the Marcham four-times-jetted repeater waits. With it, the AI confirms your excavation and CCTV diagnostic capability, asks whether the drain run passes within two metres of the Leylandii trunks, and captures: Marcham 1970s detached, Leylandii boundary, blocks every 2-3 months, jetted 4 times this year, kitchen + WC slow after jetting, CCTV survey + excavation repair if roots, prefers excavation over lining, weekday access."
  scenario="It is 2am on a Sunday in December. A property developer DMs after studying your new-build drainage portfolio: 'Impressive adoptable drainage work. We are developing a 58-house estate in Carterton — mixed two-to-four-bed houses plus a community centre. Need the complete drainage package: foul and surface water to adoptable standard under Section 104 with Thames Water. Foul — 110mm from each plot to inspection chambers to a 150mm main at 1:80. Surface water — permeable paving to the parking courts, filter drains to the access roads, and an attenuation crate system under the landscaped area sized for 1:100+40% with a vortex flow control. The community centre needs a grease interceptor for the kitchen and separate foul and surface water connections. Full CCTV survey of the adopted network before handover inspection. Programme starts with earthworks in ten weeks. Can you handle this scale alongside our programme? Budget is firm — we need competitive pricing.' Without AI DMs, the 58-house estate waits until Sunday afternoon. With AI DMs, the reply at 2:01am confirms your adoptable drainage capability, asks about the existing ground investigation results and the site levels, and captures: Carterton 58 houses + community centre, 110mm foul + 150mm main 1:80, permeable paving, filter drains, attenuation crate 1:100+40% vortex, grease interceptor community kitchen, Section 104 Thames Water, CCTV adoption survey, 10-week start."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-instagram-dms/"
  tradePageUrl="/drainage-contractors/ai-receptionist/"
  ctaHeadline="Turn 6,000 Views on an Abingdon Root Excavation into a Marcham Survey"
  ctaSubhead={`Ninety seconds of Leylandii roots extracted and Victorian clay replaced with uPVC earns six thousand views. AI Instagram DMs converts the Marcham neighbour's four-times-jetted repeater into a CCTV diagnostic survey. Add-on at £${pricing.addOn.price}/month.`}
/>
