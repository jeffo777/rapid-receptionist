---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Catches Availability Check Texts',
    text: "Homeowners text extension companies to gauge interest — 'hi, are you taking on new extension work this year?' A fast reply confirms capacity and starts the conversation. A delay of several hours suggests a company already overstretched."
  },
  {
    icon: '📐',
    title: 'Builds Extension Briefs from Short Messages',
    text: "A text like 'want a rear extension on our semi, about 4m, Witney' gives the AI enough to start the conversation — and it asks about the property type, planning status, and whether an architect is involved. Your lead summary arrives complete."
  },
  {
    icon: '🔔',
    title: 'Secures Neighbour Referral Texts Instantly',
    text: "Extension referrals are incredibly powerful — a neighbour sees the transformation through the garden fence and texts: 'Just seen what you did at number 42 — we want something similar.' The AI captures the referral within seconds while the motivation is at its peak."
  },
  {
    icon: '🌙',
    title: 'Active During Evening Decisions',
    text: "Extension decisions happen after work. A couple measures their kitchen at 8pm, agrees they need more space, and texts a builder. That 8pm text is a genuine commitment. The AI captures it."
  },
  {
    icon: '📋',
    title: 'Consolidates Fragmented Messages',
    text: "Texts arrive in pieces — 'need an extension' then 'rear of the house' then 'about 5 metres deep' then 'Abingdon area.' The AI assembles the complete picture and delivers one structured lead."
  },
  {
    icon: '📱',
    title: 'Professional Channel',
    text: "AI SMS uses your business number. Clients text a professional line and receive professional responses."
  }
];

const faqs = [
  {
    question: "How does the AI respond to extension enquiry texts?",
    answer: "The AI reads the message and responds professionally using your company name. A detailed text — 'want a single-storey rear extension, about 4x6m, have planning, in OX14' — is captured with all context. A vague text — 'do you do extensions?' — prompts the AI to ask about the project type, size, planning situation, and location."
  },
  {
    question: "Will the person texting realise it is AI?",
    answer: "The response reads like an extension specialist replying between site tasks — professional, direct, and knowledgeable about extension types. Homeowners texting builders care about speed and relevance. The AI provides both within seconds, using your company name and asking the right questions about their project."
  },
  {
    question: "What about texts from existing extension clients?",
    answer: "Clients on a live build sometimes text about deliveries, access, or schedule changes. The AI captures these operational messages and flags them separately from new extension enquiries, so your dashboard clearly distinguishes a new £50,000 project lead from a client confirming the bi-fold delivery slot."
  },
  {
    question: "What does AI SMS cost for extension specialists?",
    answer: `AI SMS is priced at £${pricing.addOn.price}/month as an add-on. Given that the average domestic extension project ranges from £30,000 to £100,000, capturing even one enquiry through a timely text response during a busy on-site day represents a substantial return relative to the monthly add-on cost.`
  },
  {
    question: "Can I respond to texts myself?",
    answer: "Typing your own reply in any thread transfers control to you. The AI recognises your message and steps back. Between builds, at the office, or in the van, you handle texts personally. On site, in the trench, or up on the scaffold, the AI covers."
  },
  {
    question: "How is text data handled?",
    answer: "Text conversations containing property addresses, extension dimensions, planning details, and contact numbers are encrypted and stored on UK and EU servers governed by UK GDPR. Data goes only to you and is never shared, sold, or used for any secondary purpose."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for UK Extension Specialists | Rapid Receptionist"
  description={`AI SMS for UK extension specialists. Responds to rear extension texts, neighbour referrals, and project enquiries while you are on site. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/extension-specialists/ai-sms/"
  channelName="AI SMS"
  tradeName="Extension Specialist"
  tradeNamePlural="Extension Specialists"
  tradeSlug="extension-specialists"
  headline="AI SMS for UK Extension Specialist Businesses"
  accentWord="Extension Specialist"
  subhead="A homeowner texts asking about a single-storey rear extension with bi-folds and a vaulted ceiling. You are setting out footings on another project. Your AI replies in seconds."
  scenario="It is 9:10pm on a Tuesday. A homeowner in Carterton has spent the evening measuring her kitchen — 3.2 metres by 2.8 metres, barely enough room for a family of four. She and her husband have agreed: they need a rear extension. She texts three extension specialists from Google: 'Hi — we have a 3-bed semi in OX18 and we desperately need more kitchen space. Thinking a single-storey rear extension, about 4 metres deep. We do not have architect drawings yet. Do you do design and build? Can you come and advise us on what is possible?' Without AI SMS, you see the text Wednesday morning at the builders' merchant. Two other extension companies responded last night — one at 9:25pm with a cheerful reply offering a kitchen-table consultation, the other at 9:40pm with examples of similar semi-detached extensions. Both offered site visits. Your reply at 7:30am Wednesday is the third. With AI SMS, the response arrives at 9:11pm: 'Thank you for your message. Design-and-build kitchen extensions on semi-detached houses are one of our most popular services. Could you confirm whether you have explored permitted development for your property? We will arrange a free consultation to discuss your options and provide guidance on design and costs.' She replies with her postcode, confirms she has not investigated PD yet, and mentions school half-term is a good time for a visit. Wednesday morning you open the lead: 3-bed semi, OX18, single-storey rear, kitchen extension, 4m depth, design-and-build, no drawings, PD not yet assessed, half-term preferred. You call at 8am, discuss PD eligibility for a semi, and book a half-term visit."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/extension-specialists/ai-receptionist/"
  ctaHeadline="Catch Every Fence-Side Referral Text While You Fit the Steel"
  ctaSubhead={`The neighbour watching your extension take shape texts while you clean the mortar. The AI replies before you reach the van. Add-on at £${pricing.addOn.price}/month.`}
/>
