---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📷',
    title: 'Converts Extension Portfolio Engagement',
    text: "Extension reels — drone footage of a wraparound taking shape, a time-lapse from foundation to finished kitchen-diner, a reveal of bi-fold doors opening for the first time — captivate homeowners planning similar projects. When a follower DMs, the AI captures their own extension vision."
  },
  {
    icon: '🎯',
    title: 'Reaches Design-Forward Homeowners',
    text: "Instagram's audience includes homeowners who care about aesthetics — polished concrete floors, handleless kitchens, Crittall-style glazing. A DM saying 'love the look of that extension — we want the same style' is a premium lead from someone willing to invest in quality."
  },
  {
    icon: '📱',
    title: 'Handles Kitchen Photo DMs',
    text: "Followers DM with photos of their current kitchen — asking 'can you transform something like this?' The AI acknowledges the images, asks about the property type and dimensions, and attaches the photos to your lead."
  },
  {
    icon: '🌙',
    title: 'Captures Evening Content Browsing',
    text: "Extension reels perform best after 7pm when homeowners are on the sofa imagining their dream kitchen-diner. The AI captures every DM that these reels inspire."
  },
  {
    icon: '📋',
    title: 'Structures Aspirational DMs',
    text: "DMs from extension followers start aspirational — 'we want this' with a screenshot. The AI grounds the conversation by asking about property type, dimensions, planning, and postcode."
  },
  {
    icon: '🔗',
    title: 'Monetises Your Visual Library',
    text: "Every drone shot, build time-lapse, and kitchen reveal you post can trigger a DM. The AI converts each visual impression into a fully detailed extension lead."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "Switch your Instagram to a Business or Creator account and link it to your Facebook Business page. This is a free change that takes two minutes. Extension companies producing regular visual content — finished kitchens, build-progress reels, drone footage of extensions taking shape — generally operate Business accounts already for the reach analytics and promotional tools provided."
  },
  {
    question: "What extension DMs arrive through Instagram?",
    answer: "Domestic enquiries from homeowners captivated by your finished extension content. Typical DMs include 'we want something identical to the kitchen in your last reel,' 'how much would a similar extension cost on a semi-detached?', and 'can you do a wraparound on a terraced house?' These leads carry high conversion potential because the homeowner has already been convinced by your portfolio quality."
  },
  {
    question: "How quickly does the AI respond to extension DMs?",
    answer: "Responses arrive within seconds. Instagram shows read receipts, creating an immediate impression of availability and professionalism. Extension specialists competing with three to five other companies for the same homeowner's project win by responding first. A same-day reply loses to a same-minute reply."
  },
  {
    question: "What does Instagram DMs cost?",
    answer: `Instagram DMs is £${pricing.addOn.price}/month as an add-on. Extension companies whose Instagram content regularly generates enquiries — particularly those with strong before-and-after and reel content — find that this channel captures some of the highest-value residential leads. A single converted kitchen-diner extension from an Instagram DM typically exceeds £40,000.`
  },
  {
    question: "Can I reply to DMs personally?",
    answer: "Sending your own message in any DM thread transfers the conversation to you immediately. The AI steps aside. Most extension specialists let the AI handle the initial scope capture and then follow up personally to discuss design preferences, arrange the site visit, and present the quotation."
  },
  {
    question: "Is DM information kept private?",
    answer: "All Instagram DM content — messages, kitchen photos, architect sketches, property details, and contact information — is encrypted and stored on UK and EU servers under UK GDPR. No DM data is shared with other companies, used for advertising, or accessed by anyone outside your business."
  }
];
