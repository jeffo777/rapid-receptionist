---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📧',
    title: 'Acknowledges Commercial Facade Tenders',
    text: "Main contractors and QSs email cladding subcontract tenders with panel specifications, fire compliance requirements, and programme milestones. The cladding firm that acknowledges first — referencing the system, material, and area — stays on the tender shortlist."
  },
  {
    icon: '📐',
    title: 'References Panel Specifications',
    text: "When a QS emails specifying 'Trespa Meteon HPL panels, satin finish, RAL 7021 Black Grey, concealed fixings to aluminium carriers, mineral wool 140mm, Siderise cavity barriers, A2-s1,d0 combustibility, 2,200 square metres,' the AI acknowledgement references the panel, colour, insulation, barriers, fire class, and area."
  },
  {
    icon: '🕒',
    title: 'Covers Your Installation Hours',
    text: "Cladding crews spend entire days on MEWPs and scaffold — every person at height. A QS's facade tender arriving at 9am goes unread until the platform descends at 5pm. The sixty-second acknowledgement positions your firm ahead of every competing cladding contractor."
  },
  {
    icon: '🗂️',
    title: 'Separates Tenders from Material Orders',
    text: "Your inbox mixes QS tenders, panel manufacturer delivery confirmations, bracket supplier invoices, MEWP hire booking confirmations, cavity barrier supplier dispatch notes, and CWCT training correspondence. The AI filters genuine tenders from operational emails."
  },
  {
    icon: '🤝',
    title: 'Builds Contractor Loyalty',
    text: "Main contractors with multi-phase developments need reliable cladding subcontractors. Consistent instant acknowledgements across housing blocks, commercial offices, and education buildings establish your firm as the facade specialist they programme into every building."
  },
  {
    icon: '📎',
    title: 'Notes Drawing Attachments',
    text: "Cladding tenders include elevation drawings, cladding layout plans, detail sections, cavity barrier positions, and programme bar charts. The AI notes these attachments in the acknowledgement."
  }
];

const faqs = [
  {
    question: "Does the AI produce cladding quotes from tenders?",
    answer: "Pricing is never generated by the system — only a professional receipt referencing the panel specification, fire compliance, and project scope is sent. Your cladding quotation — panels, carrier system, brackets, fixings, insulation, cavity barriers, sealants, MEWP hire, labour, and programme — is prepared by you from the measured elevation drawings and specification documents."
  },
  {
    question: "Will it respond to panel supplier and MEWP hire emails?",
    answer: "You configure during onboarding which email types trigger the acknowledgement. Panel manufacturer dispatch confirmations, bracket supplier invoices, MEWP hire booking receipts, insulation delivery notes, and CWCT membership updates are automatically excluded. Only genuine project tenders and enquiries from main contractors, architects, and building owners receive the professional response."
  },
  {
    question: "How does it handle homeowner cladding enquiries by email?",
    answer: "Homeowner emails through your website — 'we want timber cladding on our extension, can you come and quote?' — receive a professional reply asking about the cladding material preference (cedar, larch, or composite), the approximate area, the property type, and whether the cladding is for a new extension or an existing wall."
  },
  {
    question: "What does email response cost for cladding contractors?",
    answer: `Email response is £${pricing.addOn.price}/month as an add-on. A commercial rainscreen package generates £50,000 to £500,000 in contract value. Acknowledging a QS's three-week tender within sixty seconds — while your crew installed panels from the MEWP on another site — often determines whether your firm receives the Bill of Quantities and the pre-tender site visit invitation.`
  },
  {
    question: "Can all follow-up tender correspondence come from me?",
    answer: "Once the receipt acknowledgement has been sent, every subsequent communication is authored entirely by you. Your measured facade survey, panel schedule, carrier bracket layout, cavity barrier specification, MEWP access plan, method statement, programme, and warranty documentation are prepared and submitted by you and your estimating team."
  },
  {
    question: "How is cladding tender data secured?",
    answer: "Cladding tenders contain building elevations, panel specifications, fire compliance certificates, cavity barrier layouts, and commercially sensitive pricing. All email content is encrypted, stored on UK and EU servers under UK GDPR, and shared only with you. No tender information reaches competing cladding contractors or third parties."
  }
];
---

<ChannelTradeLayout
  title="AI Email Response for UK Cladding Contractors | Rapid Receptionist"
  description={`AI email response for UK cladding contractors. Acknowledges rainscreen tenders, facade variation requests, and timber cladding enquiries within sixty seconds. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/cladding-contractors/ai-email-response/"
  channelName="AI Email Response"
  tradeName="Cladding Contractor"
  tradeNamePlural="Cladding Contractors"
  tradeSlug="cladding-contractors"
  headline="AI Email Response for UK Cladding Contractor Companies"
  accentWord="Cladding"
  subhead="An architect emails a rainscreen cladding specification for a mixed-use development — ACM replacement on twelve storeys. Your AI acknowledges the tender while you fix aluminium cassettes on a scaffold."
  scenario="It is 7am on a Monday. Your inbox accumulated over the weekend: a main contractor requesting cladding for a new primary school in Abingdon — 'Equitone Natura fibre cement, vertical format, RAL colour TBC, about 800 square metres, SFS substrate, Siderise barriers, programme to follow steelwork in 8 weeks,' an architect requesting timber cladding on a contemporary barn conversion near Burford — 'charred larch vertical boards, open-jointed, stainless steel clips, breather membrane, approximately 120 square metres across three elevations,' a facilities manager requesting panel replacement on a 1990s office building in Kidlington — 'several composite panels damaged and faded, need colour-matched replacements, about 30 panels across the ground floor,' and a panel supplier confirming next week's delivery of Trespa HPL. Without AI Email Response, the school tender and barn conversion sit until Tuesday evening. Two competitors responded Monday morning. With AI Email Response, the school Equitone specification is acknowledged with material and programme noted, the charred larch barn conversion references the charred finish and stainless clips, the panel replacement references the colour-matching requirement, and the supplier email is filtered."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-email-response/"
  tradePageUrl="/cladding-contractors/ai-receptionist/"
  ctaHeadline="Acknowledge the 3,400 sqm University Lab Tender While You Remediate in Banbury"
  ctaSubhead={`A QS's four-week tender for Reynobond A2 across five elevations with BS 8414 evidence starts when the email lands. Your sixty-second acknowledgement locks your place on the site visit list. Add-on at £${pricing.addOn.price}/month.`}
/>
