---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Striking Facade Content',
    text: "Cladding photography is inherently visual — zinc-wrapped gables, larch-clad extensions, and aluminium rainscreen on commercial blocks. When an architect or self-builder messages about their own facade, the AI converts portfolio engagement into a project lead."
  },
  {
    icon: '📸',
    title: 'Handles Panel Damage Photo Messages',
    text: "Facilities managers message with photos of cracked panels, faded composite sheets, and storm-dislodged fixings — 'can you replace these panels?' The AI asks about the panel type, building height, and the number of affected panels."
  },
  {
    icon: '⚡',
    title: 'Captures MC Booking Messages',
    text: "Main contractors browse your facade portfolio and message from site — 'saw your zinc work, need a cladding team for our Banbury school next month.' The AI captures the system, area, and programme while you install panels elsewhere."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Material Research',
    text: "Architects and self-builders research cladding systems in the evening — comparing zinc to copper, larch to Accoya, and fibre cement to HPL. Messages about material performance and costs arrive after 8pm."
  },
  {
    icon: '📋',
    title: 'Qualifies Facade Project Scale',
    text: "Messenger conversations begin broadly — 'how much does cladding cost?' The AI asks about the material, building type, area, height, and whether the project is domestic or commercial — categorising the enquiry before you engage."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Elevation Shot',
    text: "Every zinc standing seam detail, larch board close-up, and rainscreen completion drone shot generates enquiries from design professionals who value facade precision."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my cladding firm?",
    answer: "We handle the Messenger connection during your onboarding — if you do not have a Business page, we create one with you on the call in about ten minutes. Cladding companies posting facade completion galleries, zinc detail close-ups, and timber installation time-lapses usually already have an active Business page, so the integration may be ready to go straight away. Once connected, the AI manages every incoming message from architects, self-builders, and main contractors."
  },
  {
    question: "What cladding enquiries come through Messenger?",
    answer: "Architects message about material selection for planning applications. Self-builders message about mixed-material facades for contemporary houses. Main contractors message about cladding subcontract availability after reviewing your project gallery. Facilities managers message about panel replacement and storm damage. Each sender has viewed your completed facade work and identified your firm's installation quality."
  },
  {
    question: "How fast does the AI reply to cladding messages?",
    answer: "Replies arrive in the sender's inbox within seconds of the message. Facebook's active indicator confirms your cladding firm is immediately available. An architect who has compared six cladding portfolios and finally messages their top choice expects a swift, material-literate response — not an unread message that suggests the firm lacks capacity."
  },
  {
    question: "What does Messenger cost for cladding contractors?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. A commercial rainscreen package generates £50,000 to £500,000. One main contractor's facade programme — captured through a prompt Messenger reply while you aligned panels at another site — justifies the channel cost indefinitely.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Reply once in any thread and the AI stands aside permanently. Most cladding contractors let the AI capture the initial scope — system type, material, area, height, fire class, and programme — then engage to discuss the site measurement, detail solutions, and tender pricing."
  },
  {
    question: "How is Messenger data from cladding queries protected?",
    answer: "All Messenger conversations, facade photographs, building locations, material specifications, fire compliance details, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No facade details reach competing cladding firms, are shared with panel manufacturers, or are disclosed to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Cladding Contractors | Rapid Receptionist"
  description={`AI Facebook Messenger for UK cladding contractors. Converts facade portfolio content into rainscreen tenders and timber cladding bookings. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/cladding-contractors/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Cladding Contractor"
  tradeNamePlural="Cladding Contractors"
  tradeSlug="cladding-contractors"
  headline="AI Facebook Messenger for UK Cladding Contractor Companies"
  accentWord="Cladding"
  subhead="You post photos of a completed zinc standing-seam facade on a coastal apartment block. A developer messages about composite cladding for a new-build office. Your AI captures the enquiry while you fix."
  scenario="It is 11pm on a Friday. A building safety manager for a housing association messages about a remediation programme — three residential blocks built in 2005, each five storeys, clad in composite aluminium panels that have been identified as having a polyethylene (PE) core during a recent intrusive survey. The Building Safety Act requires their replacement with A2-rated alternatives. His message: 'Hi — we manage three five-storey residential blocks near Cowley. Built 2005. Composite cladding has been confirmed PE core following intrusive investigation. Building Safety Act requires full strip and replacement with A2-rated panels. Each block is approximately 900 square metres of cladding. Need to appoint a specialist contractor for all three blocks. Programme is phased — one block at a time. Can you handle this scale of remediation? We have DLUHC funding approved.' Without AI Messenger, the remediation message waits until Monday. One firm replied at 11:30pm. With AI Messenger, the reply arrives at 11:01pm: 'Thank you — PE-core ACM remediation is a specialised requirement. Could you confirm the existing fixing system type and whether the SFS substrate behind the panels is in serviceable condition?' He confirms the SFS appears sound. Monday you call: three blocks Cowley, 2,700 sqm total, PE-core ACM strip, A2 replacement, phased, DLUHC funded, SFS condition sound."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/cladding-contractors/ai-receptionist/"
  ctaHeadline="Turn 87 Likes on a Zinc-Larch Junction into a Victorian Villa Extension Tender"
  ctaSubhead={`Three photos of a Charlbury mixed-material facade earn eighty-seven likes. AI Messenger converts an architect's zinc cassette enquiry into a folded metal envelope specification. Add-on at £${pricing.addOn.price}/month.`}
/>
