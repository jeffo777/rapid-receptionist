---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '⚡',
    title: 'Answers While Your Hands Are Full',
    text: "Plastering is one of the few trades where stopping mid-job genuinely ruins the work. Whether you run a small plastering business, a plastering contractor operation, or a rendering company, you cannot put down a loaded trowel to answer a phone. The AI handles every call — greeting callers with your business name and capturing what they need — while your skim sets perfectly."
  },
  {
    icon: '🧠',
    title: 'Understands Plastering Enquiries',
    text: "When a caller says 'the plaster is blown in the kitchen' or 'I need the Artex taken off the bedroom ceiling,' the AI understands what they mean. It captures the right details — room sizes, surface conditions, the type of work — so your callback is informed and efficient."
  },
  {
    icon: '🚨',
    title: 'Escalates Real Emergencies',
    text: "Plaster falling from a ceiling in a nursery. Water streaming through a rendered wall. The AI recognises emergency language and escalates immediately — reaching your mobile first, then our human team if needed. Routine re-skim enquiries are captured as standard leads."
  },
  {
    icon: '🕐',
    title: 'Covers Your Evenings and Weekends',
    text: "Homeowners often call in the evening after discovering damage — a crack they noticed when moving furniture, a damp patch that appeared after rain. Those 7pm and Saturday morning calls are prime leads. The AI catches every one."
  },
  {
    icon: '📋',
    title: 'Detailed Lead Summaries',
    text: "Every call is summarised with the caller's name, number, location, what work they need, and how urgent it is. When you call back, you already know whether it's a bathroom re-skim, a full house re-plaster, or an insurance repair — no guessing."
  },
  {
    icon: '🎯',
    title: 'Your Business Name, Your Greeting',
    text: "The AI answers as your plastering business. 'Good morning, thank you for calling Whitfield Plastering, how can I help?' Your callers hear a professional greeting that matches your brand, not a generic answering machine."
  }
];

const faqs = [
  {
    question: "What does the AI say when a plastering customer calls?",
    answer: "It greets the caller with your business name — 'Good morning, thank you for calling [your business name], how can I help you today?' It then has a natural conversation to understand the work needed. For plastering businesses and rendering contractors, it asks about the type of job (re-skim, rendering, repair, Artex removal), the property type and location, how urgent it is, and captures the caller's name and contact details."
  },
  {
    question: "Can it tell the difference between a quick patch job and a full re-plaster?",
    answer: "The AI captures what the caller describes — it doesn't try to assess or quote the job. If someone says 'just a small patch above the door,' that's recorded. If someone says 'every room in the house needs doing,' that's recorded too. You get the full picture in the lead summary and decide how to prioritise your callback."
  },
  {
    question: "What if someone calls about rendering rather than internal plastering?",
    answer: "The AI handles both. Whether a caller is asking about a bedroom re-skim, a full external render, monocouche render, pebble dash, or insulated render systems, the AI captures the details. It doesn't differentiate or filter — it records what the customer describes and sends it to you."
  },
  {
    question: "How many minutes of phone time do I get?",
    answer: "The Core plan includes 300 minutes of AI phone conversation time per month. For most sole trader plasterers and small plastering firms, this comfortably covers the call volume. If you consistently go over, additional minutes are charged at 20p each — no cap and no penalty."
  },
  {
    question: "Can I still take calls myself when I want to?",
    answer: "Yes. You set when the AI activates — only when you are unavailable, busy, or after hours. When you are available, calls ring through to you as normal. The AI is your backup, not your replacement."
  },
  {
    question: "How does Rapid Receptionist protect my customers' data?",
    answer: "All data captured during phone calls — names, numbers, addresses, job descriptions — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted in transit and at rest, stored on UK and EU servers, and shared only with you. We never sell or repurpose it. You remain the data controller; we act as your data processor under a formal agreement."
  }
];
---

<ChannelTradeLayout
  title="AI Phone Answering for Plasterers | Rapid Receptionist"
  description={`AI phone answering for UK plasterers, plastering contractors, and rendering businesses. Answers every call with your business name, captures plastering enquiry details, and escalates emergencies. 300 minutes included. From £${pricing.tiers.starter.price}/month.`}
  canonicalUrl="/plasterers/ai-phone-answering/"
  channelName="AI Phone Answering"
  tradeName="Plasterer"
  tradeNamePlural="Plasterers"
  tradeSlug="plasterers"
  headline="AI Phone Answering for Plasterers"
  accentWord="Plasterers"
  subhead="Whether you are a sole trader plasterer or a plastering contractor with a team, you cannot stop mid-coat to answer the phone. A property developer needs two flats re-skimmed before handover next Friday. Your AI answers, captures the brief, and the lead is in your inbox before the plaster dries."
  scenario="It is 10:15am on a Wednesday. You are skimming a hallway ceiling in a semi-detached in Stockport — the bonding coat has been on since yesterday and you have got a two-hour window to get the finish coat on before it kicks off. Your phone rings in the van. A homeowner in Didsbury has just moved in and every ceiling in the house has cracks and loose plaster from the previous owner pulling out old coving. They want someone to look at it this week. Without AI Phone Answering, they hear your voicemail, think 'he is probably too busy,' and google 'plasterer near me Didsbury' to find someone who answers. With AI Phone Answering, they hear: 'Good morning, thank you for calling, how can I help?' The AI captures the full scope — five ceilings, loose plaster and previous coving damage, Didsbury postcode, available all week. You finish the hallway at 12:30 and call them back with a plan."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-phone-answering/"
  tradePageUrl="/plasterers/ai-receptionist/"
  ctaHeadline="Stop Missing Plastering Jobs"
  ctaSubhead={`Every missed call is a room that someone else will skim. From £${pricing.tiers.starter.price}/month.`}
/>
