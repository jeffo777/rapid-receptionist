---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls about re-plastering their lounge ceiling after a leak. Your phone's in the van and you're halfway through skimming a hallway. They get voicemail, hang up, and call the next plasterer on Google.",
    with: "The same homeowner calls. Your AI receptionist answers: 'Good morning, thank you for calling. How can I help?' It captures the ceiling damage details, the property address, and books a callback for your lunch break. You finish the skim and call them back with every detail in front of you."
  },
  {
    without: "A letting agent emails at 6pm on Friday asking for a quote to re-plaster three flats before new tenants move in next month. You don't see the email until Monday. By then, two other plasterers have already quoted.",
    with: "The email gets an instant acknowledgement confirming you've received the specification. Monday morning, you review the full brief — property addresses, room counts, timeline — and respond first with a considered quote."
  },
  {
    without: "A previous customer recommends you in a local Facebook group. Someone messages your page asking about availability for a full house re-skim. The message sits unread for three days.",
    with: "The Facebook message gets an instant reply capturing the enquirer's details, the scope of work, and their postcode. You follow up with a call the next morning — before they've had time to message anyone else."
  }
];

const specialisms = [
  {
    category: "Domestic Plastering",
    items: ["Full room re-skims", "Ceiling repairs and replacements", "Plaster patching and blending", "Artex removal and over-boarding", "Coving and cornice installation", "New-build plaster finishing"]
  },
  {
    category: "External Rendering",
    items: ["Sand and cement render", "Monocouche (one-coat) render", "Silicone render systems", "Pebble dash and roughcast", "Render repair and patching", "Insulated render (EWI) systems"]
  },
  {
    category: "Specialist & Commercial",
    items: ["Dry lining and partition walls", "Venetian plaster and polished plaster", "Acoustic and fire-rated plastering", "Heritage lime plastering", "Commercial office fit-outs", "Multi-unit residential developments"]
  }
];

const clientTypes = [
  {
    icon: "🏠",
    title: "Domestic Homeowners",
    description: "Homeowners calling about re-skims, ceiling repairs, Artex removal, or plaster patching — often after discovering damage or during a renovation. Whether they searched for a plasterer, a plastering company, or a local plastering contractor, they want reassurance, a rough timeline, and confidence that someone will get back to them."
  },
  {
    icon: "🏗️",
    title: "Builders & Main Contractors",
    description: "Site managers and builders looking for plastering subcontractors and rendering contractors on new builds, extensions, and refurbishment projects. They need quick availability checks from reliable plastering contractors and often work to tight programme schedules."
  },
  {
    icon: "🏢",
    title: "Landlords & Property Managers",
    description: "Letting agents and landlords needing plaster repairs between tenancies, often at short notice. They want a plastering business that responds quickly, provides clear pricing, and communicates reliably across multiple properties."
  },
  {
    icon: "🔧",
    title: "Insurance & Restoration Work",
    description: "Loss adjusters, restoration companies, and insurers sourcing plastering firms for flood, fire, and leak damage repairs. These enquiries are time-sensitive and they expect any plastering company they contact to respond within hours, not days."
  }
];

const faqs = [
  {
    question: "How does the AI know about plastering terminology?",
    answer: "During setup, your AI receptionist is configured with plastering-specific vocabulary — skim coats, float and set, bonding, PVA, dubbing out, wet plaster vs dry lining, one-coat render, scratch coat, and everything else a plastering customer might describe. When a homeowner says 'the plaster is blown in the hallway,' the AI understands what that means and captures it correctly. It doesn't need to be a plasterer — it just needs to understand enough to capture the lead accurately."
  },
  {
    question: "Can the AI handle calls about both internal plastering and external rendering?",
    answer: "Yes. The AI captures the nature of the work regardless of whether the caller is asking about a bedroom re-skim, an Artex ceiling removal, a full external render, or a specialist polished plaster finish. It identifies the type of work from the conversation and includes it in the lead summary so you know exactly what you're calling back about."
  },
  {
    question: "What happens when someone calls about an emergency — like plaster falling off a ceiling?",
    answer: "The AI recognises urgency in the conversation. If a caller describes plaster falling from a ceiling, water coming through a wall, or structural damage, the AI escalates immediately — first attempting to reach you on your mobile, then escalating to our human operators if you're unavailable. Routine re-skim requests and quote enquiries are handled as standard leads."
  },
  {
    question: "How much does it cost for a plastering business or plastering contractor?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month and includes AI phone answering (300 minutes) plus unlimited website chat — covering the two channels that generate the most leads for plastering businesses. Additional channels like WhatsApp, SMS, Facebook, Instagram, email, and missed call text-back are £${pricing.addOn.price}/month each. The All Channels bundle at £${pricing.tiers.all.price}/month covers everything. The pricing is the same whether you are a sole trader plasterer, a plastering contractor with a crew, or a rendering company — there is no difference based on business size. There is a one-time setup fee of £${pricing.setup.price} (refundable if you cancel within 30 days).`
  },
  {
    question: "Is this suitable for a small plastering company or sole trader?",
    answer: "Absolutely. Whether you are a sole trader plasterer, a two-man plastering business, a rendering contractor with a small crew, or a larger plastering firm handling commercial contracts — this was built for you. Sole traders and small plastering contractors are the ones up a ladder when the phone rings. You cannot employ a receptionist. The AI handles the calls you physically cannot answer — morning, evening, weekends — and sends you every lead with full details so you can follow up between jobs."
  },
  {
    question: "Can I use this alongside my existing phone number?",
    answer: "Yes. We set up call forwarding from your existing business number to your Rapid Receptionist line. Your customers dial the same number they always have — nothing changes on their end. When you're available, calls ring through to you as normal. When you're on a job, the AI picks up. The whole setup is done for you by our team."
  },
  {
    question: "How does Rapid Receptionist handle my customers' personal data?",
    answer: "All customer data is managed in accordance with UK GDPR and the Data Protection Act 2018. Contact details, property addresses, and job descriptions are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never sell, share, or repurpose enquiry data. You remain the data controller; Rapid Receptionist operates as your data processor under a formal agreement. Our full privacy policy is available on site."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for Plasterers | Rapid Receptionist"
  description={`AI receptionist for UK plasterers, plastering businesses, and rendering contractors. Answers calls, captures leads from chat, WhatsApp, Facebook and more — while you are skimming, rendering, or on site. From £${pricing.tiers.starter.price}/month.`}
  canonicalUrl="/plasterers/ai-receptionist/"
  tradeName="Plasterer"
  tradeNamePlural="Plasterers"
  tradeSlug="plasterers"
  headline="The Rapid Response AI Receptionist for Plasterers"
  accentWord="Plasterers"
  subhead={`Whether you run a one-man plastering business or a plastering contractor with a crew of six, the problem is the same — you cannot answer the phone while you are on the tools. Your AI receptionist answers every call, captures every lead from chat, WhatsApp, and social media, and sends you the details. From £${pricing.tiers.starter.price}/month.`}
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Plastering Jobs to Missed Calls"
  ctaSubhead={`Every call your plastering business misses is a customer calling the next plastering contractor. From £${pricing.tiers.starter.price}/month — respond first, win the work.`}
/>
