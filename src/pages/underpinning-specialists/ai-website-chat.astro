---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Engages Worried Homeowners Researching Subsidence',
    text: "Homeowners discovering cracks spend hours researching online — reading about subsidence, comparing underpinning methods, and looking for reassurance. When they reach your website, chat provides immediate engagement from a specialist firm while they are at their most anxious."
  },
  {
    icon: '📐',
    title: 'Qualifies Crack Severity',
    text: "Through conversation, the AI asks about the crack width, direction, location relative to windows and doors, and whether the cracks are getting worse. This initial triage helps you prioritise genuine subsidence enquiries from cosmetic plaster cracking."
  },
  {
    icon: '🕐',
    title: 'Converts Evening Panic Research',
    text: "Subsidence research peaks in the evening — homeowners notice cracks after work, photograph them, and search for specialists. At 10pm a homeowner types: 'We have just noticed diagonal cracks running from our back door to the roofline — wider at the top. Our house is 1930s and there is a large oak tree next door. Is this subsidence?' The chat provides reassurance and captures the lead."
  },
  {
    icon: '📊',
    title: 'Explains Underpinning Processes',
    text: "Visitors ask worried questions — 'how long does underpinning take?', 'will we need to move out?', 'does insurance cover it?' The AI responds from your profile with helpful context while capturing their property and crack details."
  },
  {
    icon: '🔗',
    title: 'Works Alongside Case Studies',
    text: "Underpinning websites showcase completed projects — before-and-after crack photos, excavation sequences, and monitoring reports. Chat converts nervous visitors browsing your success stories into consultation bookings."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat is bundled with phone answering at £${pricing.tiers.core.price}/month. Unlimited conversations about subsidence, settlement, and foundation repair.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my underpinning website?",
    answer: "We handle the entire setup for you during onboarding. Our team adds the chat widget to your website so you never need to worry about code or plugins. It works across any platform your site runs on. If you already have a web developer managing your site, or you prefer to paste in a short snippet yourself, we will provide the code and it takes about a minute. Most underpinning specialists let us handle the digital side while they focus on excavating bays."
  },
  {
    question: "Can the AI reassure worried homeowners about subsidence?",
    answer: "Your profile informs the AI about your company's approach, experience, and typical project scope. When a homeowner asks 'we have cracks and we are terrified — is our house going to fall down?' the AI provides measured, professional reassurance from your profile, explains that a structural engineer assessment is the first step, and captures the property details, crack description, and insurance status for your follow-up."
  },
  {
    question: "What does chat capture from underpinning visitors?",
    answer: "The AI gathers the property type and age, the crack pattern and severity, the suspected cause (trees, drainage, clay shrinkage), whether a structural engineer has inspected the property, the insurance claim status and insurer, the caller's role (homeowner, loss adjuster, engineer, builder), and contact details for your follow-up."
  },
  {
    question: "Does chat affect my website loading speed?",
    answer: "The chat widget initialises after your existing content has rendered completely — project case studies, before-and-after galleries, and testimonial sections display at their standard speed before the chat interface appears. The footprint is minimal and creates no perceptible delay on any page."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Chat is part of the same Core plan as phone answering at £${pricing.tiers.core.price}/month. For underpinning specialists, these two channels address the primary enquiry routes: daytime phone calls from loss adjusters and structural engineers, and evening website conversations from homeowners researching subsidence symptoms and remediation options.`
  },
  {
    question: "How is visitor data from underpinning queries handled?",
    answer: "Chat conversations containing property addresses, crack descriptions, insurance claim references, structural engineer details, and visitor contact information are encrypted and stored on UK and EU servers under UK GDPR. Lead summaries are shared exclusively with you. No property information reaches competing underpinning firms or any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Website Chat for UK Underpinning Specialists | Rapid Receptionist"
  description={`AI website chat for UK underpinning specialists. Engages worried homeowners researching subsidence symptoms and foundation repair options. Included at £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/underpinning-specialists/ai-website-chat/"
  channelName="AI Website Chat"
  tradeName="Underpinning Specialist"
  tradeNamePlural="Underpinning Specialists"
  tradeSlug="underpinning-specialists"
  headline="AI Website Chat for UK Underpinning Specialist Companies"
  accentWord="Underpinning"
  subhead="A homeowner finds your site at 11pm after noticing a crack above the front door has doubled in width over the summer. They describe clay soil, nearby trees, and a sinking bay. Chat captures the lead."
  scenario="It is midnight on a Sunday. A property developer in Witney is buying a row of four Victorian terraced houses at auction to convert into flats. The auction pack includes a structural survey that flags 'historic movement to the front elevation party wall area with monitoring recommended.' He knows from experience this could mean underpinning. He finds your website and types: 'Hi — buying 4 Victorian terraces at auction. The survey mentions historic movement at the party walls on the front elevations. Need a specialist to assess whether underpinning is needed before I commit. Also need to understand the Party Wall Act implications if underpinning affects the neighbours. Can you do a pre-purchase foundation assessment? Auction is in 3 weeks. Witney, OX28. What would you charge for 4 assessments?' Without chat, he emails on Monday and waits. With AI Website Chat, the AI asks about the survey's crack width measurements, whether tell-tales have been installed, and the age and construction type of the party walls. The developer provides details. Monday you call: four Victorian terraces, Witney, auction in three weeks, party wall concerns, pre-purchase assessments."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-website-chat/"
  tradePageUrl="/underpinning-specialists/ai-receptionist/"
  ctaHeadline="Reassure the Worried Abingdon Homeowner While Her Lime Tree Cracks Widen"
  ctaSubhead={`A homeowner with 5mm diagonal cracks and a neighbour's lime tree is reading about subsidence at 9:30pm. Your chat provides specialist context and captures the lead. Included at £${pricing.tiers.core.price}/month.`}
/>
