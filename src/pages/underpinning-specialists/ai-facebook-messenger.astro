const benefits = [
  {
    icon: '💬',
    title: 'Converts Before-and-After Subsidence Posts',
    text: "Underpinning before-and-after content draws strong engagement — dramatic crack close-ups, excavation sequences beneath listed buildings, and completed repairs with monitoring data showing stabilised movement. When a worried homeowner messages about their own cracks, the AI captures the assessment lead."
  },
  {
    icon: '📸',
    title: 'Handles Crack Photo Messages',
    text: "Homeowners message with crack photos — 'does this look like subsidence?' The AI asks about the crack direction, width, whether it is growing, the property age, nearby trees, and insurance status, converting anxious photo messages into structured assessment leads."
  },
  {
    icon: '⚡',
    title: 'Captures Neighbourhood Concern',
    text: "When you underpin a property on a street, neighbours notice the excavation works and start examining their own walls. Messages asking 'you are working on number 42 — we have similar cracks on our house' convert adjacency awareness into assessment bookings."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Worry',
    text: "Subsidence anxiety peaks in the evening. Homeowners photograph cracks after work, compare them to photos from last month, and message specialists. Messages at 10pm about 'cracks that are definitely getting wider' carry genuine urgency."
  },
  {
    icon: '📋',
    title: 'Qualifies Casual Crack Enquiries',
    text: "Messenger conversations start with worry — 'how much does underpinning cost?' The AI asks about the crack pattern, property type, suspected cause, and insurance position, transforming anxiety into a structured foundation assessment lead."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Case Study Post',
    text: "Every excavation time-lapse, crack repair sequence, and monitoring report showcase posted to Facebook can generate an assessment booking from a property owner recognising similar symptoms in their own home."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my underpinning firm?",
    answer: "The Messenger integration needs a Business page — personal Facebook profiles are not compatible with the AI. Underpinning companies posting case study content — dramatic crack documentation, excavation sequences, before-and-after structural repairs, and monitoring data — attract engagement from homeowners, loss adjusters, and structural engineers who assess your specialist capability before sending enquiries."
  },
  {
    question: "What underpinning enquiries arrive through Messenger?",
    answer: "Predominantly worried homeowners and occasionally loss adjusters. Homeowners message with crack photos and anxious questions — 'is this subsidence?', 'will my house fall down?', 'how much does underpinning cost?' Loss adjusters message about claim logistics. Both are pre-engaged contacts who have already reviewed your subsidence case studies and identified you as a foundation specialist."
  },
  {
    question: "How fast does the AI reply to underpinning messages?",
    answer: "The response reaches the sender within seconds. Facebook's active status indicator shows your specialist firm is engaged immediately. Worried homeowners who have spent the evening researching subsidence and finally decided to contact a specialist respond best to an instant, measured, reassuring reply that demonstrates specialist foundation knowledge."
  },
  {
    question: "What does Messenger cost for underpinning firms?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. Underpinning projects range from £3,000 single-elevation domestic mass concrete work to £80,000 complex multi-elevation piled schemes. One homeowner's subsidence claim — captured through a prompt Messenger reply to a worried evening crack photo while competing firms' messages sat overnight — covers the channel cost for the foreseeable future.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Respond in any Messenger thread and the AI yields control to you permanently for that conversation. Most underpinning firms let the AI capture the initial concern — crack details, property type, insurance status, and engineer involvement — then follow up to provide specialist reassurance, explain the investigation process, and arrange the site visit."
  },
  {
    question: "How is Messenger data from underpinning queries protected?",
    answer: "All Messenger conversations, crack photographs, property locations, insurance claim references, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No property details are disclosed to competing underpinning firms, shared with insurers beyond the instructing party, or sold to any third party."
  }
];
