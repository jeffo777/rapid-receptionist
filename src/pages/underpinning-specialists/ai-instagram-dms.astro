---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📷',
    title: 'Converts Excavation and Repair Reels',
    text: "Underpinning reels have compelling visual drama — a confined trench beneath a Listed Georgian wall, concrete pouring into a shored bay, and the final reveal of repaired brickwork with zero movement on the monitoring data. When followers DM about cracks in their own property, the AI captures the assessment lead."
  },
  {
    icon: '🎯',
    title: 'Reaches Property-Conscious Audiences',
    text: "Instagram reaches homeowners who care deeply about their property — design-focused renovators, period property enthusiasts, and developers. A DM from someone who has studied your foundation repair case studies is a pre-qualified lead with genuine structural concern."
  },
  {
    icon: '📱',
    title: 'Handles Crack Photo DMs',
    text: "Worried homeowners DM crack photos — 'this appeared last month and it is getting wider.' The AI asks about the crack direction, width progression, property age, and nearby trees, converting visual anxiety into a structured foundation assessment brief."
  },
  {
    icon: '🌙',
    title: 'Captures Late-Night Subsidence Anxiety',
    text: "Homeowners lie awake worrying about cracks. At midnight they photograph the crack with their phone torch, compare it to last week's photo, and DM an underpinning specialist. These late-night messages represent the most anxious and action-ready homeowners."
  },
  {
    icon: '📋',
    title: 'Structures Worried DMs',
    text: "DMs about underpinning start emotionally — 'how much to fix a cracked house?' The AI provides measured reassurance, asks about the crack characteristics and property details, and converts anxiety into a quotable assessment brief."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Repair Showcase',
    text: "Every excavation time-lapse, crack monitoring close-up, and completed repair reveal generates potential assessment bookings from property owners noticing the same symptoms on their own walls."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "Convert to a Business or Creator profile from your settings — a two-minute process at no cost, linked to your Facebook Business page. Underpinning specialist firms producing case study content — dramatic crack documentation, excavation beneath historic buildings, and monitoring data showing stabilisation — gain professional analytics that help extend every post's reach to property owners searching for foundation expertise."
  },
  {
    question: "What underpinning DMs come through Instagram?",
    answer: "Primarily worried homeowners and occasionally structural engineers. Homeowners DM with crack photos and anxious questions about subsidence, insurance, and repair costs. Engineers DM about specialist underpinning contractors for their own referrals. Each sender has viewed your case study content and chosen your firm based on demonstrated foundation repair expertise."
  },
  {
    question: "How quickly does the AI respond to underpinning DMs?",
    answer: "Within seconds of the DM arriving. Instagram's read receipt confirms that your specialist firm is actively engaged. Anxious homeowners who have finally decided to contact an underpinning specialist — after days of studying their cracks and researching subsidence — need an immediate, measured, professionally reassuring response that validates their concern and explains the next steps."
  },
  {
    question: "What does Instagram DMs cost for underpinning firms?",
    answer: `Instagram DMs is £${pricing.addOn.price}/month as a channel add-on. Underpinning projects span from £3,000 single-elevation domestic work to £80,000 complex piled schemes. One homeowner's insurance subsidence claim, captured through a prompt midnight DM reply while two competitors' messages accumulated, transforms the monthly channel cost into the most productive lead investment you make all year.`
  },
  {
    question: "Can I reply to DMs myself?",
    answer: "Post one reply into any DM thread and the AI steps aside for good. It recognises your message and withdraws. Most underpinning specialists let the AI capture the initial concern — crack details, property type, location, insurance status, and engineer involvement — then follow up personally with reassurance, explain the investigation process, and arrange the assessment visit."
  },
  {
    question: "Is DM data from underpinning queries private?",
    answer: "All Instagram DM content — crack photographs, property descriptions, insurance references, monitoring concerns, and sender contact details — is encrypted and stored on UK and EU servers under UK GDPR. Nothing reaches competing underpinning firms, is disclosed to insurance companies beyond your instructing party, or is made available to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Instagram DMs for Underpinning Specialists | Rapid Receptionist"
  description={`AI Instagram DMs for UK underpinning specialists. Converts subsidence case studies and crack repair reels into foundation assessment bookings. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/underpinning-specialists/ai-instagram-dms/"
  channelName="AI Instagram DMs"
  tradeName="Underpinning Specialist"
  tradeNamePlural="Underpinning Specialists"
  tradeSlug="underpinning-specialists"
  headline="AI Instagram DMs for Underpinning Specialist Companies"
  accentWord="Underpinning"
  subhead="Your latest reel is a sixty-second time-lapse of a mini-pile underpinning installation beneath a Grade II listed Georgian townhouse in central Oxford — the compact CFA rig positioning in the confined rear garden, boring 150mm piles to 9-metre depth through alluvial deposits to the gravel bearing stratum, the reinforced concrete needle beam being formed against the existing rubble stone foundation, and the final shot showing the complete pile-and-beam system with the historic wall above sitting securely on its new foundations. Twelve thousand views. A property developer in Jericho DMs: 'Incredible work beneath a listed building. We are converting a Georgian townhouse into three flats — the front elevation has differential settlement and the existing foundations are only 500mm deep on soft silt. Our structural engineer recommends piled underpinning because the bearing stratum is at 11 metres. The building is Grade II listed and the conservation officer requires minimal visual impact. Can you install mini piles inside a listed building without damaging the historic fabric? About 18 piles across the front elevation, 150mm CFA to 11 metres, needle beam system. Completion needed in 10 weeks.' You are on site. Without AI DMs, the developer's message waits. With it, the AI asks about the conservation officer's specific conditions, the internal floor construction, and whether the building has cellars accessible for piling rig access. Your lead — Georgian townhouse, Jericho, Grade II listed conversion, differential settlement, 500mm foundations, soft silt, 18x CFA piles, 11m depth, needle beam, conservation constraints, 10-week programme — is captured."
  scenario="It is 1am on a Saturday. A homeowner in Eynsham has been monitoring cracks in her 1960s bungalow for six months. She installed a pencil-line tell-tale across the main crack in February and at midnight she checked it — the crack has moved beyond the pencil mark. She has been reading about subsidence all evening and your Instagram case studies have convinced her that professional help is needed. She DMs: 'Hi — I have been watching a crack on my bungalow for 6 months and tonight I checked my tell-tale mark and the crack has moved past it. The bungalow is 1960s, on clay, and there is a row of leylandii along the boundary about 3 metres away. The crack runs diagonally from the bedroom window corner up to the eaves. Inside, the plaster is cracked in the same room and the window is harder to open than it was. I think this is subsidence. Should I call my insurance? I am with LV=. What happens next?' Without AI DMs, she checks repeatedly for a reply and sleeps badly. Two firms reply Saturday morning. With AI DMs, the response arrives at 1:02am: 'Thank you — the fact that your tell-tale confirms progressive movement is significant and you should report this to LV= as potential subsidence. They will appoint a structural engineer to investigate. Could you confirm whether the leylandii are on your property or the neighbour's, and whether any other rooms show cracking?' She confirms the trees are on the neighbour's land and the hallway has small cracks too. Saturday you review: 1960s bungalow, Eynsham, progressive diagonal cracking, tell-tale confirmed movement, leylandii 3m on neighbour's land, multiple rooms, LV= insured."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-instagram-dms/"
  tradePageUrl="/underpinning-specialists/ai-receptionist/"
  ctaHeadline="Turn a Georgian Townhouse Time-Lapse into a Grade II Piled Underpinning Tender"
  ctaSubhead={`A sixty-second CFA rig reel earns twelve thousand views. AI Instagram DMs converts every developer message into a piling specification with conservation constraints. Add-on at £${pricing.addOn.price}/month.`}
/>
