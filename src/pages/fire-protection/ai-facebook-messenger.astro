---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Fire Safety Project Posts',
    text: "Fire protection before-and-afters are compelling — riser cupboards transformed from cable chaos to certified compartmentation, steelwork coated from bare to fully protected. Building managers seeing these transformations message wanting the same standard applied to their own buildings."
  },
  {
    icon: '📸',
    title: 'Handles Deficiency Photo Messages',
    text: "Building managers message with photos of missing fire stopping, degraded intumescent coatings, or damaged fire doors. The AI acknowledges the photos, asks about the building type and compliance deadline, and captures the deficiency images alongside a structured remediation lead."
  },
  {
    icon: '⚡',
    title: 'Captures Word-of-Mouth Referrals',
    text: "A building manager who used your fire stopping services recommends you to a colleague on Facebook. The colleague messages your page. The AI captures the referral lead with the original recommendation as social proof."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Report Reviews',
    text: "Building managers and Responsible Persons review fire risk assessments in the evening and message fire protection firms while the deficiencies are fresh in their minds. The AI captures these compliance-driven weekend and evening enquiries."
  },
  {
    icon: '📋',
    title: 'Structures Compliance Messages',
    text: "Messenger conversations about fire protection start with urgency — 'we have just failed an inspection.' The AI structures the enquiry by asking about the building type, deficiency nature, and enforcement timeline."
  },
  {
    icon: '🔗',
    title: 'Monetises Your Certification Content',
    text: "Every FIRAS-labelled fire stopping photo, intumescent coating project, and sprinkler installation video posted on Facebook can generate a compliance enquiry. The AI converts professional credibility into remediation contracts."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my fire protection company?",
    answer: "Yes — you need a Business page rather than a personal profile, as the Messenger integration requires Business page access. Most fire protection companies already operate a Facebook Business page to showcase FIRAS-certified installations, sprinkler commissioning projects, and intumescent coating work. The AI simply adds instant professional message handling on top of your existing presence."
  },
  {
    question: "What fire protection enquiries come through Messenger?",
    answer: "Primarily building manager and compliance-driven leads. Common messages include 'our fire risk assessment has found issues — can you survey?', 'need fire stopping in a residential block — are you FIRAS-certified?', and 'looking to upgrade our fire alarm to an L1 system.' These leads often carry enforcement deadlines, making responsiveness commercially critical."
  },
  {
    question: "How quickly does the AI reply on Messenger?",
    answer: "Within seconds. Messenger shows active status, creating an impression of immediate availability. Building managers comparing three fire protection firms — often under enforcement pressure — award the survey appointment to the company that responds first with informed questions about the building type, deficiency scope, and compliance deadline."
  },
  {
    question: "What does Messenger cost for fire protection companies?",
    answer: `Add Messenger for £${pricing.addOn.price}/month as a channel add-on. Fire protection contracts span from £3,000 alarm installations to £200,000 compartmentation remediation programmes. One building manager's multi-block remediation contract — secured through a prompt Facebook response while competitors' messages sat unread over the weekend — repays the add-on cost for years.`
  },
  {
    question: "Can I continue the Messenger conversation?",
    answer: "Reply in any Messenger thread and the conversation transfers to you. The AI steps aside. Most fire protection specialists let the AI capture the initial scope — building type, fire discipline, deficiency details, certification requirement, deadline — then follow up personally to discuss methodology, arrange the survey, and present the remediation proposal."
  },
  {
    question: "How is Messenger data from fire safety queries protected?",
    answer: "All Messenger conversations, deficiency photographs, building addresses, fire risk assessment references, and contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you and is never shared with competing fire protection firms, disclosed to building owners, or used for advertising."
  }
];
