<ChannelTradeLayout
  title="AI Facebook Messenger for UK Fire Protection & Sprinkler Contractors | Rapid Receptionist"
  description={`AI Facebook Messenger for UK fire protection contractors. Converts compliance posts and fire safety content into building manager remediation enquiries. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/fire-protection/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Fire Protection Contractor"
  tradeNamePlural="Fire Protection & Sprinkler Contractors"
  tradeSlug="fire-protection"
