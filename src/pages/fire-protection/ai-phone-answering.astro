---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Answers While You Seal the Penetrations',
    text: "Fire stopping operatives spend hours on scaffold platforms and in riser cupboards — sealant gun in hand, sealing around cables, pipes, and ducts. The AI answers every call in your company name and captures the fire protection scope while you maintain compartment integrity."
  },
  {
    icon: '🏗️',
    title: 'Captures Complex Fire Safety Briefs',
    text: "When a fire engineer describes needing 'FIRAS-certified fire stopping to all penetrations through one-hour compartment walls, intumescent paint to exposed steelwork providing sixty-minute fire resistance, and cavity barriers to the rainscreen cladding,' the AI records the full passive fire protection scope."
  },
  {
    icon: '🚨',
    title: 'Escalates Enforcement-Driven Calls',
    text: "Building control enforcement notices and fire risk assessment Action Plans generate urgent calls — a freeholder needing compartmentation remediated within weeks, or a housing association requiring alarm upgrades across fifty flats. The AI identifies regulatory urgency and escalates immediately."
  },
  {
    icon: '🌙',
    title: 'Catches After-Hours Compliance Calls',
    text: "Building managers receive fire risk assessments and read them in the evening. The 8pm call about 'deficiencies found in the compartmentation of the communal risers' is a genuine regulatory lead from someone under pressure to act."
  },
  {
    icon: '📋',
    title: 'Leads Structured for Tendering',
    text: "Each lead specifies the fire protection service required (sprinkler, alarm, stopping, coatings), building type and height, the fire rating or alarm category, the certification standard needed (FIRAS, BAFSA), and the programme or inspection deadline."
  },
  {
    icon: '🏷️',
    title: 'Certified Credibility',
    text: "Fire protection work is certification-driven — FIRAS, IFC, BAFSA membership. A professional AI greeting that asks about alarm categories, fire ratings, and certification requirements immediately signals a company operating at the required standard."
  }
];

const faqs = [
  {
    question: "What does the AI ask callers about their fire protection needs?",
    answer: "The questions adapt to the caller's description. A main contractor needing fire stopping is asked about the building type, number of penetrations, wall construction (masonry, stud, concrete), fire rating required, and programme milestones. A building manager commissioning an alarm upgrade is asked about the current system type, the category required (L1, L2, L3), the number of flats or floors, and the fire risk assessment deadline. A homeowner needing a domestic sprinkler system is asked about the property type, water supply, and building regulations requirements."
  },
  {
    question: "Can the AI handle calls about both active and passive fire protection?",
    answer: "Sprinkler system installations, fire alarm upgrades, emergency lighting — these are active systems. Fire stopping, intumescent coatings, fire doors, cavity barriers, and compartmentation — these are passive protection. The AI distinguishes between them and captures the appropriate scope. A company delivering both active and passive services receives leads correctly categorised under each discipline."
  },
  {
    question: "What about calls during sprinkler commissioning or alarm handover?",
    answer: "Commissioning days are among the most intense in fire protection — pressure-testing sprinkler pipework, programming addressable alarm panels, and walking the building with building control for sign-off. The AI handles every incoming call so you can focus entirely on the technical handover. New enquiries accumulate as leads; urgent operational calls from the current project are escalated."
  },
  {
    question: "How many call minutes are included?",
    answer: `The Core plan provides ${pricing.tiers.core.minutes} minutes at £${pricing.tiers.core.price}/month. Fire protection companies receive a mix of main contractor subcontract enquiries, building manager upgrade requests, architect specification tenders, and domestic sprinkler leads. Most firms operate well within the allowance. If a large housing association contract generates increased volume, overage is billed at 20p per minute without penalties.`
  },
  {
    question: "Can I answer calls during office survey days?",
    answer: "When you are in the office — writing fire stopping reports, preparing compartmentation schedules, reviewing drawings, or pricing tenders — you may prefer to answer calls yourself. Your dashboard lets you switch between AI and personal answering instantly. During on-site installation and commissioning phases, route all calls to the AI."
  },
  {
    question: "How is fire protection project data secured?",
    answer: "Fire protection enquiries contain building addresses, compartmentation layouts, fire strategy documents, alarm schedules, and compliance-sensitive information involving building safety obligations. All data is encrypted, stored on UK and EU servers under UK GDPR, and accessible exclusively to you. No project information is shared with competing fire protection firms, disclosed to developers, or sold to third parties."
  }
];
---

<ChannelTradeLayout
  title="AI Phone Answering for UK Fire Protection & Sprinkler Contractors | Rapid Receptionist"
  description={`AI phone answering for UK fire protection contractors. Captures fire stopping, sprinkler, alarm upgrade, and compartmentation enquiries while you are on site. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/fire-protection/ai-phone-answering/"
  channelName="AI Phone Answering"
  tradeName="Fire Protection Contractor"
  tradeNamePlural="Fire Protection & Sprinkler Contractors"
  tradeSlug="fire-protection"
  headline="AI Phone Answering for UK Fire Protection Companies"
  accentWord="Fire Protection"
  subhead="A managing agent calls needing emergency fire door remediation after a Section 11 Fire Risk Assessment — twenty-three doors failed. Your AI captures the building details while you fit fire collars."
  scenario="It is 2pm on a Wednesday. You are in the basement of a commercial building in Summertown applying intumescent paint to the underside of a steel beam — the second of three coats required to achieve sixty-minute fire resistance. Four calls come in between 1:30 and 4pm. Without AI Phone Answering, one leaves a voicemail — 'need fire stopping on a project' — three hang up. By Thursday, two have spoken to competitors. With AI Phone Answering, all four are answered. Lead one: main contractor on a residential conversion in Botley needing FIRAS-certified fire stopping to 180 service penetrations through one-hour compartment walls — programme start in three weeks. Lead two: architect requesting intumescent coating quotes for structural steelwork on a new-build office — 2,400 square metres of steel requiring sixty-minute protection. Lead three: school business manager needing a fire alarm upgrade from an L3 to an L1 system during the summer holiday — six-week window. Lead four: homeowner in a self-build needing a domestic mist sprinkler system to satisfy Welsh building regulations. At 4:15pm you check four leads — a £28,000 fire stopping contract, a £35,000 intumescent coating project, a £22,000 school alarm upgrade, and a £4,500 domestic mist system — and begin prioritising callbacks."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-phone-answering/"
  tradePageUrl="/fire-protection/ai-receptionist/"
  ctaHeadline="Housing Association, Steel Coating, School Alarm, Mist System — All in Two Hours"
  ctaSubhead={`While you applied the second intumescent coat, four fire protection opportunities called. The AI captured every specification and deadline. From £${pricing.tiers.core.price}/month.`}
/>
