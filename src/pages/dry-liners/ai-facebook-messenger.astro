---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '🏗️ 💬 📱', title: 'Captures Recommendations', text: "A fit-out company asks in a trade Facebook group: 'Anyone know a reliable dry liner for a big office job?' Someone tags your page. They message you. The AI responds instantly and captures the project." },
  { icon: '⚡', title: 'Responds Before Competitors', text: "Facebook messages from contractors are time-sensitive. Your AI responds in seconds — before other dry liners notice the notification." },
  { icon: '🏗️ 🏗️ 📱', title: 'Handles Commercial Enquiries', text: "Office fit-outs, retail units, residential developments — the AI captures the scope regardless of project type." },
  { icon: '🏗️ 📋 📱', title: 'Active During Peak Hours', text: "Contractors browse Facebook in the evening and at weekends. The AI catches every message." },
  { icon: '📋 📷 📱', title: 'Structured Leads', text: "The AI captures project type, scope, specification, and timeline — delivering a brief you can act on." },
  { icon: '📷 📱', title: 'Project Photos to Contracts', text: "You post a completed MF ceiling installation. A contractor messages asking about availability. The AI captures the lead." }
];

const faqs = [
  { question: "How does AI Facebook Messenger work for dry liners?", answer: "When someone messages your Facebook Business page, the AI responds immediately with a professional greeting and asks about the dry lining work they need. It captures partition types, board specifications, ceiling systems, project scope, timeline, and contact details through a natural conversation. You receive a structured lead summary with everything you need to quote or arrange a site visit." },
  { question: "How much does it cost?", answer: `AI Facebook Messenger is an add-on channel at £${pricing.addOn.price}/month on top of the Core plan at £${pricing.tiers.core.price}/month. For dry lining firms posting project photos and time-lapses on Facebook, this channel converts page visitors into genuine enquiries. One commercial partition lead captured through Messenger covers the add-on cost many times over.` },
  { question: "Can I reply personally?", answer: "Yes. The AI handles the initial response so the enquirer gets an instant professional reply rather than waiting hours. You can jump into the conversation at any point and continue it yourself. The AI steps back as soon as you take over, so the transition is seamless." },
  { question: "How is data protected?", answer: "All message data is managed under UK GDPR and the Data Protection Act 2018. Conversations, contact details, and project specifications are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never access or repurpose your Messenger enquiry data." }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Dry Liners | Rapid Receptionist"
  description={`AI Facebook Messenger for UK dry liners and dry lining contractors. Instant Messenger responses to commercial and domestic enquiries. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/dry-liners/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Dry Liner"
  tradeNamePlural="Dry Liners"
  tradeSlug="dry-liners"
  headline="AI Facebook Messenger for UK Dry Liners"
  accentWord="Dry Liners"
  subhead="You post a completed MF ceiling with shadow-gap detailing. A fit-out contractor messages about partitioning an open-plan office. Your AI captures the specification while you fix metal studs."
  scenario="It is 8pm on a Wednesday. A contracts manager is scrolling Facebook after a long site day. He sees a post from a mate tagging your page — photos of a clean, precise MF ceiling installation in a commercial gym conversion. He messages your page: 'Nice work. We have a care home refurbishment coming up — 30 bedrooms, corridors, and communal areas. All dry lining. Interested?' You are at home. Without AI Messenger, the message waits until you check your page — maybe Thursday evening, maybe Friday. With AI Messenger, the reply comes at 8:01pm: 'Thanks for getting in touch. We would definitely be interested. Can you share the site location and approximate start date?' By 8:15pm, you have a care home dry lining lead with the contracts manager's phone number."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/dry-liners/ai-receptionist/"
  ctaHeadline="Turn Facebook Enquiries into Dry Lining Contracts"
  ctasubhead="You post a completed MF ceiling with shadow-gap detailing. A fit-out contractor messages about partitioning an open-plan office. Your AI captures the specification while you fix metal studs."
/>
