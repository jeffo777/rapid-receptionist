---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '⚡', title: 'Answers While You Are Boarding', text: "Dry lining is physical, noisy, two-handed work. You cannot put down a pneumatic gun or step off a scaffold tower to answer a call. The AI handles every call with your business name while you keep the programme on track." },
  { icon: '🧠', title: 'Understands Dry Lining Enquiries', text: "When a site manager says 'we need metal stud partitions to the first floor with acoustic board and MF ceiling throughout,' the AI captures the specification accurately — stud type, board specification, ceiling system, and floor area." },
  { icon: '🚨', title: 'Escalates Site-Critical Calls', text: "A programme-critical change — revised partition layout before services, fire stopping needed before building control inspection, ceiling grid needing alteration before M&E installation. The AI recognises urgency and escalates to your mobile." },
  { icon: '🕐', title: 'Captures Out-of-Hours Enquiries', text: "Site managers plan ahead of programme and call subcontractors in the evening. Quantity surveyors check availability at 7am before issuing tenders. The AI captures every call." },
  { icon: '📋', title: 'Detailed Lead Summaries', text: "Every call is summarised — site location, scope of work, board specification, programme timeline, and who to call back. You return calls with full context." },
  { icon: '🎯', title: 'Professional First Impression', text: "The AI answers as your dry lining business. Main contractors hear a professional greeting — not a voicemail from a number they do not recognise." }
];

const faqs = [
  { question: "What does the AI say when a contractor calls?", answer: "It greets them with your dry lining business name and has a natural conversation about the work they need. The AI captures partition types, board specifications, ceiling systems, site location, programme dates, and contact details. You receive a structured lead summary so you can call back with the full picture rather than a vague voicemail." },
  { question: "Can it handle both commercial and domestic calls?", answer: "Yes. Whether a main contractor calls about a 2,000 sqm office fit-out needing metal stud partitions throughout or a homeowner needs a loft conversion boarded and skimmed, the AI captures the scope and delivers a lead summary. It adapts the conversation to the caller — asking about floor areas and programme dates with contractors, and about room counts and timelines with domestic customers. Every call gets the same professional treatment regardless of project size." },
  { question: "How many minutes do I get?", answer: `The Core plan includes ${pricing.tiers.core.minutes} minutes per month, which comfortably covers most two or three-man dry lining teams. Extra minutes are charged at 20p each with no penalty rates or hidden fees. Most dry liners find the included minutes more than sufficient for their call volume.` },
  { question: "Can I still take calls when I am free?", answer: "Yes. The AI only activates when you are unavailable — busy on a scaffold tower, driving between sites, or outside working hours. When you are in the office pricing a partition schedule or between jobs, calls ring through to you as normal. You stay in full control of when the AI steps in." },
  { question: "How is data protected?", answer: "All caller data is managed under UK GDPR and the Data Protection Act 2018. Names, site locations, specifications, and project details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never sell or repurpose enquiry data from your dry lining leads." }
];
---

<ChannelTradeLayout
  title="AI Phone Answering for UK Dry Liners | Rapid Receptionist"
  description={`AI phone answering for UK dry liners, dry lining contractors, and metal stud partitioning companies. Answers every call and captures specifications. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/dry-liners/ai-phone-answering/"
  channelName="AI Phone Answering"
  tradeName="Dry Liner"
  tradeNamePlural="Dry Liners"
  tradeSlug="dry-liners"
  headline="AI Phone Answering for UK Dry Liners"
  accentWord="Dry Liners"
  subhead="A main contractor calls needing partitions and MF ceilings completed before the electricians arrive on Monday. Your AI captures the floor plan while you cut plasterboard on a scaffold."
  scenario="It is 9:20am on a Tuesday. You are fixing metal stud partitions on the second floor of a commercial office conversion in Leeds — the track is down, the studs are in, and you are boarding the first side with acoustic-rated plasterboard. Your pneumatic gun fires every few seconds and the radio is competing with the noise from the flooring team next door. Your phone rings in your tool belt. A quantity surveyor at a main contractor in Wakefield is calling — they have a new contract for the dry lining package on a 40-unit apartment block and need availability for a site meeting next week. Without AI Phone Answering, they hear voicemail, mark you as unresponsive, and move to the next name on the subcontractor register. With AI Phone Answering, they hear: 'Good morning, thank you for calling, how can I help?' The AI captures the project — forty apartments, metal stud partitions throughout, MF ceilings to communal areas, Wakefield location, site meeting next Thursday. You climb down at 10:30am and call the QS back with the full specification in front of you."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-phone-answering/"
  tradePageUrl="/dry-liners/ai-receptionist/"
  ctaHeadline="Stop Missing Dry Lining Contracts"
  ctasubhead="A main contractor calls needing partitions and MF ceilings completed before the electricians arrive on Monday. Your AI captures the floor plan while you cut plasterboard on a scaffold."
/>
