---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '🏗️ 📸 📷 📱', title: 'Converts Portfolio Admirers', text: "You post a time-lapse of a metal stud partition going up — from bare floor to fully boarded in thirty seconds. A fit-out company DMs asking about your availability. The AI responds instantly." },
  { icon: '⚡', title: 'Instant Replies', text: "Contractors see your work on Instagram and message immediately. Your AI responds in seconds, keeping the conversation alive." },
  { icon: '🏗️ 📷 📱', title: 'Showcases Specialist Work', text: "Shadow gap details, curved bulkheads, clean MF ceiling lines — Instagram is the perfect platform for dry lining craftsmanship. The AI captures the leads your portfolio generates." },
  { icon: '🏗️ 📋 📱', title: 'Active During Peak Hours', text: "Instagram engagement peaks in evenings. The AI catches every DM from contractors and project managers browsing after hours." },
  { icon: '📋 📷 📱', title: 'Structured Lead Data', text: "The AI extracts project details from casual DMs and delivers actionable lead summaries." },
  { icon: '📷 📱', title: 'Content to Contracts', text: "Every project photo is a potential lead. The AI converts admiration into site meetings." }
];

const faqs = [
  { question: "How does AI Instagram DMs work for dry liners?", answer: "We connect the AI to your Instagram Business account as part of your onboarding — no technical configuration needed from you. Once live, every DM receives an instant professional reply that discusses the project, asks about scope, partition types, ceiling specifications, and timeline. You receive a clean lead summary with all the details you need to quote." },
  { question: "How much does it cost?", answer: `AI Instagram DMs is an add-on channel at £${pricing.addOn.price}/month on top of the Core plan at £${pricing.tiers.core.price}/month. For dry lining firms posting project photos, time-lapses, and detail shots on Instagram, this channel converts followers into genuine project enquiries. One commercial lead captured through an Instagram DM covers the add-on cost many times over.` },
  { question: "Do I need a business account?", answer: "Yes — but we handle the switch with you during onboarding, so you do not need to figure out any settings alone. Converting from personal to Business takes two minutes on your phone and costs nothing. Dry liners posting partition time-lapses, MF ceiling close-ups, and shadow gap detail shots often already have Business accounts for the promotional tools." },
  { question: "How is data protected?", answer: "All Instagram DM data is managed under UK GDPR and the Data Protection Act 2018. Messages, contact details, and project specifications are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never access or repurpose your Instagram enquiry data." }
];
---

<ChannelTradeLayout
  title="AI Instagram DMs for UK Dry Liners | Rapid Receptionist"
  description={`AI Instagram DMs for UK dry liners and dry lining contractors. Instant responses to Instagram direct messages. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/dry-liners/ai-instagram-dms/"
  channelName="AI Instagram DMs"
  tradeName="Dry Liner"
  tradeNamePlural="Dry Liners"
  tradeSlug="dry-liners"
  headline="AI Instagram DMs for UK Dry Liners"
  accentWord="Dry Liners"
  subhead="Your reel of a rapid stud-and-board partition installation earns three thousand views. A shopfitter DMs about ceiling bulkheads for a restaurant. Your AI responds while you tape joints."
  scenario="It is 9:30pm on a Tuesday. You posted photos earlier today of a commercial dry lining project you are proud of — a complex MF ceiling with a series of stepped bulkheads concealing services, finished with a crisp shadow gap detail throughout. A project manager at a London fit-out company sees the post and DMs: 'Excellent ceiling work. We have a 1,500 sqm office fit-out starting in April — MF ceilings throughout with similar detailing. Do you work in London?' You are watching TV. Without AI Instagram DMs, the message waits until you remember to check your DMs — maybe tomorrow, maybe the weekend. With AI Instagram DMs, the reply comes at 9:31pm: 'Thanks very much. Yes, we cover London. Can you share the site postcode and approximate programme dates? Happy to arrange a site visit.' By 9:40pm, you have a 1,500 sqm commercial lead from a fit-out company."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-instagram-dms/"
  tradePageUrl="/dry-liners/ai-receptionist/"
  ctaHeadline="Turn Instagram Followers into Dry Lining Contracts"
  ctasubhead="Your reel of a rapid stud-and-board partition installation earns three thousand views. A shopfitter DMs about ceiling bulkheads for a restaurant. Your AI responds while you tape joints."
