---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  { icon: '🏗️ 📱 ⚡ 📸', title: 'Site Managers Share Photos', text: "A site manager photographs a floor area and WhatsApps: 'Need this lot partitioned and boarded by the end of next week — can you price it?' The AI responds instantly, captures the scope, and confirms a callback." },
  { icon: '⚡', title: 'Fastest Reply Gets the Programme Slot', text: "Main contractors WhatsApp multiple subcontractors. The first to respond gets the site meeting. Your AI replies in seconds." },
  { icon: '🏗️ 📱', title: 'Handles Commercial Specifications', text: "Site managers send floor plans, specification extracts, and photos of areas needing dry lining. The AI acknowledges everything and captures the key details." },
  { icon: '🏗️ 📋 📱', title: 'Active When You Are On Site', text: "You are boarding from 7am to 4pm. WhatsApp messages from contractors arrive throughout the day. Every message gets an immediate response." },
  { icon: '🏗️ 📋 📱 🎯', title: 'Rich Project Data', text: "WhatsApp conversations contain photos, voice notes, and detailed descriptions. The AI captures it all and delivers a comprehensive lead summary." },
  { icon: '🏗️ 📱 🎯', title: 'Professional Response', text: "Instant WhatsApp replies position your dry lining business as responsive and organised — exactly what main contractors want from a subcontractor." }
];

const faqs = [
  { question: "How does AI WhatsApp work for dry lining contractors?", answer: "When a site manager or contractor messages your business WhatsApp, the AI responds immediately with a professional reply. It captures the project scope, board specifications, partition types, ceiling systems, programme dates, and site location through a natural conversation. You receive a lead summary with the full details — including any photos or voice notes sent — so you can follow up with context." },
  { question: "How much does it cost?", answer: `AI WhatsApp is an add-on channel at £${pricing.addOn.price}/month on top of the Core plan at £${pricing.tiers.core.price}/month. For dry lining firms where site managers and contractors communicate primarily through WhatsApp, this channel keeps every conversation alive while you are boarding. One commercial partition lead recovered through an instant WhatsApp reply covers the add-on cost many times over.` },
  { question: "Can I jump into conversations?", answer: "Yes. The AI handles the initial response so the contractor knows their message has been received and you are interested. You take over the conversation at any point — at your next break, at lunchtime, or on the drive home. The handover is seamless and the contractor sees a continuous professional exchange." },
  { question: "How is data protected?", answer: "All WhatsApp data is managed under UK GDPR and the Data Protection Act 2018. Messages, photos, voice notes, and contact details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never access or repurpose your WhatsApp enquiry data." }
];
---

<ChannelTradeLayout
  title="AI WhatsApp for UK Dry Liners | Rapid Receptionist"
  description={`AI WhatsApp for UK dry liners, dry lining contractors, and partitioning companies. Instant responses to WhatsApp enquiries. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/dry-liners/ai-whatsapp/"
  channelName="AI WhatsApp"
  tradeName="Dry Liner"
  tradeNamePlural="Dry Liners"
  tradeSlug="dry-liners"
  headline="AI WhatsApp for UK Dry Liners"
  accentWord="Dry Liners"
  subhead="A site manager WhatsApps reflected ceiling plans and partition layouts for a medical centre refit. Your AI responds while you fix resilient bars in a corridor ceiling."
  scenario="It is 3:40pm on a Thursday. A project manager at a fit-out company in Bristol WhatsApps you a photo of a 400 sqm open-plan office space: 'Hi, we need this divided into 12 offices, 2 meeting rooms, and a kitchenette. Metal stud throughout, acoustic board to meeting rooms, MF ceiling to corridors. Programme starts in 3 weeks. Can you price it?' You are up a scaffold tower in a warehouse conversion in Bath, firing boards onto an MF grid. Without AI WhatsApp, the message sits until 5pm. The PM messaged three dry lining contractors — one replied at 3:45pm and arranged a site visit for tomorrow. With AI WhatsApp, the reply goes out at 3:41pm: 'Thanks for the details. We can definitely help with this. Can I grab the site postcode and your availability for a site visit this week?' By 3:50pm, you have a 400 sqm commercial contract lead."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-whatsapp/"
  tradePageUrl="/dry-liners/ai-receptionist/"
  ctaHeadline="Respond to Every Dry Lining Enquiry on WhatsApp"
  ctasubhead="A site manager WhatsApps reflected ceiling plans and partition layouts for a medical centre refit. Your AI responds while you fix resilient bars in a corridor ceiling."
/>
