---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A site manager calls while you are fixing metal stud partitions in a commercial office fit-out. Your pneumatic gun is firing, the dust extraction is running, and you are three partitions into a tight programme. The call goes to voicemail. He wanted to discuss adding two extra meeting rooms to the floor plan — an additional week of work — but he calls the next dry lining subcontractor on his list.",
    with: "The same site manager calls. Your AI receptionist answers professionally, captures the change — two extra meeting rooms, same specification, needs boarding by Friday week — and confirms you will call back. You finish the partition run and ring him at your next break with the full picture."
  },
  {
    without: "An architect emails on Thursday evening with a revised ceiling layout for a restaurant fit-out — MF ceiling grid with acoustic panels, bulkheads to conceal services, and fire-rated board above the kitchen extract. You do not see the email until Monday. By then, two other dry lining companies have acknowledged.",
    with: "The email gets an instant acknowledgement confirming you have received the revised specification. Monday morning, you open a clean summary — acoustic requirements, fire rating, bulkhead locations — and respond before anyone else."
  },
  {
    without: "A main contractor WhatsApps you about dry lining forty apartments in a residential tower block — dot and dab to external walls, metal stud partitions throughout, MF ceilings in communal areas. You are up a scaffold tower boarding a ceiling and your phone is in the welfare unit. The message sits unread for six hours.",
    with: "The WhatsApp gets an instant reply capturing the scope — forty apartments, specification details, programme timeline. The contractor gets confirmation you are interested. You see the lead at your next break and call to arrange a site visit."
  }
];

const specialisms = [
  {
    category: "Metal Stud & Partitioning",
    items: ["Metal stud partitioning", "Acoustic partition systems", "Fire-rated partition construction", "Demountable partition installation", "Curved and feature partitions", "Shaft wall and riser enclosures"]
  },
  {
    category: "Ceilings & Boarding",
    items: ["MF ceiling systems", "Suspended plasterboard ceilings", "Dot and dab wall lining", "Acoustic ceiling installations", "Bulkhead and coffer construction", "Shadow gap and feature ceiling detailing"]
  },
  {
    category: "Specialist Boarding",
    items: ["Fire-rated boarding (30, 60, 90, 120 min)", "Acoustic boarding and resilient bar systems", "Moisture-resistant boarding for wet areas", "Impact-resistant boarding for commercial", "Access panel installation", "Service void and riser boarding"]
  }
];

const clientTypes = [
  {
    icon: "🏗️",
    title: "Main Contractors & Fit-Out Companies",
    description: "The backbone of your workload — main contractors running commercial office fit-outs, retail units, restaurant refurbishments, and residential developments. They need a dry lining subcontractor who can mobilise quickly, work to programme, and deliver consistent quality across large floor areas. Your speed of response when they call determines whether you get on the tender list."
  },
  {
    icon: "🏢",
    title: "Commercial Property Developers",
    description: "Developers converting warehouses to offices, fitting out speculative commercial units, or refurbishing ageing office stock. They often need dry lining priced and programmed months in advance, and they want subcontractors who respond promptly to specification changes during the build."
  },
  {
    icon: "🏠",
    title: "Domestic Renovation Clients",
    description: "Homeowners converting lofts, garages, and basements who need plasterboard lined and ready for a plasterer. Smaller jobs, but they often lead to repeat work and referrals. These customers value communication and reliability over the cheapest price."
  },
  {
    icon: "📊",
    title: "Acoustic & Fire Protection Clients",
    description: "Recording studios, music rooms, home cinemas, party wall upgrades, and HMO conversions requiring specific acoustic or fire performance. These projects demand specialist knowledge of board types, resilient bar systems, and independent wall constructions — and customers need a dry liner who understands the specifications."
  }
];

const faqs = [
  {
    question: "Does the AI understand dry lining terminology?",
    answer: "Yes. During setup, your AI receptionist is configured with dry lining vocabulary — metal stud, MF ceiling, dot and dab, plasterboard, acoustic board, fire-rated board, resilient bar, access panels, bulkheads, shadow gaps, and every other term your customers use. When a site manager calls about 'MF ceiling to the open-plan area with acoustic board and shadow gap detail,' the AI records it accurately."
  },
  {
    question: "Can the AI handle both commercial and domestic dry lining enquiries?",
    answer: "Absolutely. Whether a main contractor calls about dry lining forty apartments or a homeowner needs a garage conversion boarded out, the AI captures the scope, specification, timeline, and contact details. You see the full brief before you call back."
  },
  {
    question: "What happens if someone calls about an urgent change on site?",
    answer: "The AI recognises urgency. If a site manager describes a programme-critical change — revised partition layout, additional fire stopping needed before inspection, ceiling grid needs altering before services go in — the AI escalates immediately, trying your mobile first, then our human operators."
  },
  {
    question: "How much does it cost for a dry lining business?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of AI phone answering plus unlimited website chat. Additional channels like WhatsApp and Facebook are £${pricing.addOn.price}/month each. Setup is £${pricing.setup.price} one-time (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a small dry lining team?",
    answer: "It was designed for exactly this. A two or three-man dry lining team is on site from 7am to 4pm — you are boarding, fixing stud work, or running ceiling grids and you physically cannot answer calls. The AI handles every call and sends you the details at your break."
  },
  {
    question: "Can I still take calls when I am available?",
    answer: "Yes. The AI only activates when you are unavailable. When you are in the office pricing work or driving between sites, calls come through as normal."
  },
  {
    question: "How does Rapid Receptionist handle customer data?",
    answer: "All customer data is managed under UK GDPR and the Data Protection Act 2018. Names, addresses, site locations, specifications, and job details are encrypted during transmission and storage, held on UK and EU servers, and shared only with you. We never sell or repurpose enquiry data."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for UK Dry Liners | Rapid Receptionist"
  description={`AI receptionist for UK dry liners, dry lining contractors, and metal stud partitioning companies. Answers calls, captures leads from chat, WhatsApp, and social media while you are on site. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/dry-liners/ai-receptionist/"
  tradeName="Dry Liner"
  tradeNamePlural="Dry Liners"
  tradeSlug="dry-liners"
  headline="The Rapid Response AI Receptionist for UK Dry Liners"
  accentWord="Dry Liners"
  subhead={`You cannot answer the phone while you are fixing metal stud, running MF ceiling grids, or boarding partitions on a commercial fit-out. Your AI receptionist picks up every call, captures every lead from chat, WhatsApp, and social media, and sends you the details at your next break. From £${pricing.tiers.core.price}/month.`}
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Dry Lining Work to Missed Calls"
  ctaSubhead={`Every call your dry lining business misses is a contract going to another subcontractor. From £${pricing.tiers.core.price}/month — respond first, win the work.`}
/>
