const benefits = [
  {
    icon: '📷',
    title: 'Converts Glass Installation Reels',
    text: "Glazing reels captivate homeowners — time-lapses of bi-fold doors opening to reveal a garden, close-ups of silicone-bonded frameless panels, and drone shots of glass balustrades catching the sunlight. When a follower DMs after watching, the AI captures their glazing vision."
  },
  {
    icon: '🎯',
    title: 'Reaches Design-Conscious Homeowners',
    text: "Instagram attracts homeowners who care about aesthetics — frameless glass walls, minimal-frame sliders, flush-fit rooflights. A DM saying 'your frameless work is stunning — we are extending and want the same clean lines' is a premium lead valuing craftsmanship over price."
  },
  {
    icon: '📱',
    title: 'Handles Reference Photo DMs',
    text: "Followers DM with screenshots of glass installations they admire — 'can you do something like this?' The AI asks about their own property, the opening sizes, and the glass type, converting visual aspiration into a qualified measurement lead."
  },
  {
    icon: '🌙',
    title: 'Captures Evening Renovation Planning',
    text: "Homeowners scroll Instagram after dinner, dreaming of glass extensions and bi-fold doors. DMs sent at 10pm are high-intent leads from people committed enough to reach out. The AI captures them before the inspiration fades."
  },
  {
    icon: '📋',
    title: 'Structures Aspirational Glass DMs',
    text: "DMs about glazing start aspirational — 'love the look of that extension.' The AI grounds the conversation by asking about the opening dimensions, frame preference, glass specification, and timeline."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Glass Detail Shot',
    text: "Every frameless edge detail, structural silicone close-up, and completed extension walkthrough can trigger a DM. The AI converts visual admiration into measured glazing contracts."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "Switch to a Business or Creator account linked to your Facebook Business page — a free two-minute change. Glazing contractors producing visual content — frameless installations, bi-fold openings, balustrade panoramas — benefit from the audience analytics and promotional tools a Business account provides."
  },
  {
    question: "What glazing DMs arrive through Instagram?",
    answer: "Primarily domestic enquiries from homeowners inspired by your installation photography. Common DMs include 'how much for bi-folds like those in a 3-metre opening?', 'can you do a frameless glass balustrade on a balcony?', and 'we want to replace our conservatory glass with something more modern — can you advise?' These leads convert well because the homeowner has already been convinced by your photographic portfolio."
  },
  {
    question: "How fast does the AI respond to glazing DMs?",
    answer: "Within seconds. Instagram displays read receipts, creating an impression of immediate professionalism. Homeowners messaging three to five glazing companies award the measurement appointment to the first who responds with informed questions about their opening size, frame preference, and glass type."
  },
  {
    question: "What does Instagram DMs cost for glazing companies?",
    answer: `Instagram DMs is £${pricing.addOn.price}/month as a channel add-on. Glazing contractors with strong visual portfolios find that DMs produce some of their highest-value leads — homeowners who have pre-selected based on visual quality. A single converted bi-fold or balustrade installation sourced from an Instagram DM typically starts at £3,000 and can exceed £30,000 for structural glass packages.`
  },
  {
    question: "Can I reply personally to DMs?",
    answer: "Reply once in any DM thread and the AI hands control to you. It recognises your response and steps back permanently. Most glaziers find it efficient to let the AI gather the basics first — glass type, opening dimensions, frame colour preference, and property postcode — before taking over personally to advise on specifications, share before-and-after examples, and schedule the on-site measurement."
  },
  {
    question: "Is DM data from glazing queries kept private?",
    answer: "All Instagram DM content — reference photos, opening dimensions, glass specifications, property details, and contact information — is encrypted and stored on UK and EU servers under UK GDPR. No data is shared with competing glaziers, used for advertising, or made accessible to third parties."
  }
