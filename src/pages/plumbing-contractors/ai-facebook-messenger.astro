import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Bathroom Transformation Content',
    text: "Bathroom renovations are visually striking — a dated avocado suite replaced with a walk-in wetroom, freestanding bath, and wall-hung WC. When a homeowner messages about their own bathroom, the AI captures a renovation lead."
  },
  {
    icon: '📸',
    title: 'Handles Emergency Leak Messages',
    text: "Homeowners and letting agents message photos of dripping pipes, water-stained ceilings, and flooding kitchens — 'can someone come urgently?' The AI asks about the water source, isolation status, and property access."
  },
  {
    icon: '⚡',
    title: 'Captures Builder Connection Requests',
    text: "Builders browse your portfolio and message from site — 'need a plumber for kitchen and bathroom connections on a house extension.' The AI captures the scope while you fit sanitaryware elsewhere."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Bathroom Planning',
    text: "Homeowners design bathrooms in the evening — comparing sanitaryware, studying layout options, and scrolling plumber portfolios. Messages about 'the wetroom in your latest post' arrive after 8pm."
  },
  {
    icon: '📋',
    title: 'Qualifies Plumbing Project Scale',
    text: "Messenger conversations begin with 'how much to fit a bathroom?' The AI asks about the room dimensions, sanitaryware selection, existing system, and timeline — building a specification before your first survey."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Before-and-After',
    text: "Every dated bathroom stripped and reborn, every wetroom with linear drain precision, and every freestanding bath installation generates enquiries from homeowners who imagine their own bathroom transformed."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my plumbing firm?",
    answer: "Messenger operates through a Business page exclusively. Plumbing firms posting bathroom renovation before-and-afters, wetroom installation sequences, and underfloor heating manifold close-ups generate exceptional local engagement — homeowners tag partners and friends planning renovations, builders save your work for future referrals."
  },
  {
    question: "What plumbing enquiries come through Messenger?",
    answer: "Homeowners wanting bathroom renovations, kitchen replumbing, and en-suite additions after viewing your completed projects. Builders needing plumbing connections for extensions and conversions. Letting agents seeking reliable plumbers for tenant maintenance across property portfolios. Architects studying your installation quality for specification decisions."
  },
  {
    question: "How fast does the AI reply to plumbing messages?",
    answer: "Every Messenger enquiry generates a response within seconds. Facebook's active indicator confirms that your plumbing firm monitors messages. A homeowner who has spent an evening comparing plumber portfolios and finally messages their top choice expects a prompt, knowledgeable reply — not an abandoned inbox that suggests limited capacity."
  },
  {
    question: "What does Messenger cost for plumbing contractors?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. A bathroom renovation generates £3,000 to £10,000. A single full bathroom strip-and-refit — secured through a prompt Messenger reply to a before-and-after post while you pressed fittings on another site — justifies the channel cost immediately.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Reply once in any thread and the AI yields that conversation permanently. Most plumbers let the AI extract the initial details — fixture list, room size, system type, and timeline — then engage to discuss the site survey, material choices, and pricing in person."
  },
  {
    question: "How is Messenger data from plumbing queries protected?",
    answer: "All Messenger conversations, leak photographs, property addresses, system specifications, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No plumbing project details reach competitors, merchants, or any third party."
  }
];
