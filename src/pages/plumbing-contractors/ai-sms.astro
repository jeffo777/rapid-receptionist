const benefits = [
  {
    icon: '💬',
    title: 'Catches Developer Programme Texts',
    text: "Main contractors text plumbing gangs mid-build — 'plots 8-10 ready for first fix Monday, need your team on site 7am.' The first plumber to confirm maintains the programme slot."
  },
  {
    icon: '📐',
    title: 'Builds Plumbing Briefs from Short Messages',
    text: "A text like 'bathroom refit, bath shower WC basin, 1950s semi, Kidlington, start in 2 weeks' gives the AI the essentials. It asks about the existing system, the hot water source, and the room dimensions."
  },
  {
    icon: '🔔',
    title: 'Secures Referral Texts',
    text: "When a satisfied customer recommends your plumbing to a friend, that friend texts about their own bathroom or kitchen. The AI captures the referral while the recommendation carries maximum trust."
  },
  {
    icon: '🌙',
    title: 'Active After Installation Hours',
    text: "Main contractors confirm next-week first-fix slots in the evening. Homeowners text bathroom questions after dark. Landlords report tenant leaks overnight. The AI captures every after-hours plumbing text."
  },
  {
    icon: '📋',
    title: 'Assembles Multi-Text Plumbing Details',
    text: "Messages arrive in fragments — 'leaking pipe' then 'under the kitchen sink' then 'tenant flat' then 'Cowley' then 'can you come tomorrow.' The AI constructs one complete emergency lead from every piece."
