---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Answers While You Solder and Connect',
    text: "Soldering copper joints under a bath, connecting an unvented cylinder with the blow torch lit, running PEX through floor joists, or gluing a solvent-weld waste system — plumbing demands both hands and unbroken concentration. The AI answers every call in your company name."
  },
  {
    icon: '🏗️',
    title: 'Captures Plumbing Briefs at Every Scale',
    text: "When a main contractor calls about first-fix plumbing on a twenty-plot estate, the AI captures the system type, pipe material, SVP layout, and programme. When a homeowner calls about a dripping tap, the AI captures the tap type, location, and urgency."
  },
  {
    icon: '🚨',
    title: 'Handles Emergency Plumbing Calls',
    text: "Burst mains, leaking unvented cylinders, blocked soil stacks, failed stopcocks with water pouring through ceilings, and pin-hole leaks behind tiled walls — plumbing emergencies flood properties within minutes. The AI captures the emergency type, location, isolation status, and access arrangements."
  },
  {
    icon: '🌙',
    title: 'Catches Evening Bathroom Enquiries',
    text: "Homeowners research bathroom renovations in the evening — browsing sanitaryware, sketching layouts, and pricing their dream en-suite. The AI captures every evening call while their renovation ambition peaks."
  },
  {
    icon: '📋',
    title: 'Leads Built for Plumbing Pricing',
    text: "Each lead specifies the plumbing scope (new install, renovation, repair, or emergency), the system type, the fixture count, the property type and age, access arrangements, and programme — everything required for accurate plumbing pricing."
  },
  {
    icon: '🏷️',
    title: 'G3-Qualified Professionalism',
    text: "A plumbing firm that answers professionally and asks about the cylinder type, TMV requirement, and system pressure signals qualified expertise that main contractors and homeowners trust for their most complex installations."
  }
];

const faqs = [
  {
    question: "What does the AI ask callers about their plumbing project?",
    answer: "Questions adapt precisely to the enquiry type. A homeowner wanting a new bathroom hears questions about the room size, the sanitaryware selection (bath, shower enclosure or tray, WC type, basin style), the existing pipework condition, and the renovation timeline. A main contractor requesting first-fix plumbing on a new-build estate is asked about the plot count, the pipe system (copper, PEX, or push-fit), the SVP locations, the UFH specification, and the build programme in relation to the carpenter's frame."
  },
  {
    question: "Can the AI handle both domestic and commercial plumbing calls?",
    answer: "Domestic bathroom installations — selecting sanitaryware, routing waste, and connecting hot-and-cold supplies — require different qualification details than commercial washroom programmes with TMV schedules, boosted cold water, RPZ valves, and Building Regulations Part G compliance. The AI constructs entirely separate lead formats and asks entirely different questions, preventing any confusion between residential renovations and commercial fit-out tenders."
  },
  {
    question: "What about calls during active installations?",
    answer: "Plumbing installations involve irreversible steps — a soldered joint must be completed before the copper cools, a solvent-weld connection sets in seconds, and an unvented cylinder commissioning sequence must run uninterrupted. Walking away mid-procedure costs materials, creates potential leak points, and compromises safety. The AI handles every call while you maintain the concentration that watertight plumbing demands."
  },
  {
    question: "How many minutes are included?",
    answer: `Your Core plan provides ${pricing.tiers.core.minutes} minutes at £${pricing.tiers.core.price}/month. Plumbing contractors handle a mix of emergency leak calls, homeowner bathroom quotes, developer first-fix tenders, and commercial washroom programmes. The blend of short urgent calls and longer specification discussions is accommodated within the allowance. Overage runs at 20p per minute with no contract lock-in.`
  },
  {
    question: "Can I take calls during quoting?",
    answer: "During site surveys, measurement visits, and quotation preparation — manage calls directly from your phone. When your hands are occupied — soldering, pressing fittings, or working in confined spaces under floors — route calls to the AI. Switch from your dashboard whenever your working conditions change."
  },
  {
    question: "How is plumbing project data secured?",
    answer: "Plumbing enquiries contain property addresses, system specifications, developer programme details, unvented cylinder serial numbers, and commercially sensitive tender information. All data is encrypted, stored on UK and EU servers under UK GDPR, and accessible exclusively to you. No project details reach competing plumbing firms, are shared with merchants, or are disclosed to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Phone Answering for UK Plumbing Contractors | Rapid Receptionist"
  description={`AI phone answering for UK plumbing contractors. Captures developer first-fix programmes, homeowner bathroom quotes, and emergency leak calls while you solder. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/plumbing-contractors/ai-phone-answering/"
  channelName="AI Phone Answering"
  tradeName="Plumbing Contractor"
  tradeNamePlural="Plumbing Contractors"
  tradeSlug="plumbing-contractors"
  headline="AI Phone Answering for UK Plumbing Contractor Companies"
  accentWord="Plumbing"
  subhead="A main contractor calls at 10:15am. He is building a new-build housing development on the western edge of Abingdon — twenty-four detached and semi-detached houses across three phases. Phase one starts in six weeks. Each house requires full first-fix plumbing: mains entry through the utility wall with MDPE to copper transition, stopcock, PRV set to 3 bar, 22mm and 15mm copper carcass pipework through the floor joists, soil vent pipe to both bathrooms and the en-suite, waste pipework to kitchen and utility, and a manifold-fed PEX underfloor heating system on the ground floor with six zones per house. Second fix follows the plasterer by ten weeks — Megaflo Eco Plus 250i unvented cylinders, all sanitaryware (Ideal Standard Concept Air on the show homes, standard range on the rest), TMV2 valves on every bath and basin, and kitchen sink with waste disposal. You are on the first floor of a new-build in Wantage — pressing Viega Profipress fittings onto 22mm copper around the en-suite manifold tee, the press gun clamping each joint with a hydraulic squeeze. Both hands on the gun, the pipe run half-complete. Without AI Phone Answering, the twenty-four-plot contract goes to voicemail. With it, the AI captures: Abingdon 24 houses, 3 phases, first fix (mains/PRV/copper carcass/SVP/waste/PEX UFH 6-zone), second fix (Megaflo Eco Plus 250i/Ideal Standard Concept Air/TMV2/kitchen), 6-week start, plasterer +10 weeks for second fix."
  scenario="It is 1:30pm on a Tuesday. Three calls between noon and 1:30pm. You are under the kitchen floor of a Victorian terrace in Jericho — replacing a corroded lead water main with 15mm barrier PEX, crawling through a 450mm void with a head torch, pipe cutter, and push-fit fittings. Without AI Phone Answering, one voicemail and two hang-ups. With it, all three are answered. Lead one: a homeowner in Summertown — 'complete bathroom renovation, strip everything, new bath with shower over, wall-hung WC, floating vanity basin, heated towel rail, the room is about 2.5 by 3 metres, we want it done in three weeks.' Lead two: an architect in Headington — 'high-end en-suite for a loft conversion, walk-in wetroom with linear drain, wall-hung Duravit sanitaryware, concealed cistern, Hansgrohe thermostatic shower, underfloor heating, drawing complete.' Lead three: a letting agent in Cowley — 'leaking bath waste in a ground-floor flat, tenant says water is dripping through the kitchen ceiling below, need someone today.' At 2pm you emerge from the void. Three leads — a bathroom strip-and-refit, a high-end loft wetroom, and an emergency bath waste."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-phone-answering/"
  tradePageUrl="/plumbing-contractors/ai-receptionist/"
  ctaHeadline="Capture the 24-Plot First-Fix Programme While You Press Fittings in Wantage"
  ctaSubhead={`A main contractor needs Megaflo cylinders, PEX UFH, and TMVs across twenty-four houses in three phases. The AI captured every specification while the Viega press gun clamped the en-suite tee. From £${pricing.tiers.core.price}/month.`}
/>
