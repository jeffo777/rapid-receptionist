<ChannelTradeLayout
  title="AI Website Chat for UK Plumbing Contractors | Rapid Receptionist"
  description={`AI website chat for UK plumbing contractors. Engages homeowners planning bathroom renovations and architects specifying wetroom installations. Included at £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/plumbing-contractors/ai-website-chat/"
  channelName="AI Website Chat"
  tradeName="Plumbing Contractor"
  tradeNamePlural="Plumbing Contractors"
  tradeSlug="plumbing-contractors"
