---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Engages Homeowners Planning Bathrooms',
    text: "Homeowners spend weeks browsing sanitaryware, studying tile layouts, and imagining their dream bathroom. Chat captures them when they land on your portfolio — ready to commit but needing reassurance about timelines, costs, and feasibility."
  },
  {
    icon: '📐',
    title: 'Qualifies Plumbing Project Scope',
    text: "Through conversation, the AI identifies whether the visitor needs a bathroom renovation, a kitchen refit, en-suite plumbing for a loft conversion, emergency leak repair, or new-build first-fix. You receive a categorised project lead."
  },
  {
    icon: '🕐',
    title: 'Converts Evening Renovation Research',
    text: "Homeowners design bathrooms at 10pm — comparing sanitaryware brands, sketching floor plans, and searching 'plumber near me for bathroom refit.' Chat captures their specification intent while they visualise the finished room."
  },
  {
    icon: '📊',
    title: 'Explains Plumbing System Differences',
    text: "Visitors ask practical questions — 'what is an unvented cylinder?', 'can I have a wetroom upstairs?', 'do I need to upgrade my mains for a power shower?' The AI responds from your profile knowledge while gathering their property details."
  },
  {
    icon: '🔗',
    title: 'Works Alongside Bathroom Galleries',
    text: "Your website shows completed bathrooms — walk-in showers, freestanding baths, wall-hung WCs, and heated towel rails. Chat converts visitors studying your craftsmanship into booked site surveys."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat is part of phone answering at £${pricing.tiers.core.price}/month. Unlimited plumbing conversations — from dripping taps to commercial washroom refits.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my plumbing website?",
    answer: "We install it for you during onboarding — you do not need to touch any code. Our team adds the widget to your site and it goes live within minutes, regardless of whether your site is on WordPress, Wix, Squarespace, or something custom. If you prefer to manage it yourself or have a web developer who looks after your site, we will send you the snippet to paste in. Takes about a minute. Most plumbers just say sort it and we do."
  },
  {
    question: "Can the AI advise on system choices?",
    answer: "Your company profile configures the AI with your installation preferences and capabilities. When a visitor types 'should I get an unvented cylinder or a combi?' the AI responds from your profile context — mentioning flow rates, property size, and simultaneous demand — while capturing the property type, the number of bathrooms, and the current system."
  },
  {
    question: "What does chat capture from plumbing visitors?",
    answer: "The AI gathers the plumbing need (renovation, new install, repair, or emergency), the fixture list if applicable, the room dimensions, the existing system type, the property age and type, the renovation timeline, and visitor contact information for your follow-up."
  },
  {
    question: "Does chat slow my plumbing website?",
    answer: "Bathroom photography, sanitaryware galleries, and accreditation logos load at their full speed before the chat interface activates. The lightweight widget initialises after all existing content renders. No impact on page speed, SEO scores, or user experience."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Website chat is included within phone answering at £${pricing.tiers.core.price}/month. For plumbing contractors, both channels target complementary enquiry streams: daytime calls from main contractors booking first-fix programmes and builders needing plumbing connections, and evening website conversations from homeowners designing their bathroom renovation and comparing sanitaryware options.`
  },
  {
    question: "How is visitor data from plumbing queries handled?",
    answer: "Chat conversations containing property addresses, system specifications, fixture selections, renovation timelines, and visitor contact information are encrypted and stored on UK and EU servers under UK GDPR. Lead summaries go exclusively to you. No plumbing project details reach competitors or third parties."
  }
];
