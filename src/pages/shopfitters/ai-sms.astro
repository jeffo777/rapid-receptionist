---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Catches Quick Availability Texts',
    text: "Operators text shopfitters to test capacity — 'hi, can you take on a new fit-out starting next month?' A prompt reply opens the conversation. A multi-hour delay suggests a company already overcommitted."
  },
  {
    icon: '📐',
    title: 'Builds Fit-Out Briefs from SMS Fragments',
    text: "A text like 'need a shopfitter for a new juice bar, 500sqft, Headington, opening in 6 weeks' gives the AI enough to start — and it asks about the concept, specification status, and key elements. Your lead arrives complete."
  },
  {
    icon: '🔔',
    title: 'Secures Designer Referral Texts',
    text: "Interior designers text their preferred shopfitters when new projects land: 'Got a boutique fit-out in the Westgate — interested?' The AI responds in seconds while the designer's attention is on selecting a contractor."
  },
  {
    icon: '🌙',
    title: 'Active After Shop Closing Time',
    text: "Retail and hospitality operators think about fit-outs after trading hours. A salon owner closing at 8pm and texting about a refurbishment. A pub landlord texting at 11pm about a bar refit during January closure. The AI captures both."
  },
  {
    icon: '📋',
    title: 'Assembles Multi-Text Threads',
    text: "Texts arrive in fragments — 'need a fit-out' then 'it is a barber shop' then 'about 350sqft' then 'Cowley Road.' The AI assembles the complete brief and adds concept and timeline through follow-ups."
  },
  {
    icon: '📱',
    title: 'Professional Commercial Channel',
    text: "AI SMS uses your business number. Commercial conversations with operators, designers, and landlords stay on a professional line."
  }
];

const faqs = [
  {
    question: "How does the AI handle a fit-out enquiry text?",
    answer: "The AI reads the message and responds in your company name. A detailed text — 'need a complete fit-out for a coffee shop, 600sqft bare shell in Botley, opening 1st March, have an interior designer' — is captured with full context. A brief text — 'do you do restaurant fit-outs?' — prompts the AI to ask about the venue type, size, concept, and timeline."
  },
  {
    question: "Will the sender know it is AI?",
    answer: "The reply reads like a shopfitter responding between tasks — professional, direct, and commercially aware. It uses your company name and asks relevant questions about the venue and deadline. Operators and designers texting shopfitters care about speed and specialism; the AI delivers both in seconds."
  },
  {
    question: "What about texts from active fit-out clients?",
    answer: "Clients on a live fit-out sometimes text about access keys, delivery schedules, or finish selections. The AI captures these and categorises them separately from new enquiries. Your dashboard clearly distinguishes a new £80,000 restaurant enquiry from a current client confirming the worktop colour."
  },
  {
    question: "What does AI SMS cost for shopfitting companies?",
    answer: `AI SMS is priced at £${pricing.addOn.price}/month as a channel add-on. Shopfitting contracts range from £15,000 boutique refreshes to six-figure multi-site programmes. Capturing one operator's enquiry through a rapid text response — while competitors' phones sat in the dust — delivers returns that vastly exceed the annual channel cost.`
  },
  {
    question: "Can I respond to texts personally?",
    answer: "Your own reply in any text thread returns control to you immediately. The AI steps back. During workshop days or office time, handle texts personally. During intense on-site fit-out periods, let the AI maintain the professional response."
  },
  {
    question: "How is text data handled?",
    answer: "Text messages containing venue addresses, lease details, fit-out specifications, and contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes only to you and is never shared, sold, or repurposed."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for UK Shopfitters | Rapid Receptionist"
  description={`AI SMS for UK shopfitting companies. Responds to operator enquiry texts, designer referrals, and fit-out availability checks while you are on site. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/shopfitters/ai-sms/"
  channelName="AI SMS"
  tradeName="Shopfitter"
  tradeNamePlural="Shopfitters"
  tradeSlug="shopfitters"
  headline="AI SMS for UK Shopfitting Businesses"
  accentWord="Shopfitting"
  subhead="A restaurant owner texts about a bar refit with new counters and banquette seating before reopening. You are fitting display cabinets in a boutique. Your AI replies in seconds."
  scenario="It is 9:15pm on a Monday. A gym owner in Kidlington has decided to refurbish the reception and changing room areas. The gym is members-only, open 6am to 10pm, so all work must happen between 10:30pm and 5:30am — overnight fits only. He texts four shopfitters: 'Hi — need a refit of gym reception and changing rooms. About 800 sqft total. All work needs to be done overnight because the gym stays open. New reception counter, locker system, vinyl flooring, LED lighting. Budget is £22k. Can you handle overnight work?' Without AI SMS, you see the text Tuesday morning. Two shopfitters replied Monday night — one confirming experience of overnight working and asking to arrange a 10pm site visit. With AI SMS, the response arrives at 9:16pm: 'Thank you for your message. Overnight fit-out projects are something we handle regularly — we understand the operational constraints of 24-hour and extended-hours venues. Could you confirm the gym's address and your preferred week for the refit? We will arrange an evening site visit to assess the scope.' He replies with the address and confirms the refit should happen in January. Tuesday morning you open the lead: gym reception and changing rooms, 800sqft, Kidlington, overnight access only, counter, lockers, flooring, lighting, £22k budget, January programme. You call at 9am and book a Wednesday 10pm walkthrough."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/shopfitters/ai-receptionist/"
  ctaHeadline="Catch the Salon Referral Text While You Fix the Feature Wall"
  ctaSubhead={`The salon owner two doors down saw your joinery and texted. The AI replied while your phone sat in the sawdust. Add-on at £${pricing.addOn.price}/month.`}
/>
