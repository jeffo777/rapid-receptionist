const benefits = [
  {
    icon: '⚡',
    title: 'Instant Acknowledgement',
    text: "Builders and architects email detailed specifications and expect a prompt response. Your AI sends an immediate acknowledgement confirming your joinery business has received the brief — while other carpentry contractors leave the email unread for days."
  },
  {
    icon: '📋',
    title: 'Handles Complex Specifications',
    text: "Joinery emails often include drawings, schedules, and material lists. The AI acknowledges the attachments, confirms receipt, and tells the sender you will review and respond — buying you time to assess properly."
  },
  {
    icon: '???',
    title: 'Wins Builder Confidence',
    text: "When a builder sends a first fix schedule to five carpentry contractors, the one who acknowledges first is the one they trust. An instant email reply puts your joinery company at the top of the list."
  },
  {
    icon: '📧',
    title: 'Covers Out-of-Hours Emails',
