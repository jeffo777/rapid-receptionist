    text: "Every email exchange is summarised and sent to you as a lead. You review it when you are ready — no hunting through your inbox."
  }
];

const faqs = [
  {
    question: "How does AI Email Response work for joinery businesses?",
    answer: "When someone emails your business, the AI sends an instant, professional acknowledgement confirming receipt. It includes your business name and tells the sender when to expect a full response. This works for joinery contractors, carpentry businesses, and sole trader joiners."
  },
  {
    question: "Does it reply to every email automatically?",
    answer: "It acknowledges inbound enquiries — new project requests, specifications, quote requests. It does not reply to spam, marketing emails, or existing conversation threads."
  },
  {
    question: "Can it handle emails with attachments?",
    answer: "Yes. If a builder sends drawings or a material schedule, the AI acknowledges the attachments and confirms your joinery business will review them. It does not open or interpret drawings — it ensures the sender knows you have received everything."
  },
  {
    question: "How much does AI Email Response cost?",
    answer: `AI Email is an add-on at £${pricing.addOn.price}/month. Pair with the Core plan (£${pricing.tiers.core.price}/month).`
  },
  {
    question: "Does it work with my existing email address?",
    answer: "Yes. We configure email forwarding so enquiries sent to your existing address are picked up by the AI. Your email remains unchanged."
  },
  {
    question: "Is email data handled securely?",
    answer: "Yes. All email data is managed under UK GDPR, encrypted in transit and at rest, and stored on UK and EU servers."
  }
];
