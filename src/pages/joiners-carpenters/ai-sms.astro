const benefits = [
  {
    icon: '📋',
    title: 'Captures Drive-By Leads',
    text: "Neighbours see your van, passers-by see your sign. They text because it feels quick and informal. Your AI replies instantly, turning a casual text into a captured lead for your joinery business."
  },
  {
    icon: '?',
    title: 'Instant Professional Reply',
    text: "A text reply within seconds tells the customer your carpentry company is responsive and professional. It resets their expectation � they wait for your callback instead of texting the next joiner."
  },
  {
    icon: '🔗',
    title: 'No Workshop Interruptions',
    text: "You cannot check texts safely while operating power tools. The AI handles SMS conversations throughout the day so your joinery contractor operation keeps running safely."
  },
  {
    icon: '📐',
    title: 'Full Lead Details from Short Texts',
    text: "Even from a short opening text like 'do you fit doors?' the AI draws out the full picture � how many doors, the property type, the timeline, and their contact number."
  },
  {
    icon: '💬',
    title: 'After-Hours Text Capture',
    text: "Texts arrive throughout the evening and into the night. The AI replies regardless � no leads lost to overnight silence."
  },
  {
