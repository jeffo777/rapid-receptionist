    title: 'Follows Up Missed Calls',
    text: "Pair SMS with Missed Call Text-Back and customers who do not reach you by phone can text back and engage with the AI. Two safety nets for your carpentry business."
  }
];

const faqs = [
  {
    question: "How does AI SMS work for joiners?",
    answer: "When someone texts your business number, the AI responds instantly and has a natural text conversation. It asks about the work needed, captures details, and sends you a structured lead. Perfect for joinery businesses that receive enquiries by text."
  },
  {
    question: "What kind of texts does it handle?",
    answer: "Everything from short enquiries like 'do you hang doors?' to detailed messages about fitted furniture, staircases, or renovation work. The AI adapts to the length and complexity of the enquiry."
  },
  {
    question: "How much does AI SMS cost?",
    answer: `AI SMS is an add-on at �${pricing.addOn.price}/month. The same price for sole trader joiners, carpentry contractors, and larger joinery companies.`
  },
  {
    question: "Can I reply to texts myself?",
    answer: "Yes. The AI handles the initial engagement and lead capture. You can take over the conversation at any time."
  },
  {
    question: "Does it work with my existing number?",
    answer: "Yes. SMS is routed through your Rapid Receptionist number, which is connected to your existing business line via call forwarding."
  },
  {
    question: "How is text data protected?",
    answer: "All SMS data is encrypted, stored on UK and EU servers, and managed under UK GDPR. Shared only with you � never sold or repurposed."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for Joiners & Carpenters | Rapid Receptionist"
  description={`AI SMS for UK joiners, carpentry contractors, and joinery businesses. Responds instantly to text enquiries about carpentry and joinery work. Captures leads 24/7. �${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/joiners-carpenters/ai-sms/"
  channelName="AI SMS"
  tradeName="Joiner"
  tradeNamePlural="Joiners & Carpenters"
  tradeSlug="joiners-carpenters"
  headline="AI SMS for Joiners & Carpenters"
  accentWord="Joiners"
  subhead="A neighbour spots your joinery contractor van outside and texts: 'Can you fit shelves in an alcove?' Instead of that text going unread while your carpentry business finishes the kitchen install, your AI replies in seconds � professional, detailed, and the lead is captured."
  scenario="It is 2pm on a Wednesday. You are fitting a run of bespoke shelving in a home office in Bramhall � the timber is cut, the battens are up, and you are levelling each shelf by hand. Your phone buzzes on the windowsill. A text from an unknown number: 'Hi, I got your number off your van. We need all the internal doors replacing in our house � seven doors plus handles and hinges. Are you available in the next month?' You are focused on getting the level right and do not see the text until 5:30pm. Without AI SMS, you think about replying but decide to do it properly tomorrow � and tomorrow turns into Friday. With AI SMS, they get a reply in seconds: 'Thanks for your message. We would be happy to quote for the door replacement. Could you confirm how many doors, whether they are standard sizes, and your postcode? We will arrange a callback today.' You call them at 5:45 and book a measure-up for Saturday morning. Seven doors � a solid day's work."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/joiners-carpenters/ai-receptionist/"
  ctaHeadline="Stop Losing Text Enquiries"
  ctaSubhead={`A quick text from a neighbour could be a full house of doors. Your AI replies instantly. �${pricing.addOn.price}/month.`}
/>
