---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Heritage Project Photo Posts',
    text: "Stonemasonry is inherently visual — a restored church parapet, a carved fireplace surround, a repointed Cotswold cottage. When a follower sees your completed restoration post and sends a Messenger enquiry, the AI responds instantly, captures their project details, and converts visual appreciation into a viable commission lead."
  },
  {
    icon: '📸',
    title: 'Handles Damage Photo Messages',
    text: "Homeowners sometimes message Facebook pages with photos of stonework problems — crumbling mortar, spalling window sills, leaning boundary walls. The AI acknowledges the images, asks about the building age and stone type, and delivers the photos alongside a structured lead summary for your assessment."
  },
  {
    icon: '⚡',
    title: 'Responds Faster Than Traditional Methods',
    text: "Stonemasonry enquiries through Facebook tend to come from homeowners who have found your page through local recommendations or searched for 'stonemason near me.' These are discovery-phase leads — responding immediately keeps you at the top of their mind. A day-long wait sends them to the next mason in the results."
  },
  {
    icon: '🕐',
    title: 'Captures Weekend Browsing Enquiries',
    text: "Homeowners browse Facebook on Saturday mornings and see a friend's recommendation: 'Used this mason for our chimney rebuild — brilliant work.' They visit your page, see your portfolio, and message. The AI captures the weekend lead and your brief is waiting on Monday."
  },
  {
    icon: '📋',
    title: 'Structures Casual Messages into Briefs',
    text: "Messenger conversations wander — a question about cost, a mention of the building's age, a side note about council permission. The AI consolidates the thread into a clean lead: work type, stone type, building status, location, and contact details."
  },
  {
    icon: '🔗',
    title: 'Generates Revenue from Your Content',
    text: "Posting completed masonry work on Facebook earns engagement. AI Messenger converts engagement into commissions. Every carved corbel and restored doorway you share can generate an enquiry that becomes a paying project."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my masonry practice?",
    answer: "A Facebook Business page with Messenger enabled is required — personal profiles cannot be connected. Most stonemasons already have a presence on Facebook for sharing completed work and customer reviews. Even if your page is minimally maintained, the AI handles incoming Messenger enquiries with full professionalism."
  },
  {
    question: "What masonry enquiries come through Facebook Messenger?",
    answer: "The majority are domestic — homeowners in stone-built areas who have seen your work, received a recommendation, or found your page while searching locally. Common requests involve chimney repointing, boundary wall repairs, hearth installations, garden wall construction, and occasionally carved stone commissions. You also see enquiries from property developers and architects who discover your page through shared posts."
  },
  {
    question: "How fast does the AI respond on Messenger?",
    answer: "Responses arrive within seconds. Facebook displays active status and read receipts, so the sender sees immediate engagement. For stonemasonry — a specialist trade where qualified masons are scarce and waiting lists are long — the speed of response signals both capability and current availability. A homeowner receiving an instant, knowledgeable reply is far less likely to message competitors."
  },
  {
    question: "What does AI Facebook Messenger cost for a stonemason?",
    answer: `This channel costs £${pricing.addOn.price}/month as an add-on to the Core plan. In stonemasonry — where a modest garden wall repair starts around £1,000 and heritage restoration contracts routinely reach five or six figures — one commission captured through a Messenger response covers the add-on cost for the rest of your career.`
  },
  {
    question: "Can I continue Messenger conversations myself?",
    answer: "The moment you type a reply in any Messenger conversation, the AI steps aside and you take over. Many stonemasons prefer the AI to handle the initial response and pre-qualification, then follow up personally to discuss stone selection, building heritage, and the depth of specification that this craft demands."
  },
  {
    question: "How is Messenger data handled?",
    answer: "All Messenger conversations, photos, building details, and contact information are encrypted and stored on UK and EU servers under UK GDPR. Lead data is delivered exclusively to you and is never used for advertising, sold to third parties, or accessed for any purpose beyond your lead summaries."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for Stonemasons | Rapid Receptionist"
  description={`AI Facebook Messenger for UK stonemasons. Responds to chimney repair enquiries, wall restoration requests, and carved stonework commissions through your page. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/stonemasons/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Stonemason"
  tradeNamePlural="Stonemasons"
  tradeSlug="stonemasons"
  headline="AI Facebook Messenger for Stonemasons"
  accentWord="Stonemasons"
  subhead="You post a photo of a completed church tower repointing — limestone walls glowing in afternoon sunlight, crisp lime mortar profiles, scaffold barely visible at the base. A retired couple in Burford see the post through a friend's share and message: 'Our cottage has been cement-pointed — it is trapping moisture and the stone is spalling. Can you strip the cement and repoint in lime? About four elevations.' You are on a scaffold thirty feet up, pointing a different church, chisel in hand. Without AI Messenger, the message sits until Thursday. With it, the couple get an instant response, share photos of their cottage, and your lead summary — cement removal, lime repointing, four elevations, Burford — is waiting when you descend."
  scenario="It is 11am on a Sunday. A homeowner in the Yorkshire Dales is scrolling Facebook after breakfast. He sees a post from a local heritage group praising a mason's recent chimney rebuild on a former mill — your work. The photos show coursed gritstone laid with lime mortar, new stone copings, and a lead-lined flaunching. He clicks through to your page, sees your gallery of chimney and wall work, and sends a Messenger message: 'Impressive work on that mill chimney. Ours is similar — coursed gritstone on a 1830s farmhouse, the pointing has failed and several stones have come loose. Two chimney pots are cracked too. Can you come and have a look?' Without AI Facebook Messenger, you see the message Monday evening. By then he has also contacted two other masons through Facebook — one responded Sunday afternoon and has booked a Wednesday site visit. With AI Messenger, the AI replies at 11:01am: 'Thank you — that mill chimney was a rewarding project. Gritstone chimney repairs on period farmhouses are exactly the work we specialise in. Could you share your postcode and some photos of the chimney? One of our team will call you tomorrow to arrange a visit.' He sends three photos — the eroded pointing, the loose stones, and the cracked pots — and shares his postcode. Monday morning you open a lead with a clear brief: 1830s gritstone farmhouse, chimney repointing, loose stones, cracked pots, Yorkshire Dales, photos attached. You call at 8:30am and book a Thursday morning survey."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/stonemasons/ai-receptionist/"
  ctaHeadline="Turn Heritage Masonry Posts into Restoration Commissions"
  ctaSubhead={`Every church tower and chimney rebuild you share on Facebook can generate an enquiry. AI Messenger converts that engagement into paying commissions. Add-on at £${pricing.addOn.price}/month.`}
/>
