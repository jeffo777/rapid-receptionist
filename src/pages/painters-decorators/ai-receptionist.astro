---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls about redecorating the entire downstairs of their semi — lounge, dining room, hallway, and stairs. You are up a ladder cutting in around a coving line and cannot reach your phone. They get voicemail, assume you are fully booked, and call the next painting and decorating business on Google.",
    with: "Your AI receptionist answers: 'Good morning, thank you for calling. How can I help?' It captures the room count, the current wall condition, whether wallpaper stripping is needed, and their timeline. By the time you come down the ladder, the lead is in your inbox with everything you need to quote."
  },
  {
    without: "A letting agent emails asking if your decorating business can repaint four flats to landlord white before new tenants move in next month. You do not check email until Saturday. By then, two other painting contractors have already priced and one has started.",
    with: "The letting agent gets an instant acknowledgement confirming your painting company has received the specification. You review the brief on Saturday, assess the scope, and reply first thing Monday — with a professional quote that lands before anyone else follows up."
  },
  {
    without: "A previous customer tags your painting business in a local Facebook group: 'Best decorator in Manchester.' Three people message your page asking for quotes. The messages sit unread for five days.",
    with: "All three Facebook messages get an instant reply. The AI captures each enquirer's details, the rooms they want decorating, and their postcode. You follow up on Monday morning — before they have had time to message anyone else."
  }
];

const specialisms = [
  {
    category: "Interior Decorating",
    items: ["Full room repaints — walls and ceilings", "Wallpaper hanging and stripping", "Feature wall creation", "Coving and cornice painting", "Stairwell and hallway decorating", "Specialist paint finishes — eggshell, satinwood, chalk paint"]
  },
  {
    category: "Exterior Painting",
    items: ["Full exterior house painting", "Fascia, soffit, and bargeboard painting", "Window and door frame painting", "Rendered wall painting", "Garage and outbuilding painting", "Wrought iron railings and gates"]
  },
  {
    category: "Commercial & Specialist",
    items: ["Office and commercial property repaints", "Landlord and tenancy turnaround painting", "New-build snagging and finishing", "Shopfront and retail painting", "Spray painting — internal and external", "Period property and heritage decorating"]
  }
];

const clientTypes = [
  {
    icon: "??",
    title: "Domestic Homeowners",
    description: "Homeowners wanting rooms repainted, wallpaper hung, or a full house redecoration. Whether they searched for a painter, a decorator, a painting and decorating business, or a local decorating contractor, they want someone clean, reliable, and easy to communicate with."
  },
  {
    icon: "??",
    title: "Landlords & Letting Agents",
    description: "Property managers needing rental properties repainted between tenancies — often at short notice. They want a painting contractor who responds quickly, quotes fairly, and turns work around fast across multiple properties."
  },
  {
    icon: "???",
    title: "Builders & Developers",
    description: "Site managers sourcing painting and decorating subcontractors for new-build snagging, show home finishing, and commercial fit-outs. They need fast availability from reliable decorating businesses and work to strict handover dates."
  },
  {
    icon: "??",
    title: "Interior Designers",
    description: "Designers specifying exact colour schemes, specialist finishes, and wallpaper installations. They want a painting company that understands colour accuracy, can work with premium paints, and delivers a flawless finish."
  }
];

const faqs = [
  {
    question: "How does the AI understand painting and decorating terminology?",
    answer: "During setup, your AI receptionist learns the vocabulary of the trade — emulsion, satinwood, eggshell, undercoat, primer, masking, cutting in, mist coat, sugar soap, lining paper, paste-the-wall, feature wall, coving, dado rail, and more. When a homeowner says 'the ceiling has got yellow stains and the woodwork needs glossing,' the AI understands and captures it correctly."
  },
  {
    question: "Can the AI handle both interior and exterior decorating enquiries?",
    answer: "Yes. Whether the caller wants a lounge repainted, wallpaper hung in a bedroom, the outside of the house painted, or fascias and soffits done, the AI captures the work type, scope, and details. It sends you the full summary for your assessment."
  },
  {
    question: "What happens if someone calls about an emergency — like water damage to a ceiling?",
    answer: "The AI recognises urgency. If a caller describes water staining from a leak, flaking paint from damp, or damage that needs immediate attention before a property inspection, the AI escalates — trying your mobile first, then our human operators. Routine decorating enquiries are captured as standard leads."
  },
  {
    question: "How much does it cost for a painting and decorating business?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month and includes AI phone answering (300 minutes) plus unlimited website chat. Additional channels — WhatsApp, SMS, Facebook, Instagram, email, and missed call text-back — are £${pricing.addOn.price}/month each. The pricing is the same whether you are a sole trader decorator, a painting contractor with a team, or a painting and decorating company handling commercial work. There is a one-time setup fee of £${pricing.setup.price} (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a small painting business or sole trader decorator?",
    answer: "Absolutely. Whether you are a one-man decorating business, a painting contractor with one or two others, or a larger painting and decorating company — this was built for you. Sole trader decorators are the ones up a ladder when the phone rings. You cannot answer with a roller in your hand. The AI catches every call."
  },
  {
    question: "Can the AI provide decorating quotes?",
    answer: "No — and that is deliberate. Decorating prices depend on room size, wall condition, preparation needed, paint quality, and whether wallpaper is involved. The AI captures all relevant details and passes the lead for your personal assessment and quoting."
  },
  {
    question: "How does Rapid Receptionist protect my customers' personal data?",
    answer: "All data captured — names, numbers, addresses, job details — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted in transit and at rest, stored on UK and EU servers, and shared only with you. We never sell, share, or repurpose enquiry data. You remain the data controller; we act as your data processor under a formal agreement."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for UK Painters & Decorators | Rapid Receptionist"
  description={`AI receptionist for UK painters, decorators, painting businesses, and decorating contractors. Answers calls, captures leads from chat, WhatsApp, Facebook and more — while you are on the tools. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/painters-decorators/ai-receptionist/"
  tradeName="Painter & Decorator"
  tradeNamePlural="Painters & Decorators"
  tradeSlug="painters-decorators"
  headline="The Rapid Response AI Receptionist for UK Painters & Decorators"
  accentWord="Painters"
  subhead="You cannot answer the phone while cutting in at a cornice, rolling emulsion on a ceiling, or spraying a kitchen on a scaffold tower. Your AI captures every decorating lead."
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Decorating Jobs to Missed Calls"
  ctasubhead="You cannot answer the phone while cutting in at a cornice, rolling emulsion on a ceiling, or spraying a kitchen on a scaffold tower. Your AI captures every decorating lead."
/>
