---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CookieConsent from '../components/CookieConsent.astro';

const faqs = [
  {
    question: "How quickly will someone get back to me?",
    answer: "We aim to respond to every enquiry within 1 working day. Most enquiries get a reply much faster than that. Weekend and evening enquiries are answered the next working morning."
  },
  {
    question: "I'm not sure which plan I need. Can you help?",
    answer: "Absolutely. Tell us about your trade, how many calls you typically get, and which channels your customers use to contact you. We'll recommend the right setup — no upselling, no pressure. Most sole traders start with the Core plan and add channels as they see where leads come from."
  },
  {
    question: "What happens after I submit the form?",
    answer: "One of our team will review your enquiry and get in touch — usually by email first, then a quick call if needed. We'll ask a few questions about your business, explain exactly how the setup works, and get you live within 48 hours of signing up. The entire onboarding is done for you."
  },
  {
    question: "Is there a sales pitch involved?",
    answer: "No. We answer your questions honestly, explain what the service does, and let you decide. The pricing is on the website — there's no hidden premium tier we'll try to push you towards. If the service isn't right for your business, we'll tell you that too."
  },
  {
    question: "How does Rapid Receptionist handle data protection and GDPR?",
    answer: "Rapid Receptionist operates in full compliance with UK GDPR and the Data Protection Act 2018. All client information collected by your AI receptionist — names, phone numbers, property addresses, project descriptions — is encrypted both in transit and at rest, stored exclusively on UK and EU servers, and shared only with you as the business owner. We never sell, distribute, or repurpose personal data for any reason. Both you and your clients can request data deletion at any time. You remain the data controller; we operate as your data processor under a formal data processing agreement. Full details are in our <a href='/privacy/'>privacy policy</a>."
  }
];
---

<BaseLayout
  title="Contact Rapid Receptionist — Get in Touch | UK Construction Trades"
  description="Questions about Rapid Receptionist for your construction trade? Get in touch. Email, phone, or contact form. We typically respond within 1 working day."
  canonicalUrl="/contact/"
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="section contact-hero" id="contact-hero">
    <div class="container">
      <span class="badge badge--accent">Contact Us</span>
      <h1>Got a Question About <span class="text-accent">Your Trade?</span></h1>
      <p class="contact-hero__sub">Whether you want to know how Rapid Receptionist works for your specific construction trade, need help choosing the right channels, or want to understand how the AI handles your enquiries — we're here. No sales pitch, just straight answers.</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="section section--alt" id="contact-main">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Form -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <p class="contact-form-intro">Fill in the form and we'll get back to you within 1 working day. If it's urgent, call us directly.</p>

          <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="cdff8e5c-8299-4373-bf8c-96506118b438">
            <input type="hidden" name="subject" value="New Contact Form Submission — Rapid Receptionist">
            <input type="hidden" name="from_name" value="Rapid Receptionist Website">
            <input type="checkbox" name="botcheck" class="hidden" style="display:none">

            <div class="form-group">
              <label for="contact-name">Your Name</label>
              <input type="text" id="contact-name" name="name" required placeholder="John Smith" autocomplete="name" />
            </div>

            <div class="form-group">
              <label for="contact-email">Email Address</label>
              <input type="email" id="contact-email" name="email" required placeholder="john@example.co.uk" autocomplete="email" />
            </div>

            <div class="form-group">
              <label for="contact-phone">Phone Number <span class="form-optional">(optional)</span></label>
              <input type="tel" id="contact-phone" name="phone" placeholder="07XXX XXXXXX" autocomplete="tel" />
            </div>

            <div class="form-group">
              <label for="contact-message">Your Message</label>
              <textarea id="contact-message" name="message" required rows="5" placeholder="Tell us what you'd like to know..."></textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--lg contact-submit" id="contact-submit">
              Send Message
            </button>

            <div id="contact-result" class="form-result" style="display:none"></div>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="contact-info">
          <div class="contact-info-card">
            <div class="contact-info-card__icon">📧</div>
            <h3>Email Us</h3>
            <p>For general enquiries, quotes, or support.</p>
            <a href="mailto:hello@rapidreceptionist.co.uk" class="contact-info-card__link">hello@rapidreceptionist.co.uk</a>
          </div>

          <div class="contact-info-card">
            <div class="contact-info-card__icon">📞</div>
            <h3>Call Us</h3>
            <p>Speak to a real person during office hours.</p>
            <a href="tel:+44XXXXXXXXXX" class="contact-info-card__link">Coming Soon</a>
            <span class="contact-info-card__hours">Mon–Fri, 9am–5pm</span>
          </div>

          <div class="contact-info-card">
            <div class="contact-info-card__icon">⏱️</div>
            <h3>Response Time</h3>
            <p>We aim to respond to every enquiry within 1 working day. Most get a reply much faster.</p>
          </div>

          <div class="contact-info-card">
            <div class="contact-info-card__icon">🇬🇧</div>
            <h3>UK-Based</h3>
            <p>Rapid Receptionist is a UK company, supporting UK construction trades. All communication in UK English, all pricing in GBP.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQAccordion faqs={faqs} />

  <CookieConsent />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: calc(var(--header-height) + var(--space-16));
    padding-bottom: var(--space-12);
    text-align: center;
  }

  .contact-hero h1 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-extrabold);
    line-height: var(--leading-tight);
    max-width: 700px;
    margin: var(--space-4) auto var(--space-6);
  }

  .contact-hero__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-10);
    align-items: start;
  }

  /* Form */
  .contact-form-wrap h2 {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-2);
  }

  .contact-form-intro {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .form-group {
    margin-bottom: var(--space-5);
  }

  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .form-optional {
    color: var(--color-text-muted);
    font-weight: var(--font-normal);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    color: var(--color-text-primary);
    font-size: var(--text-base);
    font-family: var(--font-family);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(30, 144, 255, 0.15);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%239CA3AF' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: var(--space-10);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    width: 100%;
  }

  /* Info Sidebar */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    transition: border-color var(--transition-base);
  }

  .contact-info-card:hover {
    border-color: var(--color-border-accent);
  }

  .contact-info-card__icon {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .contact-info-card h3 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-1);
  }

  .contact-info-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2);
  }

  .contact-info-card__link {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
  }

  .contact-info-card__hours {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      order: -1;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .contact-info {
      grid-template-columns: 1fr;
    }
  }
  .form-result {
    margin-top: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    text-align: center;
    font-weight: var(--font-medium);
  }

  .form-result--success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .form-result--error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const result = document.getElementById('contact-result');
  const submitBtn = document.getElementById('contact-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form)
      });
      const data = await response.json();

      if (data.success) {
        result.style.display = 'block';
        result.className = 'form-result form-result--success';
        result.textContent = 'Message sent successfully! We\'ll get back to you within 1 working day.';
        form.reset();
      } else {
        throw new Error(data.message || 'Something went wrong');
      }
    } catch (error) {
      result.style.display = 'block';
      result.className = 'form-result form-result--error';
      result.textContent = 'Something went wrong. Please try again or email us directly at hello@rapidreceptionist.co.uk';
    } finally {
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
