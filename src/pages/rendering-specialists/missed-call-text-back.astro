---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Catches Calls During Topcoat Application',
    text: "Applying silicone topcoat, floating a scratch coat level, sponge-finishing a monocouche gable, and embedding mesh into an EWI basecoat — rendering demands both hands and unbroken technique. Missed Call Text Back texts every unanswered caller within seconds."
  },
  {
    icon: '⏱️',
    title: 'Holds Developer Programme Callers',
    text: "A developer with blockwork ready on the next four plots calls his preferred renderer. Voicemail? He calls the next gang. A branded text — 'Thanks for calling — we are on the scaffold rendering and will call back shortly' — holds your programme position."
  },
  {
    icon: '🏷️',
    title: 'Accredited Professional Image',
    text: "An instant branded text from a rendering specialist signals organised professionalism — the calibre of firm that developers trust with estate-wide monocouche programmes where colour consistency matters on every plot."
  },
  {
    icon: '📊',
    title: 'Essential During Full Render Days',
    text: "Rendering days fill from dawn to dusk — every hour on the scaffold applying and finishing coats before the temperature drops or rain arrives. Missed Call Text Back captures every developer, homeowner, and architect enquiry during your most weather-dependent working days."
  },
  {
    icon: '📋',
    title: 'Captures Reply Render Details',
    text: "Callers reply with scope — 're-render semi, about 120 sqm, Silver Grey, Headington, need quote.' Replies arrive on your dashboard before the sponge float leaves the topcoat."
  },
  {
    icon: '🔄',
    title: 'Pairs with AI Phone Answering',
    text: "Phone Answering conducts full rendering conversations. Missed Call Text Back covers edge cases — a call during a critical topcoat pass, a phone buried under render bags on the ground, or a single-ring hang-up. Together: zero lost rendering leads."
  }
];

const faqs = [
  {
    question: "When does the missed call text send?",
    answer: "Seconds after the call ends — before the developer dials his backup rendering gang. During estate render programmes where your entire team works scaffold-to-scaffold across the plots, this immediate branded text keeps your firm commercially active without interrupting a single trowel stroke on the topcoat."
  },
  {
    question: "What does the text message say?",
    answer: "You compose the wording during setup and adjust it at any time. A rendering-specific message reads: 'Thank you for calling [company name]. We are currently rendering on site. We will return your call at the earliest opportunity. Reply with your rendering requirements for a quicker response.' This signals active capability and invites project details."
  },
  {
    question: "Does this replace AI Phone Answering?",
    answer: "Both systems protect your rendering business as complementary layers. Phone Answering holds full conversations — identifying the render system, colour, area, substrate, and programme. Missed Call Text Back handles rare edge scenarios — a call while you flatten a critical topcoat section that cannot be interrupted, a phone signal lost behind a blockwork gable, or a caller disconnecting before the AI picks up. Running both ensures zero rendering enquiries disappear."
  },
  {
    question: "How much does Missed Call Text Back cost?",
    answer: `This add-on is £${pricing.addOn.price}/month. A domestic whole-house render generates £4,000 to £12,000. Recovering one missed call from a developer — who had a twenty-house monocouche programme ready to issue — through a timely branded text delivers revenue that dwarfs the channel cost for years.`
  },
  {
    question: "Do callers reply to the text?",
    answer: "Developers reply with programme requirements — 'monocouche, 12 plots, Weber Ivory, bellcasts, need gang in 4 weeks.' Homeowners reply with project summaries — 'semi in Summertown, cracked render, want silicone, about 110 sqm.' Architects reply with specification briefs — 'lime render, listed cottage, 80 sqm, Cotswold stone substrate.' These render leads arrive on your dashboard while the float finishes the bay."
  },
  {
    question: "How is missed call data stored?",
    answer: "Missed caller information, text replies containing property addresses, render system preferences, colour codes, and contact details are encrypted and held on UK and EU servers under UK GDPR. Only you can access the data. Nothing reaches competing rendering firms or any third party."
  }
];
---

<ChannelTradeLayout
  title="Missed Call Text Back for UK Rendering Specialists | Rapid Receptionist"
  description={`Missed Call Text Back for UK rendering specialists. Automatically texts callers while you apply monocouche or silicone topcoat from the scaffold. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/rendering-specialists/missed-call-text-back/"
  channelName="Missed Call Text Back"
  tradeName="Rendering Specialist"
  tradeNamePlural="Rendering Specialists"
  tradeSlug="rendering-specialists"
  headline="Missed Call Text Back for UK Rendering Specialist Companies"
  accentWord="Rendering"
  subhead="You are floating a scratch coat on a gable end three storeys up when a developer calls about rendering an entire housing estate. A text goes out in five seconds — the contract stays warm."
  scenario="It is 2pm on a hot August Wednesday. You have been rendering since 6am — starting before the sun hit the south elevation of a detached house in Eynsham. The heat is accelerating drying times, and every section must be floated and finished within minutes of application. Five missed calls between 6am and 2pm. Without Missed Call Text Back, you check at 4pm: five unknowns, two voicemails — 'developer calling' and 'render repair' — three permanently lost. With Missed Call Text Back, all five received texts. Reply one: 'developer Carterton — 8 new houses, Weber monocouche, Sand Beige, bellcasts and stops, blockwork in 6 weeks, need tender.' Reply two: 'homeowner Witney — pebbledash bungalow, want to strip and re-render in silicone, about 150 sqm.' Reply three: 'builder Abingdon — extension render, 30 sqm, need to match existing cream.' Reply four: 'housing association — EWI programme, 18 flats, ECO4 funded, need PAS 2035 installer.' Reply five: 'homeowner Woodstock — render crack repair, south gable, about 15 sqm patch.' Five leads. Friday you prioritise — the developer's 8-house programme, the EWI eighteen-flat tender, the pebbledash strip, the extension match, and the crack repair."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/missed-call-text-back/"
  tradePageUrl="/rendering-specialists/ai-receptionist/"
  ctaHeadline="Recover Five Render Leads from One Hot August Wednesday"
  ctaSubhead={`While the heat rushed every topcoat from Eynsham to sundown, five callers missed you. Five texts went out. A developer, a pebbledash strip, an extension match, an EWI programme, and a gable repair. Add-on at £${pricing.addOn.price}/month.`}
/>
