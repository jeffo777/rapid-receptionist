const faqs = [
  {
    question: "How do I install chat on my HVAC website?",
    answer: "We do the full installation for you during onboarding. Our team places the widget on your site so it goes live across every page — your comfort cooling services, maintenance contracts, and emergency callout pages included. No technical knowledge needed. If you have an in-house marketing team or web developer who manages your online presence, we can send them the code snippet and they will have it embedded in minutes."
  },
  {
    question: "Can the AI advise on heat pump sizing?",
