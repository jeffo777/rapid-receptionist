---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Engages Visitors Researching Heat Pumps',
    text: "Homeowners spend weeks comparing ASHP brands, reading SCOP ratings, and calculating whether the BUS grant makes conversion affordable. Chat captures them on your website — ready to commit but needing clarity on sizing, noise, and running costs."
  },
  {
    icon: '📐',
    title: 'Qualifies HVAC Project Scope Online',
    text: "Through conversation, the AI determines whether the visitor needs a domestic heat pump, commercial VRF system, chiller replacement, MVHR installation, or emergency cooling repair. You receive a categorised lead with the correct HVAC scope."
  },
  {
    icon: '🕐',
    title: 'Converts Evening AC Failures',
    text: "Office air conditioning fails after the facilities team leaves. Server room temperatures climb. The duty manager finds your website and types 'air conditioning stopped working, server room 28 degrees and rising.' Chat captures the system type and business impact instantly."
  },
  {
    icon: '📊',
    title: 'Explains Heat Pump Options to Visitors',
    text: "Visitors ask 'air source or ground source?', 'what SCOP should I expect?', 'will I need bigger radiators?' The AI responds from your MCS profile — comparative running costs, radiator compatibility, and noise data — while capturing the property and insulation level."
  },
  {
    icon: '🔗',
    title: 'Works Alongside Installation Galleries',
    text: "Your website displays installed outdoor units, neat pipework runs, and commissioned plant rooms. Chat converts visitors admiring your F-Gas certified workmanship into booked surveys."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat is bundled with phone answering at £${pricing.tiers.core.price}/month. Unlimited HVAC conversations — from BUS grant consultations to chiller replacement tenders.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my HVAC website?",
    answer: "Onboarding provides a single JavaScript snippet for your website header — compatible with WordPress, Wix, Squarespace, or custom HTML. The branded chat widget displays across every page instantly. HVAC firms with outdoor unit installation galleries and MCS or F-Gas accreditation prominently displayed see strong chat engagement from visitors who have already assessed your installation standard."
  },
  {
    question: "Can the AI advise on heat pump sizing?",
    answer: "Your MCS-certified company profile configures the AI with your sizing methodology and brand preferences. When a visitor types 'is a 12kW ASHP enough for a 4-bed detached house?' the AI references your typical approach — heat loss calculations, insulation assessment, and existing emitter evaluation — while collecting the property construction decade, the wall insulation type, the glazing standard, and the current heating fuel."
  },
  {
    question: "What does chat capture from HVAC visitors?",
    answer: "The AI records the HVAC requirement category (heat pump, air conditioning, ventilation, chiller, or maintenance), the property or building type and size, the current system manufacturer and age, the heating or cooling concern, the energy source, any grant awareness, and the visitor's contact details for your follow-up."
  },
  {
    question: "Does chat slow my HVAC contractor website?",
    answer: "MCS certification badges, heat pump installation photography, manufacturer partner logos, and Trustpilot review feeds load at their full speed before the chat widget initialises. The lightweight component loads asynchronously entirely after existing page content renders. No measurable impact on page speed or search ranking."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Website chat comes bundled with phone answering at £${pricing.tiers.core.price}/month — no additional fee. HVAC contractors gain dual coverage: weekday phone calls from facilities managers tendering VRF replacements and developers specifying MVHR systems, combined with evening and weekend chats from homeowners whose oil bills have prompted serious heat pump research.`
  },
  {
    question: "How is visitor data from HVAC queries handled?",
    answer: "Chat conversations containing building addresses, refrigerant system details, F-Gas logbook references, BMS credentials, and visitor contact information are encrypted and stored on UK and EU servers under UK GDPR. Leads are delivered exclusively to you. No HVAC project details reach competitors or third-party aggregators."
  }
];
