<ChannelTradeLayout
  title="Missed Call Text Back for HVAC Contractors | Rapid Receptionist"
  description={`Missed Call Text Back for UK HVAC contractors. Automatically texts callers while you braze refrigerant lines, hold standing vacuums, and commission climate systems. Add-on at £${pricing.addOn.price}/month.`}
