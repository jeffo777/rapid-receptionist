---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts AC Installation Content',
    text: "Air conditioning installations are visually impressive — gleaming outdoor units, neat copper pipework in trunking, and ceiling cassettes flush with the grid. When a follower messages about their overheating office or south-facing bedroom, the AI captures a cooling lead."
  },
  {
    icon: '📸',
    title: 'Handles HVAC Emergency Messages',
    text: "Facilities managers message about VRF systems tripping, chillers shutting down, and server rooms overheating — 'our cooling has failed and it is 30 degrees inside.' The AI responds immediately, asks about the system manufacturer and error code, and builds a priority lead."
  },
  {
    icon: '⚡',
    title: 'Captures Commercial Maintenance Leads',
    text: "Facilities managers browse your commercial installations on Facebook and message — 'need an F-Gas contractor for our building's annual AC maintenance programme.' The AI captures the building size, unit count, and current contract status."
  },
  {
    icon: '🕐',
    title: 'Active During Heatwave Demand',
    text: "Every heatwave triggers a flood of cooling enquiries. Homeowners, office managers, and retail operators message HVAC firms simultaneously. The AI captures every overheating message while you install systems for existing clients."
  },
  {
    icon: '📋',
    title: 'Qualifies HVAC Project Category',
    text: "Messenger conversations start with 'how much for air conditioning?' The AI distinguishes between a single wall split for a bedroom, a multi-split for an entire house, a VRF system for an office, and a heat pump to replace an oil boiler — qualifying each into the correct project category."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Plant Room Photo',
    text: "Every neat outdoor unit installation, every labelled refrigerant pipework run, and every flush ceiling cassette commission generates enquiries from building managers who compare their own ageing systems."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my HVAC firm?",
    answer: "Messenger operates exclusively through a connected Business page. HVAC firms posting commercial VRF installations, neat outdoor unit arrays on roof plant decks, and domestic heat pump before-and-after sequences generate exceptional engagement — facilities managers save posts featuring clean plant room layouts as reference for their own building upgrades."
  },
  {
    question: "What HVAC enquiries come through Messenger?",
    answer: "Office managers with failing split systems during heatwaves. Homeowners wanting heat pumps after researching your ASHP installations. Property developers needing MVHR and ASHP packages for new-build estates. Restaurant owners with kitchen extract failures and dining room cooling problems. Server room managers with temperature alarm activations. Each has evaluated your F-Gas certified installation quality."
  },
  {
    question: "How fast does the AI reply to HVAC messages?",
    answer: "Messenger enquiries generate responses within seconds. Facebook's activity indicator shows your HVAC firm is immediately reachable. A facilities manager whose VRF system has failed on the hottest day of the year — with staff threatening to leave the building — demands instant engagement from a certified contractor, not an unmonitored page suggesting the firm is unavailable."
  },
  {
    question: "What does Messenger cost for HVAC contractors?",
    answer: `The Messenger channel is £${pricing.addOn.price}/month as a channel add-on. A commercial split system installation generates £4,000 to £12,000. One office manager's eight-unit multi-split installation — triggered when she messaged about a heatwave after studying your portfolio — covers the annual channel cost from a single project.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Respond once in any thread and the AI transfers control permanently. Most HVAC engineers let the AI extract the initial scope — system type, manufacturer, building size, cooling or heating requirement, and urgency level — then take over to discuss system selection, efficiency projections, and the survey date."
  },
  {
    question: "How is Messenger data from HVAC queries protected?",
    answer: "All Messenger conversations, system photographs, building addresses, F-Gas logbook references, refrigerant details, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No HVAC project details reach competitors or third-party lead aggregators."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK HVAC Contractors | Rapid Receptionist"
  description={`AI Facebook Messenger for UK HVAC contractors. Converts VRF installation photos into maintenance contracts and heat pump content into BUS grant consultations. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/hvac-contractors/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="HVAC Contractor"
  tradeNamePlural="HVAC Contractors"
  tradeSlug="hvac-contractors"
  headline="AI Facebook Messenger for UK HVAC Contractor Companies"
  accentWord="HVAC"
  subhead="You post five photos of a VRF installation in a three-storey architectural practice in Headington. Photo one: the before — three ageing window units dripping condensate down the stone facade, extension leads trailing to plug sockets, and portable fans on every desk. Photo two: the plant deck — three Mitsubishi Electric City Multi PUMY outdoor units mounted on anti-vibration feet on a flat roof section, R32 pipework in lagged copper entering through a weathered slate penetration, condensate drains connected to a new rainwater pipe. Photo three: the ceiling void — 15.88mm and 9.52mm copper refrigerant lines running through fire-stopped penetrations, each pair lagged in Armaflex insulation, secured to cable tray with plastic P-clips. Photo four: the completed office — eight Mitsubishi ceiling cassettes with round-flow panels recessed flush into the suspended ceiling tiles, each zone controlled by a PAR-40MAA wall controller, the architects clearly delighted to have removed the window units. Photo five: the commissioning screen on your Mitsubishi MELCloud tablet — superheat, subcooling, discharge temperature, and suction pressure all within specification across all eight zones. Ninety-two likes, eleven shares. A dental practice manager in Cowley messages: 'Those cassettes look incredible — much better than our ugly wall units. We have a dental surgery across two floors — six treatment rooms, a waiting area, and a reception. Currently using three old Daikin wall splits that struggle in summer and sound like aircraft — patients complain about the noise. Want ceiling cassettes like yours for the treatment rooms with individual zone control so each dentist can set their own temperature. Is this feasible in a dental practice with suspended ceilings? What is the approximate cost for six cassettes plus a waiting area unit? We are on Cowley Road.' You are brazing. Without AI Messenger, the seven-zone dental practice waits. With it, the AI confirms that suspended ceilings are ideal for cassette installations, asks about the existing electrical supply capacity and the ceiling void depth, and captures: Cowley Road dental 2-floor, 6 treatment rooms + waiting + reception, 3 Daikin wall splits old noisy, 7 ceiling cassettes with zone control, suspended ceilings, cost estimate, PAR controller per zone."
  scenario="It is 11:45pm on a Tuesday in August. A data centre manager messages: 'Evening — we operate a colocation facility in an industrial unit near Didcot. Current cooling is four Airedale DX precision cooling units, about 10 years old, R410A. One compressor failed last week and we limped through with N+1 redundancy, but if another unit trips we will breach SLA temperatures. Need an emergency assessment of the remaining units, and a design for replacement precision cooling — probably Vertiv Liebert or Schneider InRow, R32, with N+2 redundancy this time. Server hall is 400m², 300kW heat load, raised floor with under-floor air distribution. Can your F-Gas team handle data centre cooling at this scale? Budget is pre-approved — this is urgent.' Without AI Messenger, the data centre replacement waits until Wednesday. With AI Messenger, the reply at 11:46pm: 'Thank you — we undertake data centre precision cooling at this scale. Could you confirm the current hot aisle / cold aisle configuration and whether the raised floor plenum depth exceeds 600mm?' He confirms hot/cold aisle with 800mm plenum. Wednesday you call: Didcot colo, 4 Airedale DX 10yr R410A, 1 compressor failed, N+1 margin, 400m² 300kW, raised floor 800mm hot/cold, Vertiv/Schneider R32 N+2 replacement, urgent pre-approved budget."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/hvac-contractors/ai-receptionist/"
  ctaHeadline="Turn 92 Likes on a Headington VRF Install into a Cowley Dental Practice Survey"
  ctaSubhead={`Five photos of window units replaced by flush Mitsubishi cassettes with MELCloud commissioning earn ninety-two likes. AI Messenger converts the dentist's noise complaint into a seven-zone ceiling cassette survey. Add-on at £${pricing.addOn.price}/month.`}
/>
