---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📧',
    title: 'Acknowledges Commercial HVAC Tenders',
    text: "QSs and M&E consultants email HVAC subcontract packages with system specifications, plant layouts, ductwork schedules, and programme milestones. The F-Gas certified firm acknowledging first — referencing the VRF model and cassette count — stays on the tender shortlist."
  },
  {
    icon: '📐',
    title: 'References System Specifications',
    text: "When an M&E consultant emails specifying 'Daikin VRV V, R32, sixty-four ceiling cassettes, four outdoor units, BS Box branch controllers, iTouch Manager centralised control, BACnet integration to existing Siemens BMS,' the AI acknowledgement references every element."
  },
  {
    icon: '🕒',
    title: 'Covers Your Installation Hours',
    text: "HVAC installation days are consumed by brazing, vacuum testing, charging, commissioning, and BMS integration. An M&E consultant's tender email at 9am sits unread until the last system zone is commissioned at 5pm. Your instant acknowledgement preserves the tender position."
  },
  {
    icon: '🗂️',
    title: 'Separates Tenders from Supplier Invoices',
    text: "Your inbox combines M&E consultant tenders, refrigerant supplier invoices, F-Gas certification renewals, manufacturer technical bulletins, and BESA membership correspondence. The AI identifies genuine project opportunities from operational messages."
  },
  {
    icon: '🤝',
    title: 'Builds Consultant Confidence',
    text: "M&E consultants with multi-building HVAC programmes need F-Gas contractors who deliver technically precise, programme-compliant installations. Consistent instant acknowledgements establish the reliability that earns specification and preferred-contractor status."
  },
  {
    icon: '📎',
    title: 'Notes Drawing Attachments',
    text: "HVAC tenders include mechanical schematics with refrigerant pipe routes, ductwork layouts, plant room general arrangements, AHU schedules, and commissioning programmes. The AI notes every document and captures them in your lead."
  }
];

const faqs = [
  {
    question: "Does the AI produce HVAC quotes from tender emails?",
    answer: "Zero pricing is generated by the system — only a professional acknowledgement referencing the HVAC specification and project scale. Your tender response — indoor and outdoor unit costs, refrigerant pipework quantities, ductwork fabrication, controls integration, commissioning hours, and F-Gas registration fees — is calculated by you from the mechanical drawings, manufacturer trade pricing, and measured site conditions."
  },
  {
    question: "Will it respond to refrigerant supplier emails?",
    answer: "Onboarding configuration distinguishes genuine tenders from operational correspondence. Refrigerant supplier delivery confirmations, F-Gas certification renewal notices, manufacturer firmware update bulletins, and BESA membership invoices are excluded automatically. Only project tenders, client enquiries, and facilities manager maintenance requests generate the professional acknowledgement."
  },
  {
    question: "How does it handle homeowner heat pump emails?",
    answer: "Contact form submissions from homeowners — 'interested in replacing our oil boiler with an air source heat pump, 4-bed detached, no mains gas' — receive a professional response asking about the property age, the wall construction, the current radiator sizes, whether underfloor heating is present, and their awareness of the BUS grant scheme."
  },
  {
    question: "What does email response cost for HVAC contractors?",
    answer: `The email add-on is £${pricing.addOn.price}/month. A commercial VRF installation generates £30,000 to £150,000 in subcontract value. Acknowledging an M&E consultant's sixty-four-cassette tender within sixty seconds — while you charged R32 into a Daikin on another project — frequently determines whether your F-Gas firm receives the formal invitation to tender and the mandatory pre-tender site walkover.`
  },
  {
    question: "Can subsequent tender correspondence come from me?",
    answer: "From the moment the AI sends the initial acknowledgement, every subsequent communication is authored by you. Your measured survey, pipe routing design, ductwork schedule, plant room layout, controls wiring diagram, method statement, programme, and F-Gas notification are prepared and submitted entirely by your team."
  },
  {
    question: "How is HVAC tender data secured?",
    answer: "HVAC tenders contain mechanical schematics, refrigerant system specifications, ductwork layouts, and commercially sensitive pricing schedules. All email content is encrypted, stored on UK and EU servers under UK GDPR, and shared only with you. No project details reach competing HVAC contractors or third parties."
  }
];
---

<ChannelTradeLayout
  title="AI Email Response for UK HVAC Contractors | Rapid Receptionist"
  description={`AI email response for UK HVAC contractors. Acknowledges VRF tenders, heat pump specifications, and chiller replacement programmes within sixty seconds. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/hvac-contractors/ai-email-response/"
  channelName="AI Email Response"
  tradeName="HVAC Contractor"
  tradeNamePlural="HVAC Contractors"
  tradeSlug="hvac-contractors"
  headline="AI Email Response for UK HVAC Contractor Companies"
  accentWord="HVAC"
  subhead="An M&E consultant emails a VRF specification for a three-storey office refit. Your AI acknowledges the tender within seconds while you braze refrigerant pipework on a rooftop condenser."
  scenario="It is 7am on a Monday. Your inbox accumulated over the weekend: a developer needing ASHP packages on sixteen new-build houses in Carterton — 'Mitsubishi Ecodan monobloc, MVHR Zehnder, underfloor heating, MCS certified, BUS grant applications, Part L 2025,' a hotel manager in Woodstock wanting VRF replacement across thirty-two guest rooms — 'existing Toshiba SMMS, 15 years old, R407C, need R32 replacement, minimal disruption, operate during install,' a homeowner requesting a split system for a home office — 'ceiling cassette, Daikin Emura, 3.5kW, wall bracket for outdoor unit,' and a refrigerant supplier confirming Tuesday's R32 cylinder delivery. Without AI Email Response, the sixteen houses, the thirty-two-room hotel, and the home office cassette wait until Tuesday. With AI Email Response, the Carterton houses reference ASHP/MVHR/MCS/BUS, the hotel notes thirty-two rooms and R407C-to-R32 transition, the home office specifies Daikin Emura cassette, and the supplier email is filtered."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-email-response/"
  tradePageUrl="/hvac-contractors/ai-receptionist/"
  ctaHeadline="Acknowledge the 96-Unit University Science Building Tender While You Route Suction Lines"
  ctaSubhead={`An M&E consultant's six-week tender for Daikin VRV V heat recovery, HEPA laboratory AHUs, and Vertiv server cooling starts when the email lands. Your sixty-second acknowledgement secures the Wednesday workshop. Add-on at £${pricing.addOn.price}/month.`}
/>
