---
import TradeHubLayout from '../layouts/TradeHubLayout.astro';

const faqs = [
  {
    question: "How does the AI handle alarm activation and emergency security calls?",
    answer: "Security emergencies get immediate escalation. If a caller reports an alarm sounding, a break-in in progress, suspicious activity on CCTV, or a monitored alarm alert, the AI flags it as critical and contacts you instantly. It captures the site address, the nature of the alert, and any keyholding or access information. For routine enquiries — new installations, system upgrades, or maintenance — details are captured normally for your follow-up."
  },
  {
    question: "I install and maintain CCTV, alarms, and access control — can the AI handle all three?",
    answer: "Yes. The AI is configured to understand the full security installation spectrum — intruder alarms (wired and wireless), CCTV systems (analogue, IP, and cloud-based), access control (key fob, biometric, and intercom systems), fire alarms, and smart home security integration. It captures the right details for each type of enquiry: how many cameras, what area needs covering, how many doors need access control, or what alarm is currently installed."
  },
  {
    question: "A lot of my work comes from commercial clients — property managers, shop owners, warehouses. Can the AI handle those calls?",
    answer: "Commercial security enquiries often involve larger scopes and higher values than domestic work. The AI handles them by capturing site size, current security setup, what prompted the enquiry (insurance requirement, recent incident, expansion), and priority areas. A shop owner calling about anti-theft systems gets different questions than a warehouse manager who needs perimeter CCTV. The AI adapts its approach based on the type of business and the complexity of the requirement."
  },
  {
    question: "What about monitoring contracts and ARCs — does the AI understand those?",
    answer: "The AI understands that monitoring and Alarm Receiving Centre connections are key parts of many security installations. When a customer calls about monitored alarms, the AI captures whether they need new monitoring, a change of monitoring provider, or maintenance on an existing monitored system. It doesn't discuss monitoring contracts or pricing — those conversations need to happen between you and the customer. It captures the lead so you can follow up with a proper consultation."
  },
  {
    question: "Security installations often need a site survey. Does the AI book those?",
    answer: "No — and deliberately so. Security installations always need a proper site survey before quoting, and only you can assess vulnerabilities, camera angles, and sensor placement. The AI captures the customer's details, the type of security they're interested in, and the property type, then sends it all to you. You schedule the survey at a time that works for your diary."
  },
  {
    question: "I'm NSI/SSAIB accredited — does the AI mention that?",
    answer: "The AI doesn't discuss your accreditations, certifications, or compliance credentials during calls. Your NSI or SSAIB accreditation is a major selling point, and it's best communicated by you during the consultation or site survey. The AI focuses on capturing the enquiry professionally — making sure the lead reaches you with enough detail to respond quickly and demonstrate your expertise in your own words."
  },
  {
    question: "How does the AI handle calls from existing customers needing maintenance?",
    answer: "Existing customer calls are captured with the same speed and detail as new enquiries. If someone calls about a faulty sensor, a camera that's gone offline, or an alarm that keeps false-triggering, the AI captures the system type, the fault description, and the customer's details. For maintenance contracts, where response times matter, having every call answered instantly means you're always meeting your SLA — even when you're on-site at another job."
  },
  {
    question: "Smart home security is growing — does the AI understand Ring, Hive, and similar systems?",
    answer: "We train the AI to understand both professional-grade and smart home security enquiries. Some callers want a full NSI Gold system with monitoring; others want help integrating Ring doorbells, Hive cameras, and smart locks into a cohesive setup. The AI captures what the customer currently has, what they want to achieve, and whether they're looking for a professional installation or advice on upgrading their existing DIY setup."
  }
];
---

<TradeHubLayout
  title="AI Receptionist for UK Alarm & Security Installers — Never Miss a Job | Rapid Receptionist"
  description="AI receptionist built for UK alarm & security installers. Handles emergency security calls, CCTV enquiries & access control leads 24/7. Only £99/mo."
  canonicalUrl="/ai-receptionist-for-alarm-security-installers/"
  tradeName="Alarm & Security Installer"
  tradeNamePlural="Alarm & Security Installers"
  tradeSlug="alarm-security-installers"
  headline="The AI Receptionist Built for UK Alarm & Security Installers. Always Guarding Your Leads."
  accentWord="UK Alarm & Security Installers"
  subhead="When a customer's alarm goes off at 3am or a business needs emergency CCTV after a break-in, they need you now. Your AI receptionist makes sure every security call is answered — even when you're halfway through a 40-camera installation."
  speedStat="Security customers expect a response within minutes, not hours."
  speedText="Security work is trust-based and urgency-driven. A homeowner who's just been burgled isn't going to wait for a callback tomorrow. A shop owner whose alarm is sounding needs someone now. Rapid Receptionist answers every call instantly, captures the urgency, and gets the details to you in real-time."
  scenario="It's Tuesday afternoon. You're running cable for a 16-camera CCTV system across a new-build industrial unit in Sheffield. Your phone rings four times in an hour. A homeowner in Rotherham wants a full intruder alarm and CCTV system after a spate of burglaries on her street. A facilities manager in Doncaster needs access control for a new office building — 8 doors, biometric entry, and an intercom system. A pub landlord in Barnsley has had his CCTV hard drive fail and needs urgent replacement before the weekend. A letting agent wants quotes for alarm installations across a portfolio of six rental properties. You're up a ladder, drill in hand, and can't answer any of them. Without Rapid Receptionist, those four leads find another security installer. With it, every call is answered, the urgent CCTV failure is flagged, and all four leads are captured with full details."
  faqs={faqs}
/>
