---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Engages Homeowners Researching Lead Solutions',
    text: "Homeowners with persistent chimney leaks discover that 'proper lead flashing' is the permanent fix after years of failed cement fillets. When they land on your website, chat engages them during their most motivated research moment."
  },
  {
    icon: '📐',
    title: 'Qualifies Lead Project Scale',
    text: "Through conversation, the AI identifies whether the visitor needs chimney soakers, a full weathering set, valley linings, or a heritage lead roof restoration. You receive a lead with the component, code weight, and building context."
  },
  {
    icon: '🕐',
    title: 'Converts Evening Chimney Research',
    text: "Homeowners notice chimney leaks during evening rainfall, research 'lead chimney flashing' online, and find your website at 10pm. They type: 'Our chimney has leaked for years — two roofers have patched it with cement and it keeps cracking. Someone told us we need proper lead. Can you do it?' The chat captures the lead while the drip continues."
  },
  {
    icon: '📊',
    title: 'Explains Lead Codes and Bossing',
    text: "Visitors ask unfamiliar questions — 'what does code 5 mean?', 'what is bossing?', 'how long does lead last?' The AI responds from your profile with helpful context about lead weights and techniques while capturing their project details."
  },
  {
    icon: '🔗',
    title: 'Works Alongside Heritage Portfolios',
    text: "Leadwork websites showcase spectacular projects — church roofs gleaming with fresh code 7, ornamental hoppers dressed by hand, and chimney weathering photographed from scaffold height. Chat converts impressed architects and heritage officers browsing your portfolio into detailed tender conversations."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat is part of phone answering at £${pricing.tiers.core.price}/month. Unlimited conversations about lead codes, chimney weathering, valley linings, and heritage specifications.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my leadwork website?",
    answer: "A compact JavaScript snippet is provided during onboarding. Embed it into your website header — through WordPress, Squarespace, or direct HTML — and the branded chat widget deploys across every page of your leadwork firm's website. Leadworkers with heritage portfolio galleries report architects engaging with chat directly from project case study pages showing dressed chimney sets and ornamental hoppers."
  },
  {
    question: "Can the AI discuss lead weights and techniques?",
    answer: "Your company profile informs the AI about your specialisms, lead codes, and heritage accreditation. When a visitor asks 'we need the chimney done properly with lead — what code do you use for residential chimney flashing?' the AI responds from your profile context and captures the chimney dimensions, existing flashing type, and leak history."
  },
  {
    question: "What does chat capture from leadwork visitors?",
    answer: "The AI gathers the lead component needed (chimney set, valley, bay top, parapet, or full roof), the building type and heritage listing status, the existing flashing material and failure mode, the approximate dimensions, any architect or conservation officer involvement, and visitor contact information."
  },
  {
    question: "Does chat slow my leadwork website?",
    answer: "Your page content renders completely before the chat interface appears — heritage project photography, chimney weathering close-ups, ornamental hopper galleries, and accreditation badges display at their natural speed. No perceptible delay on any device or connection."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Chat is included with phone answering at £${pricing.tiers.core.price}/month as part of the Core plan. For leadworkers, both channels serve distinct enquiry patterns: daytime phone calls from roofers needing chimney sets by Friday, and evening website conversations from architects researching LSA-accredited firms for heritage restoration projects.`
  },
  {
    question: "How is visitor data from leadwork queries handled?",
    answer: "Chat conversations containing listed building addresses, heritage specifications, grant references, architectural details, and visitor contact information are encrypted and stored on UK and EU servers under UK GDPR. Lead summaries go exclusively to you. No property data reaches competing leadworkers or any third party."
  }
];
