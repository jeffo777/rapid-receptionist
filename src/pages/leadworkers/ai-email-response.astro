---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📧',
    title: 'Acknowledges Heritage Lead Tenders',
    text: "Architects and heritage consultants email lead roofing tenders with code specifications, detail drawings, and grant conditions. The leadworker that acknowledges first — referencing the code weight, joint type, and building listing — stays on the tender shortlist."
  },
  {
    icon: '📐',
    title: 'References Lead Specifications',
    text: "When an architect emails specifying 'code 7 milled lead, traditional rolls at 600mm centres, drips at 1.5m, copper clips at 450mm, lead-welded intersections, patination oil finish, LSA accredited installer required,' the AI acknowledgement references the code, roll spacing, clip type, and accreditation."
  },
  {
    icon: '🕒',
    title: 'Covers Your Scaffold Hours',
    text: "Leadworkers spend full days on the scaffold — bossing back gutters, dressing soakers, welding joints, and applying oil. An architect's heritage tender arriving at 9am sits unread until evening. The sixty-second acknowledgement keeps your tender position active."
  },
  {
    icon: '🗂️',
    title: 'Separates Tenders from Merchants',
    text: "Your inbox mixes architect tenders, lead sheet merchant delivery confirmations, copper clip supplier invoices, LSA membership correspondence, and CSCS card renewal notices. The AI identifies genuine project tenders and client enquiries from operational emails."
  },
  {
    icon: '🤝',
    title: 'Builds Architect Loyalty',
    text: "Conservation architects with ongoing listed building portfolios need reliable LSA-accredited leadworkers. Consistent instant acknowledgements across heritage projects establish your firm as the specialist they specify into every restoration."
  },
  {
    icon: '📎',
    title: 'Notes Drawing Attachments',
    text: "Heritage tenders include lead detail drawings, roll and drip layouts, section profiles, and DAC faculty documents. The AI notes these attachments in the acknowledgement and your lead summary."
  }
];

const faqs = [
  {
    question: "Does the AI produce lead quotations from tenders?",
    answer: "The system never generates pricing — only a professional receipt acknowledgement referencing the lead code, components, and project scope. Your leadwork quotation — sheet weight calculations from measured dimensions, copper clip quantities, solder and welding rod, patination oil, labour, scaffold hire, and programme — is prepared by you from the site survey and detail drawings."
  },
  {
    question: "Will it respond to lead merchant and supplier emails?",
    answer: "Onboarding lets you configure which email categories receive the acknowledgement. Lead sheet delivery confirmations, copper clip order updates, patination oil supplier invoices, LSA training bulletins, and CSCS renewal correspondence are excluded. Genuine project tenders and client enquiries are the only messages that trigger the professional response."
  },
  {
    question: "How does it handle homeowner enquiries by email?",
    answer: "Homeowner emails from your contact form — 'our chimney has leaked for years and a roofer told us we need proper lead flashing, can you come and look?' — receive a professional reply asking about the chimney position, the existing flashing material, the number of chimney stacks, and the leak location relative to the stack."
  },
  {
    question: "What does email response cost for leadworkers?",
    answer: `Email response is £${pricing.addOn.price}/month as an add-on. Heritage church lead roofing generates £10,000 to £80,000 in contract value. Acknowledging an architect's four-week tender within sixty seconds — while you bossed code 5 around a dormer junction on another listed building — often decides whether your firm reaches the interview stage for the largest church projects in the diocese.`
  },
  {
    question: "Can all follow-up tender correspondence come from me?",
    answer: "After the receipt acknowledgement, every subsequent communication is authored by you. Your measured survey report, lead weight calculation, method statement, heritage risk assessment, programme, scaffold design, and LSA warranty documentation are produced and submitted by you and your estimating team."
  },
  {
    question: "How is heritage lead tender data secured?",
    answer: "Heritage tenders contain listed building details, DAC faculty references, English Heritage grant conditions, architectural drawings, and commercially sensitive costing. All email content is encrypted, stored on UK and EU servers under UK GDPR, and shared only with you. No tender information reaches competing leadworkers or third parties."
  }
];
---

<ChannelTradeLayout
  title="AI Email Response for UK Leadworkers | Rapid Receptionist"
  description={`AI email response for UK leadworkers. Acknowledges heritage church tenders, architect specifications, and chimney flashing enquiries within sixty seconds. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/leadworkers/ai-email-response/"
  channelName="AI Email Response"
  tradeName="Leadworker"
  tradeNamePlural="Leadworkers"
  tradeSlug="leadworkers"
  headline="AI Email Response for UK Leadworker Companies"
  accentWord="Leadwork"
  subhead="A cathedral fabric advisor emails a comprehensive lead re-roofing tender for the south transept of a medieval cathedral — the existing code 8 sand-cast lead has fatigued after two hundred years with extensive longitudinal cracking along the rolls, perforation at multiple drip joints, and biological growth beneath the lead sheet. The specification calls for code 8 milled lead to match the existing thickness profile, traditional rolls at 600mm centres, drips at 1.5 metres maximum, stainless steel fixing clips at 450mm intervals, all joints lead-welded (no solder), and patination oil applied within twenty-four hours of installation. The cathedral's Fabric Advisory Committee has approved the quinquennial inspection recommendation. English Heritage has confirmed Category A grant funding covering sixty percent of the eligible works. Only LSA-accredited Master Leadworkers are eligible to tender. The scope covers approximately forty-two square metres across two bays. Tender return in six weeks with a mandatory pre-tender site visit. You are on a listed rectory in Woodstock — lead welding a back gutter joint on a chimney stack, the propane torch heating the lead to working temperature, the filler rod feeding into the molten pool while your left hand steadies the flame angle against the wind. Both hands occupied, critical technique. Without AI Email Response, the cathedral tender sits until the evening. Two competing LSA Master firms responded within ninety minutes. With it, your acknowledgement arrives within sixty seconds, referencing the south transept, code 8 milled, 42 sqm, sand-cast matching, 600mm rolls, lead-welded joints, stainless clips, patination oil, FAC approval, Category A grant, LSA Master requirement, six-week tender, mandatory site visit."
  scenario="It is 7am on a Monday. Your inbox accumulated over the weekend: a roofer requesting chimney lead on three properties in Bicester — 'doing three re-roofs back-to-back over the next two weeks, each house needs a full chimney weathering set, code 4, all ridge stacks, similar 1960s semis,' a conservation architect requesting ornamental lead rainwater goods for a Georgian townhouse in Oxford — 'replacement hopper heads and downpipes to match the existing eighteenth-century lead profiles, cast from moulds, approximately four hoppers and twelve metres of circular downpipe,' an ecclesiastical architect specifying replacement lead soakers for a church nave — 'the existing soakers have corroded and are admitting water behind the stone slates, approximately 120 soakers needed in code 3,' and a lead merchant confirming Thursday's delivery of code 5 rolls. Without AI Email Response, you scan subjects while making coffee. The cathedral tender and ornamental hopper specification sit until Tuesday. Competitors responded Monday morning. With AI Email Response, the cathedral tender gets an immediate acknowledgement referencing code 8 and FAC approval, the ornamental hopper specification is noted with Georgian profiles and cast moulds, the soaker replacement is acknowledged with code 3 and quantity, and the merchant email is filtered."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-email-response/"
  tradePageUrl="/leadworkers/ai-receptionist/"
  ctaHeadline="Acknowledge the Cathedral South Transept Tender While You Weld the Rectory Gutter"
  ctaSubhead={`A fabric advisor's six-week tender for 42 square metres of code 8 with Category A grant funding requires an LSA Master. Your sixty-second acknowledgement secures the site visit. Add-on at £${pricing.addOn.price}/month.`}
/>
