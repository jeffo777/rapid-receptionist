---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Heritage Portfolio Content',
    text: "Leadwork photography is inherently compelling — gleaming code 7 rolls on a church nave, bossed chimney back gutters dressed to perfection, and ornamental hoppers patinated to a rich grey. When an architect messages about their own lead project, the AI captures the tender lead."
  },
  {
    icon: '📸',
    title: 'Handles Failure Photo Messages',
    text: "Roofers and homeowners message with photos of cracked cement fillets, fatigued valley linings, and corroded chimney flashings — 'does this need replacing with lead?' The AI asks about the building age, listing status, and leak severity, converting photo enquiries into structured leads."
  },
  {
    icon: '⚡',
    title: 'Captures Roofer Booking Messages',
    text: "Roofers message from site — 'chimney stripped and ready, need a leadworker for Thursday.' The AI confirms your capability and asks about the chimney dimensions and code requirement while you boss a back gutter elsewhere."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Heritage Research',
    text: "Conservation officers and architects research LSA-accredited leadworkers in the evening. Messages about church re-roofing and listed building restoration arrive after 7pm. The AI captures every professional heritage enquiry."
  },
  {
    icon: '📋',
    title: 'Qualifies Heritage Lead Project Scale',
    text: "Messenger conversations start with a grand vision — 'we need the church roof redone in lead.' The AI asks about the building listing, lead code, area, current condition, and grant funding situation — building a specification-ready heritage brief."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Bossing Close-Up',
    text: "Every dressed chimney set, rolled church nave bay, and ornamental hopper photo generates enquiries from architects and roofers who recognise that the difference between leadwork and lead bodging is visible in every crease."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my leadwork firm?",
    answer: "A Facebook Business page is necessary for connecting Messenger — personal accounts cannot integrate. Leadworkers posting heritage project galleries, bossed chimney close-ups, and church nave completion shots attract exactly the architects and heritage officers who commission specialist leadwork for Grade I and Grade II listed buildings."
  },
  {
    question: "What leadwork enquiries come through Messenger?",
    answer: "A blend of roofer subcontract requests and architect heritage specifications. Roofers message about chimney weathering, valley linings, and bay tops that need fitting within their programme. Architects message about heritage lead restoration, ornamental rainwater goods, and church re-roofing. Each sender has viewed your portfolio and identified your firm's specialist leadwork capability."
  },
  {
    question: "How fast does the AI reply to leadwork messages?",
    answer: "Replies land in the sender's Messenger inbox within seconds. Facebook's active status shows your leadwork firm is immediately responsive. An architect who has spent weeks preparing a Grade II* heritage specification and finally messages their preferred LSA firm expects a swift, technically fluent response — not an unread message that sits until Friday."
  },
  {
    question: "What does Messenger cost for leadworkers?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. Heritage church lead roofing generates £10,000 to £80,000 per project. One cathedral fabric advisor's nave tender — secured through a prompt Messenger reply while you dressed a valley lining on another listed building — covers the channel cost for the foreseeable future.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Reply once in any thread and the AI yields permanently for that conversation. Most leadworkers let the AI capture the initial scope — lead component, code, building type, listing, heritage requirements, and programme — then engage to discuss the measured survey, bossing details, and quotation."
  },
  {
    question: "How is Messenger data from leadwork queries protected?",
    answer: "All Messenger conversations, project photographs, listed building details, heritage specifications, grant references, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No heritage details reach competing leadworkers, are shared with lead merchants, or are available to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Leadworkers | Rapid Receptionist"
  description={`AI Facebook Messenger for UK leadworkers. Converts heritage portfolio content into church re-roofing tenders and chimney flashing bookings. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/leadworkers/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Leadworker"
  tradeNamePlural="Leadworkers"
  tradeSlug="leadworkers"
  headline="AI Facebook Messenger for UK Leadworker Companies"
  accentWord="Leadwork"
  subhead="You post four photos of a completed chimney weathering set on a Grade II listed vicarage in Charlbury — the first shows the bare chimney stack before your arrival: eroded mortar chases, a failed cement fillet crumbling away, and water staining down the ashlar stonework. The second shows your copper clips fixed and the code 5 front apron dressed against the brickwork. The third captures the stepped flashing — each step precisely bossed into the mortar chase, pointed with lime mortar, the lead creasing cleanly against the stone slates below. The fourth shows the completed back gutter — code 5 dressed around the junction, lead-welded at the internal angle, a soaker tucked beneath each stone slate course. Ninety-six likes. A conservation architect in Oxford messages: 'Exceptional stepped flashing work — the lime mortar pointing is exactly what we need. We have a Grade I listed almshouse in Abingdon undergoing roof restoration. The existing chimney lead is original — approximately 1780 — and has finally fatigued. Two chimney stacks, both complex — one sits at the junction of two roof slopes creating a four-way intersection. We need full weathering sets in code 5, lead-welded joints, lime mortar pointing to match your vicarage work. Can you survey and provide a heritage specification?' You are on the scaffold. Without AI Messenger, the Grade I almshouse message waits. With it, the AI asks about the chimney dimensions, the roof covering (stone slate, clay, or artificial), and whether the four-way junction requires a separate saddle piece. The architect confirms stone slate and saddle needed."
  scenario="It is 10pm on a Saturday. A roofer messages: 'Hi mate — got a job next week I need help with. Doing a re-roof on a 1920s detached in North Oxford. Three chimney stacks. One on the ridge — big one, about 1000mm by 800mm. Two smaller ones on the gable walls, about 600mm square each. All need full weathering sets — stepped, apron, back gutter, soakers. The existing lead has been there since the house was built and it is all perished. Code 4 should be fine for domestic. Scaffold going up Monday. My tiler starts Wednesday. Can you get all three done Monday and Tuesday? I know it is tight but the chimney stacks are clean — the old lead just needs stripping off and chases raking out.' Without AI Messenger, the message sits until Sunday morning. One leadworker replied at 10:30pm. With AI Messenger, the reply arrives at 10:01pm: 'Three chimney sets across two days is achievable with the right preparation. Could you confirm whether the ridge chimney has a back gutter on both sides or just one, and whether the gable chimneys have parapets or sit against the slope?' He confirms: ridge chimney needs back gutter both sides, gable chimneys against the slope. Sunday you review: North Oxford 1920s detached, three chimneys, ridge 1000x800 + two gable 600mm, full weathering sets code 4, scaffold Monday, tiler Wednesday, two-day lead programme."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/leadworkers/ai-receptionist/"
  ctaHeadline="Turn 96 Likes on a Charlbury Chimney Set into a Grade I Almshouse Tender"
  ctaSubhead={`Four photos of stepped flashing with lime mortar pointing earn ninety-six likes. AI Messenger converts an architect's Grade I message into a heritage survey with four-way junction and saddle specification. Add-on at £${pricing.addOn.price}/month.`}
/>
