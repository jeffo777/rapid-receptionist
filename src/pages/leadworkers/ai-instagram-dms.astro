---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📷',
    title: 'Converts Bossing and Welding Reels',
    text: "Leadwork reels captivate professional audiences — the bossing mallet shaping code 5 around a chimney internal angle, the torch fusing a lead-welded joint, and the reveal of a dressed back gutter gleaming with fresh patination oil. When followers DM, the AI captures the lead project details."
  },
  {
    icon: '🎯',
    title: 'Reaches Heritage-Focused Architects',
    text: "Instagram attracts conservation architects, heritage officers, and church fabric advisors who research specialist contractors visually. A DM from someone who has studied your bossed chimney details and lead-welded joints represents a pre-qualified heritage tender opportunity."
  },
  {
    icon: '📱',
    title: 'Handles Lead Condition DMs',
    text: "Roofers DM photos of deteriorated lead — fatigued rolls, cracked drips, and corroded soakers. The AI asks about the building type, lead code, and component, converting technical photos into structured assessment leads."
  },
  {
    icon: '🌙',
    title: 'Catches Late Heritage Enquiries',
    text: "Conservation architects prepare specifications in the evening. Church wardens browse LSA portfolios after PCC meetings. Heritage officers identify potential contractors during evening research. The AI captures every professional DM."
  },
  {
    icon: '📋',
    title: 'Structures Heritage Tender DMs',
    text: "DMs about heritage leadwork begin with grand scope — 'we need the whole church roof in lead.' The AI asks about the building listing, existing lead condition, area, code specification, and funding body — building a tender-ready heritage brief."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Dressed Detail',
    text: "Every chimney back gutter close-up, ornamental hopper reel, and church bay completion overhead generates enquiries from professionals who value the craft difference visible in every welded joint and bossed crease."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "Navigate to your Instagram settings and convert to a Business or Creator profile at no cost. Leadworkers producing bossing close-ups, chimney weathering time-lapses, and heritage church completion drone shots gain professional insights showing exactly which architects and heritage professionals engage most — helping every post reach the conservation community."
  },
  {
    question: "What leadwork DMs arrive through Instagram?",
    answer: "Conservation architects, heritage building officers, roofers, and discerning homeowners. Architects DM about heritage restoration projects after reviewing your church and listed building portfolio. Roofers DM about chimney subcontract availability. Homeowners DM about persistent chimney leaks after seeing your domestic flashing work. Each sender has evaluated your craftsmanship through your visual portfolio."
  },
  {
    question: "How quickly does the AI respond to leadwork DMs?",
    answer: "Responses arrive within seconds of the DM landing. Instagram's read confirmation shows your leadwork firm is actively monitoring messages. An architect who has spent weeks selecting an LSA firm based on portfolio quality expects a swift, specification-literate response that demonstrates professional heritage capability — not an ignored DM that suggests the firm is too busy to tender."
  },
  {
    question: "What do Instagram DMs cost for leadworkers?",
    answer: `Instagram DMs is £${pricing.addOn.price}/month as a channel add-on. A heritage church lead project generates £10,000 to £80,000 in contract value. One cathedral fabric advisor's tender — captured through a prompt DM reply to a heritage portfolio reel while competing firms' messages accumulated — justifies the channel cost indefinitely.`
  },
  {
    question: "Can I reply to DMs myself?",
    answer: "Post one reply in any thread and the AI withdraws from that conversation permanently. Most leadworkers let the AI capture the initial enquiry scope — building type, listing, lead component, code, area, and programme — then follow up personally to discuss the measured survey, bossing details, joint specification, and quotation."
  },
  {
    question: "Is DM data from leadwork queries private?",
    answer: "Instagram DM content — heritage project photographs, listed building details, lead specifications, grant references, and sender contact information — is encrypted and stored on UK and EU servers under UK GDPR. Nothing reaches competing leadworkers, is shared with lead sheet merchants, or is made available to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Instagram DMs for Leadworkers | Rapid Receptionist"
  description={`AI Instagram DMs for UK leadworkers. Converts heritage bossing reels and chimney weathering close-ups into church re-roofing tenders and listed building restoration leads. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/leadworkers/ai-instagram-dms/"
  channelName="AI Instagram DMs"
  tradeName="Leadworker"
  tradeNamePlural="Leadworkers"
  tradeSlug="leadworkers"
  headline="AI Instagram DMs for Leadworker Companies"
  accentWord="Leadwork"
  subhead="Your latest reel is a forty-second sequence filmed on a medieval church in the Cotswolds — the camera starts at the ridge, looking down across four bays of fresh code 7 milled lead gleaming in the afternoon light. Each roll stands in perfection at 600mm centres, the drips spaced precisely at 1.5 metres, the copper clips invisible beneath the lapped edges. The shot descends to the eaves, revealing the dressed abutment where lead meets Cotswold stone slate — each soaker tucked beneath the stone, the cover flashing bossed into a lime mortar chase with surgical precision. The final frame shows the ornamental lead hopper head at the rainwater outlet — hand-formed, patched with the church's name and date of restoration, patinated to a rich grey. Eleven thousand views. A cathedral fabric manager DMs: 'Remarkable craftsmanship. Our cathedral chapter has approved quinquennial recommendations for the north choir aisle — approximately 28 square metres of code 7, four bays, existing lead circa 1890 has fatigued beyond repair. We need an LSA Master Leadworker for the tender. The existing rolls are traditional profile. English Heritage Category A grant confirmed. Would you attend a pre-tender site visit on the 22nd?' You are on the scaffold. Without AI DMs, the cathedral message waits. With it, the AI asks about the existing lead thickness, whether the timber boarding beneath requires renewal, and the programme constraints for work above an active choir aisle. The fabric manager provides details. Monday you call with full context."
  scenario="It is 2am on a Saturday. A homeowner in Summertown has been searching for a leadworker for three weeks. His Victorian semi has a persistent leak at the back of the chimney — every heavy rainfall produces a damp patch on the bedroom wall below the chimney breast. Two roofers applied cement fillet patches that cracked within a year. He has learned from research that a properly bossed code 4 back gutter and stepped flashing set is the permanent answer. After comparing four leadworkers' Instagram portfolios, your chimney detail shots convinced him. He DMs: 'Hi — been looking at your work for weeks and your chimney lead is the best I have seen. Our Victorian semi in Summertown has a chimney leak that has been patched twice with cement — it keeps cracking and leaking at the back of the stack. The chimney is on the ridge, about 800mm square, clay tiles on the roof. We need proper lead — a full weathering set like the ones in your photos. Can you come and have a look? OX2.' Without AI DMs, the message waits until Saturday morning. With AI DMs, the response arrives at 2:01am: 'Thank you — two cement failures at the chimney back confirm that only properly bossed lead will solve the problem permanently. Could you confirm whether the chimney serves working flues, and whether the existing tile courses are intact around the base of the stack?' He confirms two working flues and some disturbed tiles. Saturday you review: Victorian semi, Summertown OX2, ridge chimney 800mm, clay tiles, two cement patch failures, full weathering set needed, two working flues, disturbed tiles."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-instagram-dms/"
  tradePageUrl="/leadworkers/ai-receptionist/"
  ctaHeadline="Turn an 11,000-View Church Nave Reel into a Cathedral Choir Aisle Tender"
  ctaSubhead={`Forty seconds of code 7 rolls and copper clips earns eleven thousand views. AI Instagram DMs converts a fabric manager's message into a pre-tender site visit for 28 square metres of heritage lead. Add-on at £${pricing.addOn.price}/month.`}
/>
