---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Before-and-After Roof Transformations',
    text: "Roofing before-and-after content draws strong engagement — a tired, moss-covered roof transformed into pristine slate courses with gleaming lead flashing and new UPVC trim. When a homeowner messages about their own ageing roof, the AI captures the re-roof lead."
  },
  {
    icon: '📸',
    title: 'Handles Damage Photo Messages',
    text: "Homeowners message with photos of missing tiles, cracked ridges, and ceiling stains — 'does this need a new roof?' The AI asks about the roof age, tile type, leak severity, and insurance status, converting worried photo messages into structured repair leads."
  },
  {
    icon: '⚡',
    title: 'Captures Street-Level Interest',
    text: "When your scaffold goes up and the old tiles come off, neighbours watch the transformation. Messages from adjacent homeowners — 'you are next door at number 14, our roof looks the same age, can you look at ours too?' — convert proximity visibility into additional re-roof bookings."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Rainfall',
    text: "Homeowners discover roof problems during rain — drips appear, damp patches spread, and anxiety rises. Messages at 9pm about 'water coming through the ceiling during tonight's rain' carry genuine emergency urgency."
  },
  {
    icon: '📋',
    title: 'Qualifies Casual Roof Enquiries',
    text: "Messenger conversations start vaguely — 'how much is a new roof?' The AI asks about the property type, existing tile or slate, number of slopes, chimney presence, and fascia condition, transforming curiosity into a quotable re-roof brief."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Transformation Post',
    text: "Every scaffolded strip, tidy tile course, fresh lead flashing close-up, and aerial drone completion shot generates potential re-roof enquiries from homeowners comparing their own worn tiles to your pristine finished work."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my roofing firm?",
    answer: "A Business page is essential for the Messenger connection — personal profiles do not support the integration. Roofing firms posting transformation content — scaffold time-lapses, slate laying sequences, and completed roof drone shots — generate exceptional engagement from homeowners who compare their own ageing tiles to your pristine finished work."
  },
  {
    question: "What roofing enquiries come through Messenger?",
    answer: "Primarily homeowners and landlords. Homeowners message about re-roofs, storm damage, ridge repairs, and fascia replacement. Landlords message about tenant leak complaints and multi-property roof programmes. Builders occasionally message about extension and dormer roofing availability. Each sender has reviewed your project gallery and selected your firm based on demonstrated roofing quality."
  },
  {
    question: "How fast does the AI reply to roofing messages?",
    answer: "Replies land in the sender's inbox within seconds of the message being sent. Facebook's online indicator shows your roofing firm is actively available. After a storm, when homeowners message multiple roofers simultaneously — some at midnight with ceiling drip photos — the firm that replies first with practical advice and a tarp offer captures the emergency work."
  },
  {
    question: "What does Messenger cost for roofing firms?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. A standard domestic re-roof generates £4,000 to £12,000 in revenue. One neighbour's re-roof, captured through a prompt Messenger reply while competing firms' messages sat overnight, covers the channel cost for the foreseeable future.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Respond in any Messenger thread and the AI yields to you permanently. Most roofers let the AI capture the initial details — property type, roof problem, tile preference, access, and insurance status — then follow up to discuss the inspection date, material options, and quote."
  },
  {
    question: "How is Messenger data from roofing queries protected?",
    answer: "All Messenger conversations, damage photographs, property locations, insurance claim references, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No property details are disclosed to competing roofers, shared with scaffolding companies, or sold to any third party."
  }
];
