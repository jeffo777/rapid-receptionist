---
import TradeHubLayout from '../layouts/TradeHubLayout.astro';

const faqs = [
  {
    question: "How does the AI handle emergency garage door calls?",
    answer: "A garage door stuck open is a security risk. A garage door stuck closed with a car trapped inside is a logistics nightmare. The AI recognises both as urgent situations. If a caller describes a door that's come off its tracks, a broken spring that's made the door inoperable, or a door that won't secure the property, it escalates to you immediately. Routine enquiries like new door installations, automation upgrades, or annual servicing are captured for standard follow-up."
  },
  {
    question: "Most of my work is installations — do I really need call answering?",
    answer: "Installation enquiries are your highest-value leads — a new roller door, sectional door, or automated system can be worth £1,500-5,000 per job. When a homeowner finally decides to replace their garage door, they call two or three companies for quotes. The first to answer and sound professional wins the appointment. If they get your voicemail while your competitor picks up, you've lost the job before you even knew it existed."
  },
  {
    question: "Can the AI distinguish between different types of garage doors?",
    answer: "We train the AI to understand the full range — up-and-over doors (canopy and retractable), roller doors, sectional doors, side-hinged doors, and automated systems. It also understands the common components: springs (torsion and extension), cables, tracks, motors, remotes, and safety sensors. When a customer describes a problem, the AI captures enough detail for you to arrive prepared — or to quote remotely if the job is straightforward enough."
  },
  {
    question: "I cover a wide area — does the AI capture location?",
    answer: "Location is one of the first things captured on every call. Garage door engineers often cover a wide radius, so knowing whether a job is 15 minutes or an hour away matters for scheduling. The AI captures the customer's postcode or area, which helps you prioritise urgent callouts near your current location and plan installation appointments efficiently."
  },
  {
    question: "A lot of my work comes from property developers and building companies. Can the AI handle trade-to-trade calls?",
    answer: "Trade-to-trade enquiries often involve bulk orders, tight timelines, and repeat business potential. When a developer calls needing garage doors for a 12-unit new-build, or a building contractor needs four automated doors for a commercial project, the AI captures the project scope, timeline, and specification requirements. These are relationship-building leads, and the AI makes a professional first impression that reflects well on your business."
  },
  {
    question: "What about garage door automation and smart home integration?",
    answer: "Automation is a growing part of garage door work — retrofit motors, app-controlled openers, and smart home integration. The AI understands these enquiry types and captures what the customer currently has (manual or automated), what they want (new motor, app control, integration with home automation), and their property details. Whether it's a simple remote upgrade or a full smart garage system, the lead reaches you with enough detail to respond knowledgeably."
  },
  {
    question: "Garage door spring replacements are dangerous. Does the AI advise customers?",
    answer: "Absolutely not. The AI never provides DIY advice, safety guidance, or technical instructions. Garage door springs — especially torsion springs — are under extreme tension, and incorrect handling can cause serious injury. If a customer describes a broken spring, the AI captures the door type and the fault, and advises they don't attempt any repair themselves. The technical conversation happens when you, the qualified engineer, call them back."
  },
  {
    question: "I sell doors as well as install them — can the AI handle product enquiries?",
    answer: "Yes. Many garage door engineers supply and fit, and the AI handles product enquiries by capturing what the customer is looking for — size, material, style, colour, insulation requirements, and whether they want manual or automated. It doesn't discuss pricing or availability — that's your conversation. It gives you a fully qualified lead with enough detail to prepare a tailored quote or invite them to your showroom."
  }
];
---

<TradeHubLayout
  title="AI Receptionist for UK Garage Door Engineers — Never Miss a Job | Rapid Receptionist"
  description="AI receptionist built for UK garage door engineers. Handles emergency door calls, installation enquiries & automation leads 24/7. Only £99/mo."
  canonicalUrl="/ai-receptionist-for-garage-door-engineers/"
  tradeName="Garage Door Engineer"
  tradeNamePlural="Garage Door Engineers"
  tradeSlug="garage-door-engineers"
  headline="The AI Receptionist Built for UK Garage Door Engineers. Every Lead Secured."
  accentWord="UK Garage Door Engineers"
  subhead="Whether it's an emergency spring replacement or a quote for a new automated system, your customers expect a fast response. Your AI receptionist answers every call and message — even when you're fitting a door and can't reach your phone."
  speedStat="A missed garage door installation enquiry costs you £1,500-5,000."
  speedText="Garage door work is high-value. A single installation covers your Rapid Receptionist subscription for the next year. When a homeowner or developer is comparing companies, they go with whoever makes the best first impression — and that starts with answering the phone."
  scenario="It's a drizzly Saturday morning. You're fitting a new insulated sectional door on a detached house in Cheltenham — it's a two-man job and you're on the lifting gear, guiding the panels into the tracks. Your phone buzzes repeatedly. A homeowner in Gloucester is locked out — her garage door spring snapped and she can't open it to get her car out for a hospital appointment. A property developer in Tewkesbury needs a quote for eight roller doors across a new housing development — potentially a £25,000 contract. A regular customer in Stroud wants his old manual door automated with a smart opener. You can't stop mid-fit to answer. Without Rapid Receptionist, the locked-out customer calls another engineer, the developer finds a competitor, and your regular customer starts looking elsewhere. With it, the emergency is escalated to you immediately, and both high-value leads are captured for follow-up."
  faqs={faqs}
/>
