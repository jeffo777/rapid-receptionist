---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import SpeedBanner from '../components/SpeedBanner.astro';
import StepsGrid from '../components/StepsGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import TrustSection from '../components/TrustSection.astro';
import TestimonialSlider from '../components/TestimonialSlider.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
import CookieConsent from '../components/CookieConsent.astro';
import channels from '../data/channels.json';
import trades from '../data/trades.json';

const steps = [
  {
    number: 1,
    title: 'We Set Everything Up',
    description: "Tell us your trade, your business name, and the services you offer. We configure your AI receptionist across your chosen channels — fully done for you. You don't lift a finger."
  },
  {
    number: 2,
    title: 'Your AI Goes Live',
    description: "From the moment we switch it on, every call, message, and enquiry is handled instantly. Your AI answers with your business name, captures lead details, and triages urgent jobs — 24/7/365."
  },
  {
    number: 3,
    title: 'You Win More Work',
    description: "Every lead is captured and sent straight to you with full details. No more missed calls, no more voicemail, no more customers calling competitors while you're on a job."
  }
];

const features = channels.map(ch => ({
  icon: ch.icon,
  name: ch.name,
  description: ch.shortDescription,
  tier: ch.tierLabel,
  href: ch.pageUrl,
}));

const faqs = [
  {
    question: "What exactly is Rapid Receptionist?",
    answer: "Rapid Receptionist is an AI-powered answering service built specifically for UK tradesmen. It answers your calls, messages, and enquiries across up to 8 channels — phone, website chat, WhatsApp, SMS, email, Facebook Messenger, Instagram DMs, and missed call text-back. It captures lead details, understands the nature of the work, assesses urgency, and escalates emergencies. Available 24/7/365, including bank holidays and weekends. Start with phone and chat at £99/month, then add any extra channels you need at £19/month each."
  },
  {
    question: "How is this different from voicemail or a virtual receptionist?",
    answer: "Voicemail is where leads go to die — 85% of callers who reach voicemail will never call back, and 80% won't even leave a message. A traditional virtual receptionist costs £200-500/month, works limited hours, and only covers phone. Rapid Receptionist answers instantly across up to 8 channels, 24/7, from just £99/month. It captures more detail than most human receptionists, never takes a sick day, and never puts a caller on hold."
  },
  {
    question: "Which trades do you support?",
    answer: `We serve 13 UK trades: ${trades.map(t => t.name).join(', ')}. Each trade gets a custom-configured AI receptionist that speaks the trade's language — it knows the difference between a rewire and a socket addition, a boiler service and a gas leak. The AI is trained with trade-specific vocabulary so your customers get a professional, knowledgeable first response.`
  },
  {
    question: "What does the AI actually say when someone calls my business?",
    answer: "Your AI receptionist answers with your business name — 'Good afternoon, thank you for calling Smith's Plumbing, how can I help you today?' It then has a natural conversation to capture the caller's name, contact details, location, and the nature of the work. It assesses whether the job is urgent or routine, and either escalates emergencies to you directly or lets the caller know you'll be in touch when you're free. It never provides quotes, diagnoses faults, or books appointments — those decisions stay with you."
  },
  {
    question: "What about channels other than phone — WhatsApp, email, social media?",
    answer: "Phone and website chat are fully conversational — the AI has a real back-and-forth exchange. The other channels (WhatsApp, SMS, email, Facebook Messenger, and Instagram DMs) operate on a one-reply model: the AI captures details from the customer's message, sends one professional response acknowledging the enquiry, and lets them know you'll be in touch. Each messaging channel is available at £19/month — pick just the ones your customers actually use."
  },
  {
    question: "What happens if a caller has a genuine emergency?",
    answer: "The AI assesses urgency during every interaction. If it detects an emergency — like a gas leak, burst pipe, electrical hazard, or a vulnerable person in danger — it escalates immediately. First, it tries to reach you directly on your mobile. If you can't be reached, it's passed to our dedicated Rapid Receptionist human operators who take over the call. Your customers never get stuck in a loop. When it matters most, a real person steps in."
  },
  {
    question: "How much does it cost and what's the catch?",
    answer: "The Core plan is £99/month and covers AI phone answering with 300 minutes of talk time plus unlimited website chat — the two channels where you lose the most leads. Need WhatsApp, SMS, email, Facebook, or Instagram too? Each extra channel is £19/month, or grab everything for £179/month with the All Channels bundle. One-time £299 setup fee covers the full done-for-you configuration. No contracts — cancel anytime. And everything is covered by a 30-day money-back guarantee."
  },
  {
    question: "Why should I trust an AI to answer my business calls?",
    answer: "Because the alternative is worse. Research shows that 62% of calls to trade businesses go unanswered, and the average tradesman loses around £24,000 a year from missed calls alone. Your customers aren't leaving voicemails — they're calling your competitor. Rapid Receptionist answers every single call, instantly, professionally, with your business name. And if the AI ever reaches its limits, a real human steps in. You're not replacing yourself — you're covering the gaps when you can't get to the phone."
  },
  {
    question: "How long does setup take?",
    answer: "Most businesses are fully live within 48 hours. We handle everything — connecting your channels, configuring the AI with your business details and services, testing every response. You tell us about your business, and we do the rest. It's a genuine done-for-you setup, not a 'here's your login, good luck' situation."
  },
  {
    question: "Can I try it before I commit?",
    answer: "We don't offer a free trial — and here's why. A trial gives you a watered-down version with limited features, which doesn't show you what the service actually does. Instead, we give you the full service from day one, configured properly for your trade, with a 30-day money-back guarantee. If you don't see a benefit within 30 days, we refund everything — the £99 monthly fee and the £299 setup fee. You see the real thing, properly set up, with zero risk."
  },
  {
    question: "How does Rapid Receptionist handle data protection and GDPR?",
    answer: "Rapid Receptionist is fully compliant with UK GDPR and the Data Protection Act 2018. All customer data captured by your AI receptionist — names, phone numbers, locations, job details — is encrypted in transit and at rest, stored on secure UK/EU-based servers, and shared only with you. We never sell, trade, or use personal data for marketing. Both you and your customers can request data deletion at any time. As the tradesman, you remain the data controller for your customer data; we act as your data processor, handling it strictly according to our data processing agreement. Our full privacy policy is available at <a href='/privacy/'>rapidreceptionist.co.uk/privacy</a>."
  }
];
---

<BaseLayout
  title="AI Receptionist for UK Tradesmen — Never Miss a Job | Rapid Receptionist"
  description="AI receptionist for UK tradesmen. Answers calls and website chat 24/7 from £99/mo. Add WhatsApp, SMS, email and social channels from £19/mo each. 30-day money-back guarantee."
  canonicalUrl="/"
>
  <Header slot="header" />

  <!-- Hero -->
  <HeroSection
    headline="The AI Receptionist Built for UK Tradesmen. Always On."
    accentWord="Always On"
    subhead="Up to 8 channels. 24/7/365. Every call answered, every message captured, every lead secured — while you're on the tools. Built for UK tradesmen who can't afford to miss work."
  />

  <!-- Speed-to-Lead Banner -->
  <SpeedBanner
    stat="78% of customers hire the first business to respond."
    text="When you're up a ladder, under a boiler, or inside a consumer unit — Rapid Receptionist makes sure that first responder is still you."
  />

  <!-- How It Works -->
  <StepsGrid steps={steps} />

  <!-- What's Included — Channels -->
  <FeatureGrid features={features} columns={3} />

  <!-- Trust Section -->
  <TrustSection />

  <!-- Testimonials -->
  <TestimonialSlider />

  <!-- FAQs -->
  <FAQAccordion faqs={faqs} />

  <!-- CTA -->
  <CTASection />

  <!-- Cookie Consent -->
  <CookieConsent />

  <Footer slot="footer" />
</BaseLayout>
