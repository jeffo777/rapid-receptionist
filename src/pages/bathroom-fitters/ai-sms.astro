---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Instant Text Reply',
    text: "A landlord texts about refitting bathrooms in three rental flats. You are plumbing in a thermostatic shower valve. The AI replies within seconds, captures all three properties, and confirms you will call back."
  },
  {
    icon: '🏗️',
    title: 'Handles Trade Texts',
    text: "Builders and property managers text rather than call. The AI captures project details — number of bathrooms, specification level, timeline — so you can respond with a professional quote."
  },
  {
    icon: '🕐',
    title: 'Active Outside Working Hours',
    text: "Homeowners text at 9pm about bathroom renovations. Landlords message at 7am about vacant properties. Every text gets a prompt, professional response."
  },
  {
    icon: '📋',
    title: 'Captures Key Details',
    text: "The AI asks about bathroom type, fixtures, room dimensions, and timeline. You get a structured brief without chasing for information."
  },
  {
    icon: '⚡',
    title: 'Speed Wins Surveys',
    text: "When a homeowner texts three bathroom fitters, the first to reply gets the home visit. Your AI responds in seconds."
  },
  {
    icon: '🎯',
    title: 'Professional SMS Presence',
    text: "Instant, well-crafted texts position your business as organised — exactly the impression you want to give before spending two weeks in someone's home."
  }
];

const faqs = [
  {
    question: "How does AI SMS work for bathroom fitters?",
    answer: "When a customer texts your business number, the AI responds instantly with a natural conversation. It captures the type of bathroom work, room size, fixture preferences, timeline, and contact details."
  },
  {
    question: "How much does AI SMS cost?",
    answer: `AI SMS is an add-on at £${pricing.addOn.price}/month on top of the Core plan (£${pricing.tiers.core.price}/month with ${pricing.tiers.core.minutes} minutes of talk time). Setup is £${pricing.setup.price} one-time, refundable within 30 days.addOn.price}/month.`
  },
  {
    question: "Can I still text customers myself?",
    answer: "Yes. The AI handles initial responses. You can continue any conversation personally once you are free."
  },
  {
    question: "Does it work with my existing number?",
    answer: "Yes. AI SMS integrates with your existing business phone number. Nothing changes for your customers."
  },
  {
    question: "How is text data protected?",
    answer: "All SMS data is managed under UK GDPR. Messages and contact details are encrypted and stored on UK and EU servers, shared only with you."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for Bathroom Fitters | Rapid Receptionist"
  description={`AI SMS for UK bathroom fitters, bathroom installers, and wet room specialists. Instant text responses to every SMS enquiry. £${pricing.addOn.price}/month add-on.`}
  canonicalUrl="/bathroom-fitters/ai-sms/"
  channelName="AI SMS"
  tradeName="Bathroom Fitter"
  tradeNamePlural="Bathroom Fitters"
  tradeSlug="bathroom-fitters"
  headline="AI SMS for Bathroom Fitters"
  accentWord="Bathroom Fitters"
  subhead={`A landlord texts about three bathroom refits in a rental block. You are siliconing a shower screen. Your AI replies in seconds, captures every property, and confirms a callback. £${pricing.addOn.price}/month add-on.`}
  scenario="It is 11:45am on a Wednesday. You are fitting a vanity unit in an en-suite — the waste pipe is connected, the taps are on, and you are carefully positioning the basin top. Your phone buzzes in your pocket. A letting agent in Birmingham has texted: 'Hi, need 3 bathrooms refitted in student HMO before September. Basic white suites, new tiling. Can you quote?' Without AI SMS, the text sits unread until you finish at 1pm. The agent texted three other fitters — one replied at 11:50am and booked a site visit for Friday. With AI SMS, the reply goes out at 11:46am: 'Thanks for getting in touch. We can certainly help with that. Can I grab the property address and your budget per bathroom?' By noon, you have a confirmed lead for three bathrooms."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/bathroom-fitters/ai-receptionist/"
  ctaHeadline="Reply to Every Bathroom Text Instantly"
  ctaSubhead={`A landlord's text could be three bathroom refits. Your AI replies in seconds. £${pricing.addOn.price}/month add-on.`}
/>
