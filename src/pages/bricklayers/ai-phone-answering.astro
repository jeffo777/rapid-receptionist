---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '⚡',
    title: 'Answers When You Cannot Hear the Phone',
    text: "Between the cement mixer, the disc cutter, and the radio, construction sites are loud. Most bricklayers never hear their phone ring during the day. The AI answers every call regardless — greeting callers with your business name and capturing what they need."
  },
  {
    icon: '🧱',
    title: 'Understands Bricklaying Enquiries',
    text: "When a caller says 'the pointing on the gable end is shot' or 'we need a brick pier rebuilding,' the AI understands the context. It captures the type of work, the scope, and the urgency — so your callback is informed and efficient."
  },
  {
    icon: '🚨',
    title: 'Escalates Structural Emergencies',
    text: "A retaining wall bowing dangerously. Brickwork cracking above a lintel. A chimney leaning after a storm. The AI recognises emergency language and escalates immediately — reaching your mobile first, then our human team if needed."
  },
  {
    icon: '🕐',
    title: 'Catches Early Morning and Evening Callers',
    text: "Homeowners often call before 8am or after 6pm — when they are home to notice the problem. These are prime leads for bricklayers. The AI catches every one, regardless of the hour."
  },
  {
    icon: '📋',
    title: 'Detailed Lead Information',
    text: "Every call is summarised: caller name, number, location, work needed, urgency. When you call back, you know whether it is a garden wall rebuild, a chimney repair, or a full extension — no wasted time asking them to repeat everything."
  },
  {
    icon: '🎯',
    title: 'Professional Greeting, Every Time',
    text: "The AI answers as your business: 'Good afternoon, thank you for calling Harris Brickwork, how can I help?' Callers hear a professional operation, not a rushed voicemail left by someone who sounds out of breath."
  }
];

const faqs = [
  {
    question: "What does the AI say when a bricklaying customer calls?",
    answer: "It greets the caller with your business name and has a natural conversation. It asks what work is needed — extension, garden wall, repointing, chimney, blockwork — where the property is, how urgent the job is, and captures the caller's contact details. The whole exchange is sent to you as a structured lead."
  },
  {
    question: "Can it handle calls from builders as well as homeowners?",
    answer: "Yes. The AI handles calls from anyone — homeowners asking about garden walls, builders looking for bricklaying subcontractors, property managers needing pointing repairs. It captures the details regardless of who is calling and sends you the lead."
  },
  {
    question: "How many minutes of phone time do I get?",
    answer: "The Core plan includes 300 minutes of AI conversation time per month. For most bricklayers, this covers the volume comfortably. Additional minutes are 20p each with no cap."
  },
  {
    question: "Does it work with my existing business number?",
    answer: "Yes. We set up call forwarding from your existing number to your Rapid Receptionist line. Your customers dial the same number — nothing changes on their end."
  },
  {
    question: "Can I still answer calls myself?",
    answer: "Absolutely. The AI only activates when you are unavailable. When you are free — between jobs, at lunch, end of day — calls come through to you as normal."
  },
  {
    question: "How is caller data protected?",
    answer: "All data is managed under UK GDPR and the Data Protection Act 2018. Names, numbers, addresses, and job details are encrypted, stored on UK and EU servers, and shared only with you. We never sell or repurpose it."
  }
];
