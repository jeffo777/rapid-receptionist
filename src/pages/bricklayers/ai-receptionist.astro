---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls about rebuilding a garden wall that collapsed in the wind. You are laying a skin of blockwork on a house extension and cannot hear the phone over the mixer. They get voicemail, assume you are unreliable, and call the next bricklayer.",
    with: "Your AI receptionist answers: 'Good morning, thank you for calling. How can I help?' It captures the wall dimensions, the property address, access details, and the customer's timeline. By your tea break, the lead is in your inbox with everything you need to quote."
  },
  {
    without: "A builder emails asking if you can price a two-storey rear extension in facing brick with soldier courses and feature panels. You are on a different site all week and do not check email until Saturday. Two other bricklayers have already submitted prices.",
    with: "The builder gets an instant acknowledgement confirming you have received the spec. You review the email Sunday evening and submit your price Monday morning — while the other bricklayers are still trying to remember which emails they have not replied to."
  },
  {
    without: "A commercial property manager WhatsApps you photos of cracked pointing on the front elevation of an office block. The message sits unread for two days while you finish a domestic job.",
    with: "The AI replies within seconds, acknowledges the photos, and captures the property address and urgency. You call back that evening with the full picture — literally."
  }
];

const specialisms = [
  {
    category: "Domestic Brickwork",
    items: ["House extensions and rear returns", "Garden walls and boundary walls", "Brick BBQs, planters, and features", "Chimney repairs and rebuilds", "Brick porch and bay window construction", "Garage and outbuilding construction"]
  },
  {
    category: "Repointing & Restoration",
    items: ["Full and partial repointing", "Lime mortar repointing for period properties", "Brick cleaning and restoration", "Lintel replacement and structural repairs", "Damp-proof course (DPC) work", "Heritage and conservation brickwork"]
  },
  {
    category: "Commercial & New Build",
    items: ["New-build housing developments", "Commercial and industrial brickwork", "Blockwork and internal skins", "Feature brickwork and soldier courses", "Retaining walls and engineered brickwork", "Subcontract brickwork for main contractors"]
  }
];

const clientTypes = [
  {
    icon: "🏠",
    title: "Domestic Homeowners",
    description: "Homeowners needing extensions built, garden walls repaired, chimneys rebuilt, or repointing done. Whether they searched for a bricklayer, a bricklaying contractor, or a local brickwork company, they want someone reliable who will actually call them back."
  },
  {
    icon: "🏗️",
    title: "Builders & Main Contractors",
    description: "Site managers and builders sourcing bricklaying subcontractors and brickwork contractors for new builds, extensions, and commercial projects. They need fast availability confirmations from reliable bricklaying firms and work to tight programme deadlines with penalties for delays."
  },
  {
    icon: "🏛️",
    title: "Conservation & Heritage Projects",
    description: "Architects, conservation officers, and homeowners with listed buildings needing specialist lime mortar repointing, brick matching, or period restoration work. These enquiries require sensitivity and expertise confirmation."
  },
  {
    icon: "🏢",
    title: "Commercial Property Managers",
    description: "Facilities managers and property companies needing pointing repairs, boundary wall rebuilds, and structural brickwork maintenance across commercial portfolios. They expect any bricklaying business or masonry contractor they contact to respond professionally and follow through."
  }
];

const faqs = [
  {
    question: "How does the AI understand bricklaying terminology?",
    answer: "During setup, your AI receptionist is configured with bricklaying vocabulary — stretcher bond, Flemish bond, soldier courses, pointing, raking out, half-brick walls, cavity walls, facing brick, engineering brick, quoins, reveals, and more. When a homeowner says 'the pointing is crumbling on the front of the house' or a builder asks about 'blockwork to the internal skin,' the AI understands and captures it correctly."
  },
  {
    question: "Can the AI handle enquiries for both domestic and commercial brickwork?",
    answer: "Yes. Whether the caller needs a garden wall rebuilt, a chimney repointed, or a two-storey extension built in facing brick with feature panels, the AI captures the details. It does not differentiate between domestic and commercial — it records what the customer describes and sends the full summary to you."
  },
  {
    question: "What happens if someone calls about an emergency — like a wall collapse?",
    answer: "The AI detects urgency. If a caller describes a collapsed retaining wall, a dangerous chimney, brickwork falling onto a public path, or structural cracking, the AI escalates immediately — trying your mobile first, then passing to our human operators if you are unreachable. Routine garden wall and extension enquiries are captured as standard leads."
  },
  {
    question: "How much does it cost for a bricklaying business or brickwork contractor?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month and includes AI phone answering (300 minutes) plus unlimited website chat. Additional channels — WhatsApp, SMS, Facebook, Instagram, email, and missed call text-back — are £${pricing.addOn.price}/month each. The All Channels bundle is £${pricing.tiers.all.price}/month. The pricing is the same whether you are a sole trader bricklayer, a bricklaying contractor with a gang, or a masonry contractor handling commercial work. There is a one-time setup fee of £${pricing.setup.price} (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a small bricklaying company or sole trader?",
    answer: "For most sole traders and small bricklaying businesses, 300 minutes covers the monthly call volume comfortably. Whether you are a one-man bricklaying contractor or a brickwork company with a gang of four, the AI handles calls you physically cannot answer. If you consistently exceed 300 minutes — perhaps during a busy summer — additional minutes are charged at 20p each with no cap."
  },
  {
    question: "Can the AI quote brickwork jobs?",
    answer: "No — and that is deliberate. Brickwork pricing depends on too many variables: brick type, bond pattern, access, foundations, height, and quantity. The AI captures the details and passes the lead to you. You handle the quoting based on your expertise and a proper site assessment."
  },
  {
    question: "How does Rapid Receptionist protect my customers' personal data?",
    answer: "All data captured — names, numbers, addresses, job details — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted in transit and at rest, stored on UK and EU servers, and shared only with you. We never sell, share, or repurpose enquiry data. You remain the data controller; we act as your data processor under a formal agreement."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for Bricklayers | Rapid Receptionist"
  description="AI receptionist for UK bricklayers, bricklaying businesses, and brickwork contractors. Answers calls, captures leads from chat, WhatsApp, Facebook and more — while you are laying brick, pointing, or on site. From £${pricing.tiers.core.price}/month."
  canonicalUrl="/bricklayers/ai-receptionist/"
  tradeName="Bricklayer"
  tradeNamePlural="Bricklayers"
  tradeSlug="bricklayers"
  headline="The Rapid Response AI Receptionist for Bricklayers"
  accentWord="Bricklayers"
  subhead="Whether you run a one-man bricklaying business or a bricklaying contractor with a full gang, you cannot stop to answer the phone mid-course. Your AI receptionist answers every call, captures every lead from chat, WhatsApp, and social media, and sends you the details while your brickwork company keeps building. From £${pricing.tiers.core.price}/month."
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Bricklaying Jobs to Missed Calls"
  ctaSubhead="Every call your bricklaying business misses is a customer calling the next brickwork contractor. From £${pricing.tiers.core.price}/month — respond first, win the work."
/>
