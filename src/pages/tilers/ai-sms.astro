---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Captures Casual Enquiries',
    text: "Neighbours see your van, friends pass on your number. They text because it feels quick. Your AI replies instantly, turning a casual text into a captured lead for your tiling business."
  },
  {
    icon: '⚡',
    title: 'Instant Professional Reply',
    text: "A text reply within seconds tells the customer your tiling company is responsive. It resets their expectation — they wait for your callback instead of texting the next tile fitter."
  },
  {
    icon: '🔇',
    title: 'No On-Site Interruptions',
    text: "You cannot safely check texts while operating a wet tile cutter. The AI handles SMS conversations throughout the day so your tiling contractor operation runs without interruption."
  },
  {
    icon: '📋',
    title: 'Full Details from Short Texts',
    text: "Even from a brief text like 'do you tile bathrooms?' the AI draws out room count, tile type, substrate preparation needs, timeline, and contact details."
  },
  {
    icon: '🕐',
    title: 'After-Hours Capture',
    text: "Texts arrive throughout the evening. The AI replies regardless — no leads lost to overnight silence."
  },
  {
    icon: '🔗',
    title: 'Pairs with Missed Call Text-Back',
    text: "Customers who miss you by phone can text back and engage with the AI. Two safety nets for your tiling business."
  }
];

const faqs = [
  {
    question: "How does AI SMS work for tilers?",
    answer: "When someone texts your business number, the AI responds instantly and has a natural text conversation. It asks about the tiling work needed, captures details, and sends you a structured lead. Works for tiling businesses of every size."
  },
  {
    question: "What kind of texts does it handle?",
    answer: "Everything from short enquiries like 'do you do splashbacks?' to detailed messages about full bathroom retiles with specific tile choices. The AI adapts to the message."
  },
  {
    question: "How much does AI SMS cost?",
    answer: `AI SMS is an add-on at £${pricing.addOn.price}/month. Same price for sole trader tilers, tiling contractors, and larger tiling companies.`
  },
  {
    question: "Can I reply myself?",
    answer: "Yes. The AI handles initial engagement. You take over when you are ready."
  },
  {
    question: "Does it use my existing number?",
    answer: "Yes. SMS routes through your Rapid Receptionist number, connected to your existing line."
  },
  {
    question: "How is text data protected?",
    answer: "All SMS data is encrypted, stored on UK and EU servers, and managed under UK GDPR."
  }
];
---

<ChannelTradeLayout
  title="AI SMS for Tilers | Rapid Receptionist"
  description="AI SMS for UK tilers, tiling contractors, tile fitters, and tiling businesses. Responds instantly to text enquiries about bathroom, kitchen, and floor tiling. £${pricing.addOn.price}/month add-on."
  canonicalUrl="/tilers/ai-sms/"
  channelName="AI SMS"
  tradeName="Tiler"
  tradeNamePlural="Tilers"
  tradeSlug="tilers"
  headline="AI SMS for Tilers"
  accentWord="Tilers"
  subhead="A neighbour sees your tiling contractor van and texts: 'Do you do kitchen floors?' Instead of that text going unread while your tiling business finishes a bathroom, your AI replies in seconds — professional, detailed, and the lead is captured."
  scenario="It is 1:45pm on a Monday. You are tiling a shower enclosure in a new-build in Altrincham — the waterproof membrane is set, the first row of tiles is going on, and timing matters. Your phone buzzes on the windowsill. A text from an unknown number: 'Hi, got your number from my neighbour on Park Road. We need the kitchen and utility room floor tiling — about 28 square metres. We have the tiles already. Are you free in the next couple of weeks?' You are mid-spread and cannot stop. Without AI SMS, you intend to reply at tea break but forget until Wednesday. By then, they have found someone else. With AI SMS, they get an instant reply: 'Thanks for your message. We would be happy to look at the kitchen and utility floor. Could you confirm the tile size and your postcode? We will arrange a callback today.' You call at 5pm, confirm the tile dimensions work with the room layout, and book a start date for the following Monday."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-sms/"
  tradePageUrl="/tilers/ai-receptionist/"
  ctaHeadline="Stop Losing Text Enquiries"
  ctaSubhead="A quick text could be 28 square metres of kitchen floor. Your AI replies instantly. £${pricing.addOn.price}/month."
/>
