  },
  {
    question: "What if a visitor asks for a tiling quote through chat?",
    answer: "The AI does not quote. Tiling prices depend on room size, tile type, substrate condition, and pattern complexity. The AI captures the details and passes the lead."
  },
  {
    question: "Is website chat included in the base price?",
    answer: `Yes. Unlimited website chat is included in the Core plan at £${pricing.tiers.core.price}/month alongside phone answering. Same price for sole trader tilers and larger tiling companies.`
  },
  {
    question: "Will it slow my website down?",
    answer: "No. The widget is lightweight and loads asynchronously — no impact on page speed or search rankings."
  },
  {
    question: "How is chat data protected?",
    answer: "All data is encrypted, stored on UK and EU servers, and managed under UK GDPR."
  }
];
