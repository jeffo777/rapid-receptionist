const benefits = [
  {
    icon: '💬',
    title: 'Converts Visitors Browsing for Tilers',
    text: "Homeowners compare multiple tiling businesses before choosing. The chat widget engages them the moment they land on your site — before they click away to the next tiling contractor."
  },
  {
    icon: '📐',
    title: 'Captures Tiling-Specific Details',
    text: "The AI asks the right questions for tiling enquiries — which rooms, wall or floor or both, tile type and size, whether the substrate is prepared, and the customer's timeline."
  },
  {
    icon: '♾️',
    title: 'Unlimited Chat Sessions',
    text: "No cap. Whether your tiling company website gets 3 chat enquiries or 30 a month, every visitor is engaged without extra charges."
  },
  {
