---
import TradeHubLayout from '../../layouts/TradeHubLayout.astro';
import pricing from '../../data/pricing.json';

const withoutWithScenarios = [
  {
    without: "A homeowner calls about retiling their bathroom after ripping out the old suite. You are on your knees in a shower cubicle setting marble mosaic tiles — concentration work that cannot be interrupted. They get voicemail, assume you are too busy, and call the next tiling business on Google.",
    with: "Your AI receptionist answers: 'Good morning, thank you for calling. How can I help?' It captures the bathroom dimensions, the tile choice, whether the walls need re-boarding, and their renovation timeline. By the time you stand up and stretch, the lead is in your inbox."
  },
  {
    without: "An interior designer emails asking if your tiling company can handle a large-format porcelain feature wall in a penthouse apartment. You are on site all week and do not check email until Friday. The designer has already booked a different tiling contractor.",
    with: "The designer gets an instant acknowledgement confirming your tiling business has received the specification. You review the brief on Friday evening — tile dimensions, layout pattern, substrate preparation — and reply with a considered proposal before Monday."
  },
  {
    without: "A landlord WhatsApps your number with photos of cracked floor tiles in a rental property kitchen. The message sits unread for three days while you finish a domestic bathroom.",
    with: "The AI replies within seconds, acknowledges the photos, and captures the property address and urgency. You call the landlord that evening and book the repair for next week."
  }
];

const specialisms = [
  {
    category: "Bathroom & Wet Room Tiling",
    items: ["Full bathroom wall and floor tiling", "Wet room tanking and tiling", "Shower enclosure and niche tiling", "Mosaic feature walls and borders", "Under-tile heating installation", "Bathroom renovation tiling"]
  },
  {
    category: "Kitchen & Floor Tiling",
    items: ["Kitchen splashback tiling", "Kitchen floor tiling — porcelain, ceramic, and natural stone", "Large-format floor tiles", "Open-plan living and dining floor tiling", "Hallway and entrance floor tiling", "Conservatory and utility room tiling"]
  },
  {
    category: "Specialist & Commercial",
    items: ["Natural stone tiling — marble, slate, travertine", "Large-format and thin porcelain panels", "Commercial and retail tiling", "Swimming pool and spa tiling", "External patio and balcony tiling", "Heritage and restoration tiling"]
  }
];

const clientTypes = [
  {
    icon: "??",
    title: "Domestic Homeowners",
    description: "Homeowners looking for a tiler, a tiling business, or a local tile fitter to handle bathroom renovations, kitchen splashbacks, and floor tiling. Whether they searched for a tiling contractor or a tiling company, they want someone who works cleanly, arrives on time, and communicates well."
  },
  {
    icon: "???",
    title: "Builders & Main Contractors",
    description: "Site managers sourcing tiling subcontractors for new-build bathrooms, kitchen installs, and commercial fit-outs. They need fast availability confirmations from reliable tiling contractors and work to tight handover schedules."
  },
  {
    icon: "??",
    title: "Interior Designers & Architects",
    description: "Designers specifying large-format porcelain, natural stone, or intricate mosaic patterns. They want a tiling company that can interpret specifications, work to exacting standards, and handle premium materials without waste."
  },
  {
    icon: "??",
    title: "Landlords & Property Managers",
    description: "Letting agents and landlords needing tile repairs, bathroom retiling between tenancies, and floor tile replacement in rental properties. They expect any tiling business they contact to respond quickly and work to tight turnaround deadlines."
  }
];

const faqs = [
  {
    question: "How does the AI understand tiling terminology?",
    answer: "During setup, your AI receptionist learns tiling-specific vocabulary — porcelain, ceramic, mosaic, natural stone, grout, adhesive, tanking, substrate preparation, large-format, herringbone, brick bond, wet room, splashback, under-tile heating, and more. When a homeowner says 'the grout in the shower has gone mouldy and the tiles are lifting,' the AI understands and captures it correctly."
  },
  {
    question: "Can the AI handle enquiries for both wall tiling and floor tiling?",
    answer: "Yes. Whether the caller needs a bathroom retile, a kitchen splashback, a full-house floor in large-format porcelain, or a natural stone patio, the AI captures the type of work, the materials discussed, and the scope. It sends you the full summary so you can quote accurately."
  },
  {
    question: "What happens if someone calls about water damage behind tiles?",
    answer: "The AI detects urgency. If a caller describes water leaking through a tiled shower wall, tiles falling off in a bathroom, or a flooded wet room, the AI escalates immediately — trying your mobile first, then passing to our human operators. Routine retiling and splashback enquiries are captured as standard leads."
  },
  {
    question: "How much does it cost for a tiling business or tiling contractor?",
    answer: `The Core plan is £${pricing.tiers.core.price}/month and includes AI phone answering (300 minutes) plus unlimited website chat. Additional channels — WhatsApp, SMS, Facebook, Instagram, email, and missed call text-back — are £${pricing.addOn.price}/month each. The pricing is the same whether you are a sole trader tiler, a tiling contractor with a team, or a tiling company handling commercial work. There is a one-time setup fee of £${pricing.setup.price} (refundable within 30 days).`
  },
  {
    question: "Is this suitable for a small tiling company or sole trader tile fitter?",
    answer: "Absolutely. Whether you are a one-man tiling business, a tile fitter with an apprentice, or a larger tiling contractor handling multiple bathrooms a week — this was built for you. Sole trader tilers are the ones on their knees in a shower cubicle when the phone rings. You cannot answer. The AI catches every call."
  },
  {
    question: "Can the AI help customers choose tiles?",
    answer: "No — and that is deliberate. Tile selection involves colour, material, size, finish, suitability, and budget — decisions that require your expertise and often a showroom visit. The AI captures what the customer is looking for and passes the lead to you."
  },
  {
    question: "How does Rapid Receptionist protect my customers' personal data?",
    answer: "All data captured — names, numbers, addresses, job details — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted in transit and at rest, stored on UK and EU servers, and shared only with you. We never sell, share, or repurpose enquiry data. You remain the data controller; we act as your data processor under a formal agreement."
  }
];
---

<TradeHubLayout
  title="Rapid Response AI Receptionist for UK Tilers | Rapid Receptionist"
  description={`AI receptionist for UK tilers, tiling businesses, tile fitters, and tiling contractors. Answers calls, captures leads from chat, WhatsApp, Facebook and more — while you are on the tools. From £${pricing.tiers.core.price}/month.`}
  canonicalUrl="/tilers/ai-receptionist/"
  tradeName="Tiler"
  tradeNamePlural="Tilers"
  tradeSlug="tilers"
  headline="The Rapid Response AI Receptionist for UK Tilers"
  accentWord="Tilers"
  subhead={`Whether you run a one-man tiling business or a tiling contractor with a full team, you cannot answer the phone while you are setting tiles. Your AI receptionist answers every call, captures every lead from chat, WhatsApp, and social media, and sends you the details while your tiling company keeps tiling. From £${pricing.tiers.core.price}/month.`}
  withoutWithScenarios={withoutWithScenarios}
  specialisms={specialisms}
  clientTypes={clientTypes}
  faqs={faqs}
  ctaHeadline="Stop Losing Tiling Jobs to Missed Calls"
  ctaSubhead={`Every call your tiling business misses is a customer calling the next tile fitter. From £${pricing.tiers.core.price}/month — respond first, win the work.`}
/>
