const benefits = [
  {
    icon: '📱',
    title: 'Receives Flat Roof Damage Photos',
    text: "Homeowners and builders WhatsApp photos of blistered GRP, split felt seams, ponding water, and delaminated EPDM edges. The AI responds within seconds, asks about the leak behaviour and roof age, and attaches every photo to your repair lead."
  },
  {
    icon: '📸',
    title: 'Wins Extension Waterproofing Jobs',
    text: "Builders completing extension decks need GRP specialists fast — the plasterer is booked, the kitchen fitter scheduled, and the flat roof must be weathertight before either can start. The first GRP firm to reply books the laminating slot."
  },
  {
    icon: '⚡',
    title: 'Captures Builder Subcontract Messages',
    text: "Builders WhatsApp GRP requests mid-project — 'extension deck is down, 22 sqm, can you GRP it next week?' The AI confirms your capability and asks about the deck material, insulation requirement, and fall direction while you cure topcoat on another roof."
  },
  {
    icon: '🌙',
    title: 'Active After Laminating Hours',
    text: "Homeowners notice flat roof problems in the evening — standing water visible from an upstairs window, a damp patch appearing during rain, or bubbled topcoat peeling at the edges. The AI captures every after-hours flat roofing concern."
  },
  {
    icon: '📋',
    title: 'Structures Quick Flat Roof Briefs',
    text: "A WhatsApp saying 'extension GRP roof leaking at the upstand, about 4 years old, 3x4m, Headington' becomes a structured repair lead with system type, failure location, age, area, and postcode."
  },
  {
    icon: '🔒',
    title: 'Professional Business Channel',
    text: "AI WhatsApp operates on your business number. Roof specifications, damage documentation, and client correspondence stay separated from personal messaging."
  }
];

const faqs = [
  {
    question: "Can the AI diagnose flat roof failure from photos?",
    answer: "Structural diagnosis is beyond the AI's scope — only a qualified flat roofer on the roof can assess delamination depth, substrate condition, and insulation saturation. However, the AI responds constructively to every photograph — acknowledging the visible damage, asking whether water enters the building during rain, the roof system age, and whether previous repairs have been attempted. Every image attaches to your lead for professional assessment during your site visit."
  },
  {
    question: "What about multi-message flat roof threads?",
    answer: "Flat roof conversations evolve naturally — a homeowner sends a photo of standing water, then a close-up of cracked topcoat, then asks about GRP versus replacing the whole roof, then confirms the extension dimensions. The AI maintains the complete thread history and compiles every piece into one consolidated flat roofing lead with system, condition, area, and project scope."
  },
  {
    question: "How much does AI WhatsApp cost for flat roofing firms?",
    answer: `WhatsApp is £${pricing.addOn.price}/month as a channel add-on. A domestic GRP flat roof typically generates £1,500 to £4,000 in revenue. A commercial single-ply re-roof generates £15,000 to £80,000. Securing one builder's extension waterproofing job through a rapid WhatsApp reply — while you consolidated CSM mat on another deck — covers the channel cost immediately.`
  },
  {
    question: "Can I take over a WhatsApp conversation?",
    answer: "Post one reply in any thread and the AI hands control to you permanently. It detects your message and withdraws. Most flat roofers let the AI gather the initial specification — roof system, failure mode, area, insulation requirement, and programme urgency — then engage to discuss the measurement visit, system recommendation, and quotation."
  },
  {
    question: "How is WhatsApp data from flat roofing enquiries protected?",
    answer: "Every WhatsApp message — flat roof photographs, property locations, membrane specifications, insulation details, and sender contact information — is encrypted and stored on UK and EU servers under UK GDPR. Your data stays exclusively with you. No roof details reach competing flat roofers or are used for any secondary purpose."
  }
];
