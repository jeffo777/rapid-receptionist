const benefits = [
  {
    icon: '📱',
    title: 'Five-Second Recovery',
    text: "A homeowner calls about carpet fitting for three bedrooms. You are gluing down LVT and cannot answer. Within five seconds of the missed call, they receive a text from your business: 'Sorry I missed your call — I am on a job. How can I help?' The lead stays warm."
  },
  {
    icon: '🔄',
    title: 'Turns Missed Calls into Conversations',
    text: "Most callers who reach voicemail do not leave a message — they call the next flooring company. A text response changes the dynamic entirely. They reply with what they need and you have a text conversation on your terms."
  },
  {
    icon: '🕐',
    title: 'Works After Hours Too',
    text: "A homeowner calls at 8:30pm browsing flooring options after dinner. You do not answer. Five seconds later, they receive a text. They reply with 'LVT for kitchen and hallway, about 30 sqm.' By 8:35pm, you have a lead that would otherwise have disappeared."
  },
  {
    icon: '⚡',
    title: 'Fastest Response in the Trade',
    text: "Five seconds. That is faster than any competitor can physically pick up their phone. The instant text response positions your flooring business as responsive and professional — even when you are literally on your hands and knees."
  },
  {
    icon: '📋',
    title: 'Captures Leads Without Interrupting',
    text: "You do not need to stop what you are doing. The text goes out automatically. The customer replies at their convenience. You review the text thread during your break and call back with all the details in front of you."
  },
  {
    icon: '💰',
    title: 'Costs Less Than One Lost Job',
    text: "One missed flooring enquiry — a whole-house carpet fitting, an LVT installation for a developer — easily exceeds the monthly cost of this service. Missed call text-back pays for itself with a single recovered lead."
  }
];

const faqs = [
  {
    question: "How does missed call text-back work for flooring companies?",
    answer: "When a call to your business number goes unanswered, the system automatically sends a text message to the caller within five seconds. The text is personalised with your business name and invites them to describe what they need. Most callers reply by text, creating a lead you can follow up at your convenience."
  },
  {
    question: "What does the text message say?",
    answer: "The message is customised for your business — something like: 'Hi, this is [Your Flooring Business]. Sorry I missed your call — I am currently on a job. If you can let me know what you need, I will get back to you as soon as possible.' The wording is set during your onboarding and can be adjusted at any time."
  },
  {
    question: "What if the caller does not reply to the text?",
    answer: "You still have their phone number from the missed call log. The text serves as an immediate touchpoint that keeps your business front of mind. Even if they do not reply immediately, they know you tried to respond — which is more than most flooring companies do."
  },
  {
    question: "How much does missed call text-back cost?",
    answer: `Missed call text-back is an add-on at £${pricing.addOn.price}/month, available on any plan. Pair it with Starter (£${pricing.tiers.core.price}/month) or Core (£${pricing.tiers.core.price}/month), or get everything in the All Channels bundle at £${pricing.addOn.price}/month.`
  },
  {
    question: "Does it work with my existing phone number?",
    answer: "Yes. Missed call text-back integrates with your existing business number. Callers dial the same number they always have — the text response happens automatically in the background."
  },
  {
    question: "How is caller data protected?",
    answer: "All data from missed call text-back — phone numbers, text messages, and conversation content — is managed under UK GDPR and the Data Protection Act 2018. Data is encrypted, stored on UK and EU servers, and shared only with you."
  }
];
