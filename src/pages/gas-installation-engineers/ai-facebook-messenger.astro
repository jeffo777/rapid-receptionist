const benefits = [
  {
    icon: '💬',
    title: 'Converts Boiler Installation Content',
    text: "Boiler installations are visually reassuring — a dated back boiler ripped out, a sleek modern combi mounted on the wall, neat copper pipework, and a fresh Benchmark certificate. When a homeowner messages about their own failing boiler, the AI captures an installation lead."
  },
  {
    icon: '📸',
    title: 'Handles Emergency Gas Messages',
    text: "Homeowners message about gas smells, boiler lockouts, and carbon monoxide alarm activations — 'is this dangerous?' The AI responds immediately, asks whether the ECV has been turned off and windows opened, and builds a priority safety lead."
  },
  {
    icon: '⚡',
    title: 'Captures Landlord CP12 Requests',
    text: "Letting agents see your Gas Safe work on Facebook and message — 'need a reliable gas engineer for our rental portfolio, previous one retired.' The AI captures the portfolio size and certificate schedule."
  },
  {
    icon: '🕐',
    title: 'Active When Boilers Fail',
    text: "Boilers break down in the evening. Homeowners search Facebook for Gas Safe engineers while the house cools. A message about a flashing fault code at 9pm represents a customer willing to pay premium for morning attendance."
  },
  {
    icon: '📋',
    title: 'Qualifies Gas Project Category',
    text: "Messenger conversations begin with 'how much to replace a boiler?' The AI asks about the existing boiler, the property size, the system type, and the replacement brand preference — building a survey-ready specification."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Before-and-After',
    text: "Every old back boiler removed, every modern combi installed with neat copper pipework, and every Benchmark certificate displayed generates enquiries from homeowners whose boilers are approaching end-of-life."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my gas firm?",
    answer: "We connect Messenger to your Business page during onboarding — the whole process takes about two minutes on the call with no technical configuration from you. Gas Safe firms posting boiler installation before-and-afters, back boiler conversion sequences, and neat flue termination close-ups typically already have an active page, so yours is very likely ready to link up straight away."
  },
  {
    question: "What gas enquiries come through Messenger?",
    answer: "Homeowners with failing boilers seeking replacement quotes after viewing your installations. Landlords needing CP12 programmes for rental portfolios. Builders requiring gas connections on house extensions. Restaurant owners needing commercial gas installation for kitchen equipment. Each has studied your Gas Safe work quality through your Facebook presence."
  },
  {
    question: "How fast does the AI reply to gas messages?",
    answer: "Gas Messenger enquiries generate responses within seconds of arrival. Facebook's activity status shows your gas firm is immediately available. A homeowner whose boiler has failed on a freezing evening — searching Facebook frantically for a local Gas Safe engineer — requires instant engagement, not an abandoned inbox that implies the firm is no longer active."
  },
  {
    question: "What does Messenger cost for gas engineers?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. A boiler installation generates £2,000 to £4,500. One homeowner's Worcester Greenstar installation — triggered when she messaged about her back boiler matching your before photo — covers the annual channel cost from a single job.`
  },
  {
    question: "Can I continue Messenger conversations personally?",
    answer: "Reply once in any thread and the AI transfers control to you permanently. Most gas engineers let the AI extract the initial specification — existing boiler model, system type, property size, and urgency — then step in to discuss manufacturer preferences, warranty tiers, and the survey date."
  },
  {
    question: "How is Messenger data from gas queries protected?",
    answer: "All Messenger conversations, boiler fault code photos, property addresses, Gas Safe references, CP12 schedules, and sender contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No gas project details reach competitors or third-party lead generators."
  }
];
