const benefits = [
  {
    icon: '📷',
    title: 'Converts Power Float Reels',
    text: "Power float reels are hypnotic — the machine circling, the blade tilting, the wet concrete surface transforming into a dense polished finish under the float pans. When followers DM about their own floor project, the AI captures the booking instantly."
  },
  {
    icon: '🎯',
    title: 'Reaches Quality-Focused Contractors',
    text: "Instagram attracts builders and developers who value craftsmanship. A developer DM-ing after watching your float technique is a pre-qualified lead from someone who already trusts your finish standard and wants that quality on their project."
  },
  {
    icon: '📱',
    title: 'Handles Slab Photo DMs',
    text: "Builders DM photos of prepared sub-bases and formwork — 'ready for concrete, can you pour this?' The AI asks about the volume, grade, reinforcement, and placement method, converting a visual enquiry into a structured pour booking."
  },
  {
    icon: '🌙',
    title: 'Catches Late-Night Builder Planning',
    text: "Builders scroll through concrete portfolios after hours, shortlisting firms for upcoming pours. DMs at 11pm about 'foundation concrete for a house extension next month' are genuine bookings from contractors actively scheduling their programme."
  },
  {
    icon: '📋',
    title: 'Structures Casual DMs',
    text: "DMs about concrete begin brief — 'how much for a concrete patio?' The AI asks about the area, sub-base condition, desired finish (tamped, floated, exposed aggregate), and access — channelling casual interest into a quotable specification."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Pour Post',
    text: "Every power float sequence, boom pump placement, exposed aggregate reveal, and polished floor close-up generates potential bookings from contractors and homeowners with a similar project in mind."
  }
];

const faqs = [
  {
    question: "What Instagram account type do I need?",
    answer: "A Business or Creator profile linked to your Facebook page — converted from your settings at no cost in under two minutes. Concrete companies producing visual pour content gain professional audience insights and reach tools that amplify every power float video and finished slab showcase across a wider contractor audience."
  },
  {
    question: "What concrete DMs come through Instagram?",
    answer: "Primarily builders planning upcoming pours and homeowners wanting driveways, patios, and bases. Common DMs include 'can you pour a foundation next week?', 'how much for a polished concrete floor in my extension?', and 'do you do exposed aggregate driveways?' Each sender has already viewed your work portfolio and has a specific project with a real timeline in mind."
  },
  {
    question: "How quickly does the AI reply to concrete DMs?",
    answer: "The response lands in the sender's inbox within seconds of the DM arriving. Instagram read receipts confirm your company is engaged and responding. Builders comparing concrete teams for a programme-critical pour — where delaying the slab delays the entire build — book the firm that responds first with relevant specification questions."
  },
  {
    question: "What does Instagram DMs cost for concrete companies?",
    answer: `Instagram DMs is £${pricing.addOn.price}/month as a channel add-on. Concrete values range from £250 domestic bases to £100,000 warehouse floor contracts. One developer's multi-bay commercial floor, secured through a rapid DM while competing firms' messages sat unread overnight, transforms the monthly outlay into your strongest lead channel.`
  },
  {
    question: "Can I reply to DMs personally?",
    answer: "Drop one reply into any DM thread and the conversation becomes yours permanently. The AI detects your message and steps aside. Most concrete firms let the AI capture the opening details — slab area, grade, reinforcement, finish type, pump requirement, and pour date — then engage directly to discuss wagon scheduling, crew availability, and pricing."
  },
  {
    question: "Is DM data from concrete queries private?",
    answer: "All Instagram DM content — site photographs, pour locations, slab specifications, delivery schedules, and sender contact details — is encrypted and stored on UK and EU servers under UK GDPR. Nothing is shared with competing concrete firms, passed to ready-mix suppliers, or made available to any third party."
  }
];
