  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/concrete-specialists/ai-receptionist/"
  ctaHeadline="Turn Night Pour Time-Lapses into Distribution Hub Floor Bookings"
  ctaSubhead={`A ninety-second night pour reel earns one hundred and ninety likes. AI Messenger converts every logistics developer message into a slab booking with FM2 tolerance and racking coordination. Add-on at £${pricing.addOn.price}/month.`}
/>
