---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Power Float and Pour Videos',
    text: "Concrete finishing videos are mesmerising on Facebook — ride-on floats gliding across warehouse slabs, boom pumps swinging concrete into formwork, freshly floated surfaces gleaming under floodlights. When a contractor messages about their own slab, the AI captures the project."
  },
  {
    icon: '📸',
    title: 'Handles Site Photo Messages',
    text: "Builders message with photos of prepared sub-bases and excavated trenches — 'can you pour this foundation next week?' The AI asks about the concrete volume, grade, and placement method, converting the visual enquiry into a pour booking."
  },
  {
    icon: '⚡',
    title: 'Captures Local Contractor Referrals',
    text: "When you pour a neighbour's driveway or a builder's extension slab and they tag your company, their colleagues message: 'Can you do a similar slab for my project?' The AI converts every referral into a concrete lead."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Planning',
    text: "Builders browse Facebook after site hours, confirming concrete requirements for upcoming pours. Messages at 8pm about 'concrete for a foundation next Tuesday' carry genuine booking intent from contractors who have already seen your work."
  },
  {
    icon: '📋',
    title: 'Structures Quick Pour Requests',
    text: "Messenger conversations about concrete start simply — 'how much to concrete my driveway?' The AI asks about the area, current surface, sub-base condition, desired finish, and access for the mixer."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Pour Video',
    text: "Every power float time-lapse, boom pump placement sequence, and polished floor reveal posted to Facebook can generate a concrete booking from a contractor or homeowner with a similar project."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my concrete company?",
    answer: "We link Messenger to your page during onboarding — if you do not have a Business page, our team sets one up with you on the call. The whole process takes about ten minutes and there is no technical work on your end. Concrete companies posting pour progress time-lapses, power float sequences, and polished floor close-ups typically already run Business pages, so yours may be ready to connect immediately."
  },
  {
    question: "What concrete enquiries arrive through Messenger?",
    answer: "Predominantly builders and homeowners. Builders message about upcoming foundation pours, floor slabs, and oversite concrete — 'can you pour 15 cubic metres into strip foundations next week?' Homeowners ask about domestic slabs — 'how much to concrete my back garden for a patio?' Both are pre-qualified leads from people who have reviewed your work and need concrete for a specific project with a real timeline."
  },
  {
    question: "How quickly does the AI reply on Messenger?",
    answer: "Your reply reaches the sender within seconds of their message landing. Facebook displays your company as actively responding. Builders comparing concrete firms for a programme-critical pour — where a one-day slip pushes the bricklayers back a week — award the booking to the team that confirms availability first."
  },
  {
    question: "What does Messenger cost for concrete companies?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. Concrete projects span from £250 domestic shed bases to £80,000 multi-bay warehouse floor programmes. A single developer's warehouse floor booking, secured through a prompt Messenger reply while two competitors sat unanswered overnight, generates revenue that eclipses the channel cost for the foreseeable future.`
  },
  {
    question: "Can I continue Messenger conversations myself?",
    answer: "Post your own reply in any Messenger thread and the AI yields control permanently. It recognises your response and steps back. Most concrete firms let the AI gather the initial pour scope — volume, grade, reinforcement, pump requirement, finish, and date — then follow up to discuss wagon scheduling, pump logistics, and pricing."
  },
  {
    question: "How is Messenger data from concrete queries protected?",
    answer: "All Messenger conversations, site photographs, pour locations, concrete specifications, delivery details, and contact information are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No pour details are disclosed to competing concrete firms, shared with ready-mix suppliers, or sold to any third party."
  }
];
