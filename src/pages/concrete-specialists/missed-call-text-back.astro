---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Catches Calls from the Slab',
    text: "When you are running the power float, vibrating around rebar cages, or directing the boom pump operator — both hands occupied, concrete setting under your feet — Missed Call Text Back sends a branded text to every unanswered caller within seconds."
  },
  {
    icon: '⏱️',
    title: 'Holds Programme-Critical Builders',
    text: "A main contractor needing a foundation pour confirmed for Wednesday gets voicemail from two concrete firms and a text from yours: 'Thanks for calling — we are on an active concrete pour and will return your call this afternoon.' That contractor holds your slot in the programme."
  },
  {
    icon: '🏷️',
    title: 'Professional Concrete Operator Image',
    text: "An instant branded text from a concrete specialist signals an organised, professionally run operation — the type of concrete team that main contractors trust with programme-critical structural pours on multi-million-pound developments."
  },
  {
    icon: '📊',
    title: 'Essential During Pour Windows',
    text: "Concrete pours consume entire shifts — from the first wagon arriving to the final float pass. Every person on your crew is committed to placing, vibrating, and finishing. Missed Call Text Back captures every opportunity during your most time-critical work."
  },
  {
    icon: '📋',
    title: 'Captures Reply Pour Details',
    text: "Callers reply with scope — 'need 18m3 C25 into strip foundations Thursday morning, OX2, pump access required.' Those replies arrive on your dashboard with volume, grade, placement, and timing before you step off the slab."
  },
  {
    icon: '🔄',
    title: 'Pairs with AI Phone Answering',
    text: "Phone Answering conducts full concrete conversations and builds detailed pour briefs. Missed Call Text Back catches edge cases — a call during the loudest vibrating phase, a mobile signal lost inside formwork, or a caller hanging up before handover. Together, no concrete lead slips through."
  }
];

const faqs = [
  {
    question: "When does the missed call text send?",
    answer: "Within seconds of the call going unanswered — before the builder dials the next concrete firm on his list. During full-day pours where your phone sits in the van from 6am to 6pm, this automatic text keeps your concrete company commercially active without interrupting the placing, vibrating, and floating sequence."
  },
  {
    question: "What does the text message say?",
    answer: "You compose it during setup and revise it whenever you like. An effective concrete message reads: 'Thank you for calling [company name]. We are currently on an active concrete pour. We will return your call at the earliest opportunity. Reply with your concrete requirements for a faster response.' The wording conveys your hands-on expertise and on-site commitment."
  },
  {
    question: "Does this replace AI Phone Answering?",
    answer: "They work as layered safeguards. Phone Answering conducts full conversations — establishing the concrete grade, volume, reinforcement, placement method, flatness requirement, and pour date. Missed Call Text Back catches uncommon bypass scenarios — a one-ring disconnect during a noisy vibrating phase, a mobile signal lost inside steel formwork, or a call at the precise moment of system handover. Both active together means no concrete booking is permanently lost."
  },
  {
    question: "How much does Missed Call Text Back cost?",
    answer: `This add-on is £${pricing.addOn.price}/month. Concrete project values range from £250 domestic bases to £100,000 commercial floor programmes. Recovering one missed call from a main contractor — who needed a power floated warehouse slab confirmed for next Monday — through a branded text reply transforms a modest monthly outlay into your highest-value recovery channel.`
  },
  {
    question: "Do callers reply to the text?",
    answer: "Builders and contractors under programme pressure reply readily. Typical replies include the concrete volume, grade, foundation type, placement date, pump requirement, and postcode. This information arrives on your dashboard before the last float pass finishes, giving you full context for a priority callback the moment you step off the slab."
  },
  {
    question: "How is missed call data stored?",
    answer: "Phone numbers, text replies containing site locations, concrete volumes, grade specifications, pour schedules, and contact details are encrypted and held on UK and EU servers under UK GDPR. Only you can access the data. Nothing is shared with competing concrete firms or any third party."
  }
];
---

<ChannelTradeLayout
  title="Missed Call Text Back for UK Concrete Specialists | Rapid Receptionist"
  description={`Missed Call Text Back for UK concrete specialists. Automatically texts callers while you power float the slab — keeps foundation pours and warehouse floor bookings warm. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/concrete-specialists/missed-call-text-back/"
  channelName="Missed Call Text Back"
  tradeName="Concrete Specialist"
  tradeNamePlural="Concrete Specialists"
  tradeSlug="concrete-specialists"
  headline="Missed Call Text Back for UK Concrete Specialist Companies"
  accentWord="Concrete"
  subhead="It is 7:15am on a Tuesday. Your crew has just started a foundation pour on a new-build house in Marston — 24 cubic metres of C25 flowing through a line pump into the strip foundation formwork, the first of three wagons reversing into position, your labourer directing the pump hose while you vibrate the concrete around the starter bars and check the levels against the profile boards. The pour will run until midday. Four calls come in between 7:30 and 11am. Your phone is in the van cab forty metres away. Without Missed Call Text Back, two voicemails — 'need concrete for a slab' and 'checking your availability' — and two hang-ups. With it, all four receive texts within seconds. The first replies at 7:45: 'Builder here — got a ground-floor oversite to pour on a 5-bed detached in Wootton. 95 sqm, C25, A142 mesh, tamped finish, DPM already down. Need it poured Friday. Pump required — chute won't reach. Can you confirm crew and pump?' At the lunch break you read the reply and phone. You confirm Friday, order the wagons, and book the pump."
  scenario="It is 3pm on a Friday in January. Your team has been on a commercial pour since 5am — a 700-square-metre retail unit floor slab, C30 mesh-reinforced, placed by boom pump and power floated. The slab is now at the critical floating stage — the surface moisture has evaporated and you have a two-hour window to achieve the FM2 finish before the concrete hardens beyond floating. Every person is on the slab — two ride-on floats, two edge finishers, one person checking levels. Five missed calls between noon and 3pm. Without Missed Call Text Back, you check at 5:30pm in the van: five unknowns, one voicemail — 'can you price a warehouse floor?' — four lost forever. With Missed Call Text Back, all five received texts. Reply one: 'developer — need 1,400 sqm warehouse floor, C35 fibre, power float FM2, Witney, pour in 4 weeks.' Reply two: 'builder in Headington — foundation pour, 16m3 C25, trench fill, Wednesday.' Reply three: 'homeowner — concrete driveway, about 30 sqm, OX3.' Reply four: 'groundworker — need blinding concrete, 4m3 C20, tomorrow if possible, Cowley.' Reply five: 'architect — polished concrete floor for a house extension, 70 sqm, OX2.' Five leads. Five concrete projects from shed bases to a 1,400 sqm warehouse. Saturday morning you prioritise the warehouse developer and the architect's polished floor."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/missed-call-text-back/"
  tradePageUrl="/concrete-specialists/ai-receptionist/"
  ctaHeadline="Recover Five Concrete Leads from One January Power Float Friday"
  ctaSubhead={`While you floated the retail unit slab, five callers missed you. Five texts went out. Five replied. A warehouse floor, a foundation, a driveway, blinding concrete, and a polished extension. Add-on at £${pricing.addOn.price}/month.`}
/>
