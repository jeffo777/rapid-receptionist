import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Receives Design Reference Photos',
    text: "Homeowners WhatsApp photos of metalwork they admire — Pinterest screenshots, hotel staircase shots, café railing close-ups — alongside photos of their own space. The AI responds instantly, asks about dimensions and material preferences, and attaches every image to your lead."
  },
  {
    icon: '📸',
    title: 'Wins the Design Inspiration Moment',
    text: "A homeowner photographs a beautiful handrail in a restaurant and immediately WhatsApps fabricators: 'Can you make something like this?' The first workshop to respond with intelligent questions about materials and dimensions secures the consultation."
  },
  {
    icon: '⚡',
    title: 'Captures Contractor Subcontract Messages',
    text: "Main contractors WhatsApp fabrication requirements: 'Need 4 RSJs and connection plates for a loft conversion — mild steel, S275, CE marked. Can you quote?' The AI captures the steel specification and programme while you weld in the workshop."
  },
  {
    icon: '🌙',
    title: 'Active After Workshop Hours',
    text: "Homeowners plan metalwork projects in the evening — measuring door openings for gates, photographing spaces for railings, and sending design references. Architects forward specifications after leaving the office. The AI catches every after-hours message."
  },
  {
    icon: '📋',
    title: 'Structures Quick Fabrication Requests',
    text: "A WhatsApp saying 'need stainless balustrade for decking, about 6m run, 1100mm high, glass panels, brushed finish' becomes a structured lead with material, dimensions, infill type, and finish specified."
  },
  {
    icon: '🔒',
    title: 'Professional Workshop Channel',
    text: "AI WhatsApp uses your business number. Conversations about metalwork design, structural specifications, and project pricing stay professional and separated from personal messages."
  }
];

const faqs = [
  {
    question: "Can the AI interpret metalwork design reference photos?",
    answer: "The AI does not produce design assessments from photographs, but it responds effectively — acknowledging that the images show the styles and finishes the client is interested in — and asks the questions fabricators need: the intended location, the material preference, key dimensions (height, length, width), the desired finish, and any fixings or automation requirements. Every reference image is attached to your lead for your own design review."
  },
  {
    question: "What about evolving WhatsApp design conversations?",
    answer: "Metalwork design conversations develop through WhatsApp — a homeowner sends a gate photo, then questions about automation, then asks about matching railings for the front path, then sends a sketch of what they are imagining. The AI maintains the complete thread and your lead summary consolidates every message, photo, and design evolution into one comprehensive brief."
  },
  {
    question: "How much does AI WhatsApp cost for fabrication workshops?",
    answer: `WhatsApp is available at £${pricing.addOn.price}/month as a channel add-on. Bespoke fabrication commissions range from £800 gate sets to £25,000 feature staircases. Capturing one architect's balustrade specification or one homeowner's staircase inquiry through a rapid WhatsApp response — while your visor was down and both hands held the torch — pays for the channel many times over.`
  },
  {
    question: "Can I take over a WhatsApp conversation?",
    answer: "Type your own message in any thread and the AI transfers the conversation to you instantly. Most fabricators let the AI handle the initial capture — metalwork type, material, dimensions, finish preference, location — then take over personally to discuss design options, share similar completed projects, and arrange the site survey or workshop consultation."
  },
  {
    question: "How is WhatsApp data from fabrication enquiries kept secure?",
    answer: "All WhatsApp messages — design references, property addresses, architectural specifications, dimension details, and contact information — are encrypted and stored on UK and EU servers under UK GDPR. Data goes only to you and is never shared with competing fabricators or used for any other purpose."
  }
];
