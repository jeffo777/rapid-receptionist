<ChannelTradeLayout
  title="AI Instagram DMs for UK Security System Contractors | Rapid Receptionist"
  description={`AI Instagram DMs for UK security system contractors. Converts 4K night footage reels and alarm installation content into survey bookings and monitoring contracts. Add-on at £${pricing.addOn.price}/month.`}
