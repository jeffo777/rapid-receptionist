const benefits = [
  {
    icon: '💬',
    title: 'Engages Crime-Triggered Visitors',
    text: "Homeowners search for alarm installers after break-ins, attempted burglaries, and neighbourhood crime alerts. Chat captures them on your website at peak vulnerability — when the decision to invest in security is already made."
  },
  {
    icon: '📐',
    title: 'Qualifies Security Scope Online',
    text: "Through conversation, the AI determines whether the visitor needs an intruder alarm, CCTV, access control, a door entry system, or an integrated package. You receive a correctly categorised security lead."
  },
  {
    icon: '🕐',
    title: 'Converts Evening Alarm Enquiries',
    text: "Homeowners browse security systems after dark — reading reviews, comparing alarm grades, and checking whether their insurance demands NSI or SSAIB approval. Chat captures the enquiry when the security concern is most vivid."
  },
  {
    icon: '📊',
    title: 'Explains Security Options to Visitors',
    text: "Visitors ask 'what grade alarm do I need?', 'IP or analogue CCTV?', 'do I need monitoring?' The AI responds from your profile — comparing Grade 2 versus Grade 3, explaining police response requirements, and discussing camera resolution options."
  },
  {
    icon: '🔗',
    title: 'Works Alongside Installation Gallery',
    text: "Your website shows installed CCTV systems, neat cable runs, and professional alarm panels. Chat converts visitors who admire your NSI-approved workmanship into booked security surveys."
  },
  {
    icon: '✅',
    title: 'Included at No Extra Cost',
    text: `Website chat is included with phone answering at £${pricing.tiers.core.price}/month. Unlimited security conversations — from post-burglary alarm consultations to campus-wide integrated system tenders.`
  }
];

const faqs = [
  {
    question: "How do I install chat on my security website?",
    answer: "Onboarding provides a JavaScript snippet for your website header — WordPress, Wix, Squarespace, or custom HTML. The branded widget appears on every page instantly. Security firms with CCTV installation galleries and NSI or SSAIB accreditation badges displayed prominently experience strong chat engagement from visitors who have already assessed your approved installer credentials and want to discuss their property protection requirements."
  },
  {
    question: "Can the AI explain alarm grades to visitors?",
    answer: "Your NSI or SSAIB approved company profile configures the AI with your alarm grading expertise. When a visitor types 'what grade alarm do I need for insurance?' the AI explains that most domestic and small commercial policies require a Grade 2 system installed by an NSI or SSAIB approved contractor, while higher-risk premises may require Grade 3 — all while capturing the property type, the insurer name, and the policy requirements."
  },
  {
    question: "What does chat capture from security visitors?",
    answer: "The AI records the security requirement (alarm, CCTV, access control, intercom, or integrated), the trigger event (break-in, attempted burglary, insurance requirement, or commercial upgrade), the property type and size, any existing systems, the monitoring preference, and the visitor's contact details for your security survey follow-up."
  },
  {
    question: "Does chat slow my security website?",
    answer: "NSI accreditation badges, CCTV installation photography, alarm brand logos, and Trustpilot review feeds load at their full speed before the chat component activates. The lightweight widget initialises asynchronously after all page content renders. No measurable performance impact on page speed or search engine positioning."
  },
  {
    question: "Is website chat a separate charge?",
    answer: `Chat comes as part of the phone answering package at £${pricing.tiers.core.price}/month — zero additional cost. Security firms gain overlapping protection: weekday phone calls from facilities managers commissioning CCTV and access control upgrades, combined with evening and weekend chats from homeowners whose security concerns intensify after dark.`
  },
  {
    question: "How is visitor data from security queries handled?",
    answer: "Chat conversations containing premises addresses, existing alarm configurations, CCTV positions, access control layouts, vulnerability information, and visitor contact details are encrypted and stored on UK and EU servers under UK GDPR. Leads go exclusively to you. No security project details reach competitors or third-party lead aggregators."
  }
];
