  channelPageUrl="/construction-trades/ai-website-chat/"
  tradePageUrl="/security-system-contractors/ai-receptionist/"
  ctaHeadline="Win the Summertown Post-Burglary System While She Secures the Padlock"
  ctaSubhead={`A homeowner with a splintered back door, a police crime number, and zero security needs an NSI Gold contractor at 11:30pm. Chat captures the alarm, CCTV, doorbell, and lighting scope. Included at £${pricing.tiers.core.price}/month.`}
