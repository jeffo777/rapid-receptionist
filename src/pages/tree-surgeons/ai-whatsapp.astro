---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📱',
    title: 'Responds to Storm Damage Photos Instantly',
    text: "After a storm, WhatsApp floods with photos — trees on roofs, branches through conservatories, trunks split at the union, roots heaving out of saturated ground. You are on your first clearance job. The AI responds to every message within seconds, captures the damage and location, and delivers a prioritised lead list ranked by severity."
  },
  {
    icon: '📸',
    title: 'Processes Tree Photos for Assessment',
    text: "Homeowners send photos of the tree they want removed, reduced, or assessed — root lifting paving, a leaning trunk, fungal brackets at the base, or a canopy blocking all light. The AI acknowledges the images, asks about the tree height and species, and attaches the photos to your lead. Pre-visit photo assessment saves you wasted journeys."
  },
  {
    icon: '⚡',
    title: 'Wins the Three-Quote Race',
    text: "Homeowners typically WhatsApp three tree surgeons the same tree photo. The first professional response almost always secures the site visit. While you are in the canopy with a chainsaw, the AI ensures your reply arrives before competitors have even seen theirs."
  },
  {
    icon: '🌙',
    title: 'Captures Weekend Garden Discoveries',
    text: "Homeowners are in their gardens at weekends and notice the tree problems — the branch overhanging the neighbour's garden, the stump they want ground out, the hedge that has grown out of control. Weekend WhatsApps are high-quality domestic leads."
  },
  {
    icon: '📋',
    title: 'Structures Informal Messages',
    text: "A WhatsApp saying 'massive tree at back needs taking out, cant get any light, OX14' becomes a structured lead: tree removal, light obstruction, OX14 postcode. The AI adds species, approximate height, and access details through follow-ups."
  },
  {
    icon: '🔒',
    title: 'Professional Business Number',
    text: "AI WhatsApp runs through your business line. Clients message a professional number and receive a professional reply. Your personal WhatsApp stays private."
  }
];

const faqs = [
  {
    question: "Can the AI assess tree photos sent over WhatsApp?",
    answer: "The AI does not diagnose tree conditions, but it acknowledges photos effectively and asks the right follow-ups — species, approximate height, proximity to buildings, access for machinery, and urgency. Every image is attached to your lead summary so you can make your own assessment before the callback. Photos of fungal brackets, splits, or lean give you critical advance information that often determines what equipment to bring."
  },
  {
    question: "What about storm emergency WhatsApps?",
    answer: "Storm damage WhatsApps — 'tree just fallen on the garage roof, kids at home, help ASAP' — are flagged as urgent in your lead queue. The AI responds immediately, captures the hazard and address, and your priority notification reaches you within seconds. During storm events, the AI handles dozens of simultaneous WhatsApp threads while you work through the first clearance."
  },
  {
    question: "How much does AI WhatsApp cost for tree surgery?",
    answer: `The WhatsApp add-on costs £${pricing.addOn.price}/month alongside your Core plan. For tree surgery companies where storm-season WhatsApp volumes spike dramatically and each emergency clearance is worth £300 to £3,000, this channel captures the work that arrives while you are physically up another tree. One captured storm job pays for the add-on for years.`
  },
  {
    question: "Can I resume a WhatsApp conversation myself?",
    answer: "Typing a message directly in any WhatsApp thread hands control to you immediately — the AI steps aside. Most tree surgeons let the AI handle the initial capture and follow up personally to discuss species identification, access logistics, and pricing."
  },
  {
    question: "Is WhatsApp data secure?",
    answer: "All WhatsApp exchanges — tree photos, property addresses, damage descriptions, contact details — are encrypted and stored on UK and EU servers under UK GDPR. Data is delivered exclusively to you and never shared, sold, or repurposed."
  }
];
---

<ChannelTradeLayout
  title="AI WhatsApp for UK Tree Surgeons | Rapid Receptionist"
