const benefits = [
  {
    icon: '📱',
    title: 'Responds to Loft Photos Instantly',
    text: "Homeowners WhatsApp photos taken from inside their loft — tape measure showing headroom, the roof structure, existing water tanks, chimney breasts blocking potential layouts. The AI responds within seconds, asks about the conversion they want, and attaches every image to your lead."
  },
  {
    icon: '📸',
    title: 'Wins the Saturday Comparison',
    text: "Saturday morning is decision time for loft conversions. Homeowners WhatsApp three specialists with their loft measurements and photos. The company that responds first with informed questions — rather than Monday morning — wins the survey booking."
  },
  {
    icon: '⚡',
    title: 'Captures Neighbour Referrals',
    text: "A neighbour sees your scaffolding go up and watches the dormer take shape over two weeks. She WhatsApps: 'Love what you are doing at number 12 — can you do the same to ours?' The AI captures the referral while you are on the scaffold at number 12."
  },
  {
    icon: '🌙',
    title: 'Catches Post-Measurement Enthusiasm',
    text: "A homeowner climbs into the loft at 8pm, confirms there is enough headroom, climbs down excited, and WhatsApps a loft company at 8:30pm. That is genuine commitment. The AI captures it before the enthusiasm fades."
  },
  {
    icon: '📋',
    title: 'Structures Loft Descriptions',
    text: "A WhatsApp saying 'hip roof, 3-bed semi, want to go hip-to-gable, need two bedrooms up there, OX3' becomes a structured lead. The AI adds planning status and timeline through follow-up questions."
  },
  {
    icon: '🔒',
    title: 'Professional Business Line',
    text: "AI WhatsApp uses your business number. Client conversations stay on a professional channel. Your personal WhatsApp remains private."
  }
];

const faqs = [
  {
    question: "Can the AI interpret loft photos sent by WhatsApp?",
    answer: "The AI does not perform structural analysis from photos, but it acknowledges them effectively and asks the questions you need — what rooms do you want to create, what is the measured ridge height, are there obstructions like tanks or chimney breasts, and what conversion type are you considering? Every photo, video, and measurement sent by the homeowner is attached to your lead. Having visual context before the survey lets you arrive prepared."
  },
  {
    question: "What about WhatsApps from property developers?",
    answer: "Developers converting lofts on multiple properties for resale value increasingly use WhatsApp for speed. A developer messaging about a row of three terraced houses all needing dormer conversions is a high-value multi-project lead. The AI captures the scope — number of properties, conversion type, programme requirements — and your lead summary reads like a tender brief."
  },
  {
    question: "How much does AI WhatsApp cost for loft specialists?",
    answer: `WhatsApp is priced at £${pricing.addOn.price}/month as an add-on to the Core plan. Loft conversions range from £20,000 for a basic Velux conversion to £70,000 or more for a complex mansard. Capturing one homeowner's WhatsApp enquiry before your competitors — and winning the conversion — generates a return that eclipses the annual add-on spend.`
  },
  {
    question: "Can I continue WhatsApp conversations personally?",
    answer: "Sending your own message in any thread hands the conversation to you. The AI recognises your reply and withdraws. Most loft specialists let the AI handle the initial capture — property type, headroom, conversion preference, postcode — then follow up personally to discuss design options and book the survey."
  },
  {
    question: "How is WhatsApp data from loft enquiries protected?",
    answer: "All WhatsApp messages — loft photos, roof measurements, property addresses, conversion preferences, and contact information — are encrypted and stored on UK and EU servers under UK GDPR. Data is delivered only to you. No client information is shared with other conversion companies, sold to lead platforms, or used for any purpose beyond your lead summaries."
  }
];
