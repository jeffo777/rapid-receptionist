const faqs = [
  {
    question: "How does the AI handle a text about a loft conversion?",
    answer: "The AI reads the message and responds professionally in your company name. A detailed text — 'want a hip-to-gable conversion on our 1950s semi in OX3, need two bedrooms' — is captured with full context. A brief text — 'can you do loft conversions?' — prompts the AI to ask about the property type, conversion type, rooms wanted, and location."
  },
  {
    question: "Will the person know they are texting AI?",
    answer: "The reply reads like a loft conversion specialist responding between tasks — professional, concise, and knowledgeable about conversion types. It uses your company name and asks the right questions about the caller's roof and project requirements. Homeowners care about professionalism and speed; the AI provides both within seconds."
  },
  {
