---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Dormer Transformation Posts',
    text: "Loft conversion galleries are dramatic — cramped attics become flooded-with-light bedrooms, dormers frame panoramic views, en-suites appear where cobwebs once hung. When a follower messages your page after seeing a conversion gallery, the AI captures their project and turns visual inspiration into a booked survey."
  },
  {
    icon: '📸',
    title: 'Handles Attic Photo Messages',
    text: "Facebook followers message with photos of their dark, dusty loft space — 'this is what we are starting with, can you turn it into a bedroom?' The AI acknowledges the photos, asks about property type and headroom, and delivers the images alongside a lead showing the conversion potential."
  },
  {
    icon: '⚡',
    title: 'Captures Street-Level Referrals',
    text: "Your scaffolding and dormer taking shape are visible from the street for weeks. Neighbours see the transformation, find your Facebook page through the signage, and message. The AI captures these warm referral leads with built-in visual proof of your work quality."
  },
  {
    icon: '🕐',
    title: 'Active During Sunday Planning Sessions',
    text: "Sunday afternoons are when families make big home decisions — browsing loft conversion examples on Facebook, comparing before-and-afters, discussing whether to convert the loft or move house. The AI captures these high-stakes weekend enquiries."
  },
  {
    icon: '📋',
    title: 'Structures Aspirational Loft Messages',
    text: "Messenger conversations about loft conversions start aspirational — 'we love what you did there.' The AI grounds the vision by asking about property type, rooms wanted, and headroom, turning admiration into a measurable lead."
  },
  {
    icon: '🔗',
    title: 'Monetises Every Transformation Post',
    text: "Every dormer reveal, time-lapse build video, and finished bedroom photo posted on Facebook can trigger a Messenger enquiry. The AI converts social engagement into survey bookings."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my loft company?",
    answer: "Yes — you need a Facebook Business page with Messenger turned on. Personal Facebook profiles are not supported by the integration. Most loft conversion companies already run a Business page to showcase dormer galleries, share progress updates, and collect homeowner reviews. The AI simply adds professional message handling on top of your existing page."
  },
  {
    question: "What loft enquiries arrive through Messenger?",
    answer: "Predominantly domestic leads from homeowners who have seen your conversion galleries. Typical messages include 'can you do a dormer on a terraced house?', 'how much for a similar conversion on a semi-detached?', and 'we love the en-suite you created — our loft is about the same size.' These are pre-qualified leads from people who have already seen and liked your build quality."
  },
  {
    question: "How quickly does the AI respond on Messenger?",
    answer: "Replies arrive within seconds. Messenger displays active indicators, so homeowners see your business engaging immediately. For loft conversion specialists — where families compare three to five companies before choosing their survey shortlist — the speed of your initial professional response often determines who gets the appointment."
  },
  {
    question: "What does Messenger cost for loft specialists?",
    answer: `Messenger is available at £${pricing.addOn.price}/month as a channel add-on. Loft conversion projects span from £20,000 Velux conversions to complex mansard builds exceeding £70,000. A single project won through a prompt Facebook Messenger response — while your competitors' messages sat unread over the weekend — covers the add-on cost for years.`
  },
  {
    question: "Can I continue Messenger conversations?",
    answer: "Sending your own reply in any thread transfers the conversation to you seamlessly. Most loft specialists let the AI handle the initial scope capture — property type, conversion preference, rooms wanted, headroom if known — and then follow up personally to discuss design details, share case studies, and book the survey."
  },
  {
    question: "How is Messenger data from loft enquiries protected?",
    answer: "All Messenger conversations, attic photos, property details, conversion preferences, and homeowner contact information are encrypted and stored on UK and EU servers under UK GDPR. Data is delivered to you exclusively and is never shared with other conversion companies, sold to lead aggregators, or used for advertising purposes."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Loft Conversion Specialists | Rapid Receptionist"
  description={`AI Facebook Messenger for UK loft conversion specialists. Converts dormer and mansard gallery engagement into survey bookings from your Facebook page. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/loft-conversion-specialists/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Loft Conversion Specialist"
  tradeNamePlural="Loft Conversion Specialists"
  tradeSlug="loft-conversion-specialists"
  headline="AI Facebook Messenger for UK Loft Conversion Companies"
  accentWord="Loft Conversion"
  subhead="You post a completed dormer loft conversion with Velux windows and a Jack and Jill en suite. A homeowner messages about converting their 1930s hip roof. Your AI captures the brief while you frame."
  scenario="It is 7:30pm on a Friday. A father in Botley has been browsing loft conversion company Facebook pages — his twin daughters share a bedroom and need their own rooms before they start secondary school in September. The only option is the loft. He finds your page, scrolls through four completed conversion projects — terraced dormers, a hip-to-gable, a bungalow conversion — and messages: 'Hi — we have a 3-bed 1970s detached in OX2. The loft is massive but has a water tank and loads of old insulation up there. We need two single bedrooms for our daughters — they are starting secondary in September so we need this done over the summer. Is that achievable? Can you survey quickly?' Without AI Facebook Messenger, you see the message Saturday morning while loading tools for a site visit. You start typing but get distracted. The father has also messaged two other companies; one replied at 8pm Friday with a reassuring explanation of summer build timelines and an offer of a Tuesday survey. With AI Messenger, the reply arrives at 7:31pm: 'Thank you — two-bedroom loft conversions on 1970s detached houses are ideal projects for us. Water tanks and insulation are routinely relocated during the conversion. A summer programme is achievable with an early survey and prompt planning. Could you share photos of the existing loft and confirm the ridge height if you have measured it? We will arrange a priority survey.' He sends three loft photos — the water tank, the ridge height, and the roof structure. Saturday morning you open the lead: 3-bed 1970s detached, OX2, two single bedrooms, water tank relocation, summer programme needed, September school deadline, loft photos attached. You call at 9am and book a Monday evening survey — the earliest possible."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/loft-conversion-specialists/ai-receptionist/"
  ctaHeadline="Turn Dormer Reveal Posts into Loft Survey Bookings"
  ctaSubhead={`A hip-to-gable gallery earns a hundred and ninety likes. AI Messenger converts every enquiry into a lead with property type, headroom, and photos. Add-on at £${pricing.addOn.price}/month.`}
/>
