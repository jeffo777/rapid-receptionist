---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Catches Calls Missed During Physical Work',
    text: "Concreting posts, nailing feather edge boards, operating a post knocker, or wrestling wind-blown panels into position — fencing is hands-on work where your phone is the last thing you can reach. When a call goes unanswered, Missed Call Text Back sends a branded text within seconds. The homeowner knows you are working, not ignoring them."
  },
  {
    icon: '⏱️',
    title: 'Acts Before the Caller Moves On',
    text: "A homeowner calling about a blown fence panel will call two or three fencing companies. If your phone goes to voicemail, they call the next number immediately. A text arriving six seconds later — 'Thank you for calling, we are on site and will call you back shortly' — pauses that search. You stay in the running."
  },
  {
    icon: '🏷️',
    title: 'Branded and Trustworthy',
    text: "The text arrives from your business number with your company name. For fencing — a trade plagued by fly-by-night operators — a professional text response immediately signals that you are an established, responsive business. Trust starts before the callback."
  },
  {
    icon: '📊',
    title: 'Storm-Season Safety Net',
    text: "After a named storm, missed call volumes spike dramatically. You might miss ten, twenty, thirty calls in a single day while repairing fences. Missed Call Text Back ensures every one of those callers receives an immediate acknowledgement, reducing the number who slip away to competitors."
  },
  {
    icon: '📋',
    title: 'Gathers Context from Text Replies',
    text: "Callers often reply to the text with details — 'it is about 4 panels blown down in Abingdon, backs onto a field' or 'need a quote for a new boundary fence, about 20 metres.' Your lead summary includes the phone number and the text reply. You call back with context."
  },
  {
    icon: '🔄',
    title: 'Complement to AI Phone Answering',
    text: "Most calls are answered by the AI phone system. Missed Call Text Back catches the exceptions — callers who hang up after one ring, rare connectivity gaps, or moments when you briefly have signal but not enough for the AI to connect. Together, both systems form a complete net."
  }
];

const faqs = [
  {
    question: "When exactly does the text go out?",
    answer: "The text fires the instant a call reaches voicemail or goes unanswered within your set ring time. Delivery to the caller happens within seconds — typically before they have scrolled to the next fencing company in their search results. During storm periods when callers are anxious and impatient, this immediacy is especially valuable."
  },
  {
    question: "What does the text message say?",
    answer: "You write the message yourself during setup — it is fully customisable and can be changed at any time. A typical fencing contractor's message might read: 'Thank you for calling [your business]. We are currently on site and will call you back as soon as possible. If your fence is an emergency, reply to this text with the details.' The tone, wording, and calls to action are entirely yours."
  },
  {
    question: "Does Missed Call Text Back replace AI Phone Answering?",
    answer: "They work as a pair, not as alternatives. AI Phone Answering intercepts the call and conducts a full conversation, capturing a detailed lead. Missed Call Text Back handles the small number of calls that slip through — a caller who hangs up before the AI connects, or a brief mobile signal dropout. Phone answering is the first line; text back is the safety net behind it."
  },
  {
    question: "How much does this feature cost?",
    answer: `The add-on is £${pricing.addOn.price}/month alongside your Core plan. For a fencing contractor where a single domestic boundary replacement is worth £1,000 to £3,000 and a commercial perimeter contract can exceed £20,000, recovering even one missed call through a text response delivers a return that dwarfs the monthly cost — especially during November to March storm season when missed call rates peak.`
  },
  {
    question: "Do callers actually reply to these texts?",
    answer: "Many do. Common replies include the type of fence they need, the number of panels affected, their location, and whether it is urgent. These text replies appear in your lead summary alongside the missed call record. You start your callback knowing who called, what they need, and where they are — eliminating the 'who was that missed call from?' guessing game."
  },
  {
    question: "Is missed call data kept secure?",
    answer: "All missed call records, phone numbers, and text replies — including addresses, damage descriptions, and boundary details — are encrypted and stored on UK and EU servers under UK GDPR. Data is shared only with you. No information is sold, repurposed, or accessed by anyone outside your business."
  }
];
---

<ChannelTradeLayout
