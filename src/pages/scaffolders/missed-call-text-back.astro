---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '📞',
    title: 'Catches Calls from Height',
    text: "When you are six lifts up, fitting standards and clipping ledgers, your phone is zipped in your jacket pocket or in the van sixty metres below. Missed Call Text Back sends a branded text to every unanswered caller within seconds."
  },
  {
    icon: '⏱️',
    title: 'Holds Programme-Critical Contractors',
    text: "A main contractor needing scaffold erected for Monday gets voicemail from two scaffolders and a text from yours: 'Thanks for calling — we are on a scaffold erection and will call you back this afternoon.' That contractor holds your slot."
  },
  {
    icon: '🏷️',
    title: 'Professional Scaffold Operator Image',
    text: "An immediate branded text from a scaffolding company signals an organised, NASC-standard operation — the type of scaffolder that main contractors want on their approved list."
  },
  {
    icon: '📊',
    title: 'Essential During Full Days at Height',
    text: "Full-day erections and dismantles keep every person in your company at height from dawn to dusk. Missed Call Text Back captures every enquiry during your most physically demanding and uninterruptible work."
  },
  {
    icon: '📋',
    title: 'Captures Reply Project Details',
    text: "Callers reply with scope — 'need scaffold on 3-storey semi, back and side, for rendering, OX2, need it Thursday.' Those replies arrive in your lead summary ready for quoting before you descend."
  },
  {
    icon: '🔄',
    title: 'Pairs with AI Phone Answering',
    text: "Phone Answering conducts full scaffold conversations and builds detailed briefs. Missed Call Text Back catches edge cases — a call dropping due to poor signal at height, or a caller hanging up immediately. Together, every scaffold lead is retained."
  }
];

const faqs = [
  {
    question: "When does the missed call text send?",
    answer: "Seconds after the call goes unanswered — before the contractor starts typing the next scaffolding company into Google. During all-day erections where your phone sits in the van cab from 7am to 4pm, this automatic text keeps your scaffold company responsive without interrupting the physical work at height."
  },
  {
    question: "What does the text message say?",
    answer: "You write it during setup and update it whenever you like. A strong scaffolding message reads: 'Thank you for calling [company name]. We are currently up on a scaffold erection. We will return your call at the earliest opportunity. Reply with your scaffold needs for a faster response.' The wording reflects your trade expertise and on-site commitment."
  },
  {
    question: "Does this replace AI Phone Answering?",
    answer: "They function as complementary layers. Phone Answering conducts full conversations — identifying the scaffold type, building dimensions, number of elevations, tie requirements, hire duration, and erection deadline. Missed Call Text Back catches rare bypass scenarios — a one-ring disconnect, a mobile signal lost at height, or a call at the exact moment of system handover. Both running simultaneously means no scaffold enquiry is ever permanently lost."
  },
  {
    question: "How much does Missed Call Text Back cost?",
    answer: `This add-on costs £${pricing.addOn.price}/month. Scaffold hire values range from £300 domestic chimney access to £50,000 commercial multi-storey programmes. Recovering one missed call from a main contractor — who needed a twelve-week independent on a four-storey block — through a branded text reply transforms a modest monthly outlay into your best-returning lead channel.`
  },
  {
    question: "Do callers reply to the text?",
    answer: "Frequently — especially contractors under programme pressure. Replies typically include the building type, number of storeys, scaffold type needed, hire duration, erection date, and postcode. These arrive on your dashboard before you finish the lift, providing full context for a priority callback when you come down."
  },
  {
    question: "How is missed call data stored?",
    answer: "Phone numbers, text replies with site addresses, scaffold details, hire timelines, and contact information are encrypted and held on UK and EU servers under UK GDPR. Only you can access the data. Nothing is shared with competing scaffolding companies or any third party."
  }
];
---

<ChannelTradeLayout
  title="Missed Call Text Back for Scaffolders | Rapid Receptionist"
  description={`Missed Call Text Back for UK scaffolders. Automatically texts callers while you work at height — keeps main contractor subcontracts and domestic bookings warm. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/scaffolders/missed-call-text-back/"
  channelName="Missed Call Text Back"
  tradeName="Scaffolder"
  tradeNamePlural="Scaffolders"
  tradeSlug="scaffolders"
  headline="Missed Call Text Back for Scaffolding Companies"
  accentWord="Scaffolders"
  subhead="It is 11am on a Tuesday. You and your crew are erecting a ten-lift independent scaffold around a four-storey apartment block for a recladding contract — the structure needs to wrap all four elevations with scaffold ties drilled into the existing concrete frame, loading bays at second and fourth floor, and a pavement gantry on the street-facing elevation to protect pedestrians. Your entire team — two scaffolders and two labourers — is at height, every pair of hands occupied fitting standards into rosettes, levelling transoms, and clipping braces. Two calls come in at 11:20 and 11:45. Your phones are thirty feet below in the van. Without Missed Call Text Back, both callers hear voicemail. One leaves a message — 'need scaffold for some roof work' — the other hangs up and calls a competitor. With it, both receive texts within seconds. The first replies: 'Roofer here — got a contract for 3 houses in Marston, re-tile job, need putlog scaffold to the fronts, 3 houses in a row, need first one up by next Friday. Can you do it?' At the lunch break you check and call. You quote the three-house phased putlog and book next Friday erection."
  scenario="It is 3pm on a Friday in December. Your full team has been dismantling a large commercial scaffold since 8am — lowering boards through the lifts, striking transoms and ledgers, stacking tubes on the lorry, sorting fittings into bags. Light fades early. Five missed calls between 11am and 3pm. Without Missed Call Text Back, you check in the cab on the drive home: five unknowns, two voicemails, three lost. With Missed Call Text Back, all five received texts. Reply one at 11:20: 'main contractor — need scaffold on a new-build, 4 detached houses, putlog, phased, 20 weeks.' Reply two at 12:15: 'roofer in Witney — need scaffold on semi for re-tile, 1 elevation, 3 weeks.' Reply three at 1:30: 'stone mason — need 2-lift putlog on a cottage, chimney end, for repointing, 4 weeks, OX7.' Reply four at 2:45: 'homeowner — need scaffold at the back of the house for painters, 2 storeys, can you quote?' Reply five at 2:50: 'builder — extension going up, need scaffold for the brickwork, 2 storey, east side only, starts Monday.' Five leads. Friday evening you review: a twenty-week new-build programme, a Witney re-tile, a cottage chimney repoint, a domestic painting job, and a Monday extension erection. Saturday morning you schedule five return calls."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/missed-call-text-back/"
  tradePageUrl="/scaffolders/ai-receptionist/"
  ctaHeadline="Recover Five Scaffold Leads from One December Dismantle Friday"
  ctaSubhead={`While your crew dismantled the commercial scaffold, five callers missed you. Five texts went out. Five replied. Five projects scheduled. Add-on at £${pricing.addOn.price}/month.`}
