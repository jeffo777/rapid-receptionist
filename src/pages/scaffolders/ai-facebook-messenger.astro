---
import ChannelTradeLayout from '../../layouts/ChannelTradeLayout.astro';
import pricing from '../../data/pricing.json';

const benefits = [
  {
    icon: '💬',
    title: 'Converts Scaffold Erection Photos',
    text: "Scaffold erection photos are engaging on Facebook — complex structures taking shape, temporary roofs spanning buildings, birdcage configurations filling church interiors. When a contractor messages wanting similar access for their project, the AI captures the lead."
  },
  {
    icon: '📸',
    title: 'Handles Building Access Photo Messages',
    text: "Contractors message with building photos — 'can you scaffold this? Three storeys, narrow side access.' The AI asks about elevations, hire duration, and the contractor's trade, converting the visual enquiry into a quoted scaffold brief."
  },
  {
    icon: '⚡',
    title: 'Captures Local Trade Referrals',
    text: "When you erect an impressive temporary roof or solve a difficult access problem, the contractor posts photos tagging your company. Their colleagues message: 'Can you do similar scaffolding for our chimney project?' The AI converts every referral."
  },
  {
    icon: '🕐',
    title: 'Active During Evening Planning',
    text: "Contractors browse Facebook after site hours, planning their scaffolding needs for upcoming projects. Messages at 8pm about 'scaffold for a rendering job next month' are genuine bookings waiting to be confirmed."
  },
  {
    icon: '📋',
    title: 'Structures Quick Scaffold Requests',
    text: "Messenger conversations about scaffold start casually — 'how much to scaffold a semi for re-pointing?' The AI asks about the property height, number of elevations, and the bricklayer's start date."
  },
  {
    icon: '🔗',
    title: 'Monetises Complex Erection Content',
    text: "Every temporary roof time-lapse, church birdcage build sequence, and commercial scaffold erection video showcases the capability that wins difficult access contracts."
  }
];

const faqs = [
  {
    question: "Do I need a Facebook Business page for my scaffolding company?",
    answer: "The Messenger integration requires a Business page — personal profiles will not work. Scaffolding companies that post erection progress photos, completed project showcases, and access solution examples generate strong engagement from contractors who recognise the capability. The AI adds instant message handling to convert that engagement into scaffold bookings."
  },
  {
    question: "What scaffold enquiries come through Messenger?",
    answer: "A mix of trades contractors and homeowners. Contractors message about upcoming jobs — 'need scaffold for a re-roof in two weeks, can you do it?' Homeowners ask about domestic scaffold — 'how much to scaffold the front of our house for painting?' These leads are actionable because the sender has already reviewed your work and needs scaffold for a specific project."
  },
  {
    question: "How quickly does the AI reply on Messenger?",
    answer: "The reply arrives within seconds of the message landing. Messenger shows your company as actively responding — critical for contractors comparing scaffold firms while planning their programme. The scaffolder who confirms availability first gets the booking. Silence means the contractor moves on to the next company in their feed."
  },
  {
    question: "What does Messenger cost for scaffolding companies?",
    answer: `Messenger is £${pricing.addOn.price}/month as a channel add-on. Scaffold hire ranges from £300 domestic access to £50,000 commercial programmes. One roofer's five-house contract, secured through a prompt Messenger reply while the competition sat unanswered, generates scaffold hire revenue that exceeds the channel cost for years.`
  },
  {
    question: "Can I continue Messenger conversations myself?",
    answer: "Jump into any Messenger thread with your own reply and the conversation becomes yours permanently. The AI recognises your response and steps aside. Most scaffolders let the AI collect the initial project scope — property type, number of elevations, scaffold configuration, the requesting contractor's trade, hire weeks, and preferred erection date — then take over to discuss ground conditions, access logistics, and pricing details."
  },
  {
    question: "How is Messenger data from scaffold queries protected?",
    answer: "All Messenger conversations, building photographs, site addresses, scaffold specifications, hire schedules, and contact details are encrypted and stored on UK and EU servers under UK GDPR. Data goes exclusively to you. No project details are shared with competing scaffolding firms, disclosed to other site trades, or sold to any third party."
  }
];
---

<ChannelTradeLayout
  title="AI Facebook Messenger for UK Scaffolders | Rapid Receptionist"
  description={`AI Facebook Messenger for UK scaffolders. Converts scaffold erection photos and access solution showcases into contractor hire bookings. Add-on at £${pricing.addOn.price}/month.`}
  canonicalUrl="/scaffolders/ai-facebook-messenger/"
  channelName="AI Facebook Messenger"
  tradeName="Scaffolder"
  tradeNamePlural="Scaffolders"
  tradeSlug="scaffolders"
  headline="AI Facebook Messenger for UK Scaffolding Companies"
  accentWord="Scaffolders"
  subhead="You post a time-lapse video of a temporary roof being constructed — the scaffold structure rising around a Period townhouse in Woodstock, the temporary roof trusses spanning the ridge, the corrugated sheeting covering the entire roof area, and the final shot showing the roofers working in dry conditions underneath while rain pours off the temporary roof above them. One hundred and sixty likes, thirty-eight shares. A conservation roofer in North Oxford messages: 'Brilliant temporary roof setup — we are doing a heritage re-roof on a Listed building in Iffley and need exactly this kind of protection while we strip and re-tile with handmade tiles. The building is about 14m long and 8m wide. Can you do a temporary roof this size? We start in 5 weeks.' You are on site. Without AI Messenger, the message waits. With it, the AI asks about the ridge height, the building's listed status, and whether the temporary roof needs to extend beyond the eaves. Your lead — heritage re-roof, Iffley, Listed building, 14m x 8m, temp roof, handmade tiles, five-week start — is captured."
  scenario="It is 9:30pm on a Thursday. A small building firm in Eynsham has won a contract to render a row of four terraced houses. He needs scaffold erected on all four properties — putlog scaffold to the front elevations and independent scaffold to the rears, with the render crew moving from one property to the next over eight weeks. He finds your Facebook page through a local building group recommendation and messages: 'Hi — need scaffold on 4 terraced houses for rendering. Putlog fronts, independent rears. Render crew moves one house per fortnight. 8 week programme. Need the first 2 houses up in 10 days. Can you phase the erection to match the rendering? Eynsham OX29.' Without AI Messenger, you see the message Friday morning. One competitor replied at 10pm with a clear explanation of phased erection logistics. With AI Messenger, the reply arrives at 9:31pm: 'Thank you — phased scaffold erection to match a rendering programme is something we do regularly. Could you confirm whether the rear gardens connect or if independent access is needed for each property? We will plan the erection sequence to keep two houses scaffolded at all times.' He confirms shared rear access. Friday you open the lead: four terraced houses, Eynsham OX29, putlog fronts, independent rears, phased rendering, eight-week programme, first two in ten days, shared rear access. You call at 8am and book a site survey."
  benefits={benefits}
  faqs={faqs}
  channelPageUrl="/construction-trades/ai-facebook-messenger/"
  tradePageUrl="/scaffolders/ai-receptionist/"
  ctaHeadline="Turn Temporary Roof Time-Lapses into Heritage Re-Roof Scaffold Bookings"
  ctaSubhead={`A temporary roof video earns one hundred and sixty likes. AI Messenger converts every conservation roofer's message into a scaffold booking with dimensions and listed building requirements. Add-on at £${pricing.addOn.price}/month.`}
/>
