---
export interface SpecialismGroup {
  category: string;
  items: string[];
}

export interface Props {
  tradeName: string;
  groups: SpecialismGroup[];
}

const { tradeName, groups } = Astro.props;
---

<section class="section section--alt" id="specialisms">
  <div class="container">
    <div class="section-header">
      <h2>Types of <span class="text-accent">{tradeName}</span> Work We Cover</h2>
      <p class="section-header__sub">Your AI receptionist understands all of these — and captures the right details for each.</p>
    </div>
    <div class="spec-grid">
      {groups.map((group) => (
        <div class="spec-card fade-in">
          <h3 class="spec-card__title">{group.category}</h3>
          <ul class="spec-card__list">
            {group.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .spec-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .spec-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .spec-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .spec-card__title {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--color-accent);
  }

  .spec-card__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .spec-card__list li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding-left: var(--space-4);
    position: relative;
    line-height: var(--leading-relaxed);
  }

  .spec-card__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--font-bold);
    font-size: var(--text-xs);
  }

  @media (max-width: 768px) {
    .spec-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .spec-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
