---
import GuaranteeBadge from './GuaranteeBadge.astro';
---

<section class="section trust-section" id="trust-section">
  <div class="container container--narrow">
    <div class="trust-section__inner fade-in">
      <span class="badge badge--accent">Our Promise</span>
      <h2>Built for Construction, <span class="text-accent">Not for Corporations</span></h2>
      <blockquote class="trust-section__quote">
        <p>
          We didn't build Rapid Receptionist in a boardroom. We built it because we watched construction businesses — plasterers, bricklayers, electricians, roofers — lose work they should have won, simply because they couldn't answer the phone while they were doing their job. Whether that's in someone's kitchen, up a scaffold, or running cable through a ceiling void.
        </p>
        <p>
          Every feature, every channel, every AI response has been designed by people who understand what it means to have your hands full when the phone rings. This isn't a generic tech product with a hard-hat icon — it's a tool built specifically for the way construction trades actually operate.
        </p>
      </blockquote>
      <div class="trust-section__guarantee">
        <GuaranteeBadge />
      </div>
    </div>
  </div>
</section>

<style>
  .trust-section__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .trust-section__quote {
    max-width: 620px;
    margin: 0;
    padding: 0;
    border: none;
  }

  .trust-section__quote p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .trust-section__quote p:last-child {
    margin-bottom: 0;
  }

  .trust-section__guarantee {
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    .trust-section__quote p {
      font-size: var(--text-base);
    }
  }
</style>
