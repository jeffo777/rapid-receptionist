---
/**
 * Floating AI Receptionist Widget
 * Shows in the bottom-right after scrolling past the hero.
 * Click to expand Chat / Call CTAs that trigger the same popups as the hero.
 */
---

<div class="floating-widget" id="floating-widget" aria-label="Chat with our AI receptionist">
  <!-- Collapsed: avatar bubble -->
  <button class="floating-widget__trigger" id="floating-widget-trigger" aria-expanded="false" aria-label="Open AI receptionist">
    <div class="floating-widget__avatar-wrap">
      <img
        src="/assets/images/ai-receptionist.webp"
        alt=""
        class="floating-widget__avatar-img"
        width="56"
        height="56"
        loading="lazy"
        decoding="async"
      />
      <div class="floating-widget__ring" aria-hidden="true"></div>
      <span class="floating-widget__online" aria-hidden="true">online</span>
    </div>
  </button>

  <!-- Expanded: CTA buttons -->
  <div class="floating-widget__panel" id="floating-widget-panel" aria-hidden="true">
    <button type="button" class="floating-widget__cta floating-widget__cta--chat" id="floating-chat-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      Chat with me
    </button>
    <button type="button" class="floating-widget__cta floating-widget__cta--call" id="floating-call-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Call me
    </button>
  </div>
</div>

<style>
  /* ---------- Container ---------- */
  .floating-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
    opacity: 0;
    transform: translateY(20px) scale(0.9);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .floating-widget.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ---------- Avatar Trigger ---------- */
  .floating-widget__trigger {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    transition: transform var(--transition-fast);
  }

  .floating-widget__trigger:hover {
    transform: scale(1.08);
  }

  .floating-widget__avatar-wrap {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .floating-widget__avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Pulsing ring */
  .floating-widget__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid var(--color-accent);
    animation: widgetRingPulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  /* Online badge */
  .floating-widget__online {
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--color-primary);
    color: var(--color-accent);
    font-size: 8px;
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 1px 6px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--color-accent);
    animation: widgetRingPulse 2.8s ease-in-out infinite;
    pointer-events: none;
    font-family: var(--font-sans);
  }

  @keyframes widgetRingPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* ---------- Expanded Panel ---------- */
  .floating-widget__panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    position: absolute;
    bottom: 76px;
    right: 0;
  }

  .floating-widget__panel.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .floating-widget__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    font-family: var(--font-sans);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
    min-height: 40px;
    box-shadow: var(--shadow-lg);
  }

  .floating-widget__cta--chat {
    background: var(--color-accent);
    color: #fff;
    border: none;
    box-shadow: var(--shadow-accent);
  }

  .floating-widget__cta--chat:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-accent-lg);
  }

  .floating-widget__cta--call {
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .floating-widget__cta--call:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
    transform: translateY(-1px);
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 768px) {
    .floating-widget {
      bottom: 16px;
      right: 16px;
    }

    .floating-widget__trigger {
      width: 56px;
      height: 56px;
    }

    .floating-widget__avatar-wrap {
      width: 56px;
      height: 56px;
    }

    .floating-widget__panel {
      bottom: 68px;
    }
  }
</style>

<script>
  // Show widget after scrolling past hero
  const widget = document.getElementById('floating-widget');
  const heroSection = document.getElementById('hero-section');

  if (widget && heroSection) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          widget.classList.remove('visible');
        } else {
          widget.classList.add('visible');
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(heroSection);
  }

  // Toggle panel
  const trigger = document.getElementById('floating-widget-trigger');
  const panel = document.getElementById('floating-widget-panel');

  trigger?.addEventListener('click', () => {
    const isOpen = panel?.classList.contains('open');
    if (isOpen) {
      panel?.classList.remove('open');
      panel?.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
    } else {
      panel?.classList.add('open');
      panel?.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
    }
  });

  // Close panel when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (widget && !widget.contains(target)) {
      panel?.classList.remove('open');
      panel?.setAttribute('aria-hidden', 'true');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Chat & Call buttons trigger the same popups as hero
  const floatingChatBtn = document.getElementById('floating-chat-btn');
  const floatingCallBtn = document.getElementById('floating-call-btn');
  const chatPopup = document.getElementById('ai-chat-popup');
  const callPopup = document.getElementById('ai-call-popup');

  function openPopup(popup: HTMLElement | null) {
    popup?.classList.add('active');
    popup?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    // Close the widget panel
    panel?.classList.remove('open');
    panel?.setAttribute('aria-hidden', 'true');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  floatingChatBtn?.addEventListener('click', () => openPopup(chatPopup));
  floatingCallBtn?.addEventListener('click', () => openPopup(callPopup));
</script>
