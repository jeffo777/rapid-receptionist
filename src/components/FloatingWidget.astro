---
/**
 * Floating AI Receptionist Widget
 * Shows in the bottom-right after scrolling past the hero.
 * Click to launch the Deepgram voice agent.
 */
export interface Props {
  tradeName?: string;
}

const { tradeName = '' } = Astro.props;
---

<div class="floating-widget" id="floating-widget" aria-label="Talk to our AI receptionist" data-trade={tradeName}>
  <button class="floating-widget__trigger" id="floating-widget-trigger" aria-label="Try our AI receptionist">
    <div class="floating-widget__avatar-wrap">
      <img
        src="/assets/images/ai-receptionist.webp"
        alt="Rapid Receptionist AI assistant"
        class="floating-widget__avatar-img"
        width="56"
        height="56"
        loading="lazy"
        decoding="async"
      />
      <div class="floating-widget__ring" aria-hidden="true"></div>
      <span class="floating-widget__label" aria-hidden="true">try me</span>
    </div>
  </button>
</div>

<style>
  /* ---------- Container ---------- */
  .floating-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
    opacity: 0;
    transform: translateY(20px) scale(0.9);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .floating-widget.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ---------- Avatar Trigger ---------- */
  .floating-widget__trigger {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    transition: transform var(--transition-fast);
  }

  .floating-widget__trigger:hover {
    transform: scale(1.08);
  }

  .floating-widget__avatar-wrap {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .floating-widget__avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Pulsing ring */
  .floating-widget__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid var(--color-accent);
    animation: widgetRingPulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  /* "try me" badge */
  .floating-widget__label {
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--color-accent);
    color: #fff;
    font-size: 8px;
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    pointer-events: none;
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  @keyframes widgetRingPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 768px) {
    .floating-widget {
      bottom: 16px;
      right: 16px;
    }

    .floating-widget__trigger {
      width: 56px;
      height: 56px;
    }

    .floating-widget__avatar-wrap {
      width: 56px;
      height: 56px;
    }
  }
</style>

<script>
  // Show widget after scrolling past hero
  const widget = document.getElementById('floating-widget');
  const heroSection = document.getElementById('hero-section');

  if (widget && heroSection) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          widget.classList.remove('visible');
        } else {
          widget.classList.add('visible');
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(heroSection);
  }

  // Click launches voice agent
  const trigger = document.getElementById('floating-widget-trigger');
  trigger?.addEventListener('click', () => {
    const trade = widget?.getAttribute('data-trade') || '';
    // Use the global launcher from HeroSection
    if (typeof (window as any).launchVoiceAgent === 'function') {
      (window as any).launchVoiceAgent(trade);
    }
  });
</script>
