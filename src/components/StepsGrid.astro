---
export interface Step {
  number: number;
  title: string;
  description: string;
}

export interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section steps-section" id="how-it-works">
  <div class="container">
    <div class="section-header">
      <span class="badge badge--accent section-header__badge">How It Works</span>
      <h2>Up and Running in <span class="text-accent">3 Simple Steps</span></h2>
      <p>We handle everything — you just keep working.</p>
    </div>

    <div class="steps-grid">
      {steps.map((step) => (
        <div class="steps-grid__card fade-in">
          <div class="step-number">{step.number}</div>
          <div class="steps-grid__text">
            <h3 class="steps-grid__title">{step.title}</h3>
            <p class="steps-grid__desc">{step.description}</p>
          </div>
        </div>
      ))}

      <!-- Connector lines (desktop only) -->
      <div class="steps-grid__connectors" aria-hidden="true">
        <div class="steps-grid__line"></div>
        <div class="steps-grid__line"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    position: relative;
  }

  .steps-grid__card {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition-base), transform var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .steps-grid__card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
  }

  .steps-grid__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .steps-grid__desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Connector lines between steps */
  .steps-grid__connectors {
    display: none;
  }

  @media (min-width: 769px) {
    .steps-grid__connectors {
      display: flex;
      position: absolute;
      top: 62px;
      left: 0;
      right: 0;
      justify-content: space-between;
      padding: 0 calc(33.333% - 40px);
      pointer-events: none;
    }

    .steps-grid__line {
      height: 2px;
      flex: 1;
      background: linear-gradient(90deg, var(--color-accent), var(--color-accent-subtle));
      margin: 0 var(--space-6);
      opacity: 0.3;
    }
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .steps-grid__card {
      flex-direction: row;
      text-align: left;
      gap: var(--space-4);
      padding: var(--space-5);
      align-items: flex-start;
    }

    .steps-grid__card .step-number {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .steps-grid__title {
      font-size: var(--text-lg);
    }

    .steps-grid__desc {
      font-size: var(--text-sm);
    }
  }
</style>
