---
import channels from '../data/channels.json';

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Rapid Receptionist — Home">
      <svg class="header__logo-icon" width="24" height="24" viewBox="0 0 26 26" fill="none" aria-hidden="true">
        <circle cx="13" cy="13" r="2.5" fill="var(--color-accent)"/>
        <path class="header__logo-wave header__logo-wave--1" d="M8.5 17.5a6.4 6.4 0 0 1 0-9 M17.5 8.5a6.4 6.4 0 0 1 0 9" stroke="var(--color-accent)" stroke-width="2.3" stroke-linecap="round" fill="none"/>
        <path class="header__logo-wave header__logo-wave--2" d="M5 21a11.3 11.3 0 0 1 0-16 M21 5a11.3 11.3 0 0 1 0 16" stroke="var(--color-accent)" stroke-width="2.3" stroke-linecap="round" fill="none"/>
      </svg>
      <span class="header__logo-rapid">Rapid</span><span class="header__logo-rest"> Receptionist</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav" aria-label="Main navigation" id="main-nav">
      <ul class="header__nav-list">
        <li class="header__nav-item">
          <a
            href="/construction-trades/"
            class:list={['header__nav-link', { active: currentPath.startsWith('/construction-trades') }]}
          >
            Construction Trades
          </a>
        </li>
        <li class="header__nav-item header__dropdown" id="features-dropdown-wrap">
          <button
            class="header__nav-link header__dropdown-trigger"
            aria-expanded="false"
            aria-haspopup="true"
            id="features-dropdown-btn"
          >
            Services
            <svg class="header__dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="header__dropdown-menu" id="features-dropdown" role="menu">
            <div class="header__dropdown-grid">
              <a
                href="/construction-trades/"
                class="header__dropdown-item"
                role="menuitem"
              >
                <span class="header__dropdown-icon">🤖</span>
                <span>AI Receptionist</span>
              </a>
              {channels.map((ch) => (
                <a
                  href={ch.pageUrl}
                  class="header__dropdown-item"
                  role="menuitem"
                >
                  <span class="header__dropdown-icon">{ch.icon}</span>
                  <span>{ch.name}</span>
                </a>
              ))}
            </div>
          </div>
        </li>
        <li class="header__nav-item">
          <a
            href="/pricing/"
            class:list={['header__nav-link', { active: currentPath.startsWith('/pricing') }]}
          >
            Pricing
          </a>
        </li>
        <li class="header__nav-item">
          <a
            href="/about/"
            class:list={['header__nav-link', { active: currentPath.startsWith('/about') }]}
          >
            About
          </a>
        </li>
        <li class="header__nav-item">
          <a
            href="/contact/"
            class:list={['header__nav-link', { active: currentPath.startsWith('/contact') }]}
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>

    <!-- CTA + Mobile Toggle -->
    <div class="header__actions">
      <a href="/get-started/" class="btn btn--primary btn--sm header__cta">
        Get Started
      </a>
      <button
        class="header__mobile-toggle"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        id="mobile-menu-toggle"
      >
        <span class="header__hamburger">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="header__mobile-list">
        <li><a href="/construction-trades/" class="header__mobile-link">Construction Trades</a></li>
        <li>
          <button class="header__mobile-dropdown-trigger" id="mobile-features-btn" aria-expanded="false">
            Services
            <svg class="header__dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="header__mobile-dropdown" id="mobile-features-dropdown" aria-hidden="true">
            <a href="/construction-trades/" class="header__mobile-dropdown-item">
              <span>🤖</span>
              <span>AI Receptionist</span>
            </a>
            {channels.map((ch) => (
              <a href={ch.pageUrl} class="header__mobile-dropdown-item">
                <span>{ch.icon}</span>
                <span>{ch.name}</span>
              </a>
            ))}
          </div>
        </li>
        <li><a href="/pricing/" class="header__mobile-link">Pricing</a></li>
        <li><a href="/about/" class="header__mobile-link">About</a></li>
        <li><a href="/contact/" class="header__mobile-link">Contact</a></li>
        <li class="header__mobile-cta-wrap">
          <a href="/get-started/" class="btn btn--primary btn--lg header__mobile-cta-btn">Get Started</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ---------- Header Shell ---------- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(11, 15, 25, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border-subtle);
    height: var(--header-height);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-6);
  }

  /* ---------- Logo ---------- */
  .header__logo {
    display: flex;
    align-items: center;
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .header__logo:hover {
    color: var(--color-text-primary);
  }

  .header__logo-rapid {
    color: var(--color-accent);
    font-weight: var(--font-extrabold);
    letter-spacing: -0.01em;
    display: inline-block;
    transform: skewX(-8deg);
    margin-right: var(--space-2);
  }

  /* ---------- Logo Icon ---------- */
  .header__logo-icon {
    flex-shrink: 0;
    display: block;
  }

  .header__logo-wave--1 {
    animation: logoPulse 2.4s ease-in-out infinite;
  }

  .header__logo-wave--2 {
    animation: logoPulse 2.4s ease-in-out 0.4s infinite;
  }

  @keyframes logoPulse {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 1; }
  }

  /* ---------- Desktop Nav ---------- */
  .header__nav {
    display: flex;
    align-items: center;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .header__nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background var(--transition-fast);
    text-decoration: none;
  }

  .header__nav-link:hover,
  .header__nav-link.active {
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
  }

  /* ---------- Dropdown ---------- */
  .header__dropdown {
    position: relative;
  }

  .header__dropdown-trigger {
    cursor: pointer;
  }

  .header__dropdown-arrow {
    transition: transform var(--transition-fast);
  }

  .header__dropdown.open .header__dropdown-arrow {
    transform: rotate(180deg);
  }

  .header__dropdown-menu {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    min-width: 420px;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-base), transform var(--transition-base), visibility var(--transition-base);
    box-shadow: var(--shadow-xl);
  }

  .header__dropdown.open .header__dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .header__dropdown-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-1);
  }

  .header__dropdown-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .header__dropdown-item:hover {
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
  }

  .header__dropdown-icon {
    font-size: var(--text-base);
    width: 24px;
    text-align: center;
  }

  /* ---------- Actions ---------- */
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  /* ---------- Mobile Toggle ---------- */
  .header__mobile-toggle {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    transition: background var(--transition-fast);
  }

  .header__mobile-toggle:hover {
    background: var(--color-accent-subtle);
  }

  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 20px;
  }

  .header__hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: currentColor;
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(2) {
    opacity: 0;
  }
  .header__mobile-toggle[aria-expanded="true"] .header__hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---------- Mobile Menu ---------- */
  .header__mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-primary);
    border-top: 1px solid var(--color-border-subtle);
    padding: var(--space-6);
    overflow-y: auto;
    z-index: 999;
  }

  .header__mobile-menu.open {
    display: block;
  }

  .header__mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .header__mobile-link,
  .header__mobile-dropdown-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .header__mobile-link:hover,
  .header__mobile-dropdown-trigger:hover {
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
  }

  .header__mobile-dropdown {
    display: none;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-4);
    margin-top: var(--space-2);
  }

  .header__mobile-dropdown.open {
    display: flex;
  }

  .header__mobile-dropdown-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .header__mobile-dropdown-item:hover {
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
  }

  .header__mobile-cta-wrap {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
    margin-top: var(--space-4);
  }

  .header__mobile-cta-btn {
    width: 100%;
    text-align: center;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .header__nav { display: none; }
    .header__cta { display: none; }
    .header__mobile-toggle { display: flex; }
  }
</style>

<script>
  // Desktop dropdowns (features)
  const dropdownBtns = document.querySelectorAll('.header__dropdown-trigger');

  dropdownBtns.forEach(btn => {
    const dropdownWrap = btn.closest('.header__dropdown');
    btn.addEventListener('click', () => {
      const isOpen = dropdownWrap?.classList.contains('open');
      // Close all dropdowns first
      document.querySelectorAll('.header__dropdown').forEach(d => {
        d.classList.remove('open');
        d.querySelector('.header__dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      });
      // Toggle this one
      if (!isOpen) {
        dropdownWrap?.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Close desktop dropdowns on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    document.querySelectorAll('.header__dropdown').forEach(d => {
      if (!d.contains(target)) {
        d.classList.remove('open');
        d.querySelector('.header__dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    mobileMenu?.classList.toggle('open');
    mobileToggle.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  // Mobile dropdowns (features)
  const mobileTriggers = document.querySelectorAll('.header__mobile-dropdown-trigger');
  mobileTriggers.forEach(btn => {
    const dropdown = btn.nextElementSibling;
    btn.addEventListener('click', () => {
      const isOpen = dropdown?.classList.contains('open');
      dropdown?.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(!isOpen));
      dropdown?.setAttribute('aria-hidden', String(isOpen));
    });
  });
</script>
