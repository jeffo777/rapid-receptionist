---
export interface ClientType {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  tradeName: string;
  clients: ClientType[];
}

const { tradeName, clients } = Astro.props;
---

<section class="section" id="who-its-for">
  <div class="container">
    <div class="section-header">
      <h2>Built for <span class="text-accent">{tradeName}</span> Businesses Like Yours</h2>
    </div>
    <div class="client-grid">
      {clients.map((client) => (
        <div class="client-card fade-in">
          <span class="client-card__icon">{client.icon}</span>
          <h3>{client.title}</h3>
          <p>{client.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .client-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .client-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .client-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .client-card__icon {
    font-size: var(--text-3xl);
    display: block;
    margin-bottom: var(--space-3);
  }

  .client-card h3 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-2);
  }

  .client-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 768px) {
    .client-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .client-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
