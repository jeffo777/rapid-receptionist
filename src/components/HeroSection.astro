---
import pricing from '../data/pricing.json';
export interface Props {
  headline: string;
  subhead: string;
  accentWord?: string;
  showTrustRow?: boolean;
  showAIReceptionist?: boolean;
  greeting?: string;
  promptText?: string;
}

const {
  headline,
  subhead,
  accentWord,
  showTrustRow = true,
  showAIReceptionist = true,
  greeting = 'Questions? Chat with me 👋',
  promptText = "Tell me about your business and I'll show you how I handle your calls",
} = Astro.props;

// If accentWord provided, wrap it in a span
let processedHeadline = headline;
if (accentWord) {
  processedHeadline = headline.replace(
    accentWord,
    `<span class="text-accent">${accentWord}</span>`
  );
}
---

<section class="hero" id="hero-section">
  <div class="container hero__inner">
    <!-- Text Content -->
    <div class="hero__content">
      <h1 class="hero__headline" set:html={processedHeadline} />
      <p class="hero__subhead">{subhead}</p>

      {showTrustRow && (
        <div class="trust-row hero__trust-row hero__trust-row--desktop-only">
          <span class="trust-row__item">
            <span class="check">✓</span> 100% done for you
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            <span class="check">✓</span> Free business info updates
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            🇬🇧 UK-owned & trade-run
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            From <strong>£{pricing.tiers.core.price}/month</strong>
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            <span class="shield">🛡</span> 30-day money-back guarantee
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            No contracts
          </span>
        </div>
      )}
    </div>

    <!-- AI Receptionist CTA -->
    {showAIReceptionist && (
      <div class="hero-ai" id="hero-ai-section">
        <div class="hero-ai__visual">
          <div class="hero-ai__avatar-wrap">
            <img
              src="/assets/images/ai-receptionist.webp"
              alt="Your AI receptionist — always on, always ready"
              class="hero-ai__avatar-img"
              loading="eager"
              decoding="async"
              width="320"
              height="320"
            />
            <div class="hero-ai__avatar-glow" aria-hidden="true"></div>
            <span class="hero-ai__online-badge" aria-hidden="true">online</span>
          </div>
        </div>

        <div class="hero-ai__cta-area">
          <p class="hero-ai__greeting">{greeting}</p>
          <p class="hero-ai__prompt">{promptText}</p>
          <div class="hero-ai__buttons">
            <button type="button" class="hero-ai__btn hero-ai__btn--chat" id="hero-ai-chat-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              Chat with me
            </button>
            <button type="button" class="hero-ai__btn hero-ai__btn--call" id="hero-ai-call-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call me
            </button>
          </div>

          {showTrustRow && (
            <div class="trust-row hero__trust-row hero__trust-row--under-cta">
              <span class="trust-row__item">
                <span class="check">✓</span> 100% done for you
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                <span class="check">✓</span> Free business info updates
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                🇬🇧 UK-owned & trade-run
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                From <strong>£{pricing.tiers.core.price}/month</strong>
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                <span class="shield">🛡</span> 30-day money-back guarantee
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                No contracts
              </span>
            </div>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Chat Popup (fallback until GoHighLevel connected) -->
  <div class="ai-popup" id="ai-chat-popup" aria-hidden="true">
    <div class="ai-popup__overlay" data-close-popup></div>
    <div class="ai-popup__content">
      <button class="ai-popup__close" data-close-popup aria-label="Close">&times;</button>
      <div class="ai-popup__icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <p class="ai-popup__title">Chat Coming Soon</p>
      <p class="ai-popup__text">Our AI chat is being finalised and will be live shortly. In the meantime, get started now — no obligation, no hard sell.</p>
      <a href="/get-started/" class="ai-popup__btn">Get Started →</a>
    </div>
  </div>

  <!-- Call Popup (fallback until GoHighLevel connected) -->
  <div class="ai-popup" id="ai-call-popup" aria-hidden="true">
    <div class="ai-popup__overlay" data-close-popup></div>
    <div class="ai-popup__content">
      <button class="ai-popup__close" data-close-popup aria-label="Close">&times;</button>
      <div class="ai-popup__icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </div>
      <p class="ai-popup__title">Voice AI Coming Soon</p>
      <p class="ai-popup__text">Our voice AI receptionist is being configured and will be live shortly. Get started now to secure your spot.</p>
      <a href="/get-started/" class="ai-popup__btn">Get Started →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(var(--header-height) + var(--space-10));
    padding-bottom: var(--space-16);
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    overflow: hidden;
  }

  /* Subtle grid pattern overlay */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(30, 144, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30, 144, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-10);
  }

  /* Text Content */
  .hero__content {
    max-width: 780px;
  }

  .hero__headline {
    margin-bottom: var(--space-4);
  }

  .hero__subhead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    max-width: 620px;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  .hero__trust-row {
    margin-top: var(--space-8);
  }

  /* Hide the top trust row when AI section exists (it's duplicated under the CTA) */
  .hero__trust-row--desktop-only {
    display: none;
  }

  .hero__trust-row--under-cta {
    margin-top: var(--space-6);
  }

  /* -- AI Receptionist CTA (Primary) -- */
  .hero-ai {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .hero-ai__visual {
    display: flex;
    justify-content: center;
  }

  .hero-ai__avatar-wrap {
    position: relative;
    width: 260px;
    height: 260px;
    perspective: 800px;
  }

  .hero-ai__avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    position: relative;
    z-index: 2;
    animation: ai-head-turn 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    will-change: transform;
  }

  .hero-ai__avatar-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%);
    z-index: 1;
    animation: ai-glow-pulse 3s ease-in-out infinite;
  }

  .hero-ai__avatar-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid var(--color-accent);
    z-index: 3;
    animation: ai-ring-pulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-ai__online-badge {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--color-primary);
    color: var(--color-accent);
    font-size: 11px;
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--color-accent);
    animation: ai-ring-pulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ai-head-turn {
    0% {
      transform: rotateY(35deg) scale(0.95);
      opacity: 0.7;
    }
    60% {
      transform: rotateY(-3deg) scale(1.01);
      opacity: 1;
    }
    100% {
      transform: rotateY(0deg) scale(1);
      opacity: 1;
    }
  }

  @keyframes ai-glow-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.04); }
  }

  @keyframes ai-ring-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* CTA Area */
  .hero-ai__cta-area {
    text-align: center;
  }

  .hero-ai__greeting {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .hero-ai__prompt {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-5);
    max-width: 360px;
    margin-inline: auto;
    line-height: var(--leading-normal);
  }

  .hero-ai__buttons {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-ai__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition-fast);
    min-height: 48px;
  }

  .hero-ai__btn--chat {
    background: var(--color-accent);
    color: #fff;
    border: none;
    box-shadow: var(--shadow-accent);
  }

  .hero-ai__btn--chat:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-accent-lg);
  }

  .hero-ai__btn--call {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .hero-ai__btn--call:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
  }

  /* -- Popups -- */
  .ai-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    align-items: center;
    justify-content: center;
  }

  .ai-popup.active {
    display: flex;
  }

  .ai-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .ai-popup__content {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-2xl);
    padding: var(--space-10) var(--space-8);
    max-width: 400px;
    width: 90%;
    text-align: center;
    box-shadow: var(--shadow-xl);
  }

  .ai-popup__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .ai-popup__close:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .ai-popup__icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin: 0 auto var(--space-4);
  }

  .ai-popup__title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .ai-popup__text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .ai-popup__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: #fff;
    font-weight: var(--font-bold);
    font-size: var(--text-base);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
    min-width: 160px;
  }

  .ai-popup__btn:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: scale(1.02);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero-ai__avatar-wrap {
      width: 280px;
      height: 280px;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding-top: calc(var(--header-height) + var(--space-12));
      padding-bottom: var(--space-16);
    }

    .hero-ai__avatar-wrap {
      width: 320px;
      height: 320px;
    }
  }
</style>

<script>
  // Chat popup
  const chatBtn = document.getElementById('hero-ai-chat-btn');
  const chatPopup = document.getElementById('ai-chat-popup');
  // Call popup
  const callBtn = document.getElementById('hero-ai-call-btn');
  const callPopup = document.getElementById('ai-call-popup');

  function openPopup(popup: HTMLElement | null) {
    popup?.classList.add('active');
    popup?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closePopup(popup: HTMLElement | null) {
    popup?.classList.remove('active');
    popup?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  chatBtn?.addEventListener('click', () => openPopup(chatPopup));
  callBtn?.addEventListener('click', () => openPopup(callPopup));

  // Close buttons & overlays
  document.querySelectorAll('[data-close-popup]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const popup = (e.currentTarget as HTMLElement).closest('.ai-popup');
      closePopup(popup as HTMLElement);
    });
  });

  // Escape closes all popups
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closePopup(chatPopup);
      closePopup(callPopup);
    }
  });
</script>
