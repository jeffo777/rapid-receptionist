---
import pricing from '../data/pricing.json';
export interface Props {
  headline: string;
  subhead: string;
  accentWord?: string;
  showTrustRow?: boolean;
  showAIReceptionist?: boolean;
  tradeName?: string;
}

const {
  headline,
  subhead,
  accentWord,
  showTrustRow = true,
  showAIReceptionist = true,
  tradeName = '',
} = Astro.props;

// If accentWord provided, wrap it in a span
let processedHeadline = headline;
if (accentWord) {
  processedHeadline = headline.replace(
    accentWord,
    `<span class="text-accent">${accentWord}</span>`
  );
}
---

<section class="hero" id="hero-section">
  <div class="container hero__inner">
    <!-- Text Content -->
    <div class="hero__content">
      <h1 class="hero__headline" set:html={processedHeadline} />
      <p class="hero__subhead">{subhead}</p>

      {showTrustRow && (
        <div class="trust-row hero__trust-row hero__trust-row--desktop-only">
          <span class="trust-row__item">
            <span class="check">✓</span> 100% done for you
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            <span class="check">✓</span> Free business info updates
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            🇬🇧 UK-owned & trade-run
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            From <strong>£{pricing.tiers.core.price}/month</strong>
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            <span class="shield">🛡</span> 30-day money-back guarantee
          </span>
          <span class="trust-row__divider" aria-hidden="true"></span>
          <span class="trust-row__item">
            No contracts
          </span>
        </div>
      )}
    </div>

    <!-- AI Receptionist CTA -->
    {showAIReceptionist && (
      <div class="hero-ai" id="hero-ai-section">
        <div class="hero-ai__visual">
          <div class="hero-ai__avatar-wrap">
            <img
              src="/assets/images/ai-receptionist.webp"
              alt="Rapid Receptionist AI receptionist for UK construction trades — answers calls, chats, and messages 24/7 across 8 channels"
              class="hero-ai__avatar-img"
              loading="eager"
              decoding="async"
              width="320"
              height="320"
            />
            <div class="hero-ai__avatar-glow" aria-hidden="true"></div>
            <span class="hero-ai__online-badge" aria-hidden="true">ready to chat</span>
          </div>
        </div>

        <div class="hero-ai__cta-area">
          <div class="hero-ai__buttons">
            <button type="button" class="hero-ai__btn hero-ai__btn--try" id="hero-try-btn" data-trade={tradeName}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                <line x1="12" y1="19" x2="12" y2="23"/>
                <line x1="8" y1="23" x2="16" y2="23"/>
              </svg>
              Try Me Now
            </button>
          </div>

          {showTrustRow && (
            <div class="trust-row hero__trust-row hero__trust-row--under-cta">
              <span class="trust-row__item">
                <span class="check">✓</span> 100% done for you
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                <span class="check">✓</span> Free business info updates
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                🇬🇧 UK-owned & trade-run
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                From <strong>£{pricing.tiers.core.price}/month</strong>
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                <span class="shield">🛡</span> 30-day money-back guarantee
              </span>
              <span class="trust-row__divider" aria-hidden="true"></span>
              <span class="trust-row__item">
                No contracts
              </span>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(var(--header-height) + var(--space-6));
    padding-bottom: var(--space-12);
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    overflow: hidden;
  }

  /* Subtle grid pattern overlay */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(30, 144, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30, 144, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  /* Text Content */
  .hero__content {
    max-width: 780px;
  }

  .hero__headline {
    margin-bottom: var(--space-4);
  }

  .hero__subhead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 620px;
    margin-inline: auto;
    line-height: var(--leading-normal);
  }

  .hero__trust-row {
    margin-top: var(--space-8);
  }

  /* Hide the top trust row when AI section exists (it's duplicated under the CTA) */
  .hero__trust-row--desktop-only {
    display: none;
  }

  .hero__trust-row--under-cta {
    margin-top: var(--space-6);
  }

  /* -- AI Receptionist CTA (Primary) -- */
  .hero-ai {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .hero-ai__visual {
    display: flex;
    justify-content: center;
  }

  .hero-ai__avatar-wrap {
    position: relative;
    width: 220px;
    height: 220px;
    perspective: 800px;
  }

  .hero-ai__avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center center;
    position: relative;
    z-index: 2;
    animation: ai-head-turn 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    will-change: transform;
  }

  .hero-ai__avatar-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%);
    z-index: 1;
    animation: ai-glow-pulse 3s ease-in-out infinite;
  }

  .hero-ai__avatar-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid var(--color-accent);
    z-index: 3;
    animation: ai-ring-pulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-ai__online-badge {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    background: var(--color-secondary);
    color: var(--color-accent);
    font-size: 11px;
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: var(--radius-full);
    border: 1.5px solid transparent;
    animation: ai-badge-pulse 2.8s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ai-badge-pulse {
    0%, 100% { color: rgba(30, 144, 255, 0.4); border-color: rgba(30, 144, 255, 0.15); }
    50% { color: rgba(30, 144, 255, 1); border-color: rgba(30, 144, 255, 0.6); }
  }

  @keyframes ai-head-turn {
    0% {
      transform: rotateY(35deg) scale(0.95);
      opacity: 0.7;
    }
    60% {
      transform: rotateY(-3deg) scale(1.01);
      opacity: 1;
    }
    100% {
      transform: rotateY(0deg) scale(1);
      opacity: 1;
    }
  }

  @keyframes ai-glow-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.04); }
  }

  @keyframes ai-ring-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* CTA Area */
  .hero-ai__cta-area {
    text-align: center;
  }

  .hero-ai__buttons {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-ai__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition-fast);
    min-height: 48px;
  }

  .hero-ai__btn--try {
    background: var(--color-accent);
    color: #fff;
    border: none;
    box-shadow: var(--shadow-accent);
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-lg);
  }

  .hero-ai__btn--try:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent-lg);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero-ai__avatar-wrap {
      width: 240px;
      height: 240px;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding-top: calc(var(--header-height) + var(--space-8));
      padding-bottom: var(--space-12);
    }

    .hero-ai__avatar-wrap {
      width: 270px;
      height: 270px;
    }
  }
</style>

<script>
  // ── Voice Agent Lazy Loader ──
  // Loads voice-agent.js + CSS on first click, then starts the agent.
  let _vaLoaded = false;

  function launchVoiceAgent(tradeName) {
    if (_vaLoaded) {
      window.RapidVoiceAgent?.start(tradeName || '');
      return;
    }

    // Load CSS
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    // ⚠️ CACHE-BUST: bump this version when voice-agent-ui.css changes
    css.href = '/assets/css/voice-agent-ui.css?v=20260516a';
    document.head.appendChild(css);

    // Load JS
    const script = document.createElement('script');
    // ⚠️ CACHE-BUST: bump this version when voice-agent.js changes
    script.src = '/assets/js/voice-agent.js?v=20260516a';
    script.onload = () => {
      _vaLoaded = true;
      window.RapidVoiceAgent?.start(tradeName || '');
    };
    document.head.appendChild(script);
  }

  // Expose globally so FloatingWidget can use it too
  (window as any).launchVoiceAgent = launchVoiceAgent;

  // Hero "Try Me Now" button
  const heroTryBtn = document.getElementById('hero-try-btn');
  heroTryBtn?.addEventListener('click', () => {
    const trade = heroTryBtn.getAttribute('data-trade') || '';
    launchVoiceAgent(trade);
  });
</script>
