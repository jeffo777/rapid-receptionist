---
import CTAButton from './CTAButton.astro';
import pricing from '../data/pricing.json';
---

<div class="pricing-layout" id="pricing-layout">
  <!-- Core Plan Card -->
  <div class="pricing-plans">
    <div class="pricing-card pricing-card--core" id="pricing-card-core">
      <div class="pricing-card__badge-row">
        <span class="badge badge--trust">Core Plan</span>
      </div>
      <h3 class="pricing-card__title">Rapid Receptionist</h3>
      <p class="pricing-card__subtitle">AI phone answering + website chat — built for UK tradesmen.</p>

      <div class="pricing-card__price-row">
        <div class="pricing-card__price">
          <span class="pricing-card__currency">£</span>
          <span class="pricing-card__amount">{pricing.tiers.core.price}</span>
          <span class="pricing-card__period">/month</span>
        </div>
        <p class="pricing-card__setup">+ £{pricing.setup.price} one-time setup <span class="text-trust">(fully refundable)</span></p>
      </div>

      <div class="pricing-card__divider"></div>

      <div class="pricing-card__features">
        <h4 class="pricing-card__features-title">What's included:</h4>
        <ul class="check-list">
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>AI Phone Answering <strong>({pricing.tiers.core.minutes} mins/month)</strong></span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>AI Website Chat <strong>(Unlimited)</strong></span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>Human emergency escalation</span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>Trade-specific AI training</span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>100% done-for-you setup</span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>Answers with your business name</span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>Real-time lead notifications</span>
          </li>
          <li class="check-list__item">
            <span class="check-list__icon">✓</span>
            <span>24/7/365 availability</span>
          </li>
        </ul>
      </div>

      <div class="pricing-card__divider"></div>

      <div class="pricing-card__details">
        <div class="pricing-card__detail-row">
          <span>Phone talk time</span>
          <strong>{pricing.tiers.core.minutes} mins/month</strong>
        </div>
        <div class="pricing-card__detail-row">
          <span>Website chat messages</span>
          <strong class="text-trust">Unlimited</strong>
        </div>
        <div class="pricing-card__detail-row">
          <span>Overage rate</span>
          <strong>£0.20/min</strong>
        </div>
        <div class="pricing-card__detail-row">
          <span>Contract</span>
          <strong class="text-trust">None — cancel anytime</strong>
        </div>
      </div>

      <div class="pricing-card__cta">
        <CTAButton label={`Get Started — £${pricing.tiers.core.price}/mo`} size="lg" id="pricing-core-cta" />
        <p class="pricing-card__guarantee">
          🛡️ <strong class="text-trust">30-day money-back guarantee</strong> — setup fee + monthly fee fully refundable
        </p>
      </div>
    </div>
  </div>

  <!-- Channel Add-Ons -->
  <div class="pricing-addons" id="pricing-addons">
    <div class="pricing-addons__header">
      <span class="badge badge--accent-outline">Add-On Channels</span>
      <h3 class="pricing-addons__title">Cover Every Channel Your Customers Use</h3>
      <p class="pricing-addons__subtitle">£{pricing.addOn.price}/month per channel — add to the Core plan, or buy standalone. No minimum.</p>
      <p class="pricing-addons__setup-note">All plans include a one-time £{pricing.setup.price} done-for-you setup <span class="text-trust">(fully refundable)</span></p>
    </div>

    <div class="pricing-addons__grid">
      <div class="addon-card">
        <span class="addon-card__icon">💬</span>
        <h4 class="addon-card__name">AI WhatsApp</h4>
        <p class="addon-card__desc">Automated WhatsApp responses. Captures lead details from every message.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
      <div class="addon-card">
        <span class="addon-card__icon">📱</span>
        <h4 class="addon-card__name">AI SMS</h4>
        <p class="addon-card__desc">Professional AI text message responses to customer enquiries.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
      <div class="addon-card">
        <span class="addon-card__icon">🔔</span>
        <h4 class="addon-card__name">Missed Call Text-Back</h4>
        <p class="addon-card__desc">Automatic text sent when a call is missed — stops them calling a competitor.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
      <div class="addon-card">
        <span class="addon-card__icon">📧</span>
        <h4 class="addon-card__name">AI Email Response</h4>
        <p class="addon-card__desc">Automated email replies. Captures enquiry details and sends you the lead.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
      <div class="addon-card">
        <span class="addon-card__icon">📘</span>
        <h4 class="addon-card__name">AI Facebook Messenger</h4>
        <p class="addon-card__desc">Automated Facebook message responses. Never miss a social lead.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
      <div class="addon-card">
        <span class="addon-card__icon">📸</span>
        <h4 class="addon-card__name">AI Instagram DMs</h4>
        <p class="addon-card__desc">Automated Instagram DM responses. Captures leads from your profile.</p>
        <span class="addon-card__price">£{pricing.addOn.price}<span>/mo</span></span>
      </div>
    </div>

    <div class="pricing-addons__cta">
      <CTAButton label="Get Started" size="lg" id="pricing-addons-cta" />
    </div>
  </div>
</div>

<style>
  .pricing-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    max-width: 1100px;
    margin-inline: auto;
  }

  .pricing-plans {
    display: flex;
    justify-content: center;
  }

  /* ---- Plan Cards ---- */
  .pricing-card {
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-2xl);
    padding: var(--space-10);
    position: relative;
    overflow: hidden;
  }

  .pricing-card::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 200px;
    background: radial-gradient(ellipse, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0.5;
  }

  .pricing-card__badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .badge--accent-outline {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-card__title {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .pricing-card__subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-align: center;
    margin: 0;
    max-width: 360px;
    margin-inline: auto;
  }

  .pricing-card__price-row {
    text-align: center;
    margin-top: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-1);
  }

  .pricing-card__currency {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
  }

  .pricing-card__amount {
    font-size: var(--text-6xl);
    font-weight: var(--font-extrabold);
    color: var(--color-text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .pricing-card__period {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
  }

  .pricing-card__setup {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .pricing-card__divider {
    height: 1px;
    background: var(--color-border-subtle);
    margin-block: var(--space-6);
  }

  .pricing-card__features-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-card__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pricing-card__detail-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .pricing-card__cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .pricing-card__cta :global(.btn) {
    width: 100%;
  }

  .pricing-card__guarantee {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
    line-height: var(--leading-snug);
  }

  /* ---- Add-Ons Section ---- */
  .pricing-addons {
    text-align: center;
  }

  .pricing-addons__header {
    margin-bottom: var(--space-8);
  }

  .pricing-addons__title {
    font-size: var(--text-3xl);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .pricing-addons__subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    margin: 0;
  }

  .pricing-addons__setup-note {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-2);
  }

  .pricing-addons__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .addon-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .addon-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .addon-card__icon {
    font-size: var(--text-2xl);
    display: block;
    margin-bottom: var(--space-3);
  }

  .addon-card__name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-2);
  }

  .addon-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .addon-card__price {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-accent);
  }

  .addon-card__price span {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-muted);
  }

  .pricing-addons__cta {
    text-align: center;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .pricing-plans {
      max-width: 520px;
      margin-inline: auto;
    }

    .pricing-addons__grid {
      grid-template-columns: 1fr 1fr;
    }

    .pricing-card {
      padding: var(--space-8);
    }
  }

  @media (max-width: 480px) {
    .pricing-addons__grid {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin-inline: auto;
    }
  }
</style>
