---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import WithoutWithSection from '../components/WithoutWithSection.astro';
import ConstructionSpecialisms from '../components/ConstructionSpecialisms.astro';
import ClientTypes from '../components/ClientTypes.astro';
import StepsGrid from '../components/StepsGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatisticsSection from '../components/StatisticsSection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
import CookieConsent from '../components/CookieConsent.astro';
import channels from '../data/channels.json';
import pricing from '../data/pricing.json';

export interface FAQItem {
  question: string;
  answer: string;
}

export interface ScenarioPair {
  without: string;
  with: string;
}

export interface SpecialismGroup {
  category: string;
  items: string[];
}

export interface ClientType {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  tradeName: string;
  tradeNamePlural: string;
  tradeSlug?: string;
  headline: string;
  accentWord: string;
  subhead: string;
  withoutWithScenarios: ScenarioPair[];
  specialisms: SpecialismGroup[];
  clientTypes: ClientType[];
  faqs: FAQItem[];
  ctaHeadline?: string;
  ctaSubhead?: string;
}

const {
  title,
  description,
  canonicalUrl,
  tradeName,
  tradeNamePlural,
  tradeSlug,
  headline,
  accentWord,
  subhead,
  withoutWithScenarios,
  specialisms,
  clientTypes,
  faqs,
  ctaHeadline = `Stop Missing Jobs, ${tradeNamePlural}`,
  ctaSubhead = `Join the UK ${tradeNamePlural.toLowerCase()} who never miss a lead. From £${pricing.tiers.core.price}/month, 30-day money-back guarantee, no contracts.`,
} = Astro.props;

const steps = [
  {
    number: 1,
    title: 'Tell Us About Your Business',
    description: `Share your ${tradeName.toLowerCase()} business details — your services, your area, and how you want calls handled. We do the rest.`
  },
  {
    number: 2,
    title: 'We Configure Your AI',
    description: `Your AI receptionist is trained with ${tradeName.toLowerCase()}-specific vocabulary and scenarios. It knows your trade inside out.`
  },
  {
    number: 3,
    title: 'Start Winning More Work',
    description: `Every call, message, and enquiry is captured instantly and sent straight to you. No missed leads, no lost revenue.`
  }
];

/* Build channel URL map for trade-specific links */
const channelTradeUrlMap: Record<string, string> = {
  'ai-phone-answering': `/${tradeSlug}/ai-phone-answering/`,
  'ai-website-chat': `/${tradeSlug}/ai-website-chat/`,
  'ai-whatsapp': `/${tradeSlug}/ai-whatsapp/`,
  'ai-sms': `/${tradeSlug}/ai-sms/`,
  'ai-email': `/${tradeSlug}/ai-email-response/`,
  'ai-facebook-messenger': `/${tradeSlug}/ai-facebook-messenger/`,
  'ai-instagram-dm': `/${tradeSlug}/ai-instagram-dms/`,
  'missed-call-text-back': `/${tradeSlug}/missed-call-text-back/`,
};

const features = channels.map(ch => ({
  icon: ch.icon,
  name: ch.name,
  description: ch.shortDescription,
  tier: ch.tierLabel,
  href: tradeSlug && channelTradeUrlMap[ch.slug] ? channelTradeUrlMap[ch.slug] : ch.pageUrl,
}));

const siteUrl = 'https://rapidreceptionist.co.uk';

/* Service schema for this trade hub */
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": `AI Receptionist for ${tradeNamePlural}`,
  "name": `AI Receptionist for ${tradeNamePlural}`,
  "description": description,
  "url": `${siteUrl}${canonicalUrl}`,
  "provider": {
    "@type": "Organization",
    "name": "Rapid Receptionist",
    "url": siteUrl
  },
  "areaServed": {
    "@type": "Country",
    "name": "United Kingdom"
  },
  "offers": {
    "@type": "Offer",
    "price": String(pricing.tiers.core.price),
    "priceCurrency": "GBP",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": String(pricing.tiers.core.price),
      "priceCurrency": "GBP",
      "unitText": "month"
    }
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Included Channels",
    "itemListElement": channels.map(ch => ch.name)
  }
};

/* BreadcrumbList schema */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Construction Trades", "item": `${siteUrl}/construction-trades/` },
    { "@type": "ListItem", "position": 3, "name": `AI Receptionist for ${tradeNamePlural}` }
  ]
};

/* FAQ schema */
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

/* Append GDPR FAQ to the faqs array — completely rewritten for RR construction context */
const allFaqs = [
  ...faqs,
  {
    question: "How does Rapid Receptionist protect my clients' personal information?",
    answer: "Data security is built into every layer of our service. When your AI receptionist captures a client's name, contact number, site address, or project details, that information is encrypted both in transit and at rest using industry-standard protocols. All data is stored on UK and EU-based servers — never offshore. We operate as your data processor under UK GDPR and the Data Protection Act 2018, meaning we handle enquiry data strictly on your behalf and never sell, share, or repurpose it. You and your clients can request deletion of any stored data at any time. As the contractor, you remain the data controller for all client information captured through our service. Our full data handling practices are detailed in our <a href='/privacy/'>privacy policy</a>."
  },
  {
    question: `What if my ${tradeName.toLowerCase()} business details change?`,
    answer: `If your prices change, you add or remove a service, or your working hours shift, just let us know and we update your AI receptionist configuration for free. Routine business information updates — pricing adjustments, new service offerings, revised availability, and updated contact details — are all included at no extra cost. We handle the change on our end, typically within one working day, so your AI always reflects your current ${tradeName.toLowerCase()} business accurately.`
  }
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Header slot="header" />

  <!-- Breadcrumbs -->
  <section class="th-breadcrumbs">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="th-breadcrumb-list">
          <li><a href="/">Home</a></li>
          <li><a href="/construction-trades/">Construction Trades</a></li>
          <li aria-current="page">AI Receptionist for {tradeNamePlural}</li>
        </ol>
      </nav>
    </div>
  </section>

  <HeroSection
    headline={headline}
    accentWord={accentWord}
    subhead={subhead}
  />

  <WithoutWithSection tradeName={tradeName} scenarios={withoutWithScenarios} />

  <ConstructionSpecialisms tradeName={tradeName} groups={specialisms} />

  <ClientTypes tradeName={tradeName} clients={clientTypes} />

  <StepsGrid steps={steps} />

  <FeatureGrid features={features} columns={3} />

  <StatisticsSection />

  <FAQAccordion faqs={allFaqs} />

  <CTASection headline={ctaHeadline} subhead={ctaSubhead} />

  <CookieConsent />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Breadcrumbs */
  .th-breadcrumbs {
    padding: calc(var(--header-height) + var(--space-4)) 0 0;
  }

  .th-breadcrumb-list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .th-breadcrumb-list li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-2);
    color: var(--color-text-muted);
  }

  .th-breadcrumb-list a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .th-breadcrumb-list a:hover {
    color: var(--color-accent);
  }

  /* Hero — override HeroSection padding since breadcrumbs already account for header height */
  :global(.hero) {
    padding-top: var(--space-6) !important;
  }

  @media (min-width: 1024px) {
    :global(.hero) {
      padding-top: var(--space-8) !important;
    }
  }
</style>
