---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
import HeroSection from '../components/HeroSection.astro';
import CookieConsent from '../components/CookieConsent.astro';
import StatisticsSection from '../components/StatisticsSection.astro';
import pricing from '../data/pricing.json';

export interface FAQItem {
  question: string;
  answer: string;
}

export interface BenefitItem {
  icon: string;
  title: string;
  text: string;
}

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  channelName: string;
  tradeName: string;
  tradeNamePlural: string;
  tradeSlug: string;
  headline: string;
  accentWord: string;
  subhead: string;
  scenario: string;
  benefits: BenefitItem[];
  faqs: FAQItem[];
  channelPageUrl: string;
  tradePageUrl: string;
  pricingNote?: string;
  ctaHeadline?: string;
  ctaSubhead?: string;
}

const {
  title,
  description,
  canonicalUrl,
  channelName,
  tradeName,
  tradeNamePlural,
  tradeSlug,
  headline,
  accentWord,
  subhead,
  scenario,
  benefits,
  faqs,
  channelPageUrl,
  tradePageUrl,
  pricingNote,
  ctaHeadline = `${channelName} for ${tradeNamePlural} — Stop Missing Leads`,
  ctaSubhead = `Join the UK ${tradeNamePlural.toLowerCase()} who capture every enquiry. From £${pricing.tiers.core.price}/month. No contracts.`,
} = Astro.props;

/* Auto-generate pricing note from central pricing data if not provided */
const isCorePlan = channelName === 'AI Phone Answering' || channelName === 'AI Website Chat';
const generatedPricingNote = isCorePlan
  ? `${channelName} is included in the <strong>Core plan at £${pricing.tiers.core.price}/month</strong> with ${pricing.tiers.core.minutes} minutes of talk time and unlimited website chat. Add extra channels at <strong>£${pricing.addOn.price}/month each</strong>. <a href='/pricing/'>Full pricing →</a>`
  : `${channelName} is an <strong>add-on at £${pricing.addOn.price}/month</strong> on top of the Core plan (£${pricing.tiers.core.price}/month). <a href='/pricing/'>Full pricing →</a>`;
const resolvedPricingNote = pricingNote || generatedPricingNote;

const siteUrl = 'https://rapidreceptionist.co.uk';

/* Service schema for this channel × trade page */
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": `${channelName} for ${tradeNamePlural}`,
  "name": `${channelName} for ${tradeNamePlural}`,
  "description": description,
  "url": `${siteUrl}${canonicalUrl}`,
  "provider": {
    "@type": "Organization",
    "name": "Rapid Receptionist",
    "url": siteUrl
  },
  "areaServed": {
    "@type": "Country",
    "name": "United Kingdom"
  }
};

/* BreadcrumbList schema matching the visual breadcrumbs */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Construction Trades", "item": `${siteUrl}/construction-trades/` },
    { "@type": "ListItem", "position": 3, "name": `AI Receptionist for ${tradeNamePlural}`, "item": `${siteUrl}${tradePageUrl}` },
    { "@type": "ListItem", "position": 4, "name": `${channelName} for ${tradeNamePlural}` }
  ]
};

/* FAQ schema */
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

/* Append GDPR FAQ — unique version for channel pages, different wording from TradeHubLayout */
const allFaqs = [
  ...faqs,
  {
    question: `Is ${channelName} compliant with UK data protection law?`,
    answer: `Yes — fully. Every piece of information captured through ${channelName} is protected under UK GDPR and the Data Protection Act 2018. Client names, contact details, site addresses, and project specifics are encrypted during transmission and while stored, and held exclusively on UK and EU-based servers. We never share, sell, or repurpose any data captured on your behalf. You maintain full control as the data controller, with the right to request deletion at any point. Your clients have the same right. Rapid Receptionist acts strictly as your data processor, operating under a formal data processing agreement. You can review our approach in detail in our <a href='/privacy/'>privacy policy</a>.`
  }
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Header slot="header" />

  <!-- Breadcrumbs -->
  <section class="ct-breadcrumbs">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="ct-breadcrumb-list">
          <li><a href="/">Home</a></li>
          <li><a href="/construction-trades/">Construction Trades</a></li>
          <li><a href={tradePageUrl}>AI Receptionist for {tradeNamePlural}</a></li>
          <li aria-current="page">{channelName} for {tradeNamePlural}</li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- Hero -->
  <HeroSection
    headline={headline}
    subhead={subhead}
    accentWord={accentWord}
  />

  <!-- Scenario -->
  <section class="section section--alt" id="ct-scenario">
    <div class="container">
      <div class="ct-scenario-block">
        <p>{scenario}</p>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section" id="ct-benefits">
    <div class="container">
      <div class="section-header">
        <h2>Why {tradeNamePlural} Need <span class="text-accent">{channelName}</span></h2>
      </div>
      <div class="ct-benefits-grid">
        {benefits.map((b) => (
          <div class="ct-benefit-card fade-in">
            <span class="ct-benefit-card__icon">{b.icon}</span>
            <h3>{b.title}</h3>
            <p>{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Note -->
  <section class="section section--alt" id="ct-pricing">
    <div class="container">
      <div class="ct-pricing-note">
        <span class="ct-pricing-note__icon">💷</span>
        <p set:html={resolvedPricingNote} />
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="section" id="ct-related">
    <div class="container">
      <div class="ct-related-grid">
        <a href={channelPageUrl} class="ct-related-card">
          <span class="ct-related-card__label">Learn more about</span>
          <strong>{channelName}</strong>
          <span class="ct-related-card__arrow">→</span>
        </a>
        <a href={tradePageUrl} class="ct-related-card">
          <span class="ct-related-card__label">AI Receptionist for</span>
          <strong>{tradeNamePlural}</strong>
          <span class="ct-related-card__arrow">→</span>
        </a>
        <a href="/construction-trades/" class="ct-related-card">
          <span class="ct-related-card__label">See all</span>
          <strong>Construction Trades</strong>
          <span class="ct-related-card__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <StatisticsSection />

  <FAQAccordion faqs={allFaqs} />

  <CTASection headline={ctaHeadline} subhead={ctaSubhead} />

  <CookieConsent />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Breadcrumbs */
  .ct-breadcrumbs {
    padding: calc(var(--header-height) + var(--space-4)) 0 0;
  }

  .ct-breadcrumb-list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .ct-breadcrumb-list li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-2);
    color: var(--color-text-muted);
  }

  .ct-breadcrumb-list a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .ct-breadcrumb-list a:hover {
    color: var(--color-accent);
  }

  /* Hero */
  .ct-hero {
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
    text-align: center;
  }

  .ct-hero h1 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-extrabold);
    line-height: var(--leading-tight);
    max-width: 800px;
    margin: var(--space-4) auto var(--space-6);
  }

  .ct-hero__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0 auto var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .ct-hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Scenario Block */
  .ct-scenario-block {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-8);
    background: var(--color-surface);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-style: italic;
  }

  /* Benefits Grid */
  .ct-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .ct-benefit-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .ct-benefit-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .ct-benefit-card__icon {
    font-size: var(--text-2xl);
    display: block;
    margin-bottom: var(--space-3);
  }

  .ct-benefit-card h3 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-2);
  }

  .ct-benefit-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Pricing Note */
  .ct-pricing-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    max-width: 700px;
    margin: 0 auto;
  }

  .ct-pricing-note__icon {
    font-size: var(--text-2xl);
    flex-shrink: 0;
  }

  .ct-pricing-note p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Related Links */
  .ct-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .ct-related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .ct-related-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .ct-related-card__label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .ct-related-card strong {
    font-size: var(--text-base);
    color: var(--color-text-primary);
  }

  .ct-related-card__arrow {
    color: var(--color-accent);
    margin-top: var(--space-2);
    transition: transform var(--transition-fast);
  }

  .ct-related-card:hover .ct-related-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .ct-benefits-grid {
      grid-template-columns: 1fr;
    }

    .ct-related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .ct-benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
